<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Noctis.Controls.EqualizerAnimation"
             Width="20" Height="16">

    <StackPanel x:Name="BarsPanel" Orientation="Horizontal" Spacing="1" Height="14"
                VerticalAlignment="Center" HorizontalAlignment="Center">
        <Border x:Name="Bar1" Width="3" Height="4" Background="#E04060"
                CornerRadius="1" VerticalAlignment="Bottom" />
        <Border x:Name="Bar2" Width="3" Height="10" Background="#E04060"
                CornerRadius="1" VerticalAlignment="Bottom" />
        <Border x:Name="Bar3" Width="3" Height="6" Background="#E04060"
                CornerRadius="1" VerticalAlignment="Bottom" />
        <Border x:Name="Bar4" Width="3" Height="12" Background="#E04060"
                CornerRadius="1" VerticalAlignment="Bottom" />
        <Border x:Name="Bar5" Width="3" Height="8" Background="#E04060"
                CornerRadius="1" VerticalAlignment="Bottom" />
    </StackPanel>

</UserControl>
