<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="using:Noctis.Controls">
    <Style Selector="ctrl|EqVisualizer">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Foreground" Value="#E74856" />
        <Setter Property="Template">
            <ControlTemplate>
                <Grid ClipToBounds="True">
                    <StackPanel x:Name="BarsPanel"
                                Orientation="Horizontal"
                                Spacing="1.75"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Height="12">
                        <Rectangle x:Name="Bar1" Width="1.75" Height="1.75"
                                   RadiusX="0.875" RadiusY="0.875"
                                   VerticalAlignment="Center"
                                   Fill="{TemplateBinding Foreground}" />
                        <Rectangle x:Name="Bar2" Width="1.75" Height="1.75"
                                   RadiusX="0.875" RadiusY="0.875"
                                   VerticalAlignment="Center"
                                   Fill="{TemplateBinding Foreground}" />
                        <Rectangle x:Name="Bar3" Width="1.75" Height="1.75"
                                   RadiusX="0.875" RadiusY="0.875"
                                   VerticalAlignment="Center"
                                   Fill="{TemplateBinding Foreground}" />
                        <Rectangle x:Name="Bar4" Width="1.75" Height="1.75"
                                   RadiusX="0.875" RadiusY="0.875"
                                   VerticalAlignment="Center"
                                   Fill="{TemplateBinding Foreground}" />
                        <Rectangle x:Name="Bar5" Width="1.75" Height="1.75"
                                   RadiusX="0.875" RadiusY="0.875"
                                   VerticalAlignment="Center"
                                   Fill="{TemplateBinding Foreground}" />
                    </StackPanel>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>
