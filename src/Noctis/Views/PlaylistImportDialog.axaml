<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        x:Class="Noctis.Views.PlaylistImportDialog"
        x:DataType="vm:PlaylistImportViewModel"
        Title="Import Playlist"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Border Background="#50000000">
        <Border CornerRadius="20"
                ClipToBounds="True"
                Background="{DynamicResource AppMainBackground}"
                Width="640"
                MaxHeight="780"
                Margin="0,50"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                BoxShadow="0 8 32 0 #80000000, 0 0 0 1 #33FFFFFF">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="24,20,24,8" Spacing="2">
                    <TextBlock Text="Import Playlist" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" />
                    <TextBlock Text="Import an Exportify CSV or TuneMyMusic JSON export and match it against your library."
                               FontSize="12" Opacity="0.6" HorizontalAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>

                <Border DockPanel.Dock="Bottom" Padding="24,12,24,16">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                                   FontSize="12" Opacity="0.7" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1" Content="Close" Command="{Binding CloseCommand}"
                                Width="90" Padding="0,8" FontWeight="Bold"
                                HorizontalContentAlignment="Center" CornerRadius="999"
                                Margin="0,0,8,0" Cursor="Hand" />
                        <Button Grid.Column="2" Content="Create" Command="{Binding CreateCommand}"
                                IsEnabled="{Binding CanCreate}"
                                Width="110" Padding="0,8"
                                Classes="accent-btn"
                                Background="{DynamicResource AccentColorBrush}"
                                Foreground="{DynamicResource AccentForegroundBrush}"
                                FontWeight="SemiBold"
                                HorizontalContentAlignment="Center" CornerRadius="999" Cursor="Hand" />
                    </Grid>
                </Border>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                              Padding="24,4,24,8">
                    <StackPanel Spacing="12">
                        <Button x:Name="ChooseFileButton" Content="Choose file…"
                                HorizontalAlignment="Left" Padding="14,8" CornerRadius="16" Cursor="Hand" />

                        <StackPanel Spacing="4" IsVisible="{Binding HasPreview}">
                            <TextBlock Text="Playlist name" FontSize="12" FontWeight="SemiBold" Opacity="0.75" />
                            <TextBox Text="{Binding PlaylistName}" Watermark="Playlist name" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" IsVisible="{Binding HasPreview}">
                            <StackPanel Grid.Column="0" Spacing="1">
                                <TextBlock Text="Matched" FontSize="11" Opacity="0.5" />
                                <TextBlock Text="{Binding MatchedCount}" FontSize="22" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="1">
                                <TextBlock Text="Missing" FontSize="11" Opacity="0.5" />
                                <TextBlock Text="{Binding MissingCount}" FontSize="22" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="6" IsVisible="{Binding HasMissing}">
                            <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.5" />
                            <TextBlock Text="Missing tracks (not found in your library)" FontSize="13" FontWeight="SemiBold" Opacity="0.75" />
                            <Border Background="#10FFFFFF" CornerRadius="8" Padding="10" MaxHeight="360">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding MissingTracks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <TextBlock Text="{Binding}" FontSize="12" Opacity="0.8" Margin="0,2" TextTrimming="CharacterEllipsis" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Border>
</Window>
