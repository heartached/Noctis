<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:svc="using:Noctis.Services"
        x:Class="Noctis.Views.WrapDialog"
        x:DataType="vm:WrapViewModel"
        Title="Noctis Wrap"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False">

    <Window.Styles>
        <Style Selector="Button.share-pill">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.share-pill:pointerover">
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
        <Style Selector="Button.share-pill.active">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>

        <Style Selector="TextBlock.wrap-stat-value">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
        </Style>
        <Style Selector="TextBlock.wrap-stat-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.55"/>
        </Style>
        <Style Selector="Border.wrap-stat-card">
            <Setter Property="Background" Value="#18000000"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style Selector="TextBlock.wrap-list-header">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
    </Window.Styles>

    <!-- Full-window dimmed overlay -->
    <Border Background="#98000000" PointerPressed="OnOverlayPointerPressed">

        <!-- Centered dialog card -->
        <Border PointerPressed="OnCardPointerPressed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="22,18"
                Width="960"
                MaxHeight="720"
                CornerRadius="12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,Auto">

                <!-- Header -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="14">
                    <TextBlock FontSize="22" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="Noctis Wrap"/>
                        <Run Text="{Binding PeriodLabel}" Foreground="{DynamicResource AccentTextBrush}"/>
                    </TextBlock>
                    <Border Background="#33FFB300" CornerRadius="999" Padding="8,3"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsTestData}">
                        <TextBlock Text="TEST DATA" FontSize="10" FontWeight="Bold" Foreground="#FFD54F"/>
                    </Border>
                </StackPanel>

                <Button Grid.Row="0" Grid.Column="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="32" Height="32"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="OnCloseClick">
                    <PathIcon Data="{StaticResource DismissIcon}" Width="16" Height="16" Opacity="0.75"/>
                </Button>

                <!-- Body -->
                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,16,Auto" Margin="0,14,0,0">

                    <!-- Stats column -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="12">

                            <!-- Period + data-source pills -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Classes="share-pill" Classes.active="{Binding IsYearMode}"
                                        Content="This year" Command="{Binding SelectYearCommand}"/>
                                <Button Classes="share-pill" Classes.active="{Binding IsMonthMode}"
                                        Content="This month" Command="{Binding SelectMonthCommand}"/>
                                <Border Width="1" Height="18" Background="#30FFFFFF" VerticalAlignment="Center"/>
                                <Button Classes="share-pill" Classes.active="{Binding IsTestData}"
                                        Content="Test data" Command="{Binding UseTestDataCommand}"
                                        ToolTip.Tip="Fill with random stats to preview the layout and card"/>
                                <Button Classes="share-pill" Content="Real data"
                                        Command="{Binding UseRealDataCommand}"
                                        IsVisible="{Binding IsTestData}"/>
                            </StackPanel>

                            <TextBlock Text="No plays recorded for this period yet. Listen to some music (or use Test data to preview)."
                                       FontSize="13" Opacity="0.6" TextWrapping="Wrap"
                                       IsVisible="{Binding !HasData}"/>

                            <!-- Big numbers -->
                            <UniformGrid Columns="4" IsVisible="{Binding HasData}">
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding TotalMinutesText}"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Minutes listened"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding TotalPlaysText}"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Tracks played"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding UniqueArtistsText}"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Different artists"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding UniqueAlbumsText}"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Albums explored"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <UniformGrid Columns="4" IsVisible="{Binding HasData}">
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding UniqueTracksText}"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Unique tracks"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding LosslessText}"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Lossless plays"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding HiResText}"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Hi-Res plays"/>
                                    </StackPanel>
                                </Border>
                                <Border Classes="wrap-stat-card">
                                    <StackPanel Spacing="2">
                                        <TextBlock Classes="wrap-stat-value" Text="{Binding TopGenreText}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Classes="wrap-stat-label" Text="Top genre"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- Top lists -->
                            <Grid ColumnDefinitions="*,12,*" IsVisible="{Binding HasData}">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Classes="wrap-list-header" Text="TOP ARTISTS"/>
                                    <ItemsControl ItemsSource="{Binding TopArtists}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="svc:WrapEntry">
                                                <Grid ColumnDefinitions="24,*,Auto" Margin="0,3">
                                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontWeight="Bold" Opacity="0.45" FontSize="13"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding PlaysLabel}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Classes="wrap-list-header" Text="TOP ALBUMS" Margin="0,10,0,6"/>
                                    <ItemsControl ItemsSource="{Binding TopAlbums}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="svc:WrapEntry">
                                                <Grid ColumnDefinitions="24,*,Auto" Margin="0,3">
                                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontWeight="Bold" Opacity="0.45" FontSize="13"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Subtitle}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis"
                                                                   IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding PlaysLabel}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="2">
                                    <TextBlock Classes="wrap-list-header" Text="TOP SONGS"/>
                                    <ItemsControl ItemsSource="{Binding TopTracks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="svc:WrapEntry">
                                                <Grid ColumnDefinitions="24,*,Auto" Margin="0,3">
                                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontWeight="Bold" Opacity="0.45" FontSize="13"/>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Subtitle}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis"
                                                                   IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding PlaysLabel}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock Classes="wrap-list-header" Text="TOP GENRES" Margin="0,10,0,6"/>
                                    <ItemsControl ItemsSource="{Binding TopGenres}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="svc:WrapEntry">
                                                <Grid ColumnDefinitions="24,*,Auto" Margin="0,3">
                                                    <TextBlock Grid.Column="0" Text="{Binding Rank}" FontWeight="Bold" Opacity="0.45" FontSize="13"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding PlaysLabel}" FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Card preview -->
                    <Border Grid.Column="2"
                            Width="300" Height="450"
                            Background="#18000000"
                            CornerRadius="8">
                        <Panel>
                            <TextBlock Text="No data to preview"
                                       FontSize="13" Opacity="0.5"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding Preview, Converter={x:Static ObjectConverters.IsNull}}"/>
                            <Image Source="{Binding Preview}"
                                   Stretch="Uniform"
                                   Margin="10"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        </Panel>
                    </Border>
                </Grid>

                <!-- Footer: format toggle + actions -->
                <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,16,0,0">
                    <Button Grid.Column="0"
                            Classes="share-pill"
                            Classes.active="{Binding IsSquare}"
                            Content="1:1"
                            Command="{Binding SelectSquareCommand}"/>
                    <Button Grid.Column="1"
                            Classes="share-pill"
                            Classes.active="{Binding IsStory}"
                            Content="9:16"
                            Margin="8,0,0,0"
                            Command="{Binding SelectStoryCommand}"/>

                    <TextBlock Grid.Column="2"
                               Text="{Binding StatusText}"
                               FontSize="12" Opacity="0.7"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <Button Grid.Column="3"
                            Classes="share-pill"
                            Margin="0,0,8,0"
                            Click="OnCopyClick"
                            IsEnabled="{Binding Preview, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource CopyIcon}" Width="13" Height="13"/>
                            <TextBlock Text="Copy" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="4"
                            Classes="share-pill"
                            Background="{DynamicResource AccentColorBrush}"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            Click="OnSaveClick"
                            IsEnabled="{Binding Preview, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource SaveDiskIcon}" Width="13" Height="13"
                                      Foreground="{DynamicResource AccentForegroundBrush}"/>
                            <TextBlock Text="Save PNG" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
