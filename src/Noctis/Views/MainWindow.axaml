<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:m="using:Noctis.Models"
        xmlns:views="using:Noctis.Views"
        xmlns:controls="using:Noctis.Controls"
        xmlns:conv="using:Noctis.Converters"
        x:Class="Noctis.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Noctis"
        Icon="avares://Noctis/Assets/Icons/Noctis.ico"
        Width="1280" Height="800"
        MinWidth="780" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppMainBackground}"
        DragDrop.AllowDrop="True">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Right" Command="{Binding Player.NextCommand}" />
        <KeyBinding Gesture="Ctrl+Left" Command="{Binding Player.PreviousCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding Sidebar.CreatePlaylistCommand}" />
    </Window.KeyBindings>


    <Panel Background="Transparent">
    <DockPanel x:Name="RootPanel" Focusable="True" Background="Transparent" Margin="76,0,0,0">
        <DockPanel.RenderTransform>
            <TranslateTransform X="0">
                <TranslateTransform.Transitions>
                    <Transitions>
                        <DoubleTransition Property="X" Duration="0:0:0.2">
                            <DoubleTransition.Easing>
                                <CubicEaseOut/>
                            </DoubleTransition.Easing>
                        </DoubleTransition>
                    </Transitions>
                </TranslateTransform.Transitions>
            </TranslateTransform>
        </DockPanel.RenderTransform>

        <Grid RowDefinitions="58,*">
            <!-- Zone A: Top bar left | centered playback island | right actions -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                <!-- Full-width bottom separator line -->
                <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom"
                        Height="1" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                        Opacity="0.08"
                        IsVisible="{Binding IsLyricsViewActive, Converter={x:Static BoolConverters.Not}}" />
                <!-- Left: page title / back button (spans both columns for background) -->
                <views:TopBarView Grid.Column="0" Grid.ColumnSpan="2"
                                  DataContext="{Binding TopBar}"
                                  IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLyricsViewActive, Converter={x:Static BoolConverters.Not}, FallbackValue=True}" />

                <!-- Center: playback island (column 0 only — can never overlap column 1) -->
                <views:PlaybackBarView Grid.Column="0" Grid.ColumnSpan="2"
                                       DataContext="{Binding Player}"
                                       IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsPlaybackBarVisible, FallbackValue=False}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,4,0,4">
                    <views:PlaybackBarView.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </views:PlaybackBarView.Transitions>
                </views:PlaybackBarView>

                <!-- Right: TopBar action buttons, view toggle, search -->
                <StackPanel Grid.Column="1"
                            x:DataType="vm:TopBarViewModel"
                            DataContext="{Binding TopBar}"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLyricsViewActive, Converter={x:Static BoolConverters.Not}, FallbackValue=True}">

                    <!-- Page action buttons (e.g. Songs: Shuffle, Queue, Options) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasPageActions}">
                        <Button Classes="accent-btn" Background="#E04060"
                                BorderThickness="0" Padding="12,10" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PageShuffleCommand}"
                                ToolTip.Tip="Shuffle all songs" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource ShuffleIcon}" Width="15" Height="15"
                                     VerticalAlignment="Center" Foreground="White" />
                        </Button>
                        <Button Classes="accent-btn" Background="#E04060"
                                BorderThickness="0" Padding="12,10" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PageQueueCommand}" Tag="QueueToggle"
                                ToolTip.Tip="View Queue" VerticalAlignment="Center">
                            <Border Width="15" Height="15" Background="White" VerticalAlignment="Center"
                                    RenderOptions.BitmapInterpolationMode="HighQuality">
                                <Border.OpacityMask>
                                    <ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" />
                                </Border.OpacityMask>
                            </Border>
                        </Button>
                        <Button Classes="accent-btn" Background="#E04060"
                                BorderThickness="0" Padding="12,10" CornerRadius="999" Cursor="Hand"
                                ToolTip.Tip="Options" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource MoreDotsIcon}" Width="15" Height="15"
                                     VerticalAlignment="Center" Foreground="White" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="All Items" Command="{Binding PageSetShowAllItemsCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                     IsVisible="{Binding PageShowAllItems}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Only Favorites" Command="{Binding PageSetShowOnlyFavoritesCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                     IsVisible="{Binding PageShowOnlyFavorites}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Sort By">
                                        <MenuItem Header="Album" Command="{Binding PageSortCommand}" CommandParameter="Album" />
                                        <MenuItem Header="Artist" Command="{Binding PageSortCommand}" CommandParameter="Artist" />
                                        <MenuItem Header="Genre" Command="{Binding PageSortCommand}" CommandParameter="Genre" />
                                        <MenuItem Header="Plays" Command="{Binding PageSortCommand}" CommandParameter="Plays" />
                                        <MenuItem Header="Time" Command="{Binding PageSortCommand}" CommandParameter="Time" />
                                        <MenuItem Header="Title" Command="{Binding PageSortCommand}" CommandParameter="Title" />
                                        <Separator />
                                        <MenuItem Header="Ascending" Command="{Binding PageSortCommand}" CommandParameter="Ascending">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortAscending}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Descending" Command="{Binding PageSortCommand}" CommandParameter="Descending">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortDescending}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <!-- Playlist action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasPlaylistActions}">
                        <Button Classes="accent-btn" Background="#E04060"
                                BorderThickness="0" Padding="12,10" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PageCreateSmartPlaylistCommand}"
                                ToolTip.Tip="Create Smart Playlist" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource SmartPlaylistIcon}" Width="15" Height="15"
                                     VerticalAlignment="Center" Foreground="White" />
                        </Button>
                    </StackPanel>

                    <!-- Artist discography action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasArtistActions}">
                        <Button Classes="accent-btn" Background="#E04060"
                                BorderThickness="0" Padding="12,10" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PageShuffleArtistCommand}"
                                ToolTip.Tip="Shuffle All" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource ShuffleIcon}"
                                     Width="15" Height="15"
                                     VerticalAlignment="Center" Foreground="White" />
                        </Button>
                        <Button Classes="accent-btn" Background="#E04060"
                                BorderThickness="0" Padding="12,10" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PagePlayArtistCommand}"
                                ToolTip.Tip="Play All" VerticalAlignment="Center">
                            <Border Width="15" Height="15" Background="White" VerticalAlignment="Center"
                                    RenderOptions.BitmapInterpolationMode="HighQuality">
                                <Border.OpacityMask>
                                    <ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" />
                                </Border.OpacityMask>
                            </Border>
                        </Button>
                    </StackPanel>

                    <!-- Albums view mode toggle (Library / Cover Flow) -->
                    <Border IsVisible="{Binding HasAlbumsViewModeToggle}"
                            Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                            CornerRadius="999" Padding="3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button x:Name="AlbumsLibraryModeBtn"
                                    Command="{Binding AlbumsSetLibraryModeCommand}"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Background="#30FFFFFF" ToolTip.Tip="Library"
                                    Content="Library" FontSize="12" FontWeight="SemiBold" />
                            <Button x:Name="AlbumsUpNextModeBtn"
                                    Command="{Binding AlbumsSetCoverFlowModeCommand}"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Background="Transparent" Opacity="0.5" ToolTip.Tip="Cover Flow"
                                    Content="Cover Flow" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <!-- Search field -->
                    <Border Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                            CornerRadius="999" Padding="10,4,4,4" Height="32" MaxWidth="220"
                            IsVisible="{Binding IsSearchVisible}">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <Viewbox Grid.Column="0" Width="12" Height="12" Margin="0,0,6,0"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource SystemControlForegroundBaseHighBrush}" Opacity="0.45"
                                          Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBox Grid.Column="1"
                                     x:Name="SearchBox"
                                     Classes="search-box"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="{Binding CurrentTabName, StringFormat='Find in {0}'}"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="12" Padding="0,2"
                                     VerticalAlignment="Center" MinWidth="120"/>
                            <Button Grid.Column="2"
                                    Command="{Binding ClearSearchCommand}"
                                    IsVisible="{Binding SearchText.Length}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,2" Cursor="Hand" VerticalAlignment="Center">
                                <TextBlock Text="&#x2715;" FontSize="11" Opacity="0.5"/>
                            </Button>
                        </Grid>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- Zone C: Main Content Area + Lyrics Panel + Queue Popup -->
            <DockPanel x:Name="ContentDockPanel" Grid.Row="1">
                <!-- Lyrics side panel (right, below top bar) -->
                <Border x:Name="LyricsPanelWrapper" DockPanel.Dock="Right"
                        Width="0"
                        Margin="8,8,8,12"
                        CornerRadius="16"
                        ClipToBounds="True">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.2">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </Border.Transitions>
                    <Grid Width="340">
                        <Grid>
                            <!-- Base dark background -->
                            <Border Background="{DynamicResource AppSidebarBackground}" CornerRadius="16" />
                            <!-- Subtle color tint from album art -->
                            <Border Background="{Binding Lyrics.LyricsBackgroundBrush}"
                                    CornerRadius="16"
                                    Opacity="0.85">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.4">
                                            <DoubleTransition.Easing><CubicEaseOut/></DoubleTransition.Easing>
                                        </DoubleTransition>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                            <views:LyricsPanelView DataContext="{Binding Lyrics}" />
                        </Grid>
                    </Grid>
                </Border>

                <Grid Background="{DynamicResource AppMainBackground}">
                <ContentControl Content="{Binding CurrentView}"
                                Classes="page-host"
                                RenderTransformOrigin="50%,50%">
                    <ContentControl.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </ContentControl.Transitions>
                </ContentControl>

                <!-- Queue popup panel (right side, rounded) -->
                <Border x:Name="QueuePopupPanel"
                        HorizontalAlignment="Right"
                        Width="330"
                        Margin="0,8,8,8"
                        CornerRadius="16"
                        ClipToBounds="True"
                        Background="{DynamicResource AppSidebarBackground}"
                        IsVisible="{Binding Player.IsQueuePopupOpen}"
                        BoxShadow="-2 0 12 0 #40000000">

                    <DockPanel>
                        <!-- Header -->
                        <Grid DockPanel.Dock="Top" Margin="20,16,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Queue"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding Player.UpNext.Count, StringFormat='{}&#x2022; {0}'}"
                                           FontSize="14"
                                           Opacity="0.7"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,3"
                                    Cursor="Hand"
                                    Click="OnQueueClearClick"
                                    IsVisible="{Binding !!Player.UpNext.Count}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="18" Height="18"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                            RenderOptions.BitmapInterpolationMode="HighQuality">
                                        <Border.OpacityMask>
                                            <ImageBrush Source="avares://Noctis/Assets/Icons/Clear%20Queue%20ICON.png" Stretch="Uniform" />
                                        </Border.OpacityMask>
                                    </Border>
                                    <TextBlock Text="Clear"
                                               FontSize="14"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Separator -->
                        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" Opacity="0.08" Margin="20,0" />


                        <!-- Queue track list (virtualized, drag-reorder enabled) -->
                        <Grid x:Name="QueueListWrapper">
                            <ListBox x:Name="QueuePopupListBox"
                                     Classes="queue-popup"
                                     ItemsSource="{Binding Player.UpNext}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Margin="0,6,0,8"
                                     SelectionMode="Single"
                                     AutoScrollToSelectedItem="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                     DragDrop.AllowDrop="True"
                                     DoubleTapped="OnQueueItemDoubleTapped">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <Style Selector="ListBox.queue-popup ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="m:Track">
                                        <Grid ColumnDefinitions="Auto,*,Auto" Height="56"
                                              Margin="20,0,18,0"
                                              Background="Transparent"
                                              Tag="{Binding}"
                                              PointerPressed="OnQueueItemPointerPressed"
                                              PointerMoved="OnQueueItemPointerMoved">
                                            <Grid.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Remove from Queue"
                                                              Click="OnQueueRemoveClick">
                                                        <MenuItem.Icon>
                                                            <Border Width="14" Height="14"
                                                                    Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                                    RenderOptions.BitmapInterpolationMode="HighQuality">
                                                                <Border.OpacityMask>
                                                                    <ImageBrush Source="avares://Noctis/Assets/Icons/Clear%20Queue%20ICON.png" Stretch="Uniform" />
                                                                </Border.OpacityMask>
                                                            </Border>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Grid.ContextMenu>

                                            <!-- Album art thumbnail -->
                                            <Border Grid.Column="0"
                                                    Width="48" Height="48"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <controls:CachedImage SourcePath="{Binding AlbumArtworkPath}"
                                                                      Stretch="UniformToFill" />
                                            </Border>
                                            <!-- Title + Artist -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <Grid ColumnDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Title}"
                                                               Classes="one-line-explicit-title"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               MaxWidth="165" />
                                                    <Border Grid.Column="1"
                                                            Classes="explicit-badge compact"
                                                            Margin="4,0,0,0"
                                                            IsVisible="{Binding IsExplicit}"
                                                            ToolTip.Tip="Explicit"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="E"
                                                                   Classes="explicit-badge-text compact"
                                                                   FontSize="9"
                                                                   Opacity="0.9" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding Artist}"
                                                           FontSize="11"
                                                           Opacity="0.5"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                            <!-- Track duration -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DurationFormatted}"
                                                       FontSize="12"
                                                       Opacity="0.4"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Drop indicator line for drag reorder -->
                            <Border x:Name="QueueDropIndicator"
                                    IsHitTestVisible="False"
                                    IsVisible="False"
                                    Height="2"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Stretch"
                                    Margin="20,0"
                                    CornerRadius="1"
                                    Background="{DynamicResource AccentColorBrush}">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>

            </Grid>
            </DockPanel>

            <!-- Debug panel overlay (toggled via Ctrl+Shift+D) -->
            <views:DebugPanelView Grid.Row="1"
                                  DataContext="{Binding DebugPanel}"
                                  IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsDebugPanelVisible}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Stretch"
                                  Width="620"
                                  Margin="228,8,0,8"
                                  IsHitTestVisible="True" />
        </Grid>
    </DockPanel>

    <!-- Drag-drop overlay (shown while dragging importable files over the window) -->
    <Border x:Name="DragDropOverlay"
            IsVisible="False"
            IsHitTestVisible="False"
            Background="#18FFFFFF"
            BorderBrush="{StaticResource SystemControlHighlightAccentBrush}"
            BorderThickness="2"
            Margin="4"
            CornerRadius="8"
            Opacity="0">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Border.Transitions>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <PathIcon Data="M12,2 L12,14 M8,10 L12,14 L16,10 M4,18 L20,18"
                      Width="32" Height="32"
                      Foreground="{StaticResource SystemControlHighlightAccentBrush}" />
            <TextBlock Text="Drop files to import"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#CCFFFFFF"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>

    <!-- Sidebar: overlaid so hover-expand doesn't reflow content -->
    <Border x:Name="SidebarWrapper"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Width="60"
            Margin="8,8,8,12"
            CornerRadius="20"
            ClipToBounds="True"
            ZIndex="10">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Width" Duration="0:0:0.2">
                    <DoubleTransition.Easing>
                        <CubicEaseOut/>
                    </DoubleTransition.Easing>
                </DoubleTransition>
            </Transitions>
        </Border.Transitions>
        <views:SidebarView HorizontalAlignment="Stretch"
                           DataContext="{Binding Sidebar}" />
    </Border>

    </Panel>

</Window>
