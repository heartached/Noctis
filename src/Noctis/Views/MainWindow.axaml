<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:m="using:Noctis.Models"
        xmlns:views="using:Noctis.Views"
        xmlns:controls="using:Noctis.Controls"
        xmlns:conv="using:Noctis.Converters"
        xmlns:helpers="using:Noctis.Helpers"
        x:Class="Noctis.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Noctis"
        Icon="avares://Noctis/Assets/Icons/Noctis.ico"
        Width="1280" Height="800"
        MinWidth="780" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppMainBackground}"
        DragDrop.AllowDrop="True">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Right" Command="{Binding Player.NextCommand}" />
        <KeyBinding Gesture="Ctrl+Left" Command="{Binding Player.PreviousCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding Sidebar.CreatePlaylistCommand}" />
    </Window.KeyBindings>


    <Panel Background="Transparent">
    <DockPanel x:Name="RootPanel" Focusable="True" Background="Transparent" Margin="76,0,0,0">
        <DockPanel.RenderTransform>
            <TranslateTransform X="0">
                <TranslateTransform.Transitions>
                    <Transitions>
                        <DoubleTransition Property="X" Duration="0:0:0.2">
                            <DoubleTransition.Easing>
                                <CubicEaseOut/>
                            </DoubleTransition.Easing>
                        </DoubleTransition>
                    </Transitions>
                </TranslateTransform.Transitions>
            </TranslateTransform>
        </DockPanel.RenderTransform>

        <Grid RowDefinitions="58,*">
            <!-- Zone A: Top bar left | centered playback island | right actions -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ZIndex="20"
                  IsHitTestVisible="{Binding IsLyricsViewActive, Converter={x:Static BoolConverters.Not}, FallbackValue=True}">
                <!-- Full-width bottom separator line -->
                <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom"
                        Height="1" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                        Opacity="0.08"
                        IsVisible="{Binding IsLyricsViewActive, Converter={x:Static BoolConverters.Not}}" />
                <!-- Left: page title / back button — confined to column 0 so a long title never renders under the right action buttons -->
                <views:TopBarView Grid.Column="0"
                                  DataContext="{Binding TopBar}"
                                  IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLyricsViewActive, Converter={x:Static BoolConverters.Not}, FallbackValue=True}" />

                <!-- Right: TopBar action buttons, view toggle, search -->
                <StackPanel Grid.Column="1"
                            x:DataType="vm:TopBarViewModel"
                            DataContext="{Binding TopBar}"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLyricsViewActive, Converter={x:Static BoolConverters.Not}, FallbackValue=True}">

                    <!-- Page action buttons (e.g. Songs: Shuffle, Queue, Options) -->
                    <Border IsVisible="{Binding HasPageActions}"
                            Background="{DynamicResource AccentColorBrush}"
                            BorderBrush="{DynamicResource AccentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999" Padding="3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button Classes="accent-btn" Background="Transparent"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PageShuffleCommand}"
                                    ToolTip.Tip="Shuffle" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource ShuffleIcon}" Width="14" Height="14"
                                         VerticalAlignment="Center" Foreground="{DynamicResource AccentForegroundBrush}" />
                            </Button>
                            <Button Classes="accent-btn" Background="Transparent"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PageQueueCommand}" Tag="QueueToggle"
                                    ToolTip.Tip="Queue" VerticalAlignment="Center">
                                <Border Width="14" Height="14" Background="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center"
                                        RenderOptions.BitmapInterpolationMode="HighQuality">
                                    <Border.OpacityMask>
                                        <ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" />
                                    </Border.OpacityMask>
                                </Border>
                            </Button>
                            <Button Classes="accent-btn" Background="Transparent"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    ToolTip.Tip="Options" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource MoreDotsIcon}" Width="14" Height="14"
                                         VerticalAlignment="Center" Foreground="{DynamicResource AccentForegroundBrush}" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight"
                                            PlacementConstraintAdjustment="None"
                                            helpers:MenuOpenAnimation.EnableFlyoutClose="True">
                                    <MenuItem Header="All Items" Command="{Binding PageSetShowAllItemsCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                     IsVisible="{Binding PageShowAllItems}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Only Favorites" Command="{Binding PageSetShowOnlyFavoritesCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                     IsVisible="{Binding PageShowOnlyFavorites}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem x:Name="PageSortByMenuItem"
                                              Header="Sort By"
                                              PointerEntered="OnPageSortByMenuItemPointerEntered">
                                        <MenuItem Header="Title" Command="{Binding PageSortCommand}" CommandParameter="Title">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByTitle}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Album" Command="{Binding PageSortCommand}" CommandParameter="Album">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByAlbum}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Artist" Command="{Binding PageSortCommand}" CommandParameter="Artist">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByArtist}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Genre" Command="{Binding PageSortCommand}" CommandParameter="Genre">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByGenre}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Year" Command="{Binding PageSortCommand}" CommandParameter="Year">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByYear}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Time" Command="{Binding PageSortCommand}" CommandParameter="Time">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByTime}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Plays" Command="{Binding PageSortCommand}" CommandParameter="Plays">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByPlays}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Ascending" Command="{Binding PageSortCommand}" CommandParameter="Ascending">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortAscending}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Descending" Command="{Binding PageSortCommand}" CommandParameter="Descending">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortDescending}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        </StackPanel>
                    </Border>

                    <!-- Playlist action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasPlaylistActions}">
                        <Button Classes="accent-btn" Background="{DynamicResource AccentColorBrush}"
                                Padding="12,10" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PageCreateSmartPlaylistCommand}"
                                ToolTip.Tip="Create Smart Playlist" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource SmartPlaylistIcon}" Width="15" Height="15"
                                     VerticalAlignment="Center" Foreground="{DynamicResource AccentForegroundBrush}" />
                        </Button>
                    </StackPanel>

                    <!-- Artist discography action buttons -->
                    <Border IsVisible="{Binding HasArtistActions}"
                            Background="{DynamicResource AccentColorBrush}"
                            BorderBrush="{DynamicResource AccentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999" Padding="3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button Classes="accent-btn" Background="Transparent"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PageShuffleArtistCommand}"
                                    ToolTip.Tip="Shuffle All" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource ShuffleIcon}"
                                          Width="14" Height="14"
                                          VerticalAlignment="Center" Foreground="{DynamicResource AccentForegroundBrush}" />
                            </Button>
                            <Button Classes="accent-btn" Background="Transparent"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PagePlayArtistCommand}"
                                    ToolTip.Tip="Play All" VerticalAlignment="Center">
                                <Border Width="14" Height="14" Background="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center"
                                        Margin="2,0,0,0"
                                        RenderOptions.BitmapInterpolationMode="HighQuality">
                                    <Border.OpacityMask>
                                        <ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" />
                                    </Border.OpacityMask>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Favorites action buttons -->
                    <Border IsVisible="{Binding HasFavoritesActions}"
                            Background="{DynamicResource AccentColorBrush}"
                            BorderBrush="{DynamicResource AccentBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999" Padding="3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button Classes="accent-btn" Background="Transparent"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PageShuffleFavoritesCommand}"
                                    ToolTip.Tip="Shuffle" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource ShuffleIcon}"
                                          Width="14" Height="14"
                                          VerticalAlignment="Center" Foreground="{DynamicResource AccentForegroundBrush}" />
                            </Button>
                            <Button Classes="accent-btn" Background="Transparent"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PagePlayFavoritesCommand}"
                                    ToolTip.Tip="Play" VerticalAlignment="Center">
                                <Border Width="14" Height="14" Background="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center"
                                        Margin="2,0,0,0"
                                        RenderOptions.BitmapInterpolationMode="HighQuality">
                                    <Border.OpacityMask>
                                        <ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" />
                                    </Border.OpacityMask>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- View mode toggle (Library / Cover Flow) -->
                    <Border IsVisible="{Binding HasViewModeToggle}"
                            Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                            CornerRadius="999" Padding="3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button x:Name="AlbumsLibraryModeBtn"
                                    Command="{Binding SetLibraryModeCommand}"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Background="#30FFFFFF" ToolTip.Tip="Library"
                                    Content="Library" FontSize="12" FontWeight="SemiBold" />
                            <Button x:Name="AlbumsUpNextModeBtn"
                                    Command="{Binding SetCoverFlowModeCommand}"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Background="Transparent" Opacity="0.5" ToolTip.Tip="Cover Flow"
                                    Content="Cover Flow" FontSize="12" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <!-- Search field -->
                    <Border Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                            CornerRadius="999" Padding="10,4,4,4" Height="32" MaxWidth="220"
                            IsVisible="{Binding IsSearchVisible}">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <Viewbox Grid.Column="0" Width="12" Height="12" Margin="0,0,6,0"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{DynamicResource SystemControlForegroundBaseHighBrush}" Opacity="0.45"
                                          Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBox Grid.Column="1"
                                     x:Name="SearchBox"
                                     Classes="search-box"
                                     Text="{Binding SearchText, Mode=TwoWay}"
                                     Watermark="{Binding SearchWatermark}"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="12" Padding="0,2"
                                     VerticalAlignment="Center" MinWidth="120"/>
                            <Button Grid.Column="2"
                                    Command="{Binding ClearSearchCommand}"
                                    IsVisible="{Binding SearchText.Length}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,2" Cursor="Hand" VerticalAlignment="Center">
                                <TextBlock Text="&#x2715;" FontSize="11" Opacity="0.5"/>
                            </Button>
                        </Grid>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- Zone C: Main Content Area + Overlay Panels -->
            <DockPanel x:Name="ContentDockPanel" Grid.Row="1">
                <Grid Background="{DynamicResource AppMainBackground}">
                <ContentControl Content="{Binding CurrentView}"
                                Classes="page-host"
                                RenderTransformOrigin="50%,50%">
                    <ContentControl.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </ContentControl.Transitions>
                </ContentControl>

                <!-- Lyrics side panel overlays content so opening it does not resize album grids. -->
                <Border x:Name="LyricsPanelWrapper"
                        HorizontalAlignment="Right"
                        Width="0"
                        Margin="0,8,8,12"
                        CornerRadius="16"
                        ClipToBounds="True"
                        ZIndex="10">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.2">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </Border.Transitions>
                    <Grid Width="340">
                        <Grid>
                            <!-- Opaque dark base so the panel never bleeds through -->
                            <Border Background="{DynamicResource AppSidebarBackground}" CornerRadius="16" />
                            <!-- Vertical album-art gradient tuned for the narrow panel: colorful top-to-bottom, no dark corners -->
                            <Border Background="{Binding Lyrics.PanelBackgroundBrush}"
                                    CornerRadius="16">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.4">
                                            <DoubleTransition.Easing><CubicEaseOut/></DoubleTransition.Easing>
                                        </DoubleTransition>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>
                            <views:LyricsPanelView DataContext="{Binding Lyrics}" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Queue popup panel (right side, rounded, slightly transparent) -->
                <Border x:Name="QueuePopupPanel"
                        HorizontalAlignment="Right"
                        Width="330"
                        Margin="0,8,8,8"
                        CornerRadius="16"
                        ClipToBounds="True"
                        Background="#E61C1C1C"
                        TextElement.Foreground="White"
                        IsVisible="{Binding Player.IsQueuePopupOpen}"
                        BoxShadow="-2 0 12 0 #40000000"
                        ZIndex="20">

                    <DockPanel>
                        <!-- "Currently Playing" big header + Clear pill on the right -->
                        <Grid DockPanel.Dock="Top" Margin="20,16,20,8"
                              ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="Currently Playing"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                     Classes="accent-btn"
                                     Background="{DynamicResource AccentColorBrush}"
                                     Foreground="{DynamicResource AccentForegroundBrush}"
                                    CornerRadius="999"
                                    Padding="14,5"
                                    Cursor="Hand"
                                    Content="Clear"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Click="OnQueueClearClick"
                                    IsVisible="{Binding !!Player.UpNext.Count}"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <!-- Now-playing track card -->
                        <Border DockPanel.Dock="Top"
                                Margin="20,2,20,6"
                                IsVisible="{Binding Player.CurrentTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <Grid ColumnDefinitions="Auto,*">
                                <Border Grid.Column="0"
                                        Width="48" Height="48"
                                        CornerRadius="6"
                                        ClipToBounds="True"
                                        VerticalAlignment="Center">
                                    <controls:CachedImage SourcePath="{Binding Player.CurrentTrack.AlbumArtworkPath}"
                                                          Stretch="UniformToFill" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Player.CurrentTrack.Title}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Text="{Binding Player.CurrentTrack.Artist}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentColorBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Track count line + save-as-playlist -->
                        <Grid DockPanel.Dock="Top" Margin="20,2,20,10" ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Player.UpNext.Count, StringFormat='{}{0} &#x2022; tracks'}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Opacity="0.55" />
                            <Button Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,2"
                                    Cursor="Hand"
                                    ToolTip.Tip="Save the current queue as a playlist"
                                    Command="{Binding Player.SaveQueueAsPlaylistCommand}"
                                    IsVisible="{Binding !!Player.UpNext.Count}">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <PathIcon Data="{StaticResource PlaylistsIcon}"
                                              Width="12" Height="12"
                                              Foreground="White"
                                              Opacity="0.55"
                                              VerticalAlignment="Center" />
                                    <TextBlock Text="Save as playlist"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Opacity="0.55"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Separator -->
                        <Border DockPanel.Dock="Top" Height="1" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" Opacity="0.08" Margin="20,0" />


                        <!-- Queue track list (virtualized, drag-reorder enabled) -->
                        <Grid x:Name="QueueListWrapper">
                            <ListBox x:Name="QueuePopupListBox"
                                     Classes="queue-popup"
                                     ItemsSource="{Binding Player.UpNext}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Margin="0,6,0,8"
                                     SelectionMode="Single"
                                     AutoScrollToSelectedItem="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                     DragDrop.AllowDrop="True"
                                     DoubleTapped="OnQueueItemDoubleTapped">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,3"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <!-- Hover highlight on each queue row, matching album track-list. -->
                                    <Style Selector="Border.queue-row">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <Style Selector="Border.queue-row:pointerover">
                                        <Setter Property="Background" Value="{DynamicResource TrackListHoverBrush}"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="m:Track">
                                        <StackPanel Spacing="0">
                                        <!-- Single rounded-pill container wraps the entire row so the
                                             drag highlight covers album art + text + duration as one card. -->
                                        <Border Classes="queue-row"
                                                Margin="14,2,14,2"
                                                Padding="6,4"
                                                CornerRadius="14"
                                                Tag="{Binding}"
                                                PointerPressed="OnQueueItemPointerPressed"
                                                PointerMoved="OnQueueItemPointerMoved"
                                                PointerReleased="OnQueueItemPointerReleased"
                                                PointerCaptureLost="OnQueueItemPointerCaptureLost">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Remove from Queue"
                                                              Click="OnQueueRemoveClick">
                                                        <MenuItem.Icon>
                                                            <Border Width="14" Height="14"
                                                                    Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                                    RenderOptions.BitmapInterpolationMode="HighQuality">
                                                                <Border.OpacityMask>
                                                                    <ImageBrush Source="avares://Noctis/Assets/Icons/Clear%20Queue%20ICON.png" Stretch="Uniform" />
                                                                </Border.OpacityMask>
                                                            </Border>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                        <Grid ColumnDefinitions="Auto,*,Auto" Height="50"
                                              Background="Transparent">

                                            <!-- Album art thumbnail -->
                                            <Border Grid.Column="0"
                                                    Width="44" Height="44"
                                                    CornerRadius="6"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <controls:CachedImage SourcePath="{Binding AlbumArtworkPath}"
                                                                      Stretch="UniformToFill" />
                                            </Border>
                                            <!-- Title + Artist -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <Grid ColumnDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding TitleDisplay}"
                                                               Classes="one-line-explicit-title"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               MaxWidth="165" />
                                                    <Border Grid.Column="1"
                                                            Classes="explicit-badge compact"
                                                            Margin="4,0,0,0"
                                                            IsVisible="{Binding IsExplicit}"
                                                            ToolTip.Tip="Explicit"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="E"
                                                                   Classes="explicit-badge-text compact"
                                                                   FontSize="9"
                                                                   Opacity="0.9" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding ArtistDisplay}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentColorBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                            <!-- Track duration -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DurationFormatted}"
                                                       FontSize="12"
                                                       Foreground="White"
                                                       Opacity="0.4"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                        </Border>
                                        <!-- Separator line between tracks -->
                                        <Border Height="1"
                                                Margin="78,0,18,0"
                                                Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                Opacity="0.06" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Drop indicator line for drag reorder -->
                            <Border x:Name="QueueDropIndicator"
                                    IsHitTestVisible="False"
                                    IsVisible="False"
                                    Height="2"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Stretch"
                                    Margin="20,0"
                                    CornerRadius="1"
                                    Background="{DynamicResource AccentColorBrush}">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                            </Border>

                            <!-- Floating drag preview: follows the pointer Y while reordering. -->
                            <Border x:Name="QueueDragPreview"
                                    x:DataType="m:Track"
                                    IsHitTestVisible="False"
                                    IsVisible="False"
                                    Margin="14,0,14,0"
                                    Padding="6,4"
                                    CornerRadius="14"
                                    Background="{DynamicResource AccentColorBrush}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    BoxShadow="0 6 22 0 #80000000">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                                <Grid ColumnDefinitions="Auto,*,Auto" Height="50">
                                    <Border Grid.Column="0"
                                            Width="44" Height="44"
                                            CornerRadius="6"
                                            ClipToBounds="True"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                        <controls:CachedImage SourcePath="{Binding AlbumArtworkPath}"
                                                              Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding TitleDisplay}"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AccentForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />
                                        <TextBlock Text="{Binding ArtistDisplay}"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource AccentForegroundBrush}"
                                                   Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding DurationFormatted}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AccentForegroundBrush}"
                                               Opacity="0.7"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </Grid>
                    </DockPanel>
                </Border>

            </Grid>
            </DockPanel>

            <!-- Debug panel overlay (toggled via Ctrl+Shift+D) -->
            <views:DebugPanelView Grid.Row="1"
                                  DataContext="{Binding DebugPanel}"
                                  IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsDebugPanelVisible}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Stretch"
                                  Width="620"
                                  Margin="228,8,0,8"
                                  IsHitTestVisible="True" />
        </Grid>
    </DockPanel>

    <!-- Drag-drop overlay (shown while dragging importable files over the window) -->
    <Border x:Name="DragDropOverlay"
            IsVisible="False"
            IsHitTestVisible="False"
            Background="#18FFFFFF"
            BorderBrush="{StaticResource SystemControlHighlightAccentBrush}"
            BorderThickness="2"
            Margin="4"
            CornerRadius="8"
            Opacity="0">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Border.Transitions>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <PathIcon Data="M12,2 L12,14 M8,10 L12,14 L16,10 M4,18 L20,18"
                      Width="32" Height="32"
                      Foreground="{StaticResource SystemControlHighlightAccentBrush}" />
            <TextBlock Text="Drop files to import"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#CCFFFFFF"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>

    <!-- Bottom playback island (Apple Music-style glass pill) -->
    <views:PlaybackBarView DataContext="{Binding Player}"
                           CompactWhenLyricsPageActive="False"
                           IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsPlaybackBarMounted, FallbackValue=False}"
                           IsHitTestVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsPlaybackBarHitTestVisible, FallbackValue=False}"
                           Opacity="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).PlaybackBarOpacity, FallbackValue=0}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,16"
                           ZIndex="30" />

    <!-- Sidebar: overlaid so hover-expand doesn't reflow content -->
    <Border x:Name="SidebarWrapper"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Width="60"
            Margin="8,8,8,12"
            CornerRadius="20"
            ClipToBounds="True"
            ZIndex="10">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Width" Duration="0:0:0.2">
                    <DoubleTransition.Easing>
                        <CubicEaseOut/>
                    </DoubleTransition.Easing>
                </DoubleTransition>
            </Transitions>
        </Border.Transitions>
        <views:SidebarView HorizontalAlignment="Stretch"
                           DataContext="{Binding Sidebar}" />
    </Border>

    <!-- Settings modal overlay (dark backdrop + centered popup card) -->
    <Border IsVisible="{Binding IsSettingsModalOpen}"
            Background="#A6000000"
            ZIndex="100"
            Tapped="OnSettingsBackdropTapped">
        <Border Width="780" MaxHeight="720"
                Background="{DynamicResource AppMainBackground}"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Tapped="OnSettingsCardTapped"
                BoxShadow="0 24 60 0 #80000000">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Grid Grid.Row="0" Margin="28,22,18,8" ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Settings"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Width="32" Height="32"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="999"
                            Cursor="Hand"
                            ToolTip.Tip="Close"
                            Command="{Binding CloseSettingsCommand}">
                        <PathIcon Data="M 5 5 L 13 13 M 13 5 L 5 13"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </Button>
                </Grid>

                <!-- Settings content (existing SettingsView, scrollable) -->
                <views:SettingsView Grid.Row="1"
                                    DataContext="{Binding Settings}"
                                    Background="Transparent"/>

                <!-- Footer with Close button -->
                <Border Grid.Row="2"
                        BorderBrush="#14FFFFFF" BorderThickness="0,1,0,0"
                        Padding="20,12">
                    <Button Classes="accent-btn"
                            HorizontalAlignment="Right"
                            Padding="22,9"
                            CornerRadius="999"
                            Background="{DynamicResource AccentColorBrush}"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            Cursor="Hand"
                            Content="Close"
                            FontWeight="Bold"
                            Command="{Binding CloseSettingsCommand}"/>
                </Border>
            </Grid>
        </Border>
    </Border>

    </Panel>

</Window>
