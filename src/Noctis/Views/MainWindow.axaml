<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:m="using:Noctis.Models"
        xmlns:views="using:Noctis.Views"
        xmlns:controls="using:Noctis.Controls"
        xmlns:conv="using:Noctis.Converters"
        xmlns:helpers="using:Noctis.Helpers"
        x:Class="Noctis.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Noctis"
        Icon="avares://Noctis/Assets/Icons/Noctis.ico"
        Width="1280" Height="800"
        MinWidth="780" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppMainBackground}"
        DragDrop.AllowDrop="True">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Right" Command="{Binding Player.NextCommand}" />
        <KeyBinding Gesture="Ctrl+Left" Command="{Binding Player.PreviousCommand}" />
        <KeyBinding Gesture="Ctrl+N" Command="{Binding Sidebar.CreatePlaylistCommand}" />
        <KeyBinding Gesture="Ctrl+F" Command="{Binding Sidebar.TopBar.OpenSearchCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <!-- Ghost buttons inside the translucent page-actions pill (Songs top bar):
             muted icons that brighten with a chip-hover highlight on pointerover. -->
        <Style Selector="Button.ghost-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ghost-btn:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="Button.ghost-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChipHoverBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.ghost-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChipHoverBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
    </Window.Styles>


    <Panel Background="Transparent">
    <DockPanel x:Name="RootPanel" Focusable="True" Background="Transparent" Margin="76,0,0,0">
        <DockPanel.RenderTransform>
            <TranslateTransform X="0">
                <TranslateTransform.Transitions>
                    <Transitions>
                        <DoubleTransition Property="X" Duration="0:0:0.2">
                            <DoubleTransition.Easing>
                                <CubicEaseOut/>
                            </DoubleTransition.Easing>
                        </DoubleTransition>
                    </Transitions>
                </TranslateTransform.Transitions>
            </TranslateTransform>
        </DockPanel.RenderTransform>

        <Grid RowDefinitions="Auto,*">
            <!-- Zone A: Top bar left | centered playback island | right actions.
                 Auto-height: collapses on pages where the bar renders nothing
                 (e.g. Album Detail, whose Back/Search live in the sidebar rail). -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ZIndex="20"
                  IsHitTestVisible="{Binding IsLyricsViewActive, Converter={x:Static BoolConverters.Not}, FallbackValue=True}">
                <!-- Keeps the former fixed 58px bar height while the lyrics page is
                     active (its layout predates the collapsing bar). -->
                <Border Width="0" MinHeight="58" IsVisible="{Binding IsLyricsViewActive}" />
                <!-- Full-width bottom separator line -->
                <Border Grid.ColumnSpan="2" VerticalAlignment="Bottom"
                        Height="1" Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                        Opacity="0.08">
                    <Border.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!IsLyricsViewActive" />
                            <Binding Path="TopBar.HasBarContent" />
                        </MultiBinding>
                    </Border.IsVisible>
                </Border>
                <!-- Left: page title / back button — confined to column 0 so a long title never renders under the right action buttons -->
                <views:TopBarView Grid.Column="0"
                                  DataContext="{Binding TopBar}">
                    <views:TopBarView.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="!$parent[Window].((vm:MainWindowViewModel)DataContext).IsLyricsViewActive" FallbackValue="True" />
                            <Binding Path="HasBarContent" />
                        </MultiBinding>
                    </views:TopBarView.IsVisible>
                </views:TopBarView>

                <!-- Right: TopBar action buttons, view toggle, search -->
                <StackPanel Grid.Column="1"
                            x:DataType="vm:TopBarViewModel"
                            DataContext="{Binding TopBar}"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"
                            IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsLyricsViewActive, Converter={x:Static BoolConverters.Not}, FallbackValue=True}">
                    <StackPanel.Styles>
                        <Style Selector="Button.release-chip">
                            <Setter Property="Background" Value="{DynamicResource ChipBackground}"/>
                            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            <Setter Property="CornerRadius" Value="999"/>
                            <Setter Property="Padding" Value="14,6"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                        <Style Selector="Button.release-chip:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource ChipHoverBackground}"/>
                        </Style>
                    </StackPanel.Styles>

                    <!-- Artist discography: Type dropdown (right-aligned, mirrors the Albums grid) -->
                    <Button Classes="release-chip" VerticalAlignment="Center"
                            ToolTip.Tip="Filter by release type">
                        <Button.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="HasReleaseTypeChips"/>
                                <Binding Path="!IsPageTitleVisible"/>
                            </MultiBinding>
                        </Button.IsVisible>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Type:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ReleaseTypeFilterLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                                      RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="All"
                                          Command="{Binding ReleaseTypeFilterCommand}"
                                          CommandParameter="all"/>
                                <MenuItem Header="Albums"
                                          Command="{Binding ReleaseTypeFilterCommand}"
                                          CommandParameter="album"/>
                                <MenuItem Header="Singles"
                                          Command="{Binding ReleaseTypeFilterCommand}"
                                          CommandParameter="single"/>
                                <MenuItem Header="EPs"
                                          Command="{Binding ReleaseTypeFilterCommand}"
                                          CommandParameter="ep"/>
                                <MenuItem Header="Other"
                                          Command="{Binding ReleaseTypeFilterCommand}"
                                          CommandParameter="other"/>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Albums grid: Type / Quality / Sort dropdowns (right-aligned). Hidden on the
                         artist discography page (back button visible), which shows its own Type chip above. -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="HasReleaseTypeChips"/>
                                <Binding Path="IsPageTitleVisible"/>
                            </MultiBinding>
                        </StackPanel.IsVisible>

                        <Button Classes="release-chip" VerticalAlignment="Center"
                                ToolTip.Tip="Filter by release type">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Type:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ReleaseTypeFilterLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                                          RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="All"
                                              Command="{Binding ReleaseTypeFilterCommand}"
                                              CommandParameter="all"/>
                                    <MenuItem Header="Albums"
                                              Command="{Binding ReleaseTypeFilterCommand}"
                                              CommandParameter="album"/>
                                    <MenuItem Header="Singles"
                                              Command="{Binding ReleaseTypeFilterCommand}"
                                              CommandParameter="single"/>
                                    <MenuItem Header="EPs"
                                              Command="{Binding ReleaseTypeFilterCommand}"
                                              CommandParameter="ep"/>
                                    <MenuItem Header="Other"
                                              Command="{Binding ReleaseTypeFilterCommand}"
                                              CommandParameter="other"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <Button Classes="release-chip" VerticalAlignment="Center"
                                ToolTip.Tip="Filter by audio quality">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Quality:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding QualityFilterLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                                          RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="All"
                                              Command="{Binding QualityFilterCommand}"
                                              CommandParameter="all"/>
                                    <MenuItem Header="Lossless"
                                              Command="{Binding QualityFilterCommand}"
                                              CommandParameter="lossless"/>
                                    <MenuItem Header="Hi-Res"
                                              Command="{Binding QualityFilterCommand}"
                                              CommandParameter="hires"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <Button Classes="release-chip" VerticalAlignment="Center"
                                ToolTip.Tip="Sort albums">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="Sort:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding AlbumSortLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                                          RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                    <MenuItem Header="Default"
                                              Command="{Binding AlbumSortCommand}"
                                              CommandParameter="default"/>
                                    <MenuItem Header="Recently added"
                                              Command="{Binding AlbumSortCommand}"
                                              CommandParameter="dateadded"/>
                                    <MenuItem Header="Most played"
                                              Command="{Binding AlbumSortCommand}"
                                              CommandParameter="mostplayed"/>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <!-- Songs quality filter chips (All / Lossless / Hi-Res). Hidden in Cover Flow mode. -->
                    <Border IsVisible="{Binding SongsFiltersVisible}"
                            Background="{DynamicResource ChipBackground}"
                            CornerRadius="999" Padding="3"
                            VerticalAlignment="Center">
                        <Border.Styles>
                            <Style Selector="Button.quality-chip">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Style>
                            <Style Selector="Button.quality-chip.on">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="Background" Value="#30FFFFFF"/>
                            </Style>
                        </Border.Styles>
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button Classes="ghost-btn quality-chip" Classes.on="{Binding SongsQualityAll}"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Content="All" FontSize="12" FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Command="{Binding SongsQualityCommand}" CommandParameter="All" />
                            <Button Classes="ghost-btn quality-chip" Classes.on="{Binding SongsQualityLossless}"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Content="Lossless" FontSize="12" FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Command="{Binding SongsQualityCommand}" CommandParameter="Lossless" />
                            <Button Classes="ghost-btn quality-chip" Classes.on="{Binding SongsQualityHiRes}"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Content="Hi-Res" FontSize="12" FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Command="{Binding SongsQualityCommand}" CommandParameter="HiRes" />
                        </StackPanel>
                    </Border>

                    <!-- Page action buttons (e.g. Songs: Shuffle, Options). Hidden in Cover Flow mode. -->
                    <Border IsVisible="{Binding PageActionsVisible}"
                            Background="{DynamicResource ChipBackground}"
                            CornerRadius="999" Padding="3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button Classes="ghost-btn"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PageShuffleCommand}"
                                    ToolTip.Tip="Shuffle" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource ShuffleIcon}" Width="14" Height="14"
                                         VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="ghost-btn"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    ToolTip.Tip="Options" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource MoreDotsIcon}" Width="14" Height="14"
                                         VerticalAlignment="Center" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight"
                                            PlacementConstraintAdjustment="None"
                                            helpers:MenuOpenAnimation.EnableFlyoutClose="True">
                                    <MenuItem Header="All Items" Command="{Binding PageSetShowAllItemsCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                     IsVisible="{Binding PageShowAllItems}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Only Favorites" Command="{Binding PageSetShowOnlyFavoritesCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                     IsVisible="{Binding PageShowOnlyFavorites}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem x:Name="PageSortByMenuItem"
                                              Header="Sort By"
                                              PointerEntered="OnPageSortByMenuItemPointerEntered">
                                        <!-- Only sorts without a clickable column header; everything
                                             else is sorted by clicking the column headers directly. -->
                                        <MenuItem Header="Year" Command="{Binding PageSortCommand}" CommandParameter="Year">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByYear}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Date Added" Command="{Binding PageSortCommand}" CommandParameter="Date Added">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortByDateAdded}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Ascending" Command="{Binding PageSortCommand}" CommandParameter="Ascending">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortAscending}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Descending" Command="{Binding PageSortCommand}" CommandParameter="Descending">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                         IsVisible="{Binding PageSortDescending}" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                        </StackPanel>
                    </Border>

                    <!-- Playlist action buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasPlaylistActions}">
                        <Button Classes="accent-btn" Background="{DynamicResource AccentColorBrush}"
                                Padding="14,8" CornerRadius="999" Cursor="Hand"
                                ToolTip.Tip="New Playlist" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="New" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentForegroundBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight"
                                            helpers:MenuOpenAnimation.EnableFlyoutClose="True">
                                    <MenuItem Command="{Binding PageCreatePlaylistCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="16" Height="16" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Playlist%20icon.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                        <MenuItem.Header>
                                            <StackPanel Margin="0,5" Spacing="2">
                                                <TextBlock Text="New Playlist" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="Pick the tracks yourself" FontSize="11" Opacity="0.55" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem Command="{Binding PageCreateSmartPlaylistCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource SmartPlaylistIcon}" Width="14" Height="14"
                                                      Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                        </MenuItem.Icon>
                                        <MenuItem.Header>
                                            <StackPanel Margin="0,5" Spacing="2">
                                                <TextBlock Text="New Smart Playlist" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="Fills itself from rules you set" FontSize="11" Opacity="0.55" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Command="{Binding PageImportPlaylistCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Arrow%20Down%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                        <MenuItem.Header>
                                            <StackPanel Margin="0,5" Spacing="2">
                                                <TextBlock Text="Import Playlist…" FontSize="13" FontWeight="SemiBold" />
                                                <TextBlock Text="From an .m3u / .m3u8 file" FontSize="11" Opacity="0.55" />
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <!-- Artist discography action buttons (same chip style as the Songs page actions) -->
                    <Border IsVisible="{Binding HasArtistActions}"
                            Background="{DynamicResource ChipBackground}"
                            CornerRadius="999" Padding="3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button Classes="ghost-btn"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PageShuffleArtistCommand}"
                                    ToolTip.Tip="Shuffle All" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource ShuffleIcon}"
                                          Width="14" Height="14"
                                          VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="ghost-btn"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PagePlayArtistCommand}"
                                    ToolTip.Tip="Play All" VerticalAlignment="Center">
                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center"
                                        Margin="2,0,0,0"
                                        RenderOptions.BitmapInterpolationMode="HighQuality">
                                    <Border.OpacityMask>
                                        <ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" />
                                    </Border.OpacityMask>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Favorites action buttons — same neutral chip pill as the Songs page actions -->
                    <Border IsVisible="{Binding HasFavoritesActions}"
                            Background="{DynamicResource ChipBackground}"
                            CornerRadius="999" Padding="3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button Classes="ghost-btn"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PageShuffleFavoritesCommand}"
                                    ToolTip.Tip="Shuffle" VerticalAlignment="Center">
                                <PathIcon Data="{StaticResource ShuffleIcon}"
                                          Width="14" Height="14"
                                          VerticalAlignment="Center" />
                            </Button>
                            <Button Classes="ghost-btn"
                                    Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Command="{Binding PagePlayFavoritesCommand}"
                                    ToolTip.Tip="Play" VerticalAlignment="Center">
                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center"
                                        Margin="2,0,0,0"
                                        RenderOptions.BitmapInterpolationMode="HighQuality">
                                    <Border.OpacityMask>
                                        <ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" />
                                    </Border.OpacityMask>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Folders action buttons: Play (accent) + Shuffle / Manage Folders (neutral chips) -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"
                                IsVisible="{Binding HasFoldersActions}">
                        <Button Classes="accent-btn" Background="{DynamicResource AccentColorBrush}"
                                Padding="16,6" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PagePlayFolderCommand}"
                                ToolTip.Tip="Play folder" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Border Width="12" Height="12" Background="{DynamicResource AccentForegroundBrush}" VerticalAlignment="Center"
                                        RenderOptions.BitmapInterpolationMode="HighQuality">
                                    <Border.OpacityMask>
                                        <ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" />
                                    </Border.OpacityMask>
                                </Border>
                                <TextBlock Text="Play" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentForegroundBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Background="{DynamicResource ChipBackground}"
                                BorderThickness="0" Padding="14,6" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PageShuffleFolderCommand}"
                                Content="Shuffle" FontSize="12" FontWeight="SemiBold"
                                ToolTip.Tip="Shuffle folder" VerticalAlignment="Center" />
                        <Button Background="{DynamicResource ChipBackground}"
                                BorderThickness="0" Padding="14,6" CornerRadius="999" Cursor="Hand"
                                Command="{Binding PageManageFoldersCommand}"
                                ToolTip.Tip="Open Settings to add or remove the music folders that get scanned."
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource SettingsIcon}"
                                          Width="13" Height="13"
                                          Opacity="0.8"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="Manage Folders"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- View mode toggle (Library / Cover Flow) -->
                    <Border IsVisible="{Binding HasViewModeToggle}"
                            Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                            CornerRadius="999" Padding="3" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button x:Name="AlbumsLibraryModeBtn"
                                    Command="{Binding SetLibraryModeCommand}"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Background="#30FFFFFF" ToolTip.Tip="Library"
                                    Content="Library" FontSize="12" FontWeight="SemiBold" />
                            <Button x:Name="AlbumsUpNextModeBtn"
                                    Command="{Binding SetCoverFlowModeCommand}"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Background="Transparent" Opacity="0.5" ToolTip.Tip="Cover Flow"
                                    Content="Cover Flow" FontSize="12" FontWeight="SemiBold" />
                            <!-- Collage sub-mode: compact icon segment, only while Cover Flow is active -->
                            <Button x:Name="AlbumsCollageModeBtn"
                                    Command="{Binding ToggleCollageModeCommand}"
                                    IsVisible="{Binding IsCoverFlowMode}"
                                    BorderThickness="0" Padding="10,6" CornerRadius="999" Cursor="Hand"
                                    Background="Transparent" Opacity="0.5" ToolTip.Tip="Cover Collage">
                                <!-- Theme-aware tint: PNG alpha masks the foreground brush (flips for light/dark). -->
                                <Border Width="14" Height="14"
                                        Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                        RenderOptions.BitmapInterpolationMode="HighQuality">
                                    <Border.OpacityMask>
                                        <ImageBrush Source="avares://Noctis/Assets/Icons/Collage%20icon.png" Stretch="Uniform" />
                                    </Border.OpacityMask>
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- Zone C: Main Content Area + Overlay Panels -->
            <DockPanel x:Name="ContentDockPanel" Grid.Row="1">
                <Grid Background="{DynamicResource AppMainBackground}">
                <ContentControl Content="{Binding CurrentView}"
                                Classes="page-host"
                                RenderTransformOrigin="50%,50%">
                    <ContentControl.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </ContentControl.Transitions>
                </ContentControl>

                <!-- Lyrics side panel overlays content so opening it does not resize album grids.
                     IsVisible gates the whole subtree while closed: the karaoke word cells
                     otherwise keep measuring/arranging behind the 0-width clip on every
                     lyrics load, stalling the UI thread at track start (frozen row EQ). -->
                <Border x:Name="LyricsPanelWrapper"
                        HorizontalAlignment="Right"
                        Width="0"
                        IsVisible="False"
                        Margin="0,8,8,12"
                        CornerRadius="16"
                        ClipToBounds="True"
                        ZIndex="10">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.2">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </Border.Transitions>
                    <Grid Width="340">
                        <!-- Opaque dark base so the panel never bleeds through; the view
                             itself paints the page-matched background (artwork/solid/gradient). -->
                        <Border Background="{DynamicResource AppSidebarBackground}" CornerRadius="16"/>
                        <views:LyricsPanelView DataContext="{Binding Lyrics}"/>
                    </Grid>
                </Border>

                <!-- Queue popup panel (right side, rounded, slightly transparent).
                     Visibility and the fade/slide open-close animation are driven from
                     code-behind (IsQueuePopupOpen handler) so the close can play before
                     the panel leaves the tree — same pattern as the Settings modal. -->
                <Border x:Name="QueuePopupPanel"
                        HorizontalAlignment="Right"
                        Width="330"
                        Margin="0,8,8,8"
                        CornerRadius="16"
                        ClipToBounds="True"
                        Background="#E61C1C1C"
                        TextElement.Foreground="White"
                        IsVisible="False"
                        Opacity="0"
                        RenderTransformOrigin="100%,50%"
                        RenderTransform="translateX(16px) scale(0.97)"
                        BoxShadow="-2 0 12 0 #40000000"
                        ZIndex="20">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                                <DoubleTransition.Easing>
                                    <CubicEaseOut/>
                                </DoubleTransition.Easing>
                            </DoubleTransition>
                            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18">
                                <TransformOperationsTransition.Easing>
                                    <CubicEaseOut/>
                                </TransformOperationsTransition.Easing>
                            </TransformOperationsTransition>
                        </Transitions>
                    </Border.Transitions>

                    <Panel>

                    <DockPanel>
                        <DockPanel.Styles>
                            <!-- Artist credit acts as a link: no button chrome, subtle highlight
                                 behind the name on hover/press (matching the player bar's artist link). -->
                            <Style Selector="Button.queue-link">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                            <!-- Opt out of the global button hover/press zoom. -->
                            <Style Selector="Button.queue-link:pointerover">
                                <Setter Property="RenderTransform" Value="scale(1)"/>
                            </Style>
                            <Style Selector="Button.queue-link:pressed">
                                <Setter Property="RenderTransform" Value="scale(1)"/>
                            </Style>
                            <Style Selector="Button.queue-link /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="Button.queue-link:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="Button.queue-link:pressed /template/ ContentPresenter#PART_ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="Button.queue-link:pointerover Border.artist-text-hover">
                                <Setter Property="Background" Value="#22FFFFFF"/>
                            </Style>
                            <Style Selector="Button.queue-link:pressed Border.artist-text-hover">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Style>
                        </DockPanel.Styles>
                        <!-- Compact header: "Queue • N" + Clear ghost action -->
                        <Grid DockPanel.Dock="Top" Margin="20,16,12,6"
                              ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Queue"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="White" />
                                <TextBlock Text="{Binding Player.UpNext.Count, StringFormat='&#x2022; {0}'}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           Opacity="0.5"
                                           VerticalAlignment="Center"
                                           Margin="0,2,0,0"
                                           IsVisible="{Binding !!Player.UpNext.Count}" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="9,5"
                                    CornerRadius="999"
                                    Cursor="Hand"
                                    Margin="2,0,0,0"
                                    Click="OnQueueClearClick"
                                    IsVisible="{Binding !!Player.UpNext.Count}"
                                    VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Width="13" Height="13"
                                            Background="White"
                                            Opacity="0.65"
                                            RenderOptions.BitmapInterpolationMode="HighQuality">
                                        <Border.OpacityMask>
                                            <ImageBrush Source="avares://Noctis/Assets/Icons/Clear%20Queue%20ICON.png" Stretch="Uniform" />
                                        </Border.OpacityMask>
                                    </Border>
                                    <TextBlock Text="Clear"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="White"
                                               Opacity="0.8"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Queue track list (virtualized, drag-reorder enabled) -->
                        <Grid x:Name="QueueListWrapper">
                            <ListBox x:Name="QueuePopupListBox"
                                     Classes="queue-popup"
                                     ItemsSource="{Binding Player.UpNext}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Margin="0,6,0,8"
                                     SelectionMode="Single"
                                     AutoScrollToSelectedItem="False"
                                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                     DragDrop.AllowDrop="True"
                                     DoubleTapped="OnQueueItemDoubleTapped">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,1"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <!-- Hover highlight on each queue row, matching album track-list. -->
                                    <Style Selector="Border.queue-row">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Transitions">
                                            <Transitions>
                                                <BrushTransition Property="Background" Duration="0:0:0.12"/>
                                            </Transitions>
                                        </Setter>
                                    </Style>
                                    <Style Selector="Border.queue-row:pointerover">
                                        <Setter Property="Background" Value="{DynamicResource TrackListHoverBrush}"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="m:Track">
                                        <!-- Single rounded-pill container wraps the entire row so the
                                             drag highlight covers album art + text + number as one card. -->
                                        <Border Classes="queue-row"
                                                Margin="12,1,12,1"
                                                Padding="8,4"
                                                CornerRadius="10"
                                                Tag="{Binding}"
                                                PointerPressed="OnQueueItemPointerPressed"
                                                PointerMoved="OnQueueItemPointerMoved"
                                                PointerReleased="OnQueueItemPointerReleased"
                                                PointerCaptureLost="OnQueueItemPointerCaptureLost">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Remove from Queue"
                                                              Click="OnQueueRemoveClick">
                                                        <MenuItem.Icon>
                                                            <Border Width="14" Height="14"
                                                                    Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                                    RenderOptions.BitmapInterpolationMode="HighQuality">
                                                                <Border.OpacityMask>
                                                                    <ImageBrush Source="avares://Noctis/Assets/Icons/Clear%20Queue%20ICON.png" Stretch="Uniform" />
                                                                </Border.OpacityMask>
                                                            </Border>
                                                        </MenuItem.Icon>
                                                    </MenuItem>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                        <Grid ColumnDefinitions="Auto,*,Auto" Height="48"
                                              Background="Transparent">

                                            <!-- Album art thumbnail -->
                                            <Border Grid.Column="0"
                                                    Width="42" Height="42"
                                                    CornerRadius="7"
                                                    ClipToBounds="True"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,10,0">
                                                <controls:CachedImage SourcePath="{Binding AlbumArtworkPath}"
                                                                      RenderOptions.BitmapInterpolationMode="HighQuality"
                                                                      Stretch="UniformToFill" />
                                            </Border>
                                            <!-- Title + Artist -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <Grid ColumnDefinitions="Auto,Auto">
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding TitleDisplay}"
                                                               Classes="one-line-explicit-title"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               MaxWidth="165" />
                                                    <Border Grid.Column="1"
                                                            Classes="explicit-badge compact"
                                                            Margin="4,0,0,0"
                                                            IsVisible="{Binding IsExplicit}"
                                                            ToolTip.Tip="Explicit"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="E"
                                                                   Classes="explicit-badge-text compact"
                                                                   FontSize="9"
                                                                   Opacity="0.9" />
                                                    </Border>
                                                </Grid>
                                                <Button Classes="queue-link"
                                                        HorizontalAlignment="Left"
                                                        Margin="0,2,0,0"
                                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Player.ViewArtistCommand}"
                                                        CommandParameter="{Binding}">
                                                    <Border Classes="artist-text-hover"
                                                            CornerRadius="2"
                                                            Padding="2,0,3,0">
                                                        <TextBlock Text="{Binding ArtistDisplay}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   Opacity="0.55"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxLines="1" />
                                                    </Border>
                                                </Button>
                                            </StackPanel>
                                            <!-- Queue position (stamped from code-behind; virtualization
                                                 recycles rows, so there is no per-item index to bind). -->
                                            <TextBlock Grid.Column="2"
                                                       x:Name="QueueRowNumber"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"
                                                       Opacity="0.4"
                                                       MinWidth="20"
                                                       TextAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,4,0" />
                                        </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Drop indicator line for drag reorder -->
                            <Border x:Name="QueueDropIndicator"
                                    IsHitTestVisible="False"
                                    IsVisible="False"
                                    Height="2"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Stretch"
                                    Margin="20,0"
                                    CornerRadius="1"
                                    Background="{DynamicResource AccentColorBrush}">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                            </Border>

                            <!-- Floating drag preview: follows the pointer Y while reordering. -->
                            <Border x:Name="QueueDragPreview"
                                    x:DataType="m:Track"
                                    IsHitTestVisible="False"
                                    IsVisible="False"
                                    Margin="12,0,12,0"
                                    Padding="8,4"
                                    CornerRadius="10"
                                    Background="{DynamicResource AccentColorBrush}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    BoxShadow="0 6 22 0 #80000000">
                                <Border.RenderTransform>
                                    <TranslateTransform Y="0"/>
                                </Border.RenderTransform>
                                <Grid ColumnDefinitions="Auto,*,Auto" Height="48">
                                    <Border Grid.Column="0"
                                            Width="42" Height="42"
                                            CornerRadius="7"
                                            ClipToBounds="True"
                                            VerticalAlignment="Center"
                                            Margin="0,0,10,0">
                                        <controls:CachedImage SourcePath="{Binding AlbumArtworkPath}"
                                                              RenderOptions.BitmapInterpolationMode="HighQuality"
                                                              Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding TitleDisplay}"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Foreground="{DynamicResource AccentForegroundBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />
                                        <TextBlock Text="{Binding ArtistDisplay}"
                                                    FontSize="11"
                                                    FontWeight="Bold"
                                                    Foreground="{DynamicResource AccentForegroundBrush}"
                                                   Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </DockPanel>
                    </Panel>
                </Border>

            </Grid>
            </DockPanel>

            <!-- Debug panel overlay (toggled via Ctrl+Shift+D) -->
            <views:DebugPanelView Grid.Row="1"
                                  DataContext="{Binding DebugPanel}"
                                  IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsDebugPanelVisible}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Stretch"
                                  Width="620"
                                  Margin="228,8,0,8"
                                  IsHitTestVisible="True" />
        </Grid>
    </DockPanel>

    <!-- Drag-drop overlay (shown while dragging importable files over the window) -->
    <Border x:Name="DragDropOverlay"
            IsVisible="False"
            IsHitTestVisible="False"
            Background="#18FFFFFF"
            BorderBrush="{StaticResource SystemControlHighlightAccentBrush}"
            BorderThickness="2"
            Margin="4"
            CornerRadius="8"
            Opacity="0">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            </Transitions>
        </Border.Transitions>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <PathIcon Data="M12,2 L12,14 M8,10 L12,14 L16,10 M4,18 L20,18"
                      Width="32" Height="32"
                      Foreground="{StaticResource SystemControlHighlightAccentBrush}" />
            <TextBlock Text="Drop files to import"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#CCFFFFFF"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>

    <!-- Drop-import progress pill (spinner + "Copying files 3 of 10") -->
    <Border IsVisible="{Binding IsDropImporting}"
            IsHitTestVisible="False"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{DynamicResource IslandBackground}"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            CornerRadius="999"
            Padding="16,9"
            ZIndex="40">
        <Border.Styles>
            <!-- Same rotating-arc spinner as Settings' background work indicator -->
            <Style Selector="Ellipse.loading-spinner">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Stroke" Value="{DynamicResource AccentColorBrush}"/>
                <Setter Property="StrokeThickness" Value="2"/>
                <Setter Property="StrokeDashArray" Value="11,5"/>
                <Setter Property="StrokeLineCap" Value="Round"/>
                <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
                <Style.Animations>
                    <Animation Duration="0:0:0.85" IterationCount="INFINITE" Easing="LinearEasing">
                        <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                        <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Border.Styles>
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Ellipse Classes="loading-spinner" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding DropImportStatus}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource IslandForeground}"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>

    <!-- Bottom playback island (Apple Music-style glass pill) -->
    <views:PlaybackBarView DataContext="{Binding Player}"
                           CompactWhenLyricsPageActive="False"
                           IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsPlaybackBarMounted, FallbackValue=False}"
                           IsHitTestVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsPlaybackBarHitTestVisible, FallbackValue=False}"
                           Opacity="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).PlaybackBarOpacity, FallbackValue=0}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,16"
                           ZIndex="30" />

    <!-- Sidebar: overlaid so hover-expand doesn't reflow content -->
    <Border x:Name="SidebarWrapper"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch"
            Width="60"
            Margin="8,8,8,12"
            CornerRadius="20"
            ClipToBounds="True"
            ZIndex="10">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Width" Duration="0:0:0.2">
                    <DoubleTransition.Easing>
                        <CubicEaseOut/>
                    </DoubleTransition.Easing>
                </DoubleTransition>
            </Transitions>
        </Border.Transitions>
        <views:SidebarView HorizontalAlignment="Stretch"
                           DataContext="{Binding Sidebar}" />
    </Border>

    <!-- Settings modal overlay (dark backdrop + centered popup card).
         Visibility and the fade/scale open-close animation are driven from
         code-behind (IsSettingsModalOpen handler) so the close can play before
         the overlay leaves the tree. -->
    <Border Name="SettingsOverlay"
            IsVisible="False"
            Opacity="0"
            Background="#A6000000"
            ZIndex="100"
            Tapped="OnSettingsBackdropTapped">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                    <DoubleTransition.Easing>
                        <CubicEaseOut/>
                    </DoubleTransition.Easing>
                </DoubleTransition>
            </Transitions>
        </Border.Transitions>
        <Border Name="SettingsCard"
                Width="780" MaxHeight="720"
                Background="{DynamicResource AppMainBackground}"
                BorderBrush="#22FFFFFF"
                BorderThickness="1"
                CornerRadius="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderTransformOrigin="50%,50%"
                RenderTransform="scale(0.96)"
                Tapped="OnSettingsCardTapped"
                BoxShadow="0 24 60 0 #80000000">
            <Border.Transitions>
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <!-- Card-only fade: used by the stats back-arrow reopen, where the
                         backdrop appears instantly but the card still animates in.
                         Normal open/close never changes the card's own Opacity. -->
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                        <DoubleTransition.Easing>
                            <CubicEaseOut/>
                        </DoubleTransition.Easing>
                    </DoubleTransition>
                </Transitions>
            </Border.Transitions>
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Grid Grid.Row="0" Margin="28,22,18,8" ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="Settings"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Width="32" Height="32"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="999"
                            Cursor="Hand"
                            ToolTip.Tip="Close"
                            Command="{Binding CloseSettingsCommand}">
                        <PathIcon Data="M 5 5 L 13 13 M 13 5 L 5 13"
                                  Width="14" Height="14"
                                  Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </Button>
                </Grid>

                <!-- Settings content (existing SettingsView, scrollable) -->
                <views:SettingsView Grid.Row="1"
                                    DataContext="{Binding Settings}"
                                    Background="Transparent"/>

                <!-- Footer with Close button -->
                <Border Grid.Row="2"
                        BorderBrush="#14FFFFFF" BorderThickness="0,1,0,0"
                        Padding="20,12">
                    <Button Classes="accent-btn"
                            HorizontalAlignment="Right"
                            Padding="22,9"
                            CornerRadius="999"
                            Background="{DynamicResource AccentColorBrush}"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            Cursor="Hand"
                            Content="Close"
                            FontWeight="Bold"
                            Command="{Binding CloseSettingsCommand}"/>
                </Border>
            </Grid>
        </Border>
    </Border>

    </Panel>

</Window>
