<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:conv="using:Noctis.Converters"
             xmlns:helpers="using:Noctis.Helpers"
             xmlns:controls="using:Noctis.Controls"
             x:Class="Noctis.Views.HomeView"
             x:DataType="vm:HomeViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:ArtworkPathConverter x:Key="ArtworkConverter" />
        <conv:TrackPlaylistCommandParameterConverter x:Key="TrackPlaylistParamConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="*">
        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,20,28,28" Spacing="32">

                <!-- Section title -->
                <TextBlock Text="Most Listened To"
                           FontSize="30"
                           FontWeight="Bold" />

                <!-- Top Songs (pill grid) -->
                <StackPanel Spacing="14"
                            IsVisible="{Binding TopSongs.Count}">

                    <ItemsControl ItemsSource="{Binding TopSongs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:Track">
                                <Button Background="{DynamicResource HomeCardBackground}"
                                        BorderThickness="0"
                                        CornerRadius="6"
                                        Padding="0"
                                        Height="56"
                                        Margin="3,3"
                                        Cursor="Hand"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        helpers:DragFileBehavior.EnableFileDrag="True"
                                        Command="{Binding $parent[ItemsControl].((vm:HomeViewModel)DataContext).PlayTopSongCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover">
                                            <Setter Property="Background" Value="{DynamicResource HomeCardHoverBackground}" />
                                        </Style>
                                    </Button.Styles>
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding}" Opened="OnContextMenuOpened">
                                            <!-- Track header -->
                                            <MenuItem IsHitTestVisible="False" Focusable="False">
                                                <MenuItem.Template>
                                                    <ControlTemplate>
                                                        <Border Padding="11,8" Background="Transparent">
                                                            <ContentPresenter Content="{TemplateBinding Header}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </MenuItem.Template>
                                                <MenuItem.Header>
                                                    <Grid ColumnDefinitions="40,10,*">
                                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4" ClipToBounds="True"
                                                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                                            <Panel>
                                                                <TextBlock Text="&#x266A;" FontSize="14" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Opacity="0.3"
                                                                           IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                                <Image Source="{Binding AlbumArtworkPath, Converter={StaticResource ArtworkConverter}}"
                                                                       Stretch="UniformToFill"
                                                                       IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                            </Panel>
                                                        </Border>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                            <controls:MarqueeTextBlock Text="{Binding Title}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       MaxDisplayWidth="240" IsForArtist="False">
                                                                <controls:MarqueeTextBlock.InlineContent>
                                                                    <Border Classes="explicit-badge compact"
                                                                            VerticalAlignment="Center"
                                                                            IsVisible="{Binding IsExplicit}">
                                                                        <TextBlock Text="E"
                                                                                   Classes="explicit-badge-text compact"
                                                                                   FontSize="9"
                                                                                   Opacity="0.9" />
                                                                    </Border>
                                                                </controls:MarqueeTextBlock.InlineContent>
                                                            </controls:MarqueeTextBlock>
                                                            <controls:MarqueeTextBlock Text="{Binding Artist}" FontSize="11"
                                                                       Foreground="#E74856" MaxDisplayWidth="240" IsForArtist="True" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).PlayTopSongCommand}"
                                                      CommandParameter="{Binding}"
                                                      MaxWidth="400">
                                                <MenuItem.Header>
                                                    <TextBlock Text="{Binding Title, StringFormat='Play &quot;{0}&quot;'}"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontWeight="Normal"
                                                               FontSize="14"
                                                               FontFamily="{Binding $parent[MenuItem].FontFamily}" />
                                                </MenuItem.Header>
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Shuffle"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ShuffleTopSongsCommand}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{StaticResource ShuffleIcon}" Width="14" Height="14" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Play Next"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).PlayNextCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Forward%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Add to Queue"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).AddToQueueCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem x:Name="AddToPlaylistMenuItem1" Header="Add to Playlist">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Playlists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                                <MenuItem Header="Create New Playlist"
                                                          Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).AddTrackToNewPlaylistCommand}"
                                                          CommandParameter="{Binding}" />
                                                <Separator x:Name="PlaylistSeparator1" />
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Favorites"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ToggleTrackFavoriteCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding !IsFavorite}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Your%20Favorites%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Remove from Favorites"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ToggleTrackFavoriteCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding IsFavorite}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Metadata"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).OpenTrackMetadataCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Metadata%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Search Lyrics"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).SearchLyricsTrackCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Lyrics%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Show Folder"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ShowInExplorerTrackCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Folder%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Remove from Library"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).RemoveTrackFromLibraryCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Button.ContextMenu>

                                    <!-- Pill content: artwork + title + explicit badge -->
                                    <Grid ColumnDefinitions="56,*">
                                        <Border Grid.Column="0"
                                                Width="56" Height="56"
                                                CornerRadius="6,0,0,6"
                                                ClipToBounds="True"
                                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                            <Panel>
                                                <TextBlock Text="&#x266A;"
                                                           FontSize="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.2"
                                                           IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                <Image Source="{Binding AlbumArtworkPath, Converter={StaticResource ArtworkConverter}}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapInterpolationMode="HighQuality"
                                                       IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </Panel>
                                        </Border>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,16,0">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1" />
                                            <Border Classes="explicit-badge compact"
                                                    Margin="6,0,0,0"
                                                    IsVisible="{Binding IsExplicit}"
                                                    ToolTip.Tip="Explicit">
                                                <TextBlock Text="E"
                                                           Classes="explicit-badge-text compact"
                                                           FontSize="9"
                                                           Opacity="0.9" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Recently Played -->
                <StackPanel Spacing="14">
                    <TextBlock Text="Recently Played"
                               FontSize="22"
                               FontWeight="Bold" />

                    <!-- Empty state -->
                    <StackPanel IsVisible="{Binding !RecentlyPlayedAlbums.Count}"
                                HorizontalAlignment="Center"
                                Spacing="4"
                                Margin="0,32">
                        <TextBlock Text="No recently played music yet"
                                   FontSize="16"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock Text="Start playing some music!"
                                   FontSize="13"
                                   Opacity="0.3"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <!-- Album cards -->
                    <ItemsControl ItemsSource="{Binding RecentlyPlayedAlbums}"
                                  IsVisible="{Binding RecentlyPlayedAlbums.Count}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="5" VerticalAlignment="Top" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:Album">
                                <Button Classes="album-tile"
                                        Margin="2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        helpers:DragFileBehavior.EnableFileDrag="True"
                                        Command="{Binding $parent[ItemsControl].((vm:HomeViewModel)DataContext).OpenAlbumCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.ContextMenu>
                                        <ContextMenu DataContext="{Binding}" Opened="OnContextMenuOpened">
                                            <MenuItem IsHitTestVisible="False" Focusable="False">
                                                <MenuItem.Template>
                                                    <ControlTemplate>
                                                        <Border Padding="11,8" Background="Transparent">
                                                            <ContentPresenter Content="{TemplateBinding Header}" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </MenuItem.Template>
                                                <MenuItem.Header>
                                                    <Grid ColumnDefinitions="40,10,*">
                                                        <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4" ClipToBounds="True"
                                                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                                            <Panel>
                                                                <TextBlock Text="&#x266A;" FontSize="14" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center" Opacity="0.3"
                                                                           IsVisible="{Binding ArtworkPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                                <Image Source="{Binding ArtworkPath, Converter={StaticResource ArtworkConverter}}"
                                                                       Stretch="UniformToFill"
                                                                       IsVisible="{Binding ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                            </Panel>
                                                        </Border>
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                            <controls:MarqueeTextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold" FontSize="13"
                                                                       MaxDisplayWidth="240" IsForArtist="False">
                                                                <controls:MarqueeTextBlock.InlineContent>
                                                                    <Border Classes="explicit-badge compact"
                                                                            VerticalAlignment="Center"
                                                                            IsVisible="{Binding IsExplicit}">
                                                                        <TextBlock Text="E"
                                                                                   Classes="explicit-badge-text compact"
                                                                                   FontSize="9"
                                                                                   Opacity="0.9" />
                                                                    </Border>
                                                                </controls:MarqueeTextBlock.InlineContent>
                                                            </controls:MarqueeTextBlock>
                                                            <controls:MarqueeTextBlock Text="{Binding Artist}" FontSize="11"
                                                                       Foreground="#E74856" MaxDisplayWidth="240" IsForArtist="True" Margin="0,2,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                </MenuItem.Header>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).PlayAlbumCommand}"
                                                      CommandParameter="{Binding}"
                                                      MaxWidth="400">
                                                <MenuItem.Header>
                                                    <TextBlock Text="{Binding Name, StringFormat='Play &quot;{0}&quot;'}"
                                                               TextTrimming="CharacterEllipsis"
                                                               FontWeight="Normal"
                                                               FontSize="14"
                                                               FontFamily="{Binding $parent[MenuItem].FontFamily}" />
                                                </MenuItem.Header>
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Shuffle"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ShuffleAlbumCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{StaticResource ShuffleIcon}" Width="14" Height="14" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Play Next"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).PlayNextAlbumCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Forward%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Add to Queue"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).AddAlbumToQueueCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem x:Name="AddToPlaylistMenuItem2" Header="Add to Playlist">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Playlists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                                <MenuItem Header="Create New Playlist"
                                                          Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).AddAlbumToNewPlaylistCommand}"
                                                          CommandParameter="{Binding}" />
                                                <Separator x:Name="PlaylistSeparator2" />
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Favorites"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ToggleAlbumFavoritesCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding !IsAllTracksFavorite}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Your%20Favorites%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Remove from Favorites"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ToggleAlbumFavoritesCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding IsAllTracksFavorite}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Metadata"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).OpenMetadataCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Metadata%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Search Lyrics"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).SearchLyricsAlbumCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Lyrics%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Show Folder"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).ShowInExplorerAlbumCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Folder%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Remove from Library"
                                                      Command="{Binding $parent[UserControl].((vm:HomeViewModel)DataContext).RemoveFromLibraryCommand}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Button.ContextMenu>
                                    <StackPanel Spacing="0">
                                        <Border CornerRadius="6"
                                                ClipToBounds="True"
                                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                            <Border.Styles>
                                                <Style Selector="Border">
                                                    <Setter Property="Height" Value="{Binding $self.Bounds.Width}" />
                                                </Style>
                                            </Border.Styles>
                                            <Panel>
                                                <TextBlock Text="&#x266A;"
                                                           FontSize="48"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.2"
                                                           IsVisible="{Binding ArtworkPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                <Image Source="{Binding ArtworkPath, Converter={StaticResource ArtworkConverter}}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapInterpolationMode="HighQuality"
                                                       IsVisible="{Binding ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                            </Panel>
                                        </Border>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,5,0,0"
                                                    HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1" />
                                            <Border Classes="explicit-badge compact"
                                                    Margin="4,0,0,0"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding IsExplicit}"
                                                    ToolTip.Tip="Explicit">
                                                <TextBlock Text="E"
                                                           Classes="explicit-badge-text compact"
                                                           FontSize="9"
                                                           Opacity="0.9" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Artist}"
                                                   FontSize="12"
                                                   Opacity="0.55"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
