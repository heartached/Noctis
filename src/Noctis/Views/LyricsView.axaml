<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:conv="using:Noctis.Converters"
             xmlns:controls="using:Noctis.Controls"
             x:Class="Noctis.Views.LyricsView"
             x:DataType="vm:LyricsViewModel"
             x:Name="LyricsRoot"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity"/>
        <conv:ArtworkPathConverter x:Key="ArtworkConverter"/>
        <conv:VolumeToIconConverter x:Key="VolumeToIcon"/>
        <!-- Adaptive button/slider brushes (updated from code-behind) -->
        <SolidColorBrush x:Key="LyricsBtnBgRes" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="LyricsBtnBgHoverRes" Color="#55FFFFFF"/>
        <SolidColorBrush x:Key="LyricsSecBtnBgRes" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="LyricsSecBtnBgHoverRes" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="LyricsSliderThumbRes" Color="#EEFFFFFF"/>
        <SolidColorBrush x:Key="LyricsSliderFilledRes" Color="#CCFFFFFF"/>
        <SolidColorBrush x:Key="LyricsSliderUnfilledRes" Color="#33FFFFFF"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Explicit badge -->
        <Style Selector="Border.lyrics-explicit">
            <Setter Property="Background" Value="#88888888"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Clickable text style -->
        <Style Selector="Button.link-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.link-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="Button.link-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
        <Style Selector="Button.link-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>

        <!-- Transport control button -->
        <Style Selector="Button.lyrics-ctrl-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="Button.lyrics-ctrl-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="Button.lyrics-ctrl-btn:pressed">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="Button.lyrics-ctrl-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.lyrics-ctrl-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Play/Pause prominent button -->
        <Style Selector="Button.lyrics-play-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Seek slider -->
        <Style Selector="Slider.lyrics-seek">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Volume slider -->
        <Style Selector="Slider.lyrics-volume">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style Selector="Slider.lyrics-volume /template/ Track">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Margin" Value="7,0"/>
        </Style>
        <Style Selector="Slider.lyrics-volume /template/ RepeatButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource LyricsSliderFilledRes}"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="3,0,0,3"/>
        </Style>
        <Style Selector="Slider.lyrics-volume /template/ RepeatButton#PART_IncreaseButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource LyricsSliderUnfilledRes}"/>
            <Setter Property="Opacity" Value="0.4"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="CornerRadius" Value="0,3,3,0"/>
        </Style>
        <Style Selector="Slider.lyrics-volume /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource LyricsSliderThumbRes}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Opacity" Value="1.0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.lyrics-volume /template/ Thumb /template/ Border">
            <Setter Property="Background" Value="{DynamicResource LyricsSliderThumbRes}"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="BoxShadow" Value="0 1 3 0 #40000000"/>
        </Style>
        <Style Selector="Slider.lyrics-volume:pointerover /template/ Thumb">
            <Setter Property="RenderTransform" Value="scale(1.1)"/>
        </Style>

        <!-- Pill button style -->
        <Style Selector="Button.pill-btn">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgRes}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pill-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgHoverRes}"/>
        </Style>

        <!-- Color picker circle button -->
        <Style Selector="Button.icon-circle-btn">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgRes}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.icon-circle-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgHoverRes}"/>
        </Style>

        <!-- Color swatch button — fully transparent template, no box behind circle -->
        <Style Selector="Button.swatch-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0"/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.swatch-btn:pointerover">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
        <Style Selector="Button.swatch-btn:pressed">
            <Setter Property="Opacity" Value="0.65"/>
        </Style>

        <!-- Secondary control button (bottom row) -->
        <Style Selector="Button.lyrics-secondary-btn">
            <Setter Property="Background" Value="{DynamicResource LyricsSecBtnBgRes}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.lyrics-secondary-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource LyricsSecBtnBgHoverRes}"/>
        </Style>

        <Style Selector="ItemsControl#LyricsItemsControl Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>

        <!-- Lyric line: keep active emphasis in opacity/color only, without size/position zoom. -->
        <Style Selector="TextBlock.lyric-line">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Lyrics scrollbar -->
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,8,3,8"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Thumb">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Thumb:pointerover">
            <Setter Property="Background" Value="#66FFFFFF"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ RepeatButton">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Height" Value="0"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Rectangle">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <!-- Karaoke word styles (Lyricsfile word-level sync) -->
        <Style Selector="TextBlock.word">
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock.word.past">
            <Setter Property="Opacity" Value="1.0"/>
        </Style>
        <Style Selector="TextBlock.word.current">
            <!-- Base layer goes invisible while the accent overlay renders on top. -->
            <Setter Property="Opacity" Value="0.0"/>
        </Style>
        <Style Selector="TextBlock.word-accent">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock.word-accent.current">
            <Setter Property="Opacity" Value="1.0"/>
        </Style>
    </UserControl.Styles>

    <Grid x:Name="MainLayoutGrid" ColumnDefinitions="*,*"
          Background="{Binding FullBackgroundBrush}">


        <!-- ══════════════════════════════════════════════════════ -->
        <!-- LEFT PANEL: Cover Art + Track Info + Controls         -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Border x:Name="LeftPanel"
                Grid.Column="0"
                Background="Transparent"
                Padding="40,30">
            <StackPanel x:Name="LeftContentStack" VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        ClipToBounds="False"
                        Width="630">
                <StackPanel.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Width" Duration="0:0:0.25">
                            <DoubleTransition.Easing><CubicEaseOut/></DoubleTransition.Easing>
                        </DoubleTransition>
                    </Transitions>
                </StackPanel.Transitions>

                <!-- Album Art -->
                <Border x:Name="AlbumArtBorder"
                        Width="630" Height="630"
                        CornerRadius="12"
                        ClipToBounds="True"
                        HorizontalAlignment="Center"
                        BoxShadow="0 16 50 0 #60000000">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.25">
                                <DoubleTransition.Easing><CubicEaseOut/></DoubleTransition.Easing>
                            </DoubleTransition>
                            <DoubleTransition Property="Height" Duration="0:0:0.25">
                                <DoubleTransition.Easing><CubicEaseOut/></DoubleTransition.Easing>
                            </DoubleTransition>
                        </Transitions>
                    </Border.Transitions>
                    <Panel>
                        <Border Background="#333344">
                            <TextBlock Text="&#x266B;"
                                       FontSize="60"
                                       Foreground="#555566"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Image Source="{Binding Player.AlbumArt}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapInterpolationMode="HighQuality"
                               IsVisible="{Binding Player.AlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <controls:AnimatedCoverView
                            Source="{Binding Player.CurrentAnimatedCoverPath}"
                            IsActive="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.EnableAnimatedCovers, FallbackValue=False}" />
                    </Panel>
                </Border>

                <!-- Track Info -->
                <StackPanel Spacing="4" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <!-- Title + Explicit badge -->
                    <controls:MarqueeTextBlock Text="{Binding Player.CurrentTrack.Title, FallbackValue='No track playing'}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{Binding LyricsPrimaryFg}"
                                               MaxDisplayWidth="520"
                                               HorizontalAlignment="Center"
                                               IsLyricsPage="True"
                                               IsForArtist="False">
                        <controls:MarqueeTextBlock.InlineContent>
                            <Border Classes="lyrics-explicit"
                                    IsVisible="{Binding Player.CurrentTrack.IsExplicit, FallbackValue=False}"
                                    ToolTip.Tip="Explicit">
                                <TextBlock Text="E"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{Binding LyricsPrimaryFg}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </controls:MarqueeTextBlock.InlineContent>
                    </controls:MarqueeTextBlock>

                    <!-- Artist -->
                    <Button Classes="link-btn"
                            Command="{Binding ViewArtistCommand}"
                            HorizontalAlignment="Center">
                        <controls:MarqueeTextBlock Text="{Binding Player.CurrentTrack.Artist, FallbackValue=''}"
                                                   FontSize="17"
                                                   Foreground="{Binding LyricsAccentFg}"
                                                   MaxDisplayWidth="520"
                                                   IsLyricsPage="True"
                                                   IsForArtist="True"/>
                    </Button>

                    <!-- Album -->
                    <Button Classes="link-btn"
                            Command="{Binding ViewAlbumCommand}"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding Player.CurrentTrack.Album, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <controls:MarqueeTextBlock Text="{Binding Player.CurrentTrack.Album, FallbackValue=''}"
                                                   FontSize="14"
                                                   Foreground="{Binding LyricsAccentFg}"
                                                   MaxDisplayWidth="520"
                                                   IsLyricsPage="True"
                                                   IsForArtist="True"/>
                    </Button>
                </StackPanel>

                <!-- Genre · Year · Tracks · Lossless info -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            MaxWidth="560"
                            Spacing="0"
                            Margin="0,8,0,0"
                            ClipToBounds="True"
                            IsVisible="{Binding Player.CurrentTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock FontSize="12" Foreground="{Binding LyricsSubtleFg}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} · {1} · {2} tracks">
                                <Binding Path="Player.CurrentTrack.Genre" FallbackValue=""/>
                                <Binding Path="Player.CurrentTrack.Year" FallbackValue=""/>
                                <Binding Path="Player.CurrentTrack.TrackCount" FallbackValue=""/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text=" · "
                               FontSize="12"
                               Foreground="{Binding LyricsSubtleFg}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding Player.CurrentTrack.AudioQualityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                VerticalAlignment="Center"
                                IsVisible="{Binding Player.CurrentTrack.AudioQualityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <ToolTip.Tip>
                            <StackPanel Width="220" Spacing="4">
                                <TextBlock Text="{Binding Player.CurrentTrack.AudioQualityBadge}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                <TextBlock Text="{Binding Player.CurrentTrack.AudioQualityDetailedInfo}"
                                           FontSize="12"
                                           Opacity="0.9"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                <TextBlock Text="Lossless audio preserves more detail from the original recording."
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Opacity="0.85"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>
                        </ToolTip.Tip>
                        <Viewbox Width="16" Height="11" VerticalAlignment="Center" Margin="0,1,0,0" Opacity="0.6">
                            <Path Data="M8.184,0.35C9.944,0.35 10.703,3.296 11.338,5.238C11.673,3.842 11.497,3.542 11.857,3.542C11.99,3.542 12.126,3.633 12.126,3.798C12.126,3.809 12.123,3.839 12.117,3.883L12.091,4.058C12.02,4.522 11.845,5.494 11.654,6.144C13.198,10.191 14.345,4.861 14.474,3.772C14.493,3.615 14.612,3.542 14.731,3.542C14.891,3.542 15.022,3.662 14.997,3.843C14.72,5.605 14.295,8.35 12.547,8.35C11.582,8.35 11.04,7.595 10.611,6.73C9.54,4.626 9.047,1.093 7.997,1.093C7.66,1.093 7.411,1.444 7.394,1.444C7.362,1.444 7.337,1.301 7.023,0.909C7.322,0.567 7.734,0.35 8.184,0.35ZM2.458,0.354C5.211,0.354 5.456,7.618 7.014,7.618C7.197,7.618 7.394,7.507 7.61,7.256C7.729,7.458 7.851,7.638 7.978,7.796C7.667,8.151 7.28,8.35 6.795,8.35C5.054,8.349 4.306,5.434 3.663,3.466C3.511,4.097 3.432,4.669 3.402,4.925C3.382,5.088 3.263,5.163 3.143,5.163C3.009,5.163 2.874,5.071 2.874,4.908L2.874,4.908L2.877,4.87C2.966,4.223 3.146,3.243 3.347,2.56C3.079,1.858 2.745,1.091 2.252,1.091C1.257,1.091 0.687,3.591 0.527,4.925C0.508,5.088 0.388,5.163 0.268,5.163C0.135,5.163 0,5.071 0,4.908C0,4.896 0.001,4.883 0.002,4.87C0.283,2.836 0.808,0.354 2.458,0.354ZM5.315,0.35C5.809,0.35 6.339,0.608 6.797,1.211C6.822,1.241 7.078,1.639 7.159,1.777C8.277,3.802 8.818,7.627 9.881,7.627C10.065,7.627 10.264,7.513 10.484,7.256C10.604,7.458 10.726,7.638 10.852,7.796C10.542,8.15 10.155,8.35 9.67,8.35C6.933,8.349 6.636,1.09 5.128,1.09C4.788,1.09 4.536,1.444 4.519,1.444C4.487,1.444 4.462,1.301 4.148,0.909C4.455,0.558 4.87,0.35 5.315,0.35Z"
                                  Fill="{Binding LyricsControlFill}" />
                        </Viewbox>
                        <TextBlock Text="{Binding Player.CurrentTrack.AudioQualityBadge}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding LyricsSubtleFg}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Favorite heart inline (only for singles) -->
                    <TextBlock Text=" · "
                               FontSize="12"
                               Foreground="{Binding LyricsSubtleFg}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ShowMetadataFavoriteHeart}" />
                    <PathIcon Data="{StaticResource HeartFillIcon}"
                              Width="12" Height="12"
                              Foreground="#E74856"
                              VerticalAlignment="Center"
                              IsVisible="{Binding ShowMetadataFavoriteHeart}"/>
                </StackPanel>

                <!-- Seek Bar -->
                <Grid Margin="6,8,6,0" RowDefinitions="Auto,Auto">
                    <Grid Grid.Row="0"
                          Margin="7,0,7,4"
                          ColumnDefinitions="64,*,64">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Player.PositionText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding LyricsSubtleFg}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Player.RemainingTimeText, StringFormat='-{0}'}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding LyricsSubtleFg}"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Grid.Row="1" Height="20" ClipToBounds="False">
                        <Canvas x:Name="LyricsSeekVisual"
                                Height="20"
                                ClipToBounds="False"
                                IsHitTestVisible="False">
                            <Border x:Name="LyricsSeekTrackBackground"
                                    Height="6"
                                    CornerRadius="3"
                                    Background="{DynamicResource LyricsSliderUnfilledRes}"
                                    Canvas.Top="7"/>
                            <Border x:Name="LyricsSeekTrackFill"
                                    Height="6"
                                    CornerRadius="3"
                                    Background="{DynamicResource LyricsSliderFilledRes}"
                                    Canvas.Top="7"/>
                            <Border x:Name="LyricsSeekThumb"
                                    Width="14"
                                    Height="14"
                                    CornerRadius="7"
                                    Background="{DynamicResource LyricsSliderThumbRes}"
                                    BoxShadow="0 2 4 0 #40000000"
                                    Canvas.Top="3"/>
                        </Canvas>
                        <Slider Value="{Binding Player.PositionFraction, Mode=TwoWay}"
                                Classes="lyrics-seek"
                                Minimum="0" Maximum="1"
                                Focusable="False"
                                VerticalAlignment="Center"
                                Foreground="{Binding LyricsSliderFilled}"
                                x:Name="SeekSlider"/>
                    </Grid>
                </Grid>

                <!-- Playback Pill Island -->
                <Border Background="#F0181818" CornerRadius="999" Padding="6,4"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center">
                        <!-- Shuffle -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding Player.ToggleShuffleCommand}"
                                Width="36" Height="36"
                                ToolTip.Tip="Shuffle">
                            <Panel>
                                <Viewbox Width="18" Height="18"
                                         IsVisible="{Binding !Player.IsShuffleEnabled}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#FFFFFF" Data="{StaticResource ShuffleIcon}"/>
                                    </Canvas>
                                </Viewbox>
                                <Viewbox Width="18" Height="18"
                                         IsVisible="{Binding Player.IsShuffleEnabled}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#E74856" Data="{StaticResource ShuffleIcon}"/>
                                    </Canvas>
                                </Viewbox>
                            </Panel>
                        </Button>

                        <!-- Previous -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding Player.PreviousCommand}"
                                Width="36" Height="36"
                                ToolTip.Tip="Previous">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#FFFFFF" Data="{StaticResource PreviousIcon}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Play / Pause -->
                        <Button Classes="lyrics-play-btn"
                                Command="{Binding Player.PlayPauseCommand}"
                                Width="46" Height="46"
                                ToolTip.Tip="{Binding Player.PlayPauseTooltip}">
                            <Panel>
                                <Viewbox Width="22" Height="22"
                                         IsVisible="{Binding Player.State, Converter={x:Static ObjectConverters.NotEqual}, ConverterParameter={x:Static m:PlaybackState.Playing}}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#FFFFFF" Data="{StaticResource PlayIcon}"/>
                                    </Canvas>
                                </Viewbox>
                                <Viewbox Width="22" Height="22"
                                         IsVisible="{Binding Player.State, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static m:PlaybackState.Playing}}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#FFFFFF" Data="{StaticResource PauseIcon}"/>
                                    </Canvas>
                                </Viewbox>
                            </Panel>
                        </Button>

                        <!-- Next -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding Player.NextCommand}"
                                Width="36" Height="36"
                                ToolTip.Tip="Forward">
                            <Viewbox Width="20" Height="20">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#FFFFFF" Data="{StaticResource NextIcon}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <!-- Repeat -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding Player.CycleRepeatCommand}"
                                Width="36" Height="36"
                                ToolTip.Tip="Repeat">
                            <Panel>
                                <Viewbox Width="18" Height="18"
                                         IsVisible="{Binding Player.RepeatMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static m:RepeatMode.Off}}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#FFFFFF" Data="{StaticResource RepeatAllIcon}"/>
                                    </Canvas>
                                </Viewbox>
                                <Viewbox Width="18" Height="18"
                                         IsVisible="{Binding Player.RepeatMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static m:RepeatMode.All}}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#E74856" Data="{StaticResource RepeatAllIcon}"/>
                                    </Canvas>
                                </Viewbox>
                                <Viewbox Width="18" Height="18"
                                         IsVisible="{Binding Player.RepeatMode, Converter={x:Static ObjectConverters.Equal}, ConverterParameter={x:Static m:RepeatMode.One}}">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#E74856" Data="{StaticResource RepeatOneIcon}"/>
                                    </Canvas>
                                </Viewbox>
                            </Panel>
                        </Button>

                        <!-- More Options (3-dots) -->
                        <Button Classes="lyrics-ctrl-btn"
                                Width="36" Height="36"
                                ToolTip.Tip="Options"
                                x:Name="LyricsOptionsButton">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#FFFFFF" Data="{StaticResource MoreDotsIcon}"/>
                                </Canvas>
                            </Viewbox>
                            <Button.Flyout>
                                <MenuFlyout Placement="TopEdgeAlignedRight"
                                            PlacementConstraintAdjustment="None"
                                            x:DataType="vm:LyricsViewModel"
                                            Opened="OnTrackFlyoutOpened">
                                    <MenuItem Command="{Binding Player.PlayPauseCommand}"
                                              MaxWidth="400">
                                        <MenuItem.Header>
                                            <TextBlock Text="Play"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontWeight="Normal"
                                                       FontSize="14"
                                                       FontFamily="{Binding $parent[MenuItem].FontFamily}" />
                                        </MenuItem.Header>
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Shuffle"
                                              Command="{Binding Player.ShuffleCurrentAlbumCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource ShuffleIcon}" Width="14" Height="14" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Play Next"
                                              Command="{Binding Player.PlayNextCurrentTrackCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Forward%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Add to Queue"
                                              Command="{Binding Player.AddCurrentTrackToQueueCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Add to Playlist">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Playlists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                        <MenuItem Header="Create New Playlist"
                                                  Command="{Binding Player.AddCurrentTrackToNewPlaylistCommand}" />
                                        <Separator />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Favorites"
                                              Command="{Binding Player.ToggleCurrentTrackFavoriteCommand}"
                                              IsVisible="{Binding Player.CurrentTrack.IsFavorite, Converter={x:Static BoolConverters.Not}, FallbackValue=True}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Your%20Favorites%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Remove from Favorites"
                                              Command="{Binding Player.ToggleCurrentTrackFavoriteCommand}"
                                              IsVisible="{Binding Player.CurrentTrack.IsFavorite, FallbackValue=False}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="{Binding LyricsAccentFg}" VerticalAlignment="Center" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Metadata"
                                              Command="{Binding Player.OpenCurrentTrackMetadataCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Metadata%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Search Lyrics"
                                              Command="{Binding Player.SearchCurrentTrackLyricsCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Lyrics%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Show Folder"
                                              Command="{Binding Player.ShowCurrentTrackInExplorerCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Folder%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Remove from Library" Classes="danger"
                                              Command="{Binding Player.RemoveCurrentTrackFromLibraryCommand}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Queue (icon only) -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding Player.ShowQueueCommand}"
                                Tag="QueueToggle"
                                Width="36" Height="36"
                                ToolTip.Tip="Queue">
                            <Border Width="16" Height="16"
                                    Background="#FFFFFF"
                                    RenderOptions.BitmapInterpolationMode="HighQuality">
                                <Border.OpacityMask>
                                    <ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" />
                                </Border.OpacityMask>
                            </Border>
                        </Button>

                        <!-- Lyrics (icon only — click to go back) -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding Player.ShowLyricsCommand}"
                                Width="36" Height="36"
                                ToolTip.Tip="Lyrics">
                            <Border Width="16" Height="16"
                                    Background="#FFFFFF"
                                    RenderOptions.BitmapInterpolationMode="HighQuality">
                                <Border.OpacityMask>
                                    <ImageBrush Source="avares://Noctis/Assets/Icons/Lyrics%20ICON.png" Stretch="Uniform" />
                                </Border.OpacityMask>
                            </Border>
                        </Button>

                        <!-- Save searched lyrics (only for online results) -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding SaveLyricsToFileCommand}"
                                IsVisible="{Binding CanSaveToFile}"
                                Width="36" Height="36"
                                ToolTip.Tip="Save lyrics">
                            <PathIcon Data="{StaticResource SaveDiskIcon}"
                                      Width="14" Height="14"
                                      Foreground="#FFFFFF" />
                        </Button>

                        <!-- Remove saved/cached lyrics -->
                        <Button Classes="lyrics-ctrl-btn"
                                Command="{Binding RemoveLyricsCommand}"
                                IsVisible="{Binding CanRemoveLyrics}"
                                Width="36" Height="36"
                                ToolTip.Tip="Remove lyrics">
                            <PathIcon Data="{StaticResource TrashIcon}"
                                      Width="14" Height="14"
                                      Foreground="#E74856" />
                        </Button>

                        <!-- Synced / Plain toggle -->
                        <Border Background="#18FFFFFF"
                                CornerRadius="999"
                                Padding="2"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Synced / Plain lyrics">
                            <StackPanel Orientation="Horizontal" Spacing="1">
                                <Button Command="{Binding ToggleLyricsModeCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="10,4"
                                        CornerRadius="999"
                                        Cursor="Hand"
                                        Opacity="{Binding IsSyncTabSelected, Converter={StaticResource BoolToOpacity}}">
                                    <TextBlock Text="Synced" FontSize="11" FontWeight="SemiBold"/>
                                </Button>
                                <Button Command="{Binding ToggleLyricsModeCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="10,4"
                                        CornerRadius="999"
                                        Cursor="Hand"
                                        Opacity="{Binding IsUnsyncTabSelected, Converter={StaticResource BoolToOpacity}}">
                                    <TextBlock Text="Plain" FontSize="11" FontWeight="SemiBold"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Background color picker (icon only) -->
                        <Button Classes="lyrics-ctrl-btn"
                                Width="36" Height="36"
                                ToolTip.Tip="Background color">
                            <Border Width="14" Height="14"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                        <GradientStop Color="#FF0000" Offset="0.0"/>
                                        <GradientStop Color="#FF8000" Offset="0.17"/>
                                        <GradientStop Color="#FFFF00" Offset="0.33"/>
                                        <GradientStop Color="#00CC00" Offset="0.5"/>
                                        <GradientStop Color="#0099FF" Offset="0.67"/>
                                        <GradientStop Color="#6633FF" Offset="0.83"/>
                                        <GradientStop Color="#CC00CC" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.OpacityMask>
                                    <DrawingBrush Stretch="Uniform">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing Brush="Black"
                                                             Geometry="{StaticResource PaletteIcon}"/>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Border.OpacityMask>
                            </Border>
                            <Button.Flyout>
                                <Flyout Placement="TopEdgeAlignedRight">
                                    <Flyout.FlyoutPresenterTheme>
                                        <ControlTheme TargetType="FlyoutPresenter" BasedOn="{StaticResource {x:Type FlyoutPresenter}}">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="CornerRadius" Value="0"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="MinWidth" Value="0"/>
                                            <Setter Property="MaxWidth" Value="9999"/>
                                        </ControlTheme>
                                    </Flyout.FlyoutPresenterTheme>
                                    <Border Background="#EE141414" CornerRadius="999" Padding="6,5"
                                            BorderBrush="#22FFFFFF" BorderThickness="1">
                                        <StackPanel Orientation="Horizontal" Spacing="6"
                                                    DataContext="{Binding #LyricsRoot.DataContext}"
                                                    x:DataType="vm:LyricsViewModel">

                                            <!-- Solid / Gradient toggle -->
                                            <Border Background="#18FFFFFF" CornerRadius="999" Padding="2"
                                                    VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="1">
                                                    <Button Command="{Binding SelectColorModeSolidCommand}"
                                                            Background="Transparent"
                                                            BorderThickness="0" Padding="8,3" CornerRadius="999" Cursor="Hand"
                                                            Opacity="{Binding IsColorModeSolid, Converter={StaticResource BoolToOpacity}}">
                                                        <TextBlock Text="Solid" FontSize="10" FontWeight="SemiBold"/>
                                                    </Button>
                                                    <Button Command="{Binding SelectColorModeGradientCommand}"
                                                            Background="Transparent"
                                                            BorderThickness="0" Padding="8,3" CornerRadius="999" Cursor="Hand"
                                                            Opacity="{Binding IsColorModeGradient, Converter={StaticResource BoolToOpacity}}">
                                                        <TextBlock Text="Gradient" FontSize="10" FontWeight="SemiBold"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>

                                            <!-- Divider -->
                                            <Border Width="1" Height="16" Background="#30FFFFFF" VerticalAlignment="Center"/>

                                            <!-- Solid swatches -->
                                            <ScrollViewer x:Name="SolidSwatchScroller"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          MaxWidth="280"
                                                          IsVisible="{Binding IsColorModeSolid}">
                                                <ItemsControl ItemsSource="{Binding SolidSwatches}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:ColorSwatch">
                                                            <Button Classes="swatch-btn"
                                                                    Command="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).SetBackgroundColorCommand}"
                                                                    CommandParameter="{Binding Key}"
                                                                    ToolTip.Tip="{Binding Name}">
                                                                <Panel>
                                                                    <Border Width="20" Height="20" CornerRadius="10"
                                                                            Background="{Binding Preview}"
                                                                            BorderBrush="#33FFFFFF" BorderThickness="1"/>
                                                                    <TextBlock Text="A" FontSize="8" FontWeight="Bold"
                                                                               Foreground="White"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               IsVisible="{Binding IsAuto}"/>
                                                                </Panel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <!-- Gradient swatches -->
                                            <ScrollViewer x:Name="GradientSwatchScroller"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          MaxWidth="280"
                                                          IsVisible="{Binding IsColorModeGradient}">
                                                <ItemsControl ItemsSource="{Binding GradientSwatches}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:ColorSwatch">
                                                            <Button Classes="swatch-btn"
                                                                    Command="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).SetBackgroundColorCommand}"
                                                                    CommandParameter="{Binding Key}"
                                                                    ToolTip.Tip="{Binding Name}">
                                                                <Border Width="20" Height="20" CornerRadius="10"
                                                                        Background="{Binding Preview}"
                                                                        BorderBrush="#33FFFFFF" BorderThickness="1"/>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                        </StackPanel>
                                    </Border>
                                </Flyout>
                            </Button.Flyout>
                        </Button>

                        <!-- Volume -->
                        <StackPanel x:Name="LyricsVolumeContainer"
                                     Orientation="Horizontal" Spacing="0"
                                     VerticalAlignment="Center"
                                     PointerEntered="OnLyricsVolumeContainerEntered"
                                    PointerExited="OnLyricsVolumeContainerExited">
                            <Button Classes="lyrics-ctrl-btn"
                                    Command="{Binding Player.ToggleMuteCommand}"
                                    Width="36" Height="36"
                                    ToolTip.Tip="Mute">
                                <Panel>
                                    <Viewbox Width="18" Height="18"
                                             IsVisible="{Binding !Player.IsMuted}">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="#FFFFFF" Data="{Binding Player.Volume, Converter={StaticResource VolumeToIcon}}"/>
                                        </Canvas>
                                    </Viewbox>
                                    <Viewbox Width="18" Height="18"
                                             IsVisible="{Binding Player.IsMuted}">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="{Binding LyricsSubtleFg}" Data="{StaticResource SpeakerMuteIcon}"/>
                                        </Canvas>
                                    </Viewbox>
                                </Panel>
                            </Button>
                            <Panel VerticalAlignment="Center" Margin="-9,0,0,0">
                                <TextBlock x:Name="LyricsVolumePercentage"
                                           Text="{Binding Player.Volume}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding LyricsPrimaryFg}"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Opacity="0"
                                           IsVisible="False"
                                           IsHitTestVisible="False">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform X="0" Y="-18"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                                        </Transitions>
                                    </TextBlock.Transitions>
                                </TextBlock>
                                <Border x:Name="LyricsVolumeSliderContainer"
                                        Width="0"
                                        Height="36"
                                        ClipToBounds="True"
                                        VerticalAlignment="Center">
                                    <Border.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Width" Duration="0:0:0.2">
                                                <DoubleTransition.Easing>
                                                    <CubicEaseOut/>
                                                </DoubleTransition.Easing>
                                            </DoubleTransition>
                                        </Transitions>
                                    </Border.Transitions>
                                    <Grid Width="99" Margin="7,0,7,0"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center">
                                        <Slider x:Name="LyricsVolumeSlider"
                                                Value="{Binding Player.Volume, Mode=TwoWay}"
                                                Classes="lyrics-volume"
                                                Minimum="0" Maximum="100"
                                                Foreground="{Binding LyricsSliderFilled}"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Panel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Bottom action row: Alternate source + save status (Save/Remove moved into player bar) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Margin="0,24,0,0">
                    <!-- Switch to alternate lyrics source -->
                    <Button Classes="pill-btn"
                            Padding="10,5"
                            Height="30" MinHeight="30"
                            IsVisible="{Binding HasAlternateLyrics}"
                            Command="{Binding SwitchToAlternateLyricsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <PathIcon Data="{StaticResource AttachIcon}"
                                     Width="12" Height="12" Foreground="{Binding LyricsPrimaryFg}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AlternateLyricsLabel}" FontSize="11" Foreground="{Binding LyricsPrimaryFg}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Save status text -->
                    <TextBlock Text="{Binding SaveStatusText}"
                               FontSize="11"
                               Foreground="{Binding LyricsSubtleFg}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding SaveStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- RIGHT PANEL: Lyrics Column                           -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid x:Name="RightPanel" Grid.Column="1"
              RenderTransformOrigin="0.5,0.5">
            <Grid.Transitions>
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25">
                        <TransformOperationsTransition.Easing><CubicEaseOut/></TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                </Transitions>
            </Grid.Transitions>

            <!-- (Color picker moved to left panel bottom) -->

            <!-- Search Lyrics Button (when no lyrics) -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="-50,0,0,0"
                        Spacing="12"
                        IsVisible="{Binding ShowSearchButton}"
                        ZIndex="3">
                <TextBlock Text="{Binding SearchFailedMessage}"
                           FontSize="14"
                           Foreground="{Binding LyricsSubtleFg}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding SearchFailedMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <Button Classes="accent-btn"
                        Background="#E74856"
                        Foreground="{Binding LyricsPrimaryFg}"
                        BorderThickness="0"
                        Padding="16,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        CornerRadius="20"
                        Cursor="Hand"
                        Command="{Binding SearchLyricsCommand}"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource SearchGlobeIcon}"
                                 Width="13" Height="13"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Search Lyrics" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Searching indicator with pulse animation -->
            <TextBlock x:Name="SearchingText"
                       Text="Searching for Lyrics..."
                       FontSize="16"
                       Foreground="{Binding LyricsSubtleFg}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="-50,0,0,0"
                       IsVisible="{Binding IsSearching}"
                       ZIndex="3">
                <TextBlock.Styles>
                    <Style Selector="TextBlock#SearchingText[IsVisible=True]">
                        <Style.Animations>
                            <Animation Duration="0:0:1.5" IterationCount="INFINITE"
                                       Easing="SineEaseInOut" PlaybackDirection="Alternate">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0.3"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </TextBlock.Styles>
            </TextBlock>

            <!-- Opacity-masked lyrics container -->
            <Border ClipToBounds="True"
                    VerticalAlignment="Stretch"
                    Margin="0,20,0,20">
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Color="#A0FFFFFF" Offset="0.0"/>
                        <GradientStop Color="#E0FFFFFF" Offset="0.06"/>
                        <GradientStop Color="#FFFFFFFF" Offset="0.15"/>
                        <GradientStop Color="#FFFFFFFF" Offset="0.80"/>
                        <GradientStop Color="#E0FFFFFF" Offset="0.93"/>
                        <GradientStop Color="#A0FFFFFF" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>

                <ScrollViewer x:Name="LyricsScrollViewer"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,0,32,0">
                    <ItemsControl ItemsSource="{Binding ActiveLyricLines}"
                                  x:Name="LyricsItemsControl"
                                  MaxWidth="640"
                                  HorizontalAlignment="Left">
                        <ItemsControl.Transitions>
                            <Transitions>
                                <DoubleTransition Property="MaxWidth" Duration="0:0:0.25">
                                    <DoubleTransition.Easing><CubicEaseOut/></DoubleTransition.Easing>
                                </DoubleTransition>
                            </Transitions>
                        </ItemsControl.Transitions>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:LyricLine">
                                <Button Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="0,10"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Cursor="Hand"
                                        IsHitTestVisible="{Binding IsClickable}"
                                        Command="{Binding $parent[ItemsControl].((vm:LyricsViewModel)DataContext).SeekToLineCommand}"
                                        CommandParameter="{Binding}">
                                    <Panel HorizontalAlignment="Stretch">
                                        <!-- Main text layer (hidden for intro placeholder OR when word-level karaoke is active) -->
                                        <TextBlock Text="{Binding Text}"
                                                   Classes="lyric-line"
                                                   Classes.active="{Binding IsActive}"
                                                   FontSize="46"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsPrimaryFg}"
                                                   HorizontalAlignment="Stretch"
                                                   Opacity="{Binding LineOpacity}"
                                                   IsVisible="{Binding ShowLineText}"
                                                   TextWrapping="Wrap"/>

                                        <!-- Word-level karaoke layer (Lyricsfile word timings, only on active line) -->
                                        <ItemsControl ItemsSource="{Binding Words}"
                                                      IsVisible="{Binding ShowWords}"
                                                      Opacity="{Binding LineOpacity}"
                                                      HorizontalAlignment="Stretch">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="m:WordTiming">
                                                    <Panel>
                                                        <TextBlock Text="{Binding Text}"
                                                                   Classes="word"
                                                                   Classes.past="{Binding IsPast}"
                                                                   Classes.current="{Binding IsCurrent}"
                                                                   FontSize="46"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsPrimaryFg}"/>
                                                        <TextBlock Text="{Binding Text}"
                                                                   Classes="word-accent"
                                                                   Classes.current="{Binding IsCurrent}"
                                                                   FontSize="46"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsAccentFg}"/>
                                                    </Panel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Intro dots -->
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Margin="0,8"
                                                    Opacity="{Binding LineOpacity}"
                                                    IsVisible="{Binding IsIntroPlaceholder}"
                                                    Classes.active="{Binding IsActive}">
                                            <StackPanel.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                                                </Transitions>
                                            </StackPanel.Transitions>
                                            <Ellipse x:Name="IntroDot1" Width="8" Height="8" Fill="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsControlFill}">
                                                <Ellipse.Styles>
                                                    <Style Selector="StackPanel.active Ellipse#IntroDot1">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:1.8" IterationCount="INFINITE">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="16%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                                <KeyFrame Cue="33%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                    <Style Selector="StackPanel:not(.active) Ellipse#IntroDot1">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Style>
                                                </Ellipse.Styles>
                                            </Ellipse>
                                            <Ellipse x:Name="IntroDot2" Width="8" Height="8" Fill="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsControlFill}">
                                                <Ellipse.Styles>
                                                    <Style Selector="StackPanel.active Ellipse#IntroDot2">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:1.8" IterationCount="INFINITE" Delay="0:0:0.3">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="16%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                                <KeyFrame Cue="33%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                    <Style Selector="StackPanel:not(.active) Ellipse#IntroDot2">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Style>
                                                </Ellipse.Styles>
                                            </Ellipse>
                                            <Ellipse x:Name="IntroDot3" Width="8" Height="8" Fill="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsControlFill}">
                                                <Ellipse.Styles>
                                                    <Style Selector="StackPanel.active Ellipse#IntroDot3">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:1.8" IterationCount="INFINITE" Delay="0:0:0.6">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="16%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                                <KeyFrame Cue="33%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                    <Style Selector="StackPanel:not(.active) Ellipse#IntroDot3">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Style>
                                                </Ellipse.Styles>
                                            </Ellipse>
                                        </StackPanel>
                                    </Panel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- (Source / Save / Alternate buttons moved to left panel bottom) -->

            <!-- Follow Button -->
            <Button Classes="pill-btn"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,30"
                    ZIndex="2"
                    IsVisible="{Binding IsAutoFollowPaused}"
                    Command="{Binding ResumeAutoFollowCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource ClipboardIcon}"
                             Width="14" Height="14"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="Follow" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
