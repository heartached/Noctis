<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:conv="using:Noctis.Converters"
             xmlns:controls="using:Noctis.Controls"
             xmlns:views="using:Noctis.Views"
             xmlns:helpers="using:Noctis.Helpers"
             x:Class="Noctis.Views.LyricsView"
             x:DataType="vm:LyricsViewModel"
             x:Name="LyricsRoot"
             Background="Transparent">

    <UserControl.Resources>
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity"/>
        <conv:ArtworkPathConverter x:Key="ArtworkConverter"/>
        <conv:VolumeToIconConverter x:Key="VolumeToIcon"/>
        <conv:ProgressToSweepMaskConverter x:Key="ProgressToSweepMask"/>
        <!-- Adaptive button/slider brushes (updated from code-behind) -->
        <SolidColorBrush x:Key="LyricsBtnBgRes" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="LyricsBtnBgHoverRes" Color="#55FFFFFF"/>
        <SolidColorBrush x:Key="LyricsSecBtnBgRes" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="LyricsSecBtnBgHoverRes" Color="#33FFFFFF"/>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Explicit badge -->
        <Style Selector="Border.lyrics-explicit">
            <Setter Property="Background" Value="#88888888"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Clickable text style -->
        <Style Selector="Button.link-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.link-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="Button.link-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
        <Style Selector="Button.link-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>

        <!-- Play/Pause prominent button -->
        <Style Selector="Button.lyrics-play-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.85"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pressed">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Button.lyrics-play-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Pill button style -->
        <Style Selector="Button.pill-btn">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgRes}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pill-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgHoverRes}"/>
        </Style>

        <!-- Color picker circle button -->
        <Style Selector="Button.icon-circle-btn">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgRes}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.icon-circle-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource LyricsBtnBgHoverRes}"/>
        </Style>

        <!-- Color swatch button — fully transparent template, no box behind circle -->
        <Style Selector="Button.swatch-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Padding="0"/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.swatch-btn:pointerover">
            <Setter Property="Opacity" Value="0.8"/>
        </Style>
        <Style Selector="Button.swatch-btn:pressed">
            <Setter Property="Opacity" Value="0.65"/>
        </Style>

        <!-- Secondary control button (bottom row) -->
        <Style Selector="Button.lyrics-secondary-btn">
            <Setter Property="Background" Value="{DynamicResource LyricsSecBtnBgRes}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Button.lyrics-secondary-btn:pointerover">
            <Setter Property="Background" Value="{DynamicResource LyricsSecBtnBgHoverRes}"/>
        </Style>

        <!-- AMLL-style active-line presentation: scale up + small lift, damped-spring ease.
             Origin pinned to the left edge so text grows in place instead of drifting. -->
        <Style Selector="Button.lyric-line-btn">
            <Setter Property="RenderTransformOrigin" Value="0,0.5"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <!-- Near-critically-damped spring: <2% overshoot. Reads as a soft settle, not a bounce. -->
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.45">
                        <TransformOperationsTransition.Easing>
                            <helpers:SpringEase Damping="7.5" Frequency="4.0"/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.lyric-line-btn.active">
            <!-- Scale removed: the 1.07× zoom-from-left caused the rightmost
                 character of a long active lyric to be clipped by the ScrollViewer's
                 internal ScrollContentPresenter (e.g. the "p" in "wake up").
                 The active line is still visually distinct via bold weight + opacity. -->
            <Setter Property="RenderTransform" Value="translate(0px,-4px)"/>
        </Style>
        <!-- Suppress global hover-scale on lyric lines. -->
        <Style Selector="ItemsControl#LyricsItemsControl Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="ItemsControl#LyricsItemsControl Button.lyric-line-btn.active:pointerover">
            <Setter Property="RenderTransform" Value="translate(0px,-4px)"/>
        </Style>

        <!-- Per-word lift: words fire rapidly, so spring oscillation reads as chatter.
             Use a quick cubic ease-out instead — glides up, no bounce. -->
        <Style Selector="Panel.word-cell">
            <Setter Property="RenderTransformOrigin" Value="0.5,1"/>
            <Setter Property="RenderTransform" Value="translate(0px,0px) scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Panel.word-cell.current">
            <Setter Property="RenderTransform" Value="translate(0px,-3px) scale(1.02)"/>
        </Style>

        <!-- Lyric line: keep active emphasis in opacity/color only, without size/position zoom. -->
        <Style Selector="TextBlock.lyric-line">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Lyrics scrollbar -->
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,8,3,8"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Thumb">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinHeight" Value="24"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Thumb:pointerover">
            <Setter Property="Background" Value="#66FFFFFF"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ RepeatButton">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Height" Value="0"/>
        </Style>
        <Style Selector="ScrollViewer#LyricsScrollViewer /template/ ScrollBar:vertical /template/ Rectangle">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <!-- Karaoke word styles (Lyricsfile word-level sync) -->
        <Style Selector="TextBlock.word">
            <Setter Property="Opacity" Value="0.55"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.22" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock.word.past">
            <Setter Property="Opacity" Value="1.0"/>
        </Style>
        <Style Selector="TextBlock.word.current">
            <!-- Base layer goes invisible while the accent overlay renders on top. -->
            <Setter Property="Opacity" Value="0.0"/>
        </Style>
        <Style Selector="TextBlock.word-accent">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBlock.word-accent.current">
            <Setter Property="Opacity" Value="1.0"/>
        </Style>

        <Style Selector="Slider.lyrics-timeline-slider">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{Binding LyricsSliderFilled}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>

    <!-- Row/column definitions are fixed; wide vs narrow mode is expressed purely
         through Grid.Row/Column/Span attached properties from code-behind. -->
    <Grid x:Name="MainLayoutGrid" ColumnDefinitions="*,*" RowDefinitions="Auto,*"
          Background="{Binding FullBackgroundBrush}">
        <!-- AMLL/Apple-Music–style background: heavily-blurred album cover filling the page.
             A subtle scrim on top keeps lyric text legible against bright art. -->
        <Grid x:Name="LyricsBlurBackdrop"
              Grid.ColumnSpan="2"
              Grid.RowSpan="2"
              ZIndex="-1"
              ClipToBounds="True"
              IsHitTestVisible="False"
              IsVisible="{Binding IsColorModeArtwork}">
            <!-- Instant fallback: Player.AlbumArt is the in-memory bitmap already shown
                 in the mini-player, so it paints synchronously the moment the page
                 mounts. The high-res CachedImage below replaces it once decoded,
                 eliminating the gray flicker between page-attach and image-decode. -->
            <Image Source="{Binding Player.AlbumArt}"
                   Stretch="UniformToFill"
                   RenderOptions.BitmapInterpolationMode="HighQuality"
                   IsVisible="{Binding Player.AlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Image.Effect>
                    <BlurEffect Radius="72"/>
                </Image.Effect>
                <Image.RenderTransform>
                    <ScaleTransform ScaleX="1.18" ScaleY="1.18"/>
                </Image.RenderTransform>
            </Image>
            <controls:CachedImage SourcePath="{Binding Player.CurrentTrack.AlbumArtworkPath}"
                                  DecodeWidth="800"
                                  Stretch="UniformToFill"
                                  RenderOptions.BitmapInterpolationMode="HighQuality">
                <controls:CachedImage.Effect>
                    <BlurEffect Radius="72"/>
                </controls:CachedImage.Effect>
                <!-- Gentle outward scale so blur edges never reveal the underlying solid fill. -->
                <controls:CachedImage.RenderTransform>
                    <ScaleTransform ScaleX="1.18" ScaleY="1.18"/>
                </controls:CachedImage.RenderTransform>
            </controls:CachedImage>
            <!-- Dark scrim: drops the cover's brightness so white lyrics stay readable.
                 Kept strong enough that bright/near-white covers don't bleed a light
                 halo around the title/artist/album text. -->
            <Rectangle Fill="#99000000"/>
        </Grid>


        <!-- ══════════════════════════════════════════════════════ -->
        <!-- LEFT PANEL: Cover Art + Track Info + Controls         -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Border x:Name="LeftPanel"
                Grid.Column="0"
                Grid.RowSpan="2"
                Background="Transparent"
                Padding="40,30">
            <StackPanel x:Name="LeftContentStack" VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        ClipToBounds="False"
                        Width="760">
                <!-- No size transitions here: code-behind sizes the cover/stack/lyrics
                     from the window on attach and resize, and any transition turned
                     those instant layout snaps into a visible grow/zoom every time the
                     page opened or the window was minimized/maximized. -->

                <!-- Album Art -->
                <Border x:Name="AlbumArtBorder"
                        Width="630" Height="630"
                        CornerRadius="12"
                        ClipToBounds="True"
                        HorizontalAlignment="Center"
                        BoxShadow="0 16 50 0 #60000000">
                    <Panel>
                        <Border Background="#333344">
                            <TextBlock Text="&#x266B;"
                                       FontSize="60"
                                       Foreground="#555566"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <!-- Instant fallback bitmap (already cached at 768px for the
                             mini-player). Prevents the gray placeholder from flashing
                             between page-attach and the 1280px CachedImage decode. -->
                        <Image Source="{Binding Player.AlbumArt}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapInterpolationMode="HighQuality"
                               IsVisible="{Binding Player.AlbumArt, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <controls:CachedImage SourcePath="{Binding Player.CurrentTrack.AlbumArtworkPath}"
                                              DecodeWidth="1280"
                                              Stretch="UniformToFill"
                                              RenderOptions.BitmapInterpolationMode="HighQuality"
                                              IsVisible="{Binding Player.CurrentTrack.AlbumArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        <controls:AnimatedCoverImage
                            Source="{Binding Player.CurrentAnimatedCoverPath}"
                            IsActive="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.EnableAnimatedCovers, FallbackValue=False}" />
                    </Panel>
                </Border>

                <!-- Track Info -->
                <StackPanel Spacing="4" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <!-- Title + Explicit badge -->
                    <controls:MarqueeTextBlock x:Name="TitleMarquee"
                                               Text="{Binding Player.CurrentTrack.Title, FallbackValue='No track playing'}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{Binding LyricsPrimaryFg}"
                                               MaxDisplayWidth="520"
                                               HorizontalAlignment="Center"
                                               IsLyricsPage="True"
                                               IsForArtist="False">
                        <controls:MarqueeTextBlock.InlineContent>
                            <Border Classes="lyrics-explicit"
                                    IsVisible="{Binding Player.CurrentTrack.IsExplicit, FallbackValue=False}"
                                    ToolTip.Tip="Explicit">
                                <TextBlock Text="E"
                                           FontSize="9"
                                           FontWeight="Bold"
                                           Foreground="{Binding LyricsPrimaryFg}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </controls:MarqueeTextBlock.InlineContent>
                    </controls:MarqueeTextBlock>

                    <!-- Artist -->
                    <Button Classes="link-btn"
                            Command="{Binding ViewArtistCommand}"
                            HorizontalAlignment="Center">
                        <controls:MarqueeTextBlock x:Name="ArtistMarquee"
                                                   Text="{Binding Player.CurrentTrack.Artist, FallbackValue=''}"
                                                   FontSize="17"
                                                   Foreground="{Binding LyricsAccentFg}"
                                                   MaxDisplayWidth="520"
                                                   IsLyricsPage="True"
                                                   IsForArtist="True"/>
                    </Button>

                    <!-- Album -->
                    <Button Classes="link-btn"
                            Command="{Binding ViewAlbumCommand}"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding Player.CurrentTrack.Album, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <controls:MarqueeTextBlock x:Name="AlbumMarquee"
                                                   Text="{Binding Player.CurrentTrack.Album, FallbackValue=''}"
                                                   FontSize="14"
                                                   Foreground="{Binding LyricsAccentFg}"
                                                   MaxDisplayWidth="520"
                                                   IsLyricsPage="True"
                                                   IsForArtist="True"/>
                    </Button>
                </StackPanel>

                <!-- Genre · Year · Tracks · Lossless info -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            MaxWidth="560"
                            Spacing="0"
                            Margin="0,8,0,0"
                            ClipToBounds="True"
                            IsVisible="{Binding Player.CurrentTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock FontSize="12" Foreground="{Binding LyricsSubtleFg}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} · {1} · {2} tracks">
                                <Binding Path="Player.CurrentTrack.Genre" FallbackValue=""/>
                                <Binding Path="Player.CurrentTrack.Year" FallbackValue=""/>
                                <Binding Path="Player.CurrentTrack.TrackCount" FallbackValue=""/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <TextBlock Text=" · "
                               FontSize="12"
                               Foreground="{Binding LyricsSubtleFg}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding Player.CurrentTrack.AudioQualityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                VerticalAlignment="Center"
                                IsVisible="{Binding Player.CurrentTrack.AudioQualityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <ToolTip.Tip>
                            <StackPanel Width="220" Spacing="4">
                                <TextBlock Text="{Binding Player.CurrentTrack.AudioQualityBadge}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                <TextBlock Text="{Binding Player.CurrentTrack.AudioQualityDetailedInfo}"
                                           FontSize="12"
                                           Opacity="0.9"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                <TextBlock Text="Lossless audio preserves more detail from the original recording."
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Opacity="0.85"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>
                        </ToolTip.Tip>
                        <Viewbox Width="16" Height="11" VerticalAlignment="Center" Margin="0,1,0,0">
                            <!-- Match the adjacent "Lossless" label colour so the badge reads as one
                                 inline element instead of an icon-plus-label with mismatched tones.
                                 No Opacity here — it would dim the icon relative to the text. -->
                            <Path Data="M8.184,0.35C9.944,0.35 10.703,3.296 11.338,5.238C11.673,3.842 11.497,3.542 11.857,3.542C11.99,3.542 12.126,3.633 12.126,3.798C12.126,3.809 12.123,3.839 12.117,3.883L12.091,4.058C12.02,4.522 11.845,5.494 11.654,6.144C13.198,10.191 14.345,4.861 14.474,3.772C14.493,3.615 14.612,3.542 14.731,3.542C14.891,3.542 15.022,3.662 14.997,3.843C14.72,5.605 14.295,8.35 12.547,8.35C11.582,8.35 11.04,7.595 10.611,6.73C9.54,4.626 9.047,1.093 7.997,1.093C7.66,1.093 7.411,1.444 7.394,1.444C7.362,1.444 7.337,1.301 7.023,0.909C7.322,0.567 7.734,0.35 8.184,0.35ZM2.458,0.354C5.211,0.354 5.456,7.618 7.014,7.618C7.197,7.618 7.394,7.507 7.61,7.256C7.729,7.458 7.851,7.638 7.978,7.796C7.667,8.151 7.28,8.35 6.795,8.35C5.054,8.349 4.306,5.434 3.663,3.466C3.511,4.097 3.432,4.669 3.402,4.925C3.382,5.088 3.263,5.163 3.143,5.163C3.009,5.163 2.874,5.071 2.874,4.908L2.874,4.908L2.877,4.87C2.966,4.223 3.146,3.243 3.347,2.56C3.079,1.858 2.745,1.091 2.252,1.091C1.257,1.091 0.687,3.591 0.527,4.925C0.508,5.088 0.388,5.163 0.268,5.163C0.135,5.163 0,5.071 0,4.908C0,4.896 0.001,4.883 0.002,4.87C0.283,2.836 0.808,0.354 2.458,0.354ZM5.315,0.35C5.809,0.35 6.339,0.608 6.797,1.211C6.822,1.241 7.078,1.639 7.159,1.777C8.277,3.802 8.818,7.627 9.881,7.627C10.065,7.627 10.264,7.513 10.484,7.256C10.604,7.458 10.726,7.638 10.852,7.796C10.542,8.15 10.155,8.35 9.67,8.35C6.933,8.349 6.636,1.09 5.128,1.09C4.788,1.09 4.536,1.444 4.519,1.444C4.487,1.444 4.462,1.301 4.148,0.909C4.455,0.558 4.87,0.35 5.315,0.35Z"
                                  Fill="{Binding LyricsSubtleFg}" />
                        </Viewbox>
                        <TextBlock Text="{Binding Player.CurrentTrack.AudioQualityBadge}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding LyricsSubtleFg}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <!-- Favorite heart inline (only for singles) -->
                    <TextBlock Text=" · "
                               FontSize="12"
                               Foreground="{Binding LyricsSubtleFg}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding ShowMetadataFavoriteHeart}" />
                    <PathIcon Data="{StaticResource HeartFillIcon}"
                              Width="12" Height="12"
                              Foreground="#E74856"
                              VerticalAlignment="Center"
                              IsVisible="{Binding ShowMetadataFavoriteHeart}"/>
                </StackPanel>

                <Grid x:Name="LyricsTimeline"
                      Margin="0,14,0,0"
                      RowDefinitions="Auto,24"
                      IsVisible="{Binding Player.CurrentTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="{Binding Player.PositionText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding LyricsSubtleFg}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Player.RemainingTimeText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding LyricsSubtleFg}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                    </Grid>

                    <Grid Grid.Row="1"
                          Height="24"
                          ClipToBounds="False">
                        <Canvas Height="24"
                                ClipToBounds="False"
                                IsHitTestVisible="False">
                            <Border x:Name="LyricsTimelineTrackBackground"
                                    Height="7"
                                    CornerRadius="3.5"
                                    Background="{Binding LyricsSliderUnfilled}"
                                    Canvas.Top="8.5"/>
                            <Border x:Name="LyricsTimelineTrackFill"
                                    Height="7"
                                    CornerRadius="3.5"
                                    Background="{Binding LyricsAccentFg}"
                                    Canvas.Top="8.5"/>
                            <Border x:Name="LyricsTimelineThumb"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="8"
                                    Background="{Binding LyricsAccentFg}"
                                    BoxShadow="0 2 5 0 #40000000"
                                    Canvas.Top="4"/>
                        </Canvas>
                        <Slider x:Name="LyricsTimelineSlider"
                                Classes="lyrics-timeline-slider"
                                Value="{Binding Player.PositionFraction, Mode=TwoWay}"
                                Minimum="0"
                                Maximum="1"
                                Focusable="False"
                                VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

                <!-- Lyrics-page playback controls; timeline and track metadata live above. -->
                <views:PlaybackBarView DataContext="{Binding Player}"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,12,0,0"/>

                <!-- Hidden host button anchoring the background-color flyout -->
                <Button x:Name="LyricsColorPickerHost"
                        Width="1" Height="1"
                        Opacity="0"
                        IsHitTestVisible="False"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,2,0,0">
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <Flyout.FlyoutPresenterTheme>
                                <ControlTheme TargetType="FlyoutPresenter" BasedOn="{StaticResource {x:Type FlyoutPresenter}}">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="CornerRadius" Value="0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Setter Property="MaxWidth" Value="9999"/>
                                    <!-- Suppress the built-in ScrollViewer's scrollbars; the picker is a
                                         pill that should never show a track on either axis. -->
                                    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                                    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled"/>
                                </ControlTheme>
                            </Flyout.FlyoutPresenterTheme>
                            <Border x:Name="ColorPickerContent"
                                    Background="#EE141414" CornerRadius="999" Padding="6,5"
                                    BorderBrush="#22FFFFFF" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="6"
                                            DataContext="{Binding #LyricsRoot.DataContext}"
                                            x:DataType="vm:LyricsViewModel">

                                    <!-- Artwork / Solid / Gradient toggle -->
                                    <Border Background="#18FFFFFF" CornerRadius="999" Padding="2"
                                            VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="1">
                                            <Button Command="{Binding SelectColorModeArtworkCommand}"
                                                    Background="Transparent"
                                                    BorderThickness="0" Padding="8,3" CornerRadius="999" Cursor="Hand"
                                                    Opacity="{Binding IsColorModeArtwork, Converter={StaticResource BoolToOpacity}}"
                                                    ToolTip.Tip="Show blurred album artwork as background">
                                                <TextBlock Text="Artwork" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                            </Button>
                                            <Button Command="{Binding SelectColorModeSolidCommand}"
                                                    Background="Transparent"
                                                    BorderThickness="0" Padding="8,3" CornerRadius="999" Cursor="Hand"
                                                    Opacity="{Binding IsColorModeSolid, Converter={StaticResource BoolToOpacity}}">
                                                <TextBlock Text="Solid" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                            </Button>
                                            <Button Command="{Binding SelectColorModeGradientCommand}"
                                                    Background="Transparent"
                                                    BorderThickness="0" Padding="8,3" CornerRadius="999" Cursor="Hand"
                                                    Opacity="{Binding IsColorModeGradient, Converter={StaticResource BoolToOpacity}}">
                                                <TextBlock Text="Gradient" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- Divider between mode toggle and swatches; hidden in Artwork mode
                                         where no swatches follow, otherwise it reads as a trailing scrollbar. -->
                                    <Border Width="1" Height="16" Background="#30FFFFFF" VerticalAlignment="Center"
                                            IsVisible="{Binding IsColorModeArtwork, Converter={x:Static BoolConverters.Not}}"/>

                                    <!-- Solid swatches -->
                                    <ScrollViewer x:Name="SolidSwatchScroller"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  MaxWidth="280"
                                                  IsVisible="{Binding IsColorModeSolid}">
                                        <ItemsControl ItemsSource="{Binding SolidSwatches}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ColorSwatch">
                                                    <Button Classes="swatch-btn"
                                                            Command="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).SetBackgroundColorCommand}"
                                                            CommandParameter="{Binding Key}"
                                                            ToolTip.Tip="{Binding Name}">
                                                        <Panel>
                                                            <Border Width="20" Height="20" CornerRadius="10"
                                                                    Background="{Binding Preview}"
                                                                    BorderBrush="#33FFFFFF" BorderThickness="1"/>
                                                            <TextBlock Text="A" FontSize="8" FontWeight="Bold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       IsVisible="{Binding IsAuto}"/>
                                                        </Panel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Gradient swatches -->
                                    <ScrollViewer x:Name="GradientSwatchScroller"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  MaxWidth="280"
                                                  IsVisible="{Binding IsColorModeGradient}">
                                        <ItemsControl ItemsSource="{Binding GradientSwatches}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="4"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ColorSwatch">
                                                    <Button Classes="swatch-btn"
                                                            Command="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).SetBackgroundColorCommand}"
                                                            CommandParameter="{Binding Key}"
                                                            ToolTip.Tip="{Binding Name}">
                                                        <Border Width="20" Height="20" CornerRadius="10"
                                                                Background="{Binding Preview}"
                                                                BorderBrush="#33FFFFFF" BorderThickness="1"/>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                </StackPanel>
                            </Border>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Bottom action row: Edit Sync + Alternate source + save status (Share moved into player-bar ⋯ menu) -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Margin="0,24,0,0">
                    <!-- LRC sync editor -->
                    <Button Classes="pill-btn"
                            Padding="10,5"
                            Height="30" MinHeight="30"
                            IsVisible="{Binding ShareAvailable}"
                            ToolTip.Tip="Sync lyric timestamps to the music (tap-to-sync + nudge)"
                            Command="{Binding OpenLrcEditorCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <PathIcon Data="{StaticResource EditIcon}"
                                     Width="12" Height="12" Foreground="{Binding LyricsPrimaryFg}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Edit Sync" FontSize="11" Foreground="{Binding LyricsPrimaryFg}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Switch to alternate lyrics source -->
                    <Button Classes="pill-btn"
                            Padding="10,5"
                            Height="30" MinHeight="30"
                            IsVisible="{Binding HasAlternateLyrics}"
                            Command="{Binding SwitchToAlternateLyricsCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <PathIcon Data="{StaticResource AttachIcon}"
                                     Width="12" Height="12" Foreground="{Binding LyricsPrimaryFg}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AlternateLyricsLabel}" FontSize="11" Foreground="{Binding LyricsPrimaryFg}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Save status text -->
                    <TextBlock Text="{Binding SaveStatusText}"
                               FontSize="11"
                               Foreground="{Binding LyricsSubtleFg}"
                               VerticalAlignment="Center"
                               IsVisible="{Binding SaveStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- RIGHT PANEL: Lyrics Column                           -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Grid x:Name="RightPanel" Grid.Column="1" Grid.RowSpan="2"
              RenderTransformOrigin="0.5,0.5">
            <!-- No RenderTransform transition: the wide-mode 1.1x scale is applied
                 by code-behind on attach/resize; a transition made it zoom in every
                 time the page opened or the window was minimized/maximized. -->

            <!-- (Color picker moved to left panel bottom) -->

            <!-- Search Lyrics Button (when no lyrics) -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="-50,0,0,0"
                        Spacing="12"
                        IsVisible="{Binding ShowSearchButton}"
                        ZIndex="3">
                <TextBlock Text="{Binding SearchFailedMessage}"
                           FontSize="14"
                           Foreground="{Binding LyricsSubtleFg}"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding SearchFailedMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <Button Classes="accent-btn"
                        Background="{DynamicResource AccentColorBrush}"
                        Foreground="{DynamicResource AccentForegroundBrush}"
                        Padding="16,8"
                        FontSize="13"
                        FontWeight="SemiBold"
                        CornerRadius="20"
                        Cursor="Hand"
                        Command="{Binding SearchLyricsCommand}"
                        HorizontalAlignment="Center">
                    <TextBlock Text="Search lyrics"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentForegroundBrush}"/>
                </Button>
            </StackPanel>

            <!-- Searching indicator with pulse animation -->
            <TextBlock x:Name="SearchingText"
                       Text="Searching for Lyrics..."
                       FontSize="16"
                       Foreground="{Binding LyricsSubtleFg}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="-50,0,0,0"
                       IsVisible="{Binding IsSearching}"
                       ZIndex="3">
                <TextBlock.Styles>
                    <Style Selector="TextBlock#SearchingText[IsVisible=True]">
                        <Style.Animations>
                            <Animation Duration="0:0:1.5" IterationCount="INFINITE"
                                       Easing="SineEaseInOut" PlaybackDirection="Alternate">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="0.3"/>
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="1.0"/>
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </TextBlock.Styles>
            </TextBlock>

            <!-- Opacity-masked lyrics container.
                 ClipToBounds=False so the active line's 1.07× scale doesn't get hard-clipped
                 on the right edge ("…GOA" → "…GOAT"). Vertical clipping still handled by the
                 ScrollViewer below; the OpacityMask handles the soft top/bottom fade. -->
            <Border ClipToBounds="False"
                    VerticalAlignment="Stretch"
                    Margin="0,20,0,20">
                <Border.OpacityMask>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Color="#A0FFFFFF" Offset="0.0"/>
                        <GradientStop Color="#E0FFFFFF" Offset="0.06"/>
                        <GradientStop Color="#FFFFFFFF" Offset="0.15"/>
                        <GradientStop Color="#FFFFFFFF" Offset="0.80"/>
                        <GradientStop Color="#E0FFFFFF" Offset="0.93"/>
                        <GradientStop Color="#A0FFFFFF" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.OpacityMask>

                <ScrollViewer x:Name="LyricsScrollViewer"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="24,0,0,0">
                    <!-- FontSize set here (and adjusted from code-behind per window size)
                         is inherited by the lyric-line and karaoke TextBlocks below. -->
                    <ItemsControl ItemsSource="{Binding ActiveLyricLines}"
                                  x:Name="LyricsItemsControl"
                                  MaxWidth="640"
                                  FontSize="46"
                                  HorizontalAlignment="Left">
                        <!-- No MaxWidth transition: width is set from the window on
                             attach/resize and a transition animated the lyric column
                             width on every open and minimize/maximize. -->
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:LyricLine">
                                <Button Background="Transparent"
                                        Classes="lyric-line-btn"
                                        Classes.active="{Binding IsActive}"
                                        BorderThickness="0"
                                        Padding="0"
                                        Margin="0,10"
                                        MaxWidth="{Binding $parent[ItemsControl].MaxWidth}"
                                        HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Left"
                                        Cursor="Hand"
                                        IsHitTestVisible="{Binding IsClickable}"
                                        Command="{Binding $parent[ItemsControl].((vm:LyricsViewModel)DataContext).SeekToLineCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Effect>
                                        <BlurEffect Radius="{Binding BlurRadius}"/>
                                    </Button.Effect>
                                    <Panel HorizontalAlignment="Left"
                                           MaxWidth="{Binding $parent[ItemsControl].MaxWidth}">
                                        <!-- Main text layer (hidden for intro placeholder OR when word-level karaoke is active) -->
                                        <TextBlock Text="{Binding Text}"
                                                   Classes="lyric-line"
                                                   Classes.active="{Binding IsActive}"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsPrimaryFg}"
                                                   HorizontalAlignment="Left"
                                                   MaxWidth="{Binding $parent[ItemsControl].MaxWidth}"
                                                   Opacity="{Binding LineOpacity}"
                                                   IsVisible="{Binding ShowLineText}"
                                                   TextWrapping="Wrap"/>

                                        <!-- Word-level karaoke layer (Lyricsfile word timings, only on active line) -->
                                        <ItemsControl ItemsSource="{Binding Words}"
                                                      IsVisible="{Binding ShowWords}"
                                                      Opacity="{Binding LineOpacity}"
                                                      HorizontalAlignment="Left"
                                                      MaxWidth="{Binding $parent[ItemsControl].MaxWidth}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="m:WordTiming">
                                                    <Panel Classes="word-cell"
                                                           Classes.current="{Binding IsCurrent}">
                                                        <!-- Dim base layer (always visible) — gives unsung words a soft ghost. -->
                                                        <TextBlock Text="{Binding Text}"
                                                                   FontWeight="Bold"
                                                                   Opacity="0.45"
                                                                   Foreground="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsPrimaryFg}"/>
                                                        <!-- Bright overlay revealed left-to-right by Progress sweep. -->
                                                        <TextBlock Text="{Binding Text}"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsPrimaryFg}"
                                                                   OpacityMask="{Binding Progress, Converter={StaticResource ProgressToSweepMask}}"/>
                                                    </Panel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- Intro dots -->
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="6"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Margin="0,8"
                                                    Opacity="{Binding LineOpacity}"
                                                    IsVisible="{Binding IsIntroPlaceholder}"
                                                    Classes.active="{Binding IsActive}">
                                            <StackPanel.Transitions>
                                                <Transitions>
                                                    <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                                                </Transitions>
                                            </StackPanel.Transitions>
                                            <Ellipse x:Name="IntroDot1" Width="8" Height="8" Fill="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsControlFill}">
                                                <Ellipse.Styles>
                                                    <Style Selector="StackPanel.active Ellipse#IntroDot1">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:1.8" IterationCount="INFINITE">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="16%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                                <KeyFrame Cue="33%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                    <Style Selector="StackPanel:not(.active) Ellipse#IntroDot1">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Style>
                                                </Ellipse.Styles>
                                            </Ellipse>
                                            <Ellipse x:Name="IntroDot2" Width="8" Height="8" Fill="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsControlFill}">
                                                <Ellipse.Styles>
                                                    <Style Selector="StackPanel.active Ellipse#IntroDot2">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:1.8" IterationCount="INFINITE" Delay="0:0:0.3">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="16%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                                <KeyFrame Cue="33%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                    <Style Selector="StackPanel:not(.active) Ellipse#IntroDot2">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Style>
                                                </Ellipse.Styles>
                                            </Ellipse>
                                            <Ellipse x:Name="IntroDot3" Width="8" Height="8" Fill="{Binding $parent[UserControl].((vm:LyricsViewModel)DataContext).LyricsControlFill}">
                                                <Ellipse.Styles>
                                                    <Style Selector="StackPanel.active Ellipse#IntroDot3">
                                                        <Style.Animations>
                                                            <Animation Duration="0:0:1.8" IterationCount="INFINITE" Delay="0:0:0.6">
                                                                <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="16%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                                <KeyFrame Cue="33%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                                <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                            </Animation>
                                                        </Style.Animations>
                                                    </Style>
                                                    <Style Selector="StackPanel:not(.active) Ellipse#IntroDot3">
                                                        <Setter Property="Opacity" Value="1.0"/>
                                                    </Style>
                                                </Ellipse.Styles>
                                            </Ellipse>
                                        </StackPanel>
                                    </Panel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- (Source / Save / Alternate buttons moved to left panel bottom) -->

            <!-- Follow Button -->
            <Button Classes="pill-btn"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,30"
                    ZIndex="2"
                    IsVisible="{Binding IsAutoFollowPaused}"
                    Command="{Binding ResumeAutoFollowCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <PathIcon Data="{StaticResource ClipboardIcon}"
                             Width="14" Height="14"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="Follow" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
