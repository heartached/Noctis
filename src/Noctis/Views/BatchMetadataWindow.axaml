<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        x:Class="Noctis.Views.BatchMetadataWindow"
        x:DataType="vm:BatchMetadataViewModel"
        Title="Edit Metadata"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <!-- Pill-shaped TextBox matching the rest of Noctis dialogs -->
        <Style Selector="TextBox.pill">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <Style Selector="TextBox.pill /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1.5" />
        </Style>
        <Style Selector="TextBox.pill:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
        </Style>
        <Style Selector="TextBox.pill:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
        </Style>
    </Window.Styles>

    <Border Background="#50000000">
        <Border CornerRadius="20"
                ClipToBounds="True"
                Background="{DynamicResource AppMainBackground}"
                Width="640"
                MaxHeight="780"
                Margin="0,50"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                BoxShadow="0 8 32 0 #60000000">
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="24,20,24,8" Spacing="2">
                    <TextBlock Text="{Binding TitleText}"
                               FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Tick a field to apply its value to every selected track."
                               FontSize="12" Opacity="0.6"
                               HorizontalAlignment="Center" />
                    <Border Background="#33E5484D"
                            BorderBrush="#E5484D"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="8,2"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0">
                        <TextBlock Text="BETA · EXPERIMENTAL FEATURE"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="#FF8A8E"
                                   LetterSpacing="0.5"/>
                    </Border>
                </StackPanel>

                <!-- Footer -->
                <Border DockPanel.Dock="Bottom" Padding="24,12,24,16">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                                   FontSize="12" Opacity="0.7" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="1"
                                Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Width="100" Padding="0,8"
                                FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                CornerRadius="999"
                                Margin="0,0,8,0"
                                Cursor="Hand" />
                        <Button Grid.Column="2"
                                Content="Save"
                                Command="{Binding SaveCommand}"
                                IsEnabled="{Binding !IsSaving}"
                                Width="100" Padding="0,8"
                                Classes="accent-btn"
                                Background="{DynamicResource AccentColorBrush}"
                                Foreground="{DynamicResource AccentForegroundBrush}"
                                FontWeight="SemiBold"
                                HorizontalContentAlignment="Center"
                                CornerRadius="999"
                                Cursor="Hand" />
                    </Grid>
                </Border>

                <!-- Scrollable body -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              Padding="24,4,24,8">
                    <StackPanel Spacing="14">

                        <!-- Tag fields -->
                        <TextBlock Text="Tags" FontSize="13" FontWeight="SemiBold" Opacity="0.75" />

                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyAlbumArtist}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Album Artist" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding AlbumArtist}" Classes="pill" IsEnabled="{Binding ApplyAlbumArtist}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyArtist}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Artist" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding Artist}" Classes="pill" IsEnabled="{Binding ApplyArtist}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyAlbum}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Album" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding Album}" Classes="pill" IsEnabled="{Binding ApplyAlbum}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyGenre}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Genre" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding Genre}" Classes="pill" IsEnabled="{Binding ApplyGenre}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyYear}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Year" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding Year}" Classes="pill" IsEnabled="{Binding ApplyYear}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyComposer}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Composer" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding Composer}" Classes="pill" IsEnabled="{Binding ApplyComposer}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyGrouping}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Grouping" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding Grouping}" Classes="pill" IsEnabled="{Binding ApplyGrouping}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyTrackCount}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Track Count" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding TrackCountValue}" Classes="pill" IsEnabled="{Binding ApplyTrackCount}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyDiscNumber}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Disc Number" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding DiscNumberValue}" Classes="pill" IsEnabled="{Binding ApplyDiscNumber}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyDiscCount}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Disc Count" VerticalAlignment="Center" />
                                <TextBox Grid.Column="2" Text="{Binding DiscCountValue}" Classes="pill" IsEnabled="{Binding ApplyDiscCount}" />
                            </Grid>
                            <Grid ColumnDefinitions="Auto,140,*">
                                <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyCompilation}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="Compilation" VerticalAlignment="Center" />
                                <CheckBox Grid.Column="2" Classes="metadata-pill-checkbox" IsChecked="{Binding IsCompilation}" IsEnabled="{Binding ApplyCompilation}" Content="Part of a compilation album" VerticalAlignment="Center" />
                            </Grid>
                        </StackPanel>

                        <!-- Rename section -->
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.5" Margin="0,4,0,4" />

                        <Grid ColumnDefinitions="Auto,*">
                            <CheckBox Grid.Column="0" Classes="metadata-pill-checkbox" IsChecked="{Binding ApplyRename}" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="Rename files by pattern" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Text="Tokens: %artist% %albumartist% %album% %title% %tracknumber% %tracknumber2% %discnumber% %year% %genre% %composer%"
                                           FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>

                        <TextBox Text="{Binding RenamePattern}" Classes="pill"
                                 IsEnabled="{Binding ApplyRename}" />

                        <Border Background="#10FFFFFF" CornerRadius="8" Padding="10"
                                IsVisible="{Binding ApplyRename}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Preview (first 8 tracks)" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
                                <ItemsControl ItemsSource="{Binding RenamePreviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BatchMetadataViewModel+RenamePreview">
                                            <Grid ColumnDefinitions="*,Auto,*,Auto" Margin="0,1">
                                                <TextBlock Grid.Column="0" Text="{Binding OriginalName}" FontSize="11" Opacity="0.7" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="1" Text="→" FontSize="11" Opacity="0.5" Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="2" Text="{Binding NewName}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Text="conflict" FontSize="10"
                                                           Foreground="#E74856" FontWeight="SemiBold"
                                                           Margin="8,0,0,0"
                                                           IsVisible="{Binding Conflict}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Border>
</Window>
