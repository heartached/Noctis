<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        x:Class="Noctis.Views.AlbumDescriptionDialog"
        x:DataType="vm:AlbumDetailViewModel"
        Title="Album Description"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False">

    <!-- Full-window dimmed overlay -->
    <Border Background="#98000000"
            PointerPressed="OnOverlayPointerPressed"
            PointerWheelChanged="OnOverlayWheel">

        <!-- Centered dialog card -->
        <Border x:Name="AlbumDescriptionCard"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                PointerPressed="OnCardPointerPressed"
                Padding="22,18"
                Width="780"
                MaxWidth="840"
                MaxHeight="600"
                CornerRadius="12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid RowDefinitions="Auto,*"
                  ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Spacing="4"
                            Margin="0,0,18,0">
                    <TextBlock FontSize="38"
                               FontWeight="Bold"
                               TextWrapping="Wrap">
                        <Run Text="{Binding Album.Name}" />
                        <InlineUIContainer BaselineAlignment="Center">
                            <Border Classes="explicit-badge"
                                    IsVisible="{Binding Album.IsExplicit}"
                                    Margin="0,0,0,-2"
                                    ToolTip.Tip="Explicit">
                                <TextBlock Text="E"
                                           Classes="explicit-badge-text"
                                           FontSize="10"
                                           Opacity="0.95" />
                            </Border>
                        </InlineUIContainer>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <TextBlock FontSize="17" Opacity="0.75" VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} · {1} · {2} tracks">
                                    <Binding Path="Album.Genre" />
                                    <Binding Path="Album.Year" />
                                    <Binding Path="Album.TrackCount" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Text=" · "
                                   FontSize="17"
                                   Opacity="0.75"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding Album.AudioQualityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding Album.AudioQualityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <Viewbox Width="20" Height="14" VerticalAlignment="Center" Margin="0,2,0,0" Opacity="0.75">
                                <Path Data="M8.184,0.35C9.944,0.35 10.703,3.296 11.338,5.238C11.673,3.842 11.497,3.542 11.857,3.542C11.99,3.542 12.126,3.633 12.126,3.798C12.126,3.809 12.123,3.839 12.117,3.883L12.091,4.058C12.02,4.522 11.845,5.494 11.654,6.144C13.198,10.191 14.345,4.861 14.474,3.772C14.493,3.615 14.612,3.542 14.731,3.542C14.891,3.542 15.022,3.662 14.997,3.843C14.72,5.605 14.295,8.35 12.547,8.35C11.582,8.35 11.04,7.595 10.611,6.73C9.54,4.626 9.047,1.093 7.997,1.093C7.66,1.093 7.411,1.444 7.394,1.444C7.362,1.444 7.337,1.301 7.023,0.909C7.322,0.567 7.734,0.35 8.184,0.35ZM2.458,0.354C5.211,0.354 5.456,7.618 7.014,7.618C7.197,7.618 7.394,7.507 7.61,7.256C7.729,7.458 7.851,7.638 7.978,7.796C7.667,8.151 7.28,8.35 6.795,8.35C5.054,8.349 4.306,5.434 3.663,3.466C3.511,4.097 3.432,4.669 3.402,4.925C3.382,5.088 3.263,5.163 3.143,5.163C3.009,5.163 2.874,5.071 2.874,4.908L2.874,4.908L2.877,4.87C2.966,4.223 3.146,3.243 3.347,2.56C3.079,1.858 2.745,1.091 2.252,1.091C1.257,1.091 0.687,3.591 0.527,4.925C0.508,5.088 0.388,5.163 0.268,5.163C0.135,5.163 0,5.071 0,4.908C0,4.896 0.001,4.883 0.002,4.87C0.283,2.836 0.808,0.354 2.458,0.354ZM5.315,0.35C5.809,0.35 6.339,0.608 6.797,1.211C6.822,1.241 7.078,1.639 7.159,1.777C8.277,3.802 8.818,7.627 9.881,7.627C10.065,7.627 10.264,7.513 10.484,7.256C10.604,7.458 10.726,7.638 10.852,7.796C10.542,8.15 10.155,8.35 9.67,8.35C6.933,8.349 6.636,1.09 5.128,1.09C4.788,1.09 4.536,1.444 4.519,1.444C4.487,1.444 4.462,1.301 4.148,0.909C4.455,0.558 4.87,0.35 5.315,0.35Z"
                                      Fill="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                            </Viewbox>
                            <TextBlock Text="{Binding Album.AudioQualityBadge}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Opacity="0.75" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Spacing="8"
                                Margin="0,8,0,0">
                        <Button Content="Edit description"
                                Command="{Binding StartAlbumDescriptionEditCommand}"
                                Padding="12,6"
                                FontSize="12"
                                FontWeight="Bold"
                                CornerRadius="999"
                                Cursor="Hand"
                                Background="#E74856"
                                Foreground="White"
                                Classes="album-desc-btn"
                                IsVisible="{Binding !IsAlbumDescriptionEditing}" />
                        <Button Content="Save"
                                Command="{Binding SaveAlbumDescriptionEditCommand}"
                                Padding="12,6"
                                FontSize="12"
                                FontWeight="Bold"
                                CornerRadius="999"
                                Cursor="Hand"
                                Background="#E74856"
                                Foreground="White"
                                Classes="album-desc-btn"
                                IsVisible="{Binding IsAlbumDescriptionEditing}"
                                IsEnabled="{Binding HasAlbumDescriptionChanges}" />
                        <Button Content="Cancel"
                                Command="{Binding CancelAlbumDescriptionEditCommand}"
                                Padding="12,6"
                                FontSize="12"
                                FontWeight="Bold"
                                CornerRadius="999"
                                Cursor="Hand"
                                Background="#E74856"
                                Foreground="White"
                                Classes="album-desc-btn"
                                IsVisible="{Binding IsAlbumDescriptionEditing}" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Row="0"
                        Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="32"
                        Height="32"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="OnCloseClick">
                    <PathIcon Data="{StaticResource DismissIcon}"
                              Width="16" Height="16"
                              Opacity="0.75"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
                </Button>

                <ScrollViewer Grid.Row="1"
                              Grid.ColumnSpan="3"
                              Margin="0,16,0,0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="420">
                    <Grid>
                        <TextBlock Text="{Binding AlbumDescriptionFull}"
                                   FontSize="15"
                                   LineHeight="24"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !IsAlbumDescriptionEditing}" />
                        <TextBox Text="{Binding AlbumDescriptionEditorText}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalContentAlignment="Top"
                                 FontSize="15"
                                 MinHeight="240"
                                 IsVisible="{Binding IsAlbumDescriptionEditing}" />
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Border>
</Window>
