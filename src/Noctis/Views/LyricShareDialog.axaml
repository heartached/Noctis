<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        x:Class="Noctis.Views.LyricShareDialog"
        x:DataType="vm:LyricShareViewModel"
        Title="Share lyrics"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False">

    <Window.Styles>
        <Style Selector="Button.share-pill">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.share-pill:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
        <!-- Active (selected) and accent pills keep the red on hover instead of greying out. -->
        <Style Selector="Button.share-pill.active">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.share-pill.active:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.share-pill.active:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.share-pill.accent">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.share-pill.accent:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.share-pill.accent:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>

        <!-- Solid color swatch: kill the default Fluent hover/press square behind the round chip. -->
        <Style Selector="Button.color-swatch:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.color-swatch:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- Borderless editable lyric line. -->
        <Style Selector="TextBox.share-edit">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="2,2"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBox.share-edit:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#14FFFFFF"/>
        </Style>
        <Style Selector="TextBox.share-edit:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="#1FFFFFFF"/>
        </Style>

        <!-- A stray white glyph (the Fluent scrollbar's line-up arrow) shows at the top of
             the line list at rest, and the app-wide kill for it doesn't take here. Rather
             than chase the exact sub-part, hide the whole vertical bar when idle and reveal
             it (macOS-style) only while the list is hovered — so nothing shows at rest. -->
        <Style Selector="ScrollBar:vertical">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ScrollViewer:pointerover /template/ ScrollBar:vertical">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="ScrollBar:vertical:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <!-- Preview box height follows the card aspect: 320 for 1:1 (300px image + margins),
             480 for 9:16 — so the card fills the box instead of floating with empty bands. -->
        <Style Selector="Border.preview-box">
            <Setter Property="Height" Value="480"/>
        </Style>
        <Style Selector="Border.preview-box.square">
            <Setter Property="Height" Value="320"/>
        </Style>

        <!-- Same rotating-arc spinner as the drop-import pill and Settings' background
             work indicator — shown in the footer while a clip export is in flight. -->
        <Style Selector="Ellipse.loading-spinner">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Stroke" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeDashArray" Value="11,5"/>
            <Setter Property="StrokeLineCap" Value="Round"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:0.85" IterationCount="INFINITE" Easing="LinearEasing">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Dark, rounded flyout for the "Card options" dropdown so it matches the dialog card. -->
        <Style Selector="FlyoutPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
    </Window.Styles>

    <!-- Full-window dimmed overlay -->
    <Border Background="#98000000" PointerPressed="OnOverlayPointerPressed">

        <!-- Centered dialog card -->
        <Border PointerPressed="OnCardPointerPressed"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="22,18"
                Width="880"
                MaxHeight="700"
                CornerRadius="12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="*,Auto">

                <!-- Header -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Share lyrics" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Grid.Row="0" Grid.Column="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="32" Height="32"
                        Padding="0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Cursor="Hand"
                        Click="OnCloseClick">
                    <PathIcon Data="{StaticResource DismissIcon}" Width="16" Height="16" Opacity="0.75"/>
                </Button>

                <!-- Body: line picker (left) + preview (right) -->
                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,16,Auto" Margin="0,16,0,0">
                    <Border Grid.Column="0"
                            Background="#18000000"
                            CornerRadius="8"
                            Padding="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl x:Name="LineItems" ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SelectableLyricLine">
                                        <Border Classes.current="{Binding IsCurrent}"
                                                Background="Transparent"
                                                CornerRadius="6"
                                                Padding="4,2"
                                                Margin="0,1">
                                            <Border.Styles>
                                                <Style Selector="Border.current">
                                                    <Setter Property="Background" Value="#33E74856"/>
                                                </Style>
                                            </Border.Styles>
                                            <Grid ColumnDefinitions="Auto,*">
                                                <CheckBox Grid.Column="0"
                                                          Classes="metadata-pill-checkbox"
                                                          VerticalAlignment="Center"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                                <TextBox Grid.Column="1"
                                                         Classes="share-edit"
                                                         Text="{Binding Text, Mode=TwoWay}"
                                                         AcceptsReturn="False"
                                                         TextWrapping="Wrap"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Preview. The outer panel reserves a fixed 320x480 slot so the dialog
                         never resizes with the format; the visible box hugs the card's aspect
                         (a 1:1 card in the full 480-tall box left empty bands above and below). -->
                    <Panel Grid.Column="2" Width="320" Height="480">
                    <Border Classes="preview-box"
                            Classes.square="{Binding IsSquare}"
                            Width="320"
                            VerticalAlignment="Center"
                            Background="#18000000"
                            CornerRadius="8">
                        <Panel>
                            <TextBlock Text="Select lines to preview"
                                       FontSize="13" Opacity="0.5"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding Preview, Converter={x:Static ObjectConverters.IsNull}}"/>
                            <Image Source="{Binding Preview}"
                                   Stretch="Uniform"
                                   Margin="10"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            <!-- Live karaoke sweep, drawn over the static card while word
                                 timings are animating. Same aspect/margins, so it covers
                                 the still exactly; hidden (null) when not animating. -->
                            <Image x:Name="AnimatedPreviewImage"
                                   Source="{Binding AnimatedPreview}"
                                   IsVisible="{Binding AnimatedPreview, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   Stretch="Uniform"
                                   Margin="10"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        </Panel>
                    </Border>
                    </Panel>
                </Grid>

                <!-- Footer: card options + background dropdowns, status, actions -->
                <Grid Grid.Row="2" Grid.ColumnSpan="2" ColumnDefinitions="Auto,Auto,*,Auto,Auto" Margin="0,16,0,0">
                    <!-- Card options: layout, format, text colour & sync collapsed into one dropdown -->
                    <Button Grid.Column="0" Classes="share-pill" VerticalAlignment="Center"
                            Width="270" HorizontalContentAlignment="Stretch"
                            ToolTip.Tip="Card layout, format, text colour &amp; sync">
                        <!-- Hard-fixed width (text left, chevron pinned right) so toggling
                             Layout/Format/Text/Sync/Karaoke can't resize the pill and shift
                             the anchored flyout. MinWidth wasn't enough: "· Karaoke" pushed
                             the summary past it, so every toggle resized the pill again. Sized
                             for the longest summary ("Poster · 9:16 · White · Sync · Karaoke"). -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding CardOptionsSummary}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <PathIcon Grid.Column="1" Margin="8,0,0,0"
                                      Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"
                                      Width="11" Height="11" Opacity="0.75" VerticalAlignment="Center"/>
                        </Grid>
                        <Button.Flyout>
                            <Flyout Placement="TopEdgeAlignedLeft">
                                <StackPanel x:DataType="vm:LyricShareViewModel" Width="250" Spacing="14">
                                    <!-- Layout -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Text="Layout" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                            <Button Classes="share-pill" Classes.active="{Binding IsPanelLayout}"
                                                    Content="Card" Command="{Binding SelectPanelLayoutCommand}"
                                                    ToolTip.Tip="Rounded card with an artwork header panel"/>
                                            <Button Classes="share-pill" Classes.active="{Binding IsPosterLayout}"
                                                    Content="Poster" Command="{Binding SelectPosterLayoutCommand}"
                                                    ToolTip.Tip="Big centered artwork with centered lyrics"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Format -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Text="Format" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                            <Button Classes="share-pill" Classes.active="{Binding IsSquare}"
                                                    Content="1:1" Command="{Binding SelectSquareCommand}"/>
                                            <Button Classes="share-pill" Classes.active="{Binding IsStory}"
                                                    Content="9:16" Command="{Binding SelectStoryCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Text colour -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Text="Text" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                            <Button Classes="share-pill" Classes.active="{Binding IsAutoText}"
                                                    Content="Auto" Command="{Binding UseAutoTextCommand}"/>
                                            <Button Classes="share-pill" Classes.active="{Binding IsWhiteText}"
                                                    Content="White" Command="{Binding UseWhiteTextCommand}"/>
                                            <Button Classes="share-pill" Classes.active="{Binding IsBlackText}"
                                                    Content="Black" Command="{Binding UseBlackTextCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Sync (only when synced lyrics are available) -->
                                    <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding SyncAvailable}">
                                        <TextBlock Text="Sync to playback" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Classes="share-pill" Classes.active="{Binding SyncEnabled}"
                                                HorizontalAlignment="Right"
                                                Content="Sync" Command="{Binding ToggleSyncCommand}"/>
                                    </Grid>
                                    <!-- Karaoke word sweep on Save Video (only when ELRC word timings exist) -->
                                    <Grid ColumnDefinitions="Auto,*" IsVisible="{Binding KaraokeAvailable}">
                                        <TextBlock Text="Karaoke video" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Classes="share-pill" Classes.active="{Binding KaraokeEnabled}"
                                                HorizontalAlignment="Right"
                                                Content="Karaoke" Command="{Binding ToggleKaraokeCommand}"
                                                ToolTip.Tip="Save Video renders moving word-by-word lyrics"/>
                                    </Grid>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <!-- Background: Artwork/Solid mode + the solid color swatches, in one dropdown -->
                    <Button Grid.Column="1" Classes="share-pill" VerticalAlignment="Center"
                            Margin="8,0,0,0" Width="150" HorizontalContentAlignment="Stretch"
                            ToolTip.Tip="Card background: blurred artwork or a solid color">
                        <!-- Same hard-fixed width contract as the Card options pill, so the
                             anchored flyout never shifts when the summary changes. -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="{Binding BackgroundSummary}"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                            <PathIcon Grid.Column="1" Margin="8,0,0,0"
                                      Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"
                                      Width="11" Height="11" Opacity="0.75" VerticalAlignment="Center"/>
                        </Grid>
                        <Button.Flyout>
                            <Flyout Placement="TopEdgeAlignedLeft">
                                <StackPanel x:DataType="vm:LyricShareViewModel" Width="250" Spacing="14">
                                    <!-- Mode -->
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Text="Background" FontSize="12" Opacity="0.7" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                            <Button Classes="share-pill" Classes.active="{Binding IsArtworkBg}"
                                                    Content="Artwork" Command="{Binding UseArtworkBgCommand}"/>
                                            <Button Classes="share-pill" Classes.active="{Binding IsSolidBg}"
                                                    Content="Solid" Command="{Binding UseSolidBgCommand}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Solid colors: Auto (artwork-derived) first, then curated.
                                         Picking any chip switches to Solid mode automatically. -->
                                    <ItemsControl ItemsSource="{Binding SolidSwatches}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ShareSolidSwatch">
                                                <Button Classes="color-swatch"
                                                        Padding="0" Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand"
                                                        Command="{Binding $parent[ItemsControl].((vm:LyricShareViewModel)DataContext).SetSolidColorCommand}"
                                                        CommandParameter="{Binding Hex}"
                                                        ToolTip.Tip="{Binding Name}">
                                                    <!-- 26px wrapper leaves slack around the 22px chip so the
                                                         app-wide Button hover zoom (scale 1.045) never pushes the
                                                         circle past the presenter bounds — that clip flattened
                                                         the chip's sides. -->
                                                    <Panel Width="26" Height="26" Margin="1">
                                                        <Border Width="22" Height="22" CornerRadius="11"
                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                Background="{Binding Preview}"
                                                                BorderBrush="#55FFFFFF" BorderThickness="1">
                                                            <!-- Nested in the circle so it centers on the chip itself;
                                                                 the 1px translate drops the cap-only glyph (no descender)
                                                                 onto the optical middle instead of sitting high. -->
                                                            <TextBlock Text="A" FontSize="11" FontWeight="Bold" Foreground="White"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                       IsVisible="{Binding IsAuto}">
                                                                <TextBlock.RenderTransform>
                                                                    <TranslateTransform Y="1"/>
                                                                </TextBlock.RenderTransform>
                                                            </TextBlock>
                                                        </Border>
                                                    </Panel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Classes="loading-spinner"
                                 IsVisible="{Binding IsRendering}"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center"
                                   MaxWidth="200"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Classes="share-pill"
                            Margin="0,0,8,0"
                            Click="OnSaveVideoClick"
                            IsEnabled="{Binding CanExportVideo}"
                            Content="Save Video"
                            ToolTip.Tip="Save an MP4 clip — this lyric card with the song audio"/>
                    <Button Grid.Column="4"
                            Classes="share-pill accent"
                            Click="OnSaveClick"
                            Content="Save Card"
                            IsEnabled="{Binding Preview, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
