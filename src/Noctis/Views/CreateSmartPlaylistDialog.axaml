<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:m="using:Noctis.Models"
        xmlns:svc="using:Noctis.Services"
        x:Class="Noctis.Views.CreateSmartPlaylistDialog"
        x:DataType="vm:CreateSmartPlaylistDialogViewModel"
        Title="Create Smart Playlist"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#E74856" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#E74856" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#E74856" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="#E74856" />
        </Style>
    </Window.Styles>

    <!-- Full-window dimmed overlay that captures all input -->
    <Border Background="#50000000"
            PointerPressed="OnOverlayPointerPressed"
            PointerWheelChanged="OnOverlayWheel">

    <!-- Centered dialog card -->
    <Border CornerRadius="24"
            ClipToBounds="True"
            Background="{DynamicResource AppMainBackground}"
            Width="620"
            MaxHeight="560"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BoxShadow="0 8 32 0 #60000000">
    <DockPanel Margin="0">

        <!-- Bottom bar: preview count + Create/Cancel -->
        <Border DockPanel.Dock="Bottom"
                Padding="24,12,24,16">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="13" Opacity="0.6">
                    <TextBlock.Text>
                        <Binding Path="MatchingTrackCount" StringFormat="Matches {0} tracks" />
                    </TextBlock.Text>
                </TextBlock>
                <Button Grid.Column="2"
                        Content="Create"
                        Command="{Binding CreateCommand}"
                        Width="100"
                        Padding="0,8"
                        Classes="accent-btn"
                            Background="#E04060"
                        Foreground="White"
                        FontWeight="SemiBold"
                        HorizontalContentAlignment="Center"
                        CornerRadius="999"
                        Margin="0,0,8,0"
                        Cursor="Hand" />
                <Button Grid.Column="3"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="100"
                        Padding="0,8"
                        HorizontalContentAlignment="Center"
                        CornerRadius="999"
                        Cursor="Hand" />
            </Grid>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,16" Spacing="14">

                <!-- Title -->
                <TextBlock Text="Create Smart Playlist"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />

                <!-- Playlist Name -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Playlist Name" FontSize="13" FontWeight="SemiBold" />
                    <TextBox Text="{Binding PlaylistName}"
                             Watermark="Enter playlist name..."
                             CornerRadius="999"
                             Padding="14,8"
                             x:Name="NameTextBox" />
                    <TextBlock Text="Name is required"
                               FontSize="11"
                               Foreground="#E04060"
                               IsVisible="{Binding ShowNameRequiredError}" />
                </StackPanel>

                <!-- Description -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Description" FontSize="13" FontWeight="SemiBold" />
                    <TextBox Text="{Binding PlaylistDescription}"
                             Watermark="Enter description..."
                             CornerRadius="999"
                             Padding="14,8" />
                </StackPanel>

                <!-- Match mode -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Match" VerticalAlignment="Center" FontSize="13" />
                    <ToggleSwitch IsChecked="{Binding MatchAll}"
                                  OnContent="ALL rules"
                                  OffContent="ANY rule" />
                </StackPanel>

                <!-- Rules header -->
                <TextBlock Text="Rules" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0" />

                <!-- Rules list -->
                <ItemsControl ItemsSource="{Binding Rules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SmartPlaylistRuleViewModel">
                            <Border Background="#15FFFFFF" CornerRadius="8" Padding="12" Margin="0,4">
                                <Grid ColumnDefinitions="*,*,*,Auto">
                                    <!-- Field dropdown -->
                                    <ComboBox Grid.Column="0"
                                              ItemsSource="{Binding $parent[Window].((vm:CreateSmartPlaylistDialogViewModel)DataContext).AllFields}"
                                              SelectedItem="{Binding SelectedField}"
                                              Margin="0,0,8,0"
                                              CornerRadius="999"
                                              Padding="14,0"
                                              VerticalAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              HorizontalAlignment="Stretch" />

                                    <!-- Operator dropdown -->
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableOperators}"
                                              SelectedItem="{Binding SelectedOperator}"
                                              Margin="0,0,8,0"
                                              CornerRadius="999"
                                              Padding="14,0"
                                              VerticalAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              HorizontalAlignment="Stretch" />

                                    <!-- Value input(s) -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                        <TextBox Text="{Binding Value}"
                                                 IsVisible="{Binding ShowValueInput}"
                                                 Watermark="Value..."
                                                 MinWidth="100"
                                                 CornerRadius="999"
                                                 Padding="12,6"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 HorizontalAlignment="Stretch" />
                                        <TextBox Text="{Binding Value2}"
                                                 IsVisible="{Binding ShowValue2Input}"
                                                 Watermark="To..."
                                                 Width="80"
                                                 CornerRadius="999"
                                                 Padding="12,6"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center" />
                                    </StackPanel>

                                    <!-- Remove button -->
                                    <Button Grid.Column="3"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="999"
                                            Padding="8,4"
                                            Margin="4,0,0,0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Command="{Binding $parent[Window].((vm:CreateSmartPlaylistDialogViewModel)DataContext).RemoveRuleCommand}"
                                            CommandParameter="{Binding}">
                                        <PathIcon Data="{StaticResource DismissIcon}" Width="14" Height="14" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Rule button -->
                <Button Command="{Binding AddRuleCommand}"
                        Classes="accent-btn"
                            Background="#E04060"
                        Foreground="White"
                        BorderThickness="0"
                        HorizontalAlignment="Left"
                        Padding="16,7"
                        CornerRadius="999"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <PathIcon Data="{StaticResource AddIcon}" Width="12" Height="12" VerticalAlignment="Center" />
                        <TextBlock Text="Add Rule" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Limit section -->
                <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                    <CheckBox Classes="metadata-pill-checkbox" IsChecked="{Binding HasLimit}" Content="Limit to" VerticalAlignment="Center" Padding="4,0,0,0" />
                    <NumericUpDown Value="{Binding LimitCount}"
                                   Minimum="1" Maximum="1000"
                                   IsEnabled="{Binding HasLimit}"
                                   Width="90"
                                   Height="36"
                                   Classes="limit-pill-number"
                                   CornerRadius="999"
                                   ShowButtonSpinner="False"
                                   FormatString="0"
                                   Padding="0"
                                   TextAlignment="Center"
                                   HorizontalContentAlignment="Center"
                                   VerticalAlignment="Center"
                                   VerticalContentAlignment="Center" />
                    <TextBlock Text="tracks, sorted by" VerticalAlignment="Center" FontSize="13" />
                    <ComboBox ItemsSource="{Binding AllSortOptions}"
                              SelectedItem="{Binding SortBy}"
                              IsEnabled="{Binding HasLimit}"
                              Width="160"
                              CornerRadius="999"
                              Padding="14,0"
                              VerticalAlignment="Center"
                              VerticalContentAlignment="Center" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
    </Border>
    </Border>
</Window>
