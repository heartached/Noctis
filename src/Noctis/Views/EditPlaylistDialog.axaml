<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:conv="using:Noctis.Converters"
        xmlns:ctrl="using:Noctis.Controls"
        x:Class="Noctis.Views.EditPlaylistDialog"
        x:DataType="vm:EditPlaylistDialogViewModel"
        Title="Edit Playlist"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorConverter" />
        <conv:ArtworkPathConverter x:Key="ArtworkConverter" />
    </Window.Resources>

    <Window.Styles>
        <!-- Folder field: rounded pill AutoCompleteBox matching the other inputs -->
        <Style Selector="AutoCompleteBox.folder-input">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style Selector="AutoCompleteBox.folder-input /template/ TextBox#PART_TextBox">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,8" />
        </Style>
        <Style Selector="AutoCompleteBox.folder-input /template/ TextBox#PART_TextBox /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="White" />
        </Style>
        <Style Selector="AutoCompleteBox.folder-input:pointerover /template/ TextBox#PART_TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="White" />
        </Style>
        <Style Selector="AutoCompleteBox.folder-input:focus-within /template/ TextBox#PART_TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
        </Style>
        <!-- Suggestion dropdown: give it an opaque background so dialog content
             behind the transparent window doesn't bleed through the popup. -->
        <Style Selector="AutoCompleteBox.folder-input /template/ Border">
            <Setter Property="Background" Value="{DynamicResource AppMainBackground}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="AutoCompleteBox.folder-input /template/ ListBox#PART_SelectingItemsControl">
            <Setter Property="Background" Value="{DynamicResource AppMainBackground}" />
        </Style>
    </Window.Styles>

<!-- Full-window dimmed overlay that captures all input.
     Fade/scale open-close animation: same pattern as the Create Playlist dialog. -->
    <Border x:Name="DialogOverlay"
            Background="#50000000"
            Opacity="0"
            PointerPressed="OnOverlayPointerPressed"
            PointerWheelChanged="OnOverlayWheel">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                    <DoubleTransition.Easing>
                        <CubicEaseOut/>
                    </DoubleTransition.Easing>
                </DoubleTransition>
            </Transitions>
        </Border.Transitions>

    <!-- Centered dialog card: art rail on the left, fields on the right -->
    <Border x:Name="DialogCard"
            CornerRadius="24"
            ClipToBounds="True"
            Background="{DynamicResource AppMainBackground}"
            Width="600"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            RenderTransformOrigin="50%,50%"
            RenderTransform="scale(0.96)"
            BoxShadow="0 8 32 0 #80000000, 0 0 0 1 #33FFFFFF">
        <Border.Transitions>
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18">
                    <TransformOperationsTransition.Easing>
                        <CubicEaseOut/>
                    </TransformOperationsTransition.Easing>
                </TransformOperationsTransition>
            </Transitions>
        </Border.Transitions>
        <DockPanel>

            <!-- Header -->
            <TextBlock DockPanel.Dock="Top"
                       Text="Edit Playlist"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="24,20,24,0" />

            <!-- Bottom: Cancel / Save buttons -->
            <Border DockPanel.Dock="Bottom"
                    Padding="24,12,24,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Button Grid.Column="1"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Width="100"
                            Padding="0,8"
                            FontWeight="Bold"
                            HorizontalContentAlignment="Center"
                            CornerRadius="999"
                            Margin="0,0,8,0"
                            Cursor="Hand" />
                    <Button Grid.Column="2"
                            Content="Save"
                            Command="{Binding SaveCommand}"
                            Width="100"
                            Padding="0,8"
                            Classes="accent-btn"
                            Background="{DynamicResource AccentColorBrush}"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            FontWeight="Bold"
                            HorizontalContentAlignment="Center"
                            CornerRadius="999"
                            Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Content: cover rail | fields -->
            <Grid ColumnDefinitions="170,24,*" Margin="24,18,24,10">

                <!-- Left rail: cover art + art actions -->
                <StackPanel Grid.Column="0" Spacing="10">
                    <Border Width="170" Height="170"
                            CornerRadius="12"
                            ClipToBounds="True"
                            BoxShadow="0 6 18 0 #40000000"
                            Background="{Binding PlaylistColor, Converter={StaticResource HexColorConverter}}">
                        <Panel>
                            <!-- Fallback icon -->
                            <TextBlock Text="&#x266B;"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       Opacity="0.25"
                                       IsVisible="{Binding ShowFallbackIcon}" />

                            <!-- Single album art -->
                            <ctrl:CachedImage SourcePath="{Binding Art1}"
                                              Stretch="UniformToFill"
                                              IsVisible="{Binding HasSingleArt}" />

                            <!-- 2x2 collage -->
                            <Grid RowDefinitions="*,*"
                                  ColumnDefinitions="*,*"
                                  IsVisible="{Binding HasCollageArt}">
                                <ctrl:CachedImage Grid.Row="0" Grid.Column="0" SourcePath="{Binding Art1}" Stretch="UniformToFill" />
                                <ctrl:CachedImage Grid.Row="0" Grid.Column="1" SourcePath="{Binding Art2}" Stretch="UniformToFill" />
                                <ctrl:CachedImage Grid.Row="1" Grid.Column="0" SourcePath="{Binding Art3}" Stretch="UniformToFill" />
                                <ctrl:CachedImage Grid.Row="1" Grid.Column="1" SourcePath="{Binding Art4}" Stretch="UniformToFill" />
                            </Grid>

                            <!-- Custom cover art (highest priority) -->
                            <Image Source="{Binding CoverArtPath, Converter={StaticResource ArtworkConverter}}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                   IsVisible="{Binding HasCustomArt}" />
                        </Panel>
                    </Border>
                    <Button Content="Set Cover Art"
                            Command="{Binding SetCoverArtCommand}"
                            CommandParameter="{Binding $parent[Window]}"
                            Padding="0,6"
                            FontSize="11.5"
                            FontWeight="SemiBold"
                            CornerRadius="999"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Classes="accent-btn"
                            Background="{DynamicResource AccentColorBrush}"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            Cursor="Hand" />
                    <Button Content="Remove Cover Art"
                            Command="{Binding RemoveCoverArtCommand}"
                            Padding="0,6"
                            FontSize="11.5"
                            FontWeight="SemiBold"
                            CornerRadius="999"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            BorderThickness="0"
                            Cursor="Hand"
                            IsVisible="{Binding CoverArtPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- Right rail: fields -->
                <StackPanel Grid.Column="2" Spacing="14">

                    <!-- Playlist Name -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Name" FontSize="13" FontWeight="SemiBold" />
                        <TextBox Text="{Binding PlaylistName}"
                                 Classes="crisp-input"
                                 Watermark="Enter playlist name..."
                                 CornerRadius="999"
                                 x:Name="NameTextBox" />
                        <TextBlock Text="Name is required"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentColorBrush}"
                                   IsVisible="{Binding ShowNameRequiredError}" />
                    </StackPanel>

                    <!-- Playlist Description -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Description" FontSize="13" FontWeight="SemiBold" />
                        <TextBox Text="{Binding PlaylistDescription}"
                                 Classes="crisp-input"
                                 Watermark="Enter playlist description..."
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="88" />
                    </StackPanel>

                    <!-- Sidebar folder -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Sidebar Folder" FontSize="13" FontWeight="SemiBold" />
                        <AutoCompleteBox Text="{Binding PlaylistFolder, Mode=TwoWay}"
                                         ItemsSource="{Binding ExistingFolders}"
                                         Classes="folder-input"
                                         Watermark="No folder"
                                         FilterMode="ContainsOrdinal"
                                         MinimumPrefixLength="0" />
                        <TextBlock Text="Pick an existing folder or type a new name to group playlists in the sidebar."
                                   FontSize="10" Opacity="0.5"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Star -->
                    <CheckBox Classes="metadata-pill-checkbox"
                              Content="Star — keep at the top of the sidebar"
                              IsChecked="{Binding IsPinned}"
                              HorizontalAlignment="Left" />
                </StackPanel>
            </Grid>
        </DockPanel>
    </Border>
    </Border>
</Window>
