<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:conv="using:Noctis.Converters"
        xmlns:ctrl="using:Noctis.Controls"
        x:Class="Noctis.Views.EditPlaylistDialog"
        x:DataType="vm:EditPlaylistDialogViewModel"
        Title="Edit Playlist"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorConverter" />
        <conv:ArtworkPathConverter x:Key="ArtworkConverter" />
    </Window.Resources>

<!-- Full-window dimmed overlay that captures all input -->
    <Border Background="#50000000"
            PointerPressed="OnOverlayPointerPressed"
            PointerWheelChanged="OnOverlayWheel">

    <!-- Centered dialog card -->
    <Border CornerRadius="24"
            ClipToBounds="True"
            Background="{DynamicResource AppMainBackground}"
            Width="450"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            BoxShadow="0 8 32 0 #60000000">
        <DockPanel>

            <!-- Bottom: Done / Cancel buttons -->
            <Border DockPanel.Dock="Bottom"
                    Padding="24,12,24,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Button Grid.Column="1"
                            Content="Done"
                            Command="{Binding SaveCommand}"
                            Width="100"
                            Padding="0,8"
                            Classes="accent-btn"
                            Background="#E74856"
                            Foreground="White"
                            FontWeight="SemiBold"
                            HorizontalContentAlignment="Center"
                            CornerRadius="999"
                            Margin="0,0,8,0"
                            Cursor="Hand" />
                    <Button Grid.Column="2"
                            Content="Cancel"
                            Command="{Binding CancelCommand}"
                            Width="100"
                            Padding="0,8"
                            HorizontalContentAlignment="Center"
                            CornerRadius="999"
                            Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Margin="24,20,24,16" Spacing="14">

                <!-- Title -->
                <TextBlock Text="Edit Playlist"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center" />

                <!-- Cover art (centered) -->
                <Border Width="160" Height="160"
                        CornerRadius="10"
                        ClipToBounds="True"
                        BoxShadow="0 4 12 0 #40000000"
                        HorizontalAlignment="Center"
                        Background="{Binding PlaylistColor, Converter={StaticResource HexColorConverter}}">
                    <Panel>
                        <!-- Fallback icon -->
                        <TextBlock Text="&#x266B;"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   Opacity="0.25"
                                   IsVisible="{Binding ShowFallbackIcon}" />

                        <!-- Single album art -->
                        <ctrl:CachedImage SourcePath="{Binding Art1}"
                                          Stretch="UniformToFill"
                                          IsVisible="{Binding HasSingleArt}" />

                        <!-- 2x2 collage -->
                        <Grid RowDefinitions="*,*"
                              ColumnDefinitions="*,*"
                              IsVisible="{Binding HasCollageArt}">
                            <ctrl:CachedImage Grid.Row="0" Grid.Column="0" SourcePath="{Binding Art1}" Stretch="UniformToFill" />
                            <ctrl:CachedImage Grid.Row="0" Grid.Column="1" SourcePath="{Binding Art2}" Stretch="UniformToFill" />
                            <ctrl:CachedImage Grid.Row="1" Grid.Column="0" SourcePath="{Binding Art3}" Stretch="UniformToFill" />
                            <ctrl:CachedImage Grid.Row="1" Grid.Column="1" SourcePath="{Binding Art4}" Stretch="UniformToFill" />
                        </Grid>

                        <!-- Custom cover art (highest priority) -->
                        <Image Source="{Binding CoverArtPath, Converter={StaticResource ArtworkConverter}}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapInterpolationMode="HighQuality"
                               IsVisible="{Binding HasCustomArt}" />
                    </Panel>
                </Border>

                <!-- Set / Remove cover art buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                    <Button Content="Set Cover Art"
                            Command="{Binding SetCoverArtCommand}"
                            CommandParameter="{Binding $parent[Window]}"
                            Padding="10,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            CornerRadius="999"
                            Classes="accent-btn"
                            Background="#E74856"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand" />
                    <Button Content="Remove Cover Art"
                            Command="{Binding RemoveCoverArtCommand}"
                            Padding="10,4"
                            FontSize="11"
                            FontWeight="SemiBold"
                            CornerRadius="999"
                            BorderThickness="0"
                            Cursor="Hand"
                            IsVisible="{Binding CoverArtPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                </StackPanel>

                <!-- Playlist Name -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Playlist Name" FontSize="13" FontWeight="SemiBold" />
                    <TextBox Text="{Binding PlaylistName}"
                             Classes="crisp-input"
                             Watermark="Enter playlist name..."
                             CornerRadius="999"
                             x:Name="NameTextBox" />
                    <TextBlock Text="Name is required"
                               FontSize="11"
                               Foreground="#E74856"
                               IsVisible="{Binding ShowNameRequiredError}" />
                </StackPanel>

                <!-- Playlist Description -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Description" FontSize="13" FontWeight="SemiBold" />
                    <TextBox Text="{Binding PlaylistDescription}"
                             Classes="crisp-input"
                             Watermark="Enter playlist description..."
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="70" />
                </StackPanel>
            </StackPanel>
        </DockPanel>
    </Border>
    </Border>
</Window>
