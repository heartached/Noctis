                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next27Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1288" Canvas.Top="119" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next28Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next28Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next28Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1288" Canvas.Top="225" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next29Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next29Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next29Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1288" Canvas.Top="331" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next30Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next30Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next30Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1288" Canvas.Top="437" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next31Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next31Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next31Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                </Canvas>
            </Viewbox>

            <!-- Carousel + now-playing text (queue-driven; hidden in collage mode).
                 Stretches full-width so the nav arrows can pin to the screen edges;
                 the covers and text inside are individually centered. -->
            <StackPanel HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Spacing="0"
                        IsVisible="{Binding ShowCarousel}">

                <!-- Carousel area -->
                <Grid HorizontalAlignment="Stretch"
                      Height="460"
                      Margin="0,0"
                      IsVisible="{Binding !IsCollageMode}">

                    <!-- 15-item carousel: center + 7 each side -->
                    <!-- Solid artwork + subtle dark overlay for depth (no transparency/see-through) -->
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                          ClipToBounds="False">

                        <!-- ═══ PREVIOUS SIDE (history) ═══ -->

                        <!-- Position -7 (farthest left) -->
                        <Border Width="320" Height="320"
                                CornerRadius="6"
                                ClipToBounds="True"
                                IsVisible="{Binding Prev7ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="1"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.42" ScaleY="0.42" />
                                    <TranslateTransform X="-960" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding Prev7ArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.55" />
                            </Panel>
                        </Border>

                        <!-- Position -6 -->
                        <Border Width="320" Height="320"
                                CornerRadius="6"
                                ClipToBounds="True"
                                IsVisible="{Binding Prev6ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="2"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.46" ScaleY="0.46" />
                                    <TranslateTransform X="-840" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding Prev6ArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.48" />
                            </Panel>
                        </Border>

                        <!-- Position -5 -->
                        <Border Width="320" Height="320"
                                CornerRadius="6"
                                ClipToBounds="True"
                                IsVisible="{Binding Prev5ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="3"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.50" ScaleY="0.50" />
                                    <TranslateTransform X="-730" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding Prev5ArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.40" />
                            </Panel>
                        </Border>

                        <!-- Position -4 -->
                        <Border Width="320" Height="320"
                                CornerRadius="8"
                                ClipToBounds="True"
                                IsVisible="{Binding OffPreviousArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="4"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.55" ScaleY="0.55" />
                                    <TranslateTransform X="-625" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding OffPreviousArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.32" />
                            </Panel>
                        </Border>

                        <!-- Position -3 -->
                        <Border Width="320" Height="320"
                                CornerRadius="8"
                                ClipToBounds="True"
                                IsVisible="{Binding EdgePreviousArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="5"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.60" ScaleY="0.60" />
                                    <TranslateTransform X="-525" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding EdgePreviousArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.24" />
                            </Panel>
                        </Border>

                        <!-- Position -2 -->
                        <Border Width="320" Height="320"
                                CornerRadius="10"
                                ClipToBounds="True"
                                IsVisible="{Binding FarPreviousArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="6"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.68" ScaleY="0.68" />
                                    <TranslateTransform X="-400" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding FarPreviousArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.16" />
                            </Panel>
                        </Border>

                        <!-- Position -1 -->
                        <Border Width="320" Height="320"
                                CornerRadius="10"
                                ClipToBounds="True"
                                IsVisible="{Binding PreviousArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="7"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.80" ScaleY="0.80" />
                                    <TranslateTransform X="-280" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding PreviousArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.08" />
                            </Panel>
                        </Border>

                        <!-- ═══ CENTER COVER ═══ -->
                        <Border x:Name="CenterCover"
                                Width="440" Height="440"
                                CornerRadius="12"
                                ClipToBounds="True"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="15">
                            <Panel>
                                <!-- Placeholder when no artwork -->
                                <TextBlock Text="&#x266A;"
                                           FontSize="100"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Opacity="0.15"
                                           IsVisible="{Binding CenterArtworkPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                <ctrl:CachedImage SourcePath="{Binding CenterArtworkPath}"
                                                  Stretch="UniformToFill"
                                                  RenderOptions.BitmapInterpolationMode="HighQuality"
                                                  IsVisible="{Binding CenterArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                <ctrl:AnimatedCoverImage
                                    Source="{Binding Player.CurrentAnimatedCoverPath}"
                                    IsActive="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.EnableAnimatedCovers, FallbackValue=False}" />
                                <!-- Favorite heart overlay on the center album cover -->
                                <PathIcon Data="{StaticResource HeartFillIcon}"
                                          Width="24" Height="24"
                                          Foreground="#E74856"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Bottom"
                                          Margin="0,0,12,12"
                                          IsVisible="{Binding CenterIsFavorite}" />
                            </Panel>
                        </Border>

                        <!-- ═══ NEXT SIDE (UpNext queue) ═══ -->

                        <!-- Position +1 -->
                        <Border Width="320" Height="320"
                                CornerRadius="10"
                                ClipToBounds="True"
                                IsVisible="{Binding NextArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="7"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.80" ScaleY="0.80" />
                                    <TranslateTransform X="280" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding NextArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.08" />
                            </Panel>
                        </Border>

                        <!-- Position +2 -->
                        <Border Width="320" Height="320"
                                CornerRadius="10"
                                ClipToBounds="True"
                                IsVisible="{Binding FarNextArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="6"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.68" ScaleY="0.68" />
                                    <TranslateTransform X="400" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding FarNextArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.16" />
                            </Panel>
                        </Border>

                        <!-- Position +3 -->
                        <Border Width="320" Height="320"
                                CornerRadius="8"
                                ClipToBounds="True"
                                IsVisible="{Binding EdgeNextArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="5"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.60" ScaleY="0.60" />
                                    <TranslateTransform X="525" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding EdgeNextArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.24" />
                            </Panel>
                        </Border>

                        <!-- Position +4 -->
                        <Border Width="320" Height="320"
                                CornerRadius="8"
                                ClipToBounds="True"
                                IsVisible="{Binding OffNextArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="4"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.55" ScaleY="0.55" />
                                    <TranslateTransform X="625" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding OffNextArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.32" />
                            </Panel>
                        </Border>

                        <!-- Position +5 -->
                        <Border Width="320" Height="320"
                                CornerRadius="6"
                                ClipToBounds="True"
                                IsVisible="{Binding Next5ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="3"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.50" ScaleY="0.50" />
                                    <TranslateTransform X="730" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding Next5ArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.40" />
                            </Panel>
                        </Border>

                        <!-- Position +6 -->
                        <Border Width="320" Height="320"
                                CornerRadius="6"
                                ClipToBounds="True"
                                IsVisible="{Binding Next6ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="2"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.46" ScaleY="0.46" />
                                    <TranslateTransform X="840" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding Next6ArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.48" />
                            </Panel>
                        </Border>

                        <!-- Position +7 (farthest right) -->
                        <Border Width="320" Height="320"
                                CornerRadius="6"
                                ClipToBounds="True"
                                IsVisible="{Binding Next7ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                ZIndex="1"
                                RenderTransformOrigin="50%,50%">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.42" ScaleY="0.42" />
                                    <TranslateTransform X="960" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Panel>
                                <ctrl:CachedImage SourcePath="{Binding Next7ArtworkPath}" Stretch="UniformToFill" />
                                <Border Background="#000" Opacity="0.55" />
                            </Panel>
                        </Border>

                    </Grid>

                    <!-- Navigation arrows — pinned to the carousel's left/right edges and
                         vertically centered on the covers (siblings of the cover grid). -->
                    <Button Classes="link-btn"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="16,0,0,0"
                            ZIndex="100"
                            Command="{Binding GoPreviousCommand}"
                            IsVisible="{Binding PreviousTrack, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Opacity="0.85">
                        <Border Width="32" Height="32"
                                Background="White"
                                RenderOptions.BitmapInterpolationMode="HighQuality"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.OpacityMask>
                                <ImageBrush Source="avares://Noctis/Assets/Icons/Left%20arrow%20icon.png" Stretch="Uniform" />
                            </Border.OpacityMask>
                        </Border>
                    </Button>

                    <Button Classes="link-btn"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"
                            ZIndex="100"
                            Command="{Binding GoNextCommand}"
                            IsVisible="{Binding NextTrack, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Opacity="0.85">
                        <Border Width="32" Height="32"
                                Background="White"
                                RenderOptions.BitmapInterpolationMode="HighQuality"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.OpacityMask>
                                <ImageBrush Source="avares://Noctis/Assets/Icons/Right%20arrow%20icon.png" Stretch="Uniform" />
                            </Border.OpacityMask>
                        </Border>
                    </Button>

                </Grid>

                <!-- Track info just below the center cover (carousel only — the collage is covers-only) -->
                <StackPanel HorizontalAlignment="Center"
                            Spacing="4"
                            Margin="0,16,0,0"
                            IsVisible="{Binding !IsCollageMode}">
                    <!-- Title row with explicit badge -->
                    <ctrl:MarqueeTextBlock Text="{Binding CenterTitle}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           MaxDisplayWidth="480"
                                           HorizontalAlignment="Center"
                                           IsCoverFlow="True">
                        <ctrl:MarqueeTextBlock.InlineContent>
                            <Border Classes="explicit-badge compact"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding CenterIsExplicit}"
                                    ToolTip.Tip="Explicit">
                                <TextBlock Text="E"
                                           Classes="explicit-badge-text compact"
                                           FontSize="9"
                                           Opacity="0.9" />
                            </Border>
                        </ctrl:MarqueeTextBlock.InlineContent>
                    </ctrl:MarqueeTextBlock>
                    <Button Classes="link-btn"
                            Command="{Binding GoToArtistCommand}"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding CenterArtist, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <ctrl:MarqueeTextBlock Text="{Binding CenterArtist}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentColorBrush}"
                                               MaxDisplayWidth="400"
                                               IsCoverFlow="True"
                                               IsForArtist="True" />
                    </Button>
                    <Button Classes="link-btn"
                            Command="{Binding GoToAlbumCommand}"
                            HorizontalAlignment="Center"
                            IsVisible="{Binding CenterAlbum.Length}">
                        <ctrl:MarqueeTextBlock Text="{Binding CenterAlbum}"
                                               FontSize="13"
                                               Foreground="{DynamicResource AccentColorBrush}"
                                               MaxDisplayWidth="400"
                                               IsCoverFlow="True"
                                               IsForAlbum="True" />
                    </Button>
                </StackPanel>

            </StackPanel>

            <!-- Empty state when nothing is playing -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        IsVisible="{Binding ShowEmptyState}">
                <TextBlock Text="Nothing playing"
                           FontSize="20"
                           Opacity="0.4"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="Play some music to see the queue flow"
                           FontSize="13"
                           Opacity="0.25"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>

        </Grid>

    </Grid>

</UserControl>
