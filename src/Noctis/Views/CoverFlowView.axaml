                            IsVisible="{Binding Next9Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next9Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856"
