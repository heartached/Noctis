<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:ctrl="using:Noctis.Controls"
             x:Class="Noctis.Views.CoverFlowView"
             x:DataType="vm:CoverFlowViewModel"
             Background="{DynamicResource AppMainBackground}"
             ClipToBounds="True">

    <UserControl.Styles>
        <Style Selector="Button.link-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.link-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <!-- Kill the default Fluent hover/press square behind the arrow glyph -->
        <Style Selector="Button.link-btn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.link-btn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <!-- Override global Button:pointerover zoom — link buttons in cover flow stay still on hover -->
        <Style Selector="Button.link-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="Button.link-btn:pressed">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">

        <!-- Collage background: quiet charcoal with a subtle radial lift (collage mode only) -->
        <Panel Grid.Row="0" IsHitTestVisible="False" IsVisible="{Binding IsCollageMode}">
            <Border>
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="50%,40%" Center="50%,40%" RadiusX="70%" RadiusY="70%">
                        <GradientStop Color="#202225" Offset="0"/>
                        <GradientStop Color="#18191B" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
        </Panel>

        <!-- Blurred background: large artwork behind everything (carousel mode only) -->
        <Panel Grid.Row="0" IsHitTestVisible="False" IsVisible="{Binding !IsCollageMode}">
            <ctrl:CachedImage x:Name="BackgroundArt"
                              SourcePath="{Binding CenterArtworkPath}"
                              Stretch="UniformToFill"
                              Opacity="0.35"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding CenterArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <ctrl:CachedImage.Effect>
                    <BlurEffect Radius="40" />
                </ctrl:CachedImage.Effect>
            </ctrl:CachedImage>
            <!-- Gradient overlay for readability -->
            <Border x:Name="BackgroundOverlay" Background="{DynamicResource AppMainBackground}" Opacity="0.55" />
        </Panel>

        <!-- Main content: carousel + text stacked vertically -->
        <Grid Grid.Row="0" Margin="0,24,0,12">

            <!-- ══ Static album-art collage (decorative; library artwork, fully non-interactive) ══
                 Fixed 1410×540 design canvas, scaled down to fit on smaller windows and centred.
                 A tidy column masonry of up to 32 covers: covers in a column share a width and
                 left edge (so they line up), columns get larger toward the centre and smaller
                 toward the edges. Slots fill from the now-playing track outward through UpNext.
                 IsHitTestVisible=False → no cover is clickable, hoverable or selectable. -->
            <Viewbox Stretch="Uniform"
                     MaxWidth="1900" MaxHeight="760"
                     IsHitTestVisible="False" Margin="24,24,24,140"
                     IsVisible="{Binding IsCollageMode}">
                <Canvas Width="1410" Height="540">

                    <!-- ═══ Centre column (200): now-playing + next ═══ -->
                    <Border Canvas.Left="604" Canvas.Top="62" Width="200" Height="200" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 8 22 0 #5E000000"
                            IsVisible="{Binding CenterTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding CenterTrack.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <!-- Animated cover for the now-playing tile (same control/setting as the carousel) -->
                            <ctrl:AnimatedCoverImage
                                Source="{Binding Player.CurrentAnimatedCoverPath}"
                                IsActive="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.EnableAnimatedCovers, FallbackValue=False}" />
                            <PathIcon Data="{StaticResource HeartFillIcon}" Classes="heart-pop" Width="18" Height="18" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,9,9"
                                      IsVisible="{Binding CenterTrack.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="604" Canvas.Top="278" Width="200" Height="200" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 8 22 0 #5E000000"
                            IsVisible="{Binding NextTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding NextTrack.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="18" Height="18" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,9,9"
                                      IsVisible="{Binding NextTrack.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>

                    <!-- ═══ Inner columns (170) ═══ -->
                    <Border Canvas.Left="418" Canvas.Top="1" Width="170" Height="170" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 8 22 0 #5E000000"
                            IsVisible="{Binding FarNextTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding FarNextTrack.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="16" Height="16" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                      IsVisible="{Binding FarNextTrack.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="418" Canvas.Top="185" Width="170" Height="170" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 8 22 0 #5E000000"
                            IsVisible="{Binding EdgeNextTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding EdgeNextTrack.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="16" Height="16" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                      IsVisible="{Binding EdgeNextTrack.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="418" Canvas.Top="369" Width="170" Height="170" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 8 22 0 #5E000000"
                            IsVisible="{Binding OffNextTrack, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding OffNextTrack.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="16" Height="16" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                      IsVisible="{Binding OffNextTrack.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="820" Canvas.Top="1" Width="170" Height="170" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 8 22 0 #5E000000"
                            IsVisible="{Binding Next5Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next5Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="16" Height="16" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                      IsVisible="{Binding Next5Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="820" Canvas.Top="185" Width="170" Height="170" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 8 22 0 #5E000000"
                            IsVisible="{Binding Next6Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next6Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="16" Height="16" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                      IsVisible="{Binding Next6Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="820" Canvas.Top="369" Width="170" Height="170" CornerRadius="6" ClipToBounds="True"
