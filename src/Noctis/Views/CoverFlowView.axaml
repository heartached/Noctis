                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="16" Height="16" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,8,8"
                                      IsVisible="{Binding Next7Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>

                    <!-- ═══ Mid columns (140) ═══ -->
                    <Border Canvas.Left="262" Canvas.Top="44" Width="140" Height="140" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next8Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next8Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,7,7"
                                      IsVisible="{Binding Next8Track.IsFavorite, FallbackValue=False}"/>
