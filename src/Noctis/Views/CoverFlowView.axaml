                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next25Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="30" Canvas.Top="437" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next26Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next26Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next26Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1288" Canvas.Top="13" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next27Track, Converter={x:Static ObjectConverters.IsNotNull}}">
