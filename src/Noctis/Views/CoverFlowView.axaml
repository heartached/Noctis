                                      IsVisible="{Binding Next20Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1162" Canvas.Top="404" Width="110" Height="110" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next21Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next21Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="12" Height="12" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                      IsVisible="{Binding Next21Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>

                    <!-- ═══ Edge columns (90) ═══ -->
                    <Border Canvas.Left="30" Canvas.Top="13" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next22Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next22Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next22Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="30" Canvas.Top="119" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next23Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next23Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next23Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="30" Canvas.Top="225" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next24Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next24Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="11" Height="11" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,5,5"
                                      IsVisible="{Binding Next24Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="30" Canvas.Top="331" Width="90" Height="90" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 6 18 0 #5A000000"
                            IsVisible="{Binding Next25Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next25Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
