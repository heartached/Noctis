                        </Panel>
                    </Border>
                    <Border Canvas.Left="1006" Canvas.Top="44" Width="140" Height="140" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next11Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next11Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,7,7"
                                      IsVisible="{Binding Next11Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1006" Canvas.Top="200" Width="140" Height="140" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next12Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next12Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,7,7"
                                      IsVisible="{Binding Next12Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1006" Canvas.Top="356" Width="140" Height="140" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next13Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next13Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,7,7"
                                      IsVisible="{Binding Next13Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>

                    <!-- ═══ Outer columns (110) ═══ -->
                    <Border Canvas.Left="136" Canvas.Top="26" Width="110" Height="110" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next14Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next14Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="12" Height="12" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                      IsVisible="{Binding Next14Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="136" Canvas.Top="152" Width="110" Height="110" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next15Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next15Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="12" Height="12" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                      IsVisible="{Binding Next15Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="136" Canvas.Top="278" Width="110" Height="110" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next16Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next16Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="12" Height="12" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                      IsVisible="{Binding Next16Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="136" Canvas.Top="404" Width="110" Height="110" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next17Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next17Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="12" Height="12" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                      IsVisible="{Binding Next17Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1162" Canvas.Top="26" Width="110" Height="110" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next18Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next18Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="12" Height="12" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                      IsVisible="{Binding Next18Track.IsFavorite, FallbackValue=False}"/>
                        </Panel>
                    </Border>
                    <Border Canvas.Left="1162" Canvas.Top="152" Width="110" Height="110" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next19Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next19Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="12" Height="12" Foreground="#E74856"
                                      HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,6,6"
                                      IsVisible="{Binding Next19Track.IsFavorite, FallbackValue=False}"/>
