                    </Border>
                    <Border Canvas.Left="262" Canvas.Top="356" Width="140" Height="140" CornerRadius="6" ClipToBounds="True"
                            BoxShadow="0 7 20 0 #5A000000"
                            IsVisible="{Binding Next10Track, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <Panel>
                            <ctrl:CachedImage SourcePath="{Binding Next10Track.AlbumArtworkPath}" Stretch="UniformToFill"/>
                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856"
