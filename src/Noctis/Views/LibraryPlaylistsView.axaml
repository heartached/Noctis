<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:conv="using:Noctis.Converters"
             x:Class="Noctis.Views.LibraryPlaylistsView"
             x:DataType="vm:LibraryPlaylistsViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorConverter" />
        <conv:ArtworkPathConverter x:Key="ArtworkConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        <Separator Grid.Row="0" Classes="page-top-separator" />
        <DockPanel Grid.Row="1" Margin="16,8,16,16">

        <!-- Content area with overlay for empty state -->
        <Grid>
            <!-- Playlist grid (responsive wrap panel) -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredPlaylists}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="m:Playlist">
                            <Button Classes="album-tile"
                                    Width="270"
                                    Margin="8"
                                    Command="{Binding $parent[ItemsControl].((vm:LibraryPlaylistsViewModel)DataContext).OpenPlaylistCommand}"
                                    CommandParameter="{Binding}">

                                <!-- Context menu for playlist tiles -->
                                <Button.ContextMenu>
                                    <ContextMenu DataContext="{Binding}">
                                        <MenuItem Header="{Binding Name, StringFormat='Play &quot;{0}&quot;'}"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryPlaylistsViewModel)DataContext).PlayPlaylistCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Shuffle"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryPlaylistsViewModel)DataContext).ShufflePlaylistCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Shuffle%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Play Next"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryPlaylistsViewModel)DataContext).PlayNextPlaylistCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Forward%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Add to Queue"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryPlaylistsViewModel)DataContext).AddPlaylistToQueueCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="View Playlist"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryPlaylistsViewModel)DataContext).OpenPlaylistCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Playlists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Edit Playlist"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryPlaylistsViewModel)DataContext).EditPlaylistCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Edit%20Playlist%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator />
                                        <MenuItem Header="Delete Playlist"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryPlaylistsViewModel)DataContext).DeletePlaylistCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>

                                <StackPanel Spacing="0">
                                    <!-- Playlist artwork with color -->
                                    <Border Width="250" Height="250"
                                            CornerRadius="8"
                                            ClipToBounds="True"
                                            Background="{Binding Color, Converter={StaticResource HexColorConverter}}">
                                        <Panel>
                                            <!-- Manual playlist icon -->
                                            <TextBlock Text="♪"
                                                       FontSize="48"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"
                                                       Opacity="0.3"
                                                       IsVisible="{Binding !IsSmartPlaylist}" />
                                            <!-- Smart playlist icon -->
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        IsVisible="{Binding IsSmartPlaylist}">
                                                <PathIcon Data="{StaticResource AudioDeviceIcon}"
                                                         Width="40" Height="40"
                                                         HorizontalAlignment="Center"
                                                         Foreground="White"
                                                         Opacity="0.4" />
                                                <TextBlock Text="Smart"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="White"
                                                           Opacity="0.5"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                            <!-- Custom cover art -->
                                            <Image Source="{Binding CoverArtPath, Converter={StaticResource ArtworkConverter}}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                                   IsVisible="{Binding CoverArtPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                        </Panel>
                                    </Border>
                                    <!-- Playlist name -->
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"
                                               Margin="2,6,2,0" />
                                    <!-- Track count (manual playlists) -->
                                    <TextBlock FontSize="12"
                                               Opacity="0.6"
                                               Margin="2,2,2,0"
                                               IsVisible="{Binding !IsSmartPlaylist}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} tracks">
                                                <Binding Path="TrackIds.Count" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <!-- Smart playlist label -->
                                    <TextBlock Text="Smart Playlist"
                                               FontSize="12"
                                               Opacity="0.6"
                                               Margin="2,2,2,0"
                                               IsVisible="{Binding IsSmartPlaylist}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state overlay -->
            <StackPanel IsVisible="{Binding !FilteredPlaylists.Count}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="No playlists yet"
                           FontSize="18"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="Create a new playlist to get started"
                           FontSize="13"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>

        </DockPanel>
    </Grid>

</UserControl>
