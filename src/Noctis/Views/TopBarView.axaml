<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             x:Class="Noctis.Views.TopBarView"
             x:DataType="vm:TopBarViewModel"
             Focusable="True"
             MinHeight="58">

    <Border Padding="12,8"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0">
      <Grid>

        <!-- Back button + optional context title left-aligned (shown in detail views).
             DockPanel so the title fills remaining width and ellipsizes instead of overflowing. -->
        <DockPanel LastChildFill="True"
                   IsVisible="{Binding IsBackButtonVisible}">
            <Button DockPanel.Dock="Left"
                    Command="{Binding BackCommand}"
                    IsVisible="{Binding IsAlbumDetailBackButtonVisible}"
                     Classes="accent-btn"
                     Background="{DynamicResource AccentColorBrush}"
                     Foreground="{DynamicResource AccentForegroundBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="1"
                    Padding="16,7"
                    Margin="0,0,14,0"
                    CornerRadius="999"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Cursor="Hand">
                 <Button.Styles>
                     <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
                         <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
                     </Style>
                 </Button.Styles>
                <TextBlock Text="{Binding AlbumDetailBackButtonDisplayText}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            VerticalAlignment="Center" />
            </Button>

            <Button DockPanel.Dock="Left"
                    Command="{Binding BackCommand}"
                    IsVisible="{Binding IsGenericBackButtonVisible}"
                     Classes="accent-btn"
                     Background="{DynamicResource AccentColorBrush}"
                     Foreground="{DynamicResource AccentForegroundBrush}"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    BorderThickness="1"
                    Padding="16,7"
                    Margin="0,0,14,0"
                    CornerRadius="999"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Cursor="Hand"
                    FontSize="13"
                    FontWeight="SemiBold">
                 <Button.Styles>
                     <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
                         <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
                     </Style>
                 </Button.Styles>
                <TextBlock Text="{Binding BackButtonDisplayText}"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            VerticalAlignment="Center" />
            </Button>
            <TextBlock Text="{Binding BackContextTitle}"
                       IsVisible="{Binding IsBackContextTitleVisible}"
                       FontSize="20"
                       FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
        </DockPanel>

        <!-- Page title + release-type filter chips left-aligned (shown when back button is hidden).
             Chips only appear on the Albums grid (driven by TopBar.HasReleaseTypeChips). -->
        <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsPageTitleVisible}">
            <TextBlock Text="{Binding CurrentTabName}"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="Bold" />

            <ItemsControl ItemsSource="{Binding ReleaseTypeChips}"
                          IsVisible="{Binding HasReleaseTypeChips}"
                          VerticalAlignment="Center">
                <ItemsControl.Styles>
                    <Style Selector="Button.release-chip">
                        <Setter Property="Background" Value="{DynamicResource ChipBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <Setter Property="CornerRadius" Value="999"/>
                        <Setter Property="Padding" Value="14,6"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style Selector="Button.release-chip:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource ChipHoverBackground}"/>
                    </Style>
                    <Style Selector="Button.release-chip.active">
                        <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
                    </Style>
                    <Style Selector="Button.release-chip.active /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
                    </Style>
                </ItemsControl.Styles>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReleaseTypeChip">
                        <Button Classes="release-chip"
                                Classes.active="{Binding IsActive}"
                                Content="{Binding Label}"
                                Command="{Binding $parent[UserControl].((vm:TopBarViewModel)DataContext).ReleaseTypeChipCommand}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

      </Grid>
    </Border>

</UserControl>
