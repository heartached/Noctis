<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             x:Class="Noctis.Views.TopBarView"
             x:DataType="vm:TopBarViewModel"
             Focusable="True"
             MinHeight="58">

    <UserControl.Styles>
        <Style Selector="Button.release-chip">
            <Setter Property="Background" Value="{DynamicResource ChipBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.release-chip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChipHoverBackground}"/>
        </Style>
        <Style Selector="Button.release-chip.active">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.release-chip.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Padding="12,8"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0">
      <Grid>

        <!-- Context title + chips, left-aligned (shown in detail views). The Back action
             itself lives in the sidebar rail; this row only carries the page context.
             DockPanel so the title fills remaining width and ellipsizes instead of overflowing. -->
        <DockPanel LastChildFill="True"
                   IsVisible="{Binding IsBackButtonVisible}">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="{Binding BackContextTitle}"
                           IsVisible="{Binding IsBackContextTitleVisible}"
                           FontSize="20"
                           FontWeight="Bold"
                           MaxWidth="480"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />

                <!-- Release-type filter dropdown on the artist discography page (same
                     control as the Albums grid Type dropdown below) -->
                <Button Classes="release-chip"
                        IsVisible="{Binding HasReleaseTypeChips}"
                        VerticalAlignment="Center"
                        ToolTip.Tip="Filter by release type">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="Type:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ReleaseTypeFilterLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                                  RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedLeft">
                            <MenuItem Header="All"
                                      Command="{Binding ReleaseTypeFilterCommand}"
                                      CommandParameter="all"/>
                            <MenuItem Header="Albums"
                                      Command="{Binding ReleaseTypeFilterCommand}"
                                      CommandParameter="album"/>
                            <MenuItem Header="Singles"
                                      Command="{Binding ReleaseTypeFilterCommand}"
                                      CommandParameter="single"/>
                            <MenuItem Header="EPs"
                                      Command="{Binding ReleaseTypeFilterCommand}"
                                      CommandParameter="ep"/>
                            <MenuItem Header="Other"
                                      Command="{Binding ReleaseTypeFilterCommand}"
                                      CommandParameter="other"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </DockPanel>

        <!-- Page title + release-type filter chips left-aligned (shown when back button is hidden).
             Chips only appear on the Albums grid (driven by TopBar.HasReleaseTypeChips). -->
        <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsPageTitleVisible}">
            <TextBlock Text="{Binding PageTitleDisplay}"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="Bold" />

            <!-- Release-type filter dropdown, albums grid only -->
            <Button Classes="release-chip"
                    IsVisible="{Binding HasReleaseTypeChips}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Filter by release type">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Type:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ReleaseTypeFilterLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                              RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                        <MenuItem Header="All"
                                  Command="{Binding ReleaseTypeFilterCommand}"
                                  CommandParameter="all"/>
                        <MenuItem Header="Albums"
                                  Command="{Binding ReleaseTypeFilterCommand}"
                                  CommandParameter="album"/>
                        <MenuItem Header="Singles"
                                  Command="{Binding ReleaseTypeFilterCommand}"
                                  CommandParameter="single"/>
                        <MenuItem Header="EPs"
                                  Command="{Binding ReleaseTypeFilterCommand}"
                                  CommandParameter="ep"/>
                        <MenuItem Header="Other"
                                  Command="{Binding ReleaseTypeFilterCommand}"
                                  CommandParameter="other"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!-- Quality filter dropdown (Lossless / Hi-Res), albums grid only -->
            <Border Width="1" Height="16" Background="#30808080" VerticalAlignment="Center"
                    IsVisible="{Binding HasReleaseTypeChips}"/>
            <Button Classes="release-chip"
                    IsVisible="{Binding HasReleaseTypeChips}"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Filter by audio quality">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Quality:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding QualityFilterLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                              RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                        <MenuItem Header="All"
                                  Command="{Binding QualityFilterCommand}"
                                  CommandParameter="all"/>
                        <MenuItem Header="Lossless"
                                  Command="{Binding QualityFilterCommand}"
                                  CommandParameter="lossless"/>
                        <MenuItem Header="Hi-Res"
                                  Command="{Binding QualityFilterCommand}"
                                  CommandParameter="hires"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!-- Sort dropdown, albums grid only. Uses release-chip class so it gets the
                 same hover highlight as the filter chips (and opts out of the hover zoom). -->
            <Button Classes="release-chip"
                    IsVisible="{Binding HasReleaseTypeChips}"
                    Background="{DynamicResource ChipBackground}"
                    Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                    CornerRadius="999" Padding="14,6" FontSize="12" FontWeight="SemiBold"
                    BorderThickness="0" Cursor="Hand"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Sort albums">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Sort:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AlbumSortLabel}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <PathIcon Data="{StaticResource ChevronRightIcon}" Width="9" Height="9"
                              RenderTransform="rotate(90deg)" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedLeft">
                        <MenuItem Header="Default"
                                  Command="{Binding AlbumSortCommand}"
                                  CommandParameter="default"/>
                        <MenuItem Header="Date added"
                                  Command="{Binding AlbumSortCommand}"
                                  CommandParameter="dateadded"/>
                        <MenuItem Header="Most played"
                                  Command="{Binding AlbumSortCommand}"
                                  CommandParameter="mostplayed"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>

      </Grid>
    </Border>

</UserControl>
