<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             x:Class="Noctis.Views.TopBarView"
             x:DataType="vm:TopBarViewModel"
             Focusable="True"
             MinHeight="58">

    <UserControl.Styles>
        <Style Selector="Button.release-chip">
            <Setter Property="Background" Value="{DynamicResource ChipBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.release-chip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource ChipHoverBackground}"/>
        </Style>
        <Style Selector="Button.release-chip.active">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.release-chip.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Padding="12,8"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0">
      <Grid>

        <!-- Context title + chips, left-aligned (shown in detail views). The Back action
             itself lives in the sidebar rail; this row only carries the page context.
             DockPanel so the title fills remaining width and ellipsizes instead of overflowing. -->
        <DockPanel LastChildFill="True"
                   IsVisible="{Binding IsBackButtonVisible}">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="{Binding BackContextTitle}"
                           IsVisible="{Binding IsBackContextTitleVisible}"
                           FontSize="20"
                           FontWeight="Bold"
                           MaxWidth="480"
                           TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Center" />
            </StackPanel>
        </DockPanel>

        <!-- Page title + release-type filter chips left-aligned (shown when back button is hidden).
             Chips only appear on the Albums grid (driven by TopBar.HasReleaseTypeChips). -->
        <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    IsVisible="{Binding IsPageTitleVisible}">
            <TextBlock Text="{Binding PageTitleDisplay}"
                       VerticalAlignment="Center"
                       FontSize="22"
                       FontWeight="Bold" />

            <!-- Songs page: "2,144 songs · 138 hours" summary next to the title -->
            <TextBlock Text="{Binding SongsSummaryText}"
                       IsVisible="{Binding SongsFiltersVisible}"
                       FontSize="12"
                       Opacity="0.55"
                       Margin="-4,4,0,0"
                       VerticalAlignment="Center" />

        </StackPanel>

      </Grid>
    </Border>

</UserControl>
