<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             x:Class="Noctis.Views.TopBarView"
             x:DataType="vm:TopBarViewModel"
             Focusable="True"
             MinHeight="58">

    <Border Padding="12,8"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0">
      <Grid>

        <!-- Back button left-aligned (shown in detail views) -->
        <Button Command="{Binding BackCommand}"
                IsVisible="{Binding IsBackButtonVisible}"
                Classes="accent-btn"
                Background="#E04060"
                Foreground="White"
                BorderThickness="0"
                Padding="16,7"
                CornerRadius="999"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Cursor="Hand">
            <Button.Styles>
                <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </Button.Styles>
            <TextBlock Text="{Binding BackButtonText}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </Button>

        <!-- Page title left-aligned (shown when back button is hidden) -->
        <TextBlock Text="{Binding CurrentTabName}"
                   IsVisible="{Binding IsPageTitleVisible}"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="22"
                   FontWeight="Bold" />

        <!-- Right side: page action buttons + search field -->
        <StackPanel HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">

            <!-- Page action buttons (e.g. Songs: Shuffle, Queue, Options) -->
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasPageActions}">

                <!-- Shuffle -->
                <Button Classes="accent-btn" Background="#E04060"
                        BorderThickness="0"
                        Padding="12,10"
                        CornerRadius="999"
                        Cursor="Hand"
                        Command="{Binding PageShuffleCommand}"
                        ToolTip.Tip="Shuffle all songs"
                        VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource ShuffleIcon}" Width="15" Height="15"
                             VerticalAlignment="Center" Foreground="White" />
                </Button>

                <!-- Queue -->
                <Button Classes="accent-btn" Background="#E04060"
                        BorderThickness="0"
                        Padding="12,10"
                        CornerRadius="999"
                        Cursor="Hand"
                        Command="{Binding PageQueueCommand}"
                        Tag="QueueToggle"
                        ToolTip.Tip="View Queue"
                        VerticalAlignment="Center">
                    <Border Width="15" Height="15" Background="White" VerticalAlignment="Center"
                            RenderOptions.BitmapInterpolationMode="HighQuality">
                        <Border.OpacityMask>
                            <ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" />
                        </Border.OpacityMask>
                    </Border>
                </Button>

                <!-- Options -->
                <Button Classes="accent-btn" Background="#E04060"
                        BorderThickness="0"
                        Padding="12,10"
                        CornerRadius="999"
                        Cursor="Hand"
                        ToolTip.Tip="Options"
                        VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource MoreDotsIcon}" Width="15" Height="15"
                             VerticalAlignment="Center" Foreground="White" />
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuItem Header="All Items" Command="{Binding PageSetShowAllItemsCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                             IsVisible="{Binding PageShowAllItems}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Only Favorites" Command="{Binding PageSetShowOnlyFavoritesCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                             IsVisible="{Binding PageShowOnlyFavorites}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Sort By">
                                <MenuItem Header="Album" Command="{Binding PageSortCommand}" CommandParameter="Album" />
                                <MenuItem Header="Artist" Command="{Binding PageSortCommand}" CommandParameter="Artist" />
                                <MenuItem Header="Genre" Command="{Binding PageSortCommand}" CommandParameter="Genre" />
                                <MenuItem Header="Plays" Command="{Binding PageSortCommand}" CommandParameter="Plays" />
                                <MenuItem Header="Time" Command="{Binding PageSortCommand}" CommandParameter="Time" />
                                <MenuItem Header="Title" Command="{Binding PageSortCommand}" CommandParameter="Title" />
                                <Separator />
                                <MenuItem Header="Ascending" Command="{Binding PageSortCommand}" CommandParameter="Ascending">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                 IsVisible="{Binding PageSortAscending}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Descending" Command="{Binding PageSortCommand}" CommandParameter="Descending">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource CheckmarkIcon}" Width="14" Height="14"
                                                 IsVisible="{Binding PageSortDescending}" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

            </StackPanel>

            <!-- Playlist action buttons (e.g. Create Smart Playlist) -->
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasPlaylistActions}">
                <Button Classes="accent-btn" Background="#E04060"
                        BorderThickness="0"
                        Padding="12,10"
                        CornerRadius="999"
                        Cursor="Hand"
                        Command="{Binding PageCreateSmartPlaylistCommand}"
                        ToolTip.Tip="Create Smart Playlist"
                        VerticalAlignment="Center">
                    <PathIcon Data="{StaticResource AudioDeviceIcon}" Width="15" Height="15"
                             VerticalAlignment="Center" Foreground="White" />
                </Button>
            </StackPanel>

            <!-- Artist discography action buttons (Shuffle, Play) -->
            <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding HasArtistActions}">
                <Button Classes="accent-btn" Background="#E04060"
                        BorderThickness="0"
                        Padding="12,10"
                        CornerRadius="999"
                        Cursor="Hand"
                        Command="{Binding PageShuffleArtistCommand}"
                        ToolTip.Tip="Shuffle All"
                        VerticalAlignment="Center">
                    <Border Width="18" Height="18"
                            Background="White"
                            RenderOptions.BitmapInterpolationMode="HighQuality">
                        <Border.OpacityMask>
                            <ImageBrush Source="avares://Noctis/Assets/Icons/Shuffle%20ICON.png" Stretch="Uniform" />
                        </Border.OpacityMask>
                    </Border>
                </Button>
                <Button Classes="accent-btn" Background="#E04060"
                        BorderThickness="0"
                        Padding="12,10"
                        CornerRadius="999"
                        Cursor="Hand"
                        Command="{Binding PagePlayArtistCommand}"
                        ToolTip.Tip="Play All"
                        VerticalAlignment="Center">
                    <Border Width="18" Height="18"
                            Background="White"
                            RenderOptions.BitmapInterpolationMode="HighQuality">
                        <Border.OpacityMask>
                            <ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" />
                        </Border.OpacityMask>
                    </Border>
                </Button>
            </StackPanel>

            <!-- Albums view mode toggle (Library / Up Next) -->
            <Border IsVisible="{Binding HasAlbumsViewModeToggle}"
                    Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="8"
                    Padding="3"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <!-- Library mode button -->
                    <Button x:Name="AlbumsLibraryModeBtn"
                            Command="{Binding AlbumsSetLibraryModeCommand}"
                            BorderThickness="0"
                            Padding="10,6"
                            CornerRadius="6"
                            Cursor="Hand"
                            Background="#30FFFFFF"
                            ToolTip.Tip="Library">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource SearchIcon}" Width="13" Height="13"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="Library" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <!-- Up Next mode button -->
                    <Button x:Name="AlbumsUpNextModeBtn"
                            Command="{Binding AlbumsSetCoverFlowModeCommand}"
                            BorderThickness="0"
                            Padding="10,6"
                            CornerRadius="6"
                            Cursor="Hand"
                            Background="Transparent"
                            Opacity="0.5"
                            ToolTip.Tip="Up Next">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource ViewSortIcon}" Width="13" Height="13"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="Up Next" FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Search field, slim pill -->
            <Border Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                    CornerRadius="999"
                    Padding="10,4,4,4"
                    Height="32"
                    MaxWidth="220"
                    IsVisible="{Binding IsSearchVisible}">
                <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                    <!-- Search icon -->
                    <Viewbox Grid.Column="0" Width="12" Height="12" Margin="0,0,6,0"
                             VerticalAlignment="Center">
                        <Canvas Width="24" Height="24">
                            <Path Fill="{DynamicResource SystemControlForegroundBaseHighBrush}" Opacity="0.45"
                                  Data="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                        </Canvas>
                    </Viewbox>

                    <!-- Text input -->
                    <TextBox Grid.Column="1"
                             x:Name="SearchBox"
                             Classes="search-box"
                             Text="{Binding SearchText, Mode=TwoWay}"
                             Watermark="{Binding CurrentTabName, StringFormat='Find in {0}'}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="12"
                             Padding="0,2"
                             VerticalAlignment="Center"
                             MinWidth="120"/>

                    <!-- Clear button -->
                    <Button Grid.Column="2"
                            Command="{Binding ClearSearchCommand}"
                            IsVisible="{Binding SearchText.Length}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="6,2"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <TextBlock Text="&#x2715;" FontSize="11" Opacity="0.5"/>
                    </Button>
                </Grid>
            </Border>

        </StackPanel>

      </Grid>
    </Border>

</UserControl>
