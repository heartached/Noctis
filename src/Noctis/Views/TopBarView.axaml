<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             x:Class="Noctis.Views.TopBarView"
             x:DataType="vm:TopBarViewModel"
             Focusable="True"
             MinHeight="58">

    <Border Padding="12,8"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0">
      <Grid>

        <!-- Back button left-aligned (shown in detail views) -->
        <Button Command="{Binding BackCommand}"
                IsVisible="{Binding IsBackButtonVisible}"
                Classes="accent-btn"
                Background="#E04060"
                Foreground="White"
                BorderThickness="0"
                Padding="16,7"
                CornerRadius="999"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Cursor="Hand">
            <Button.Styles>
                <Style Selector="Button /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </Button.Styles>
            <TextBlock Text="{Binding BackButtonText}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </Button>

        <!-- Page title left-aligned (shown when back button is hidden) -->
        <TextBlock Text="{Binding CurrentTabName}"
                   IsVisible="{Binding IsPageTitleVisible}"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   FontSize="22"
                   FontWeight="Bold" />

      </Grid>
    </Border>

</UserControl>
