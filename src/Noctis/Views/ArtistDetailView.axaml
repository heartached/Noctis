<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:ctrl="using:Noctis.Controls"
             x:Class="Noctis.Views.ArtistDetailView"
             x:DataType="vm:ArtistDetailViewModel"
             Background="{DynamicResource AppMainBackground}"
             ClipToBounds="True">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto"
                  Padding="0">
        <StackPanel Spacing="32" Margin="0,0,0,40">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- HERO BANNER                                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Height="420" ClipToBounds="True">
                <Panel>
                    <!-- Artist image, fills the banner -->
                    <ctrl:CachedImage SourcePath="{Binding HeroImagePath}"
                                      Stretch="UniformToFill"
                                      IsVisible="{Binding HasHeroImage}"
                                      RenderOptions.BitmapInterpolationMode="HighQuality"/>

                    <!-- Music-note glyph when no artist image is cached -->
                    <Border IsVisible="{Binding !HasHeroImage}" Background="#101010">
                        <TextBlock Text="&#x266A;" FontSize="120"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.08"/>
                    </Border>

                    <!-- Dark gradient from bottom for the name + actions to sit on -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                                <GradientStop Offset="0.0" Color="#00000000"/>
                                <GradientStop Offset="0.55" Color="#33000000"/>
                                <GradientStop Offset="1.0" Color="#D8000000"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Title + action row at the bottom of the banner -->
                    <Grid VerticalAlignment="Bottom" Margin="32,0,32,28" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                <Border Width="32" Height="32" CornerRadius="16"
                                        Background="{DynamicResource AccentColorBrush}"
                                        Cursor="Hand">
                                    <Button Background="Transparent" BorderThickness="0"
                                            Padding="0" Width="32" Height="32"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            Command="{Binding PlayArtistCommand}"
                                            ToolTip.Tip="Play artist">
                                        <Path Data="M3,2 L11,7 L3,12 Z"
                                              Fill="White"
                                              Width="14" Height="14"
                                              Stretch="Uniform"/>
                                    </Button>
                                </Border>
                                <TextBlock Text="{Binding ArtistName}"
                                           FontSize="48" FontWeight="Bold"
                                           Foreground="White"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <TextBlock Text="{Binding HeroTagline}"
                                       FontSize="13"
                                       Foreground="#C8FFFFFF"
                                       Margin="46,0,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                                    VerticalAlignment="Bottom">
                            <Button Classes="pill-action"
                                    Command="{Binding PlayArtistCommand}"
                                    Background="{DynamicResource AccentColorBrush}"
                                    Foreground="White">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Path Data="M3,2 L11,7 L3,12 Z" Fill="White" Width="11" Height="11" Stretch="Uniform"/>
                                    <TextBlock Text="Play" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button Classes="pill-action"
                                    Command="{Binding ShuffleArtistCommand}"
                                    Background="{DynamicResource AccentColorBrush}"
                                    Foreground="White">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <PathIcon Data="{StaticResource ShuffleIcon}" Width="12" Height="12" Foreground="White"/>
                                    <TextBlock Text="Shuffle" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Panel>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- TOP SONGS + FEATURED ALBUM                           -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid Margin="32,0" ColumnDefinitions="320,*" IsVisible="{Binding TopSongs.Count}">
                <!-- Featured album card -->
                <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,28,0"
                            IsVisible="{Binding FeaturedAlbum, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="Featured Album" FontSize="18" FontWeight="Bold"/>
                    <Button Background="Transparent" BorderThickness="0" Padding="0"
                            HorizontalContentAlignment="Stretch"
                            Cursor="Hand"
                            Command="{Binding OpenAlbumCommand}"
                            CommandParameter="{Binding FeaturedAlbum}">
                        <StackPanel Spacing="10">
                            <Border CornerRadius="8" ClipToBounds="True"
                                    Width="240" Height="240" HorizontalAlignment="Left"
                                    Background="#1AFFFFFF">
                                <ctrl:CachedImage SourcePath="{Binding FeaturedAlbum.ArtworkPath}"
                                                  Stretch="UniformToFill"
                                                  RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            </Border>
                            <StackPanel Spacing="2">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Opacity="0.55"
                                           Text="{Binding FeaturedAlbum.Year, StringFormat='RELEASED {0}'}"/>
                                <TextBlock Text="{Binding FeaturedAlbum.Name}"
                                           FontSize="14" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding FeaturedAlbum.TrackCount, StringFormat='{}{0} songs'}"
                                           FontSize="12" Opacity="0.55"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Top songs list, 3 columns -->
                <StackPanel Grid.Column="1" Spacing="10">
                    <TextBlock Text="Top Songs" FontSize="18" FontWeight="Bold"/>
                    <ItemsControl ItemsSource="{Binding TopSongs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:Track}">
                                <Button Background="Transparent" BorderThickness="0"
                                        Padding="6,4" Margin="0,0,8,4"
                                        HorizontalContentAlignment="Stretch"
                                        HorizontalAlignment="Stretch"
                                        Cursor="Hand"
                                        Command="{Binding $parent[UserControl].((vm:ArtistDetailViewModel)DataContext).PlayTrackCommand}"
                                        CommandParameter="{Binding}">
                                    <Grid ColumnDefinitions="40,*" >
                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="4"
                                                ClipToBounds="True"
                                                Background="#1AFFFFFF">
                                            <ctrl:CachedImage SourcePath="{Binding AlbumArtworkPath}"
                                                              Stretch="UniformToFill"
                                                              RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center" Spacing="1">
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Text="{Binding Title}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="11" Opacity="0.55"
                                                       Text="{Binding Album}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ESSENTIAL ALBUMS                                     -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Margin="32,0" Spacing="12" IsVisible="{Binding EssentialAlbums.Count}">
                <TextBlock Text="Essential Albums" FontSize="20" FontWeight="Bold"/>
                <ItemsControl ItemsSource="{Binding EssentialAlbums}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:Album}">
                            <Button Classes="album-tile" Focusable="False" Margin="4"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding $parent[UserControl].((vm:ArtistDetailViewModel)DataContext).OpenAlbumCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Spacing="8">
                                    <Border CornerRadius="6" ClipToBounds="True"
                                            Background="#1AFFFFFF" HorizontalAlignment="Stretch"
                                            Height="200">
                                        <ctrl:CachedImage SourcePath="{Binding ArtworkPath}"
                                                          Stretch="UniformToFill"
                                                          RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                    </Border>
                                    <StackPanel Spacing="1">
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        <TextBlock FontSize="11" Opacity="0.55"
                                                   Text="{Binding Year}" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ALBUMS                                               -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Margin="32,0" Spacing="12" IsVisible="{Binding StudioAlbums.Count}">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Albums" FontSize="20" FontWeight="Bold"/>
                    <Button Grid.Column="1" Content="See all"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{DynamicResource AccentColorBrush}"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                            Command="{Binding SeeAllAlbumsCommand}"/>
                </Grid>
                <ItemsControl ItemsSource="{Binding StudioAlbums}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="5" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:Album}">
                            <Button Classes="album-tile" Focusable="False" Margin="4"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding $parent[UserControl].((vm:ArtistDetailViewModel)DataContext).OpenAlbumCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Spacing="8">
                                    <Border CornerRadius="6" ClipToBounds="True"
                                            Background="#1AFFFFFF" HorizontalAlignment="Stretch"
                                            Height="200">
                                        <ctrl:CachedImage SourcePath="{Binding ArtworkPath}"
                                                          Stretch="UniformToFill"
                                                          RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                    </Border>
                                    <StackPanel Spacing="1">
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   Text="{Binding Name}"
                                                   TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                        <TextBlock FontSize="11" Opacity="0.55"
                                                   Text="{Binding Year}" />
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- SINGLES & EPS                                        -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel Margin="32,0" Spacing="12" IsVisible="{Binding SinglesAndEps.Count}">
                <TextBlock Text="Singles &amp; EPs" FontSize="20" FontWeight="Bold"/>
                <ItemsControl ItemsSource="{Binding SinglesAndEps}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type m:Album}">
                            <Button Classes="album-tile" Focusable="False" Margin="4"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding $parent[UserControl].((vm:ArtistDetailViewModel)DataContext).OpenAlbumCommand}"
                                    CommandParameter="{Binding}">
                                <StackPanel Spacing="6">
                                    <Border CornerRadius="6" ClipToBounds="True"
                                            Background="#1AFFFFFF" HorizontalAlignment="Stretch"
                                            Height="160">
                                        <ctrl:CachedImage SourcePath="{Binding ArtworkPath}"
                                                          Stretch="UniformToFill"
                                                          RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                    </Border>
                                    <TextBlock FontSize="12" FontWeight="SemiBold"
                                               Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" MaxLines="1"/>
                                    <TextBlock FontSize="10" Opacity="0.55"
                                               Text="{Binding Year}" />
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ABOUT                                                -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Border Margin="32,8,32,0" Padding="28,24" CornerRadius="12"
                    Background="#0CFFFFFF"
                    IsVisible="{Binding HasBio}">
                <Grid ColumnDefinitions="*,260" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Column="0" Grid.Row="0"
                               Text="{Binding ArtistName, StringFormat='About {0}'}"
                               FontSize="22" FontWeight="Bold" Margin="0,0,0,12"/>
                    <TextBlock Grid.Column="0" Grid.Row="1"
                               Text="{Binding BioText}"
                               FontSize="13" Opacity="0.85"
                               TextWrapping="Wrap" MaxWidth="640"
                               HorizontalAlignment="Left"/>

                    <StackPanel Grid.Column="1" Grid.RowSpan="2" Spacing="14"
                                Margin="32,4,0,0">
                        <StackPanel Spacing="2" IsVisible="{Binding ShowFrom}">
                            <TextBlock Text="FROM" FontSize="10" FontWeight="SemiBold" Opacity="0.55"/>
                            <TextBlock Text="{Binding BioFrom}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Spacing="2" IsVisible="{Binding ShowBorn}">
                            <TextBlock Text="{Binding BioBornLabel}" FontSize="10" FontWeight="SemiBold" Opacity="0.55"/>
                            <TextBlock Text="{Binding BioBorn}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Spacing="2" IsVisible="{Binding ShowGenre}">
                            <TextBlock Text="GENRE" FontSize="10" FontWeight="SemiBold" Opacity="0.55"/>
                            <TextBlock Text="{Binding BioGenre}" FontSize="14" TextWrapping="Wrap"/>
                        </StackPanel>
                        <StackPanel Spacing="2" IsVisible="{Binding ShowType}">
                            <TextBlock Text="TYPE" FontSize="10" FontWeight="SemiBold" Opacity="0.55"/>
                            <TextBlock Text="{Binding BioType}" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Spacing="2" IsVisible="{Binding ShowArea}">
                            <TextBlock Text="AREA" FontSize="10" FontWeight="SemiBold" Opacity="0.55"/>
                            <TextBlock Text="{Binding BioArea}" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
