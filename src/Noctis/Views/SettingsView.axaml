<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:sys="using:System"
             xmlns:conv="using:Noctis.Converters"
             xmlns:controls="using:Noctis.Controls"
             x:Class="Noctis.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:PercentageToWidthConverter x:Key="PercentageToWidth" />
        <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Section header style -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Setting card -->
        <Style Selector="Border.setting-card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="22,16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>


        <!-- Setting row: label left, control right -->
        <Style Selector="Border.setting-row">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Liquid motion for every button in Settings -->
        <Style Selector="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                    <BrushTransition Property="Background" Duration="0:0:0.16"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.045)"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <!-- Theme selection button -->
        <Style Selector="Button.theme-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.theme-btn /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.theme-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
        </Style>
        <Style Selector="Button.theme-btn.active /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="#E74856"/>
        </Style>

        <!-- Danger button -->
        <Style Selector="Button.danger /template/ ContentPresenter">
            <Setter Property="Background" Value="#E74856"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#C73E4C"/>
        </Style>

        <!-- Accent button -->
        <Style Selector="Button.accent /template/ ContentPresenter">
            <Setter Property="Background" Value="#E74856"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#C73E4C"/>
        </Style>

        <!-- Pill-shaped action buttons -->
        <Style Selector="Button.pill-action">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pill-action /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>

        <!-- Small beta badge -->
        <Style Selector="Border.beta-badge">
            <Setter Property="Background" Value="#E74856"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="7,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.beta-badge TextBlock">
            <Setter Property="Text" Value="BETA"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="LetterSpacing" Value="0.5"/>
        </Style>

        <!-- Pill ComboBox -->
        <Style Selector="ComboBox.pill-combo">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <DataValidationErrors>
                        <Panel>
                            <Border Name="Background"
                                    Background="{DynamicResource ButtonBackground}"
                                    BorderThickness="0"
                                    CornerRadius="16"
                                    Padding="{TemplateBinding Padding}"
                                    MinWidth="{TemplateBinding MinWidth}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <ContentPresenter Name="PART_ContentPresenter"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    <Border Grid.Column="1"
                                            Width="15"
                                            Height="15"
                                            Margin="4,0,4,0"
                                            Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            RenderOptions.BitmapInterpolationMode="HighQuality">
                                        <Border.OpacityMask>
                                            <ImageBrush Source="avares://Noctis/Assets/Icons/Arrow Down ICON.png" Stretch="Uniform"/>
                                        </Border.OpacityMask>
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup Name="PART_Popup"
                                   PlacementTarget="{TemplateBinding}"
                                   IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}"
                                   MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                   MinWidth="{TemplateBinding MinWidth}"
                                   IsLightDismissEnabled="True"
                                   WindowManagerAddShadowHint="False"
                                   Placement="BottomEdgeAlignedLeft">
                                <Border Background="{DynamicResource ComboBoxDropDownBackground}"
                                        BorderBrush="{DynamicResource ComboBoxDropDownBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="0,4">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter Name="PART_ItemsPresenter"
                                                        ItemsPanel="{TemplateBinding ItemsPanel}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Panel>
                    </DataValidationErrors>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ComboBox.pill-combo:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>
        <Style Selector="ComboBox.pill-combo:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
        </Style>
        <!-- Selected item highlight: #E74856 -->
        <Style Selector="ComboBox.pill-combo ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#E74856"/>
        </Style>
        <Style Selector="ComboBox.pill-combo ComboBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#C73E4C"/>
        </Style>
        <Style Selector="ComboBox.transition-pill">
            <Setter Property="Width" Value="132"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="ComboBox.transition-pill /template/ Border#Background">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>
        <Style Selector="ComboBox.transition-pill:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>

        <!-- Accent sliders (horizontal) -->
        <Style Selector="Slider.accent-slider">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TickPlacement" Value="None"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ Track">
            <Setter Property="Height" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Margin" Value="0,0,-9,0"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Margin" Value="-9,0,0,0"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Height" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton#PART_IncreaseButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <DoubleTransition Property="Width" Duration="0:0:0.12"/>
                    <DoubleTransition Property="Height" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-slider:pointerover /template/ Thumb">
            <Setter Property="Width" Value="19.44"/>
            <Setter Property="Height" Value="19.44"/>
        </Style>

        <!-- Accent sliders (vertical EQ) -->
        <Style Selector="Slider.accent-vertical">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ Track">
            <Setter Property="Width" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Margin" Value="0,-9,0,0"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Margin" Value="0,0,0,-9"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Width" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton#PART_IncreaseButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="999"/>
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <DoubleTransition Property="Width" Duration="0:0:0.12"/>
                    <DoubleTransition Property="Height" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-vertical:pointerover /template/ Thumb">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">
    <ScrollViewer x:Name="SettingsScrollViewer"
                  Grid.Row="0"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,40" MaxWidth="900" HorizontalAlignment="Left" Spacing="4">

            <!-- Page title moved to the topbar (matches Albums/Songs/etc.) -->

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- APPEARANCE                                         -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="APPEARANCE"/>

            <Border Classes="setting-card" Padding="22,12">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Themes" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Choose how Noctis looks on your device."
                                   FontSize="12" Opacity="0.5"/>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <WrapPanel.Styles>
                            <Style Selector="Button.theme-btn">
                                <Setter Property="Margin" Value="0,0,10,10"/>
                            </Style>
                        </WrapPanel.Styles>
                        <!-- Dark (pure black, silver accents) -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsDarkTheme}"
                                Command="{Binding SetDarkThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#000000"
                                        BorderBrush="#1A1A1A" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#E8E8E8" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#A8A8A8" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#707070" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Dark" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Gray (default) -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsGrayTheme}"
                                Command="{Binding SetGrayThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#1E1E1E"
                                        BorderBrush="#444" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#555" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#444" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#333" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Gray" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Midnight (deep blue-black) -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsMidnightTheme}"
                                Command="{Binding SetMidnightThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#0E1322"
                                        BorderBrush="#1E2640" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#7C8CFF" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#5A6BB0" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#3A4673" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Midnight" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Light -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsLightTheme}"
                                Command="{Binding SetLightThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#F5F5F5"
                                        BorderBrush="#CCC" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#CCC" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#DDD" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#E0E0E0" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Light" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Paper (warm off-white) -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsPaperTheme}"
                                Command="{Binding SetPaperThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#F7F4EE"
                                        BorderBrush="#C8C0A8" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#3A352D" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#6E665A" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#A89F8C" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Paper" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- System -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsSystemTheme}"
                                Command="{Binding SetSystemThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        BorderBrush="#888" BorderThickness="1">
                                    <Grid ColumnDefinitions="*,*">
                                        <Border Grid.Column="0" Background="#1E1E1E"
                                                CornerRadius="5,0,0,5">
                                            <StackPanel Margin="4,5,0,0" Spacing="3">
                                                <Border Height="3" Width="16" CornerRadius="1.5"
                                                        Background="#555" HorizontalAlignment="Left"/>
                                                <Border Height="3" Width="10" CornerRadius="1.5"
                                                        Background="#444" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#F5F5F5"
                                                CornerRadius="0,5,5,0">
                                            <StackPanel Margin="2,5,0,0" Spacing="3">
                                                <Border Height="3" Width="16" CornerRadius="1.5"
                                                        Background="#CCC" HorizontalAlignment="Left"/>
                                                <Border Height="3" Width="10" CornerRadius="1.5"
                                                        Background="#DDD" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="System" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Album page cover-art tint -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="Album page tint" FontSize="15" FontWeight="SemiBold"/>
                            <Border Classes="beta-badge">
                                <TextBlock/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Use a gradient drawn from the album artwork as the page background. Stays the same across themes."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding AlbumDetailColorTintEnabled}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- AUDIO PLAYBACK                                     -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="AUDIO PLAYBACK" Margin="0,20,0,10"/>

            <!-- Transitions -->
            <Border Classes="setting-card">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Transition Mode" FontSize="15" FontWeight="SemiBold"/>
                                <Border Classes="beta-badge">
                                    <TextBlock/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Choose between standard crossfade and context-aware AutoMix."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Classes="pill-combo transition-pill"
                                  ItemsSource="{Binding AutoMixTransitionModes}"
                                  SelectedItem="{Binding AutoMixTransitionMode}"/>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding AutoMixEnabled}">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="AutoMix Strength" FontSize="13" Opacity="0.75"/>
                            <TextBlock Text="Controls how long AutoMix can lean into compatible songs."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Classes="pill-combo transition-pill"
                                  ItemsSource="{Binding AutoMixStrengthOptions}"
                                  SelectedItem="{Binding AutoMixStrength}"/>
                    </Grid>

                    <StackPanel IsVisible="{Binding AutoMixEnabled}" Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Remove silence between songs" FontSize="13" Opacity="0.75"/>
                            </StackPanel>
                            <controls:LottieToggle Grid.Column="1"
                                                  IsChecked="{Binding AutoMixRemoveSilence}"
                                                  VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Avoid AutoMix for albums" FontSize="13" Opacity="0.75"/>
                            </StackPanel>
                            <controls:LottieToggle Grid.Column="1"
                                                  IsChecked="{Binding AutoMixAvoidAlbums}"
                                                  VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="Beat-match when metadata is available" FontSize="13" Opacity="0.75"/>
                            </StackPanel>
                            <controls:LottieToggle Grid.Column="1"
                                                  IsChecked="{Binding AutoMixBeatMatch}"
                                                  VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sound Check -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Sound Check" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Automatically adjusts the volume of songs to the same level."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding SoundCheckEnabled}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Text Animation group -->
            <Border Classes="setting-card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Text Animation" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Control how long text scrolls in the player bar, Up Next, and menus."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Sub-header: Player Bar -->
                    <TextBlock Text="PLAYER BAR" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,4,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long track titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding TrackTitleMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long artist names" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding ArtistMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sub-header: Cover Flow -->
                    <TextBlock Text="COVER FLOW" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,8,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long track titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding CoverFlowMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long artist names" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding CoverFlowArtistMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long album titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding CoverFlowAlbumMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sub-header: Lyrics Page -->
                    <TextBlock Text="LYRICS PAGE" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,8,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long track titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LyricsTitleMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long artist/album names" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LyricsArtistMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- EQUALIZER                                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="EQUALIZER" Margin="0,20,0,10"/>

            <Border Classes="setting-card" Padding="22,16,38,16" ClipToBounds="False">
                <StackPanel Spacing="16">
                    <!-- Header row with icon, preset selector, and reset button -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <StackPanel Grid.Column="0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Equalizer" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Fine-tune audio frequencies for your listening preference."
                                           FontSize="12" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>
                        <ComboBox Grid.Column="2"
                                  Classes="pill-combo"
                                  ItemsSource="{Binding VisibleEqPresets}"
                                  SelectedItem="{Binding SelectedEqPresetName}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0" />
                        <Button Grid.Column="3"
                                Classes="pill-action"
                                Command="{Binding ResetEqualizerCommand}"
                                CornerRadius="16"
                                Padding="14,8"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Reset"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <!-- dB scale + 10 band sliders -->
                    <Grid ColumnDefinitions="40,*" Margin="0,8,26,0" ClipToBounds="False">
                        <!-- dB labels on the left -->
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Stretch"
                                    Margin="0,0,4,20">
                            <TextBlock Text="+12dB" FontSize="10" Opacity="0.5"
                                       VerticalAlignment="Top" />
                            <TextBlock Text="0dB" FontSize="10" Opacity="0.5"
                                       VerticalAlignment="Center"
                                       Margin="0,55,0,55" />
                            <TextBlock Text="-12dB" FontSize="10" Opacity="0.5"
                                       VerticalAlignment="Bottom" />
                        </StackPanel>

                        <!-- 10 vertical sliders in a uniform row -->
                        <UniformGrid Grid.Column="1" Columns="10" Margin="0,0,24,0">
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand0}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="60Hz" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand1}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="170Hz" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand2}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="310Hz" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand3}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="600Hz" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand4}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="1K" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand5}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="3K" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand6}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="6K" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand7}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="12K" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand8}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="14K" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Stretch" Spacing="4">
                                <Slider Orientation="Vertical" Height="160"
                                        Minimum="-12" Maximum="12"
                                        Value="{Binding EqBand9}"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        HorizontalAlignment="Center"
                                        Classes="accent-vertical" />
                                <TextBlock Text="16K" FontSize="10" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </UniformGrid>
                    </Grid>
                </StackPanel>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- LYRICS PROVIDERS                                   -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="LYRICS" Margin="0,20,0,10"/>

            <Border Classes="setting-card">
                <StackPanel Spacing="10">
                    <TextBlock Text="Online lyrics providers used when no local or embedded lyrics are found."
                               FontSize="12" Opacity="0.5" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="LRCLIB" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Community-curated lyrics database" FontSize="11" Opacity="0.5"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LrcLibEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="NetEase Cloud Music" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Large catalog including synced lyrics" FontSize="11" Opacity="0.5"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding NetEaseEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ACCOUNTS                                           -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="ACCOUNTS" Margin="0,20,0,10"/>

            <!-- Discord Rich Presence -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                            Background="#5865F2" Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <Viewbox Width="22" Height="22"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="White"
                                      Data="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Discord Rich Presence" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Display the currently playing song, artist, and album as your Discord activity status. Your friends will see what you're listening to in real time."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="2"
                                          IsChecked="{Binding DiscordRichPresenceEnabled}"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- Last.fm -->
            <Border Classes="setting-card">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                Width="40" Height="40" CornerRadius="10"
                                Background="#D51007"
                                Margin="0,0,14,0"
                                VerticalAlignment="Top">
                            <Viewbox Width="22" Height="22"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="White"
                                          Data="M10.584 17.21l-.88-2.392s-1.43 1.594-3.573 1.594c-1.897 0-3.244-1.649-3.244-4.288 0-3.382 1.704-4.591 3.381-4.591 2.42 0 3.189 1.567 3.849 3.574l.88 2.749c.88 2.666 2.529 4.81 7.284 4.81 3.409 0 5.718-1.044 5.718-3.793 0-2.227-1.265-3.381-3.63-3.931l-1.758-.385c-1.21-.275-1.567-.77-1.567-1.595 0-.934.742-1.484 1.952-1.484 1.32 0 2.034.495 2.144 1.677l2.749-.33c-.22-2.474-1.924-3.492-4.729-3.492-2.474 0-4.893.935-4.893 3.932 0 1.87.907 3.051 3.189 3.601l1.87.44c1.402.33 1.869.907 1.869 1.704 0 1.017-.99 1.43-2.86 1.43-2.776 0-3.932-1.457-4.59-3.464l-.907-2.75c-1.155-3.573-2.997-4.893-6.653-4.893C2.144 5.333 0 7.89 0 12.233c0 4.18 2.144 6.434 5.993 6.434 3.106 0 4.591-1.457 4.591-1.457z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center" Spacing="2" Margin="0,0,12,0">
                            <TextBlock Text="Last.fm Scrobbling" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                            <TextBlock Text="Scrobble your plays to Last.fm for history and recommendations."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap" MaxWidth="560"
                                       HorizontalAlignment="Left"
                                       Margin="-2,0,0,0"/>
                        </StackPanel>

                        <!-- Connected as ... (below description, when connected) -->
                        <TextBlock Grid.Column="1" Grid.Row="1"
                                   IsVisible="{Binding LastFmUsername, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="12" Opacity="0.6"
                                   Margin="0,4,12,0"
                                   VerticalAlignment="Top">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0}">
                                    <Binding Path="LastFmUsername"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <!-- Not connected state -->
                        <Button Grid.Column="2" Grid.Row="0"
                                IsVisible="{Binding !IsLastFmConnected}"
                                Content="Connect Last.fm"
                                Classes="pill-action"
                                Command="{Binding LoginLastFmCommand}"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate>
                                    <ContentPresenter Background="#E74856"
                                                      Foreground="White"
                                                      CornerRadius="16"
                                                      Padding="14,8"
                                                      FontSize="13"
                                                      FontWeight="SemiBold"
                                                      Content="{TemplateBinding Content}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Status text removed -->

                        <!-- Logout button (top-right, when connected) -->
                        <Button Grid.Column="2" Grid.Row="0"
                                IsVisible="{Binding IsLastFmConnected}"
                                Command="{Binding LogoutLastFmCommand}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Logout" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Enable Scrobbling (when connected) -->
                    <Grid IsVisible="{Binding IsLastFmConnected}" ColumnDefinitions="*,Auto" Margin="54,0,0,0">
                        <TextBlock Grid.Column="0"
                                   Text="Enable Scrobbling"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LastFmScrobblingEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- MEDIA FOLDERS                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock x:Name="MediaFoldersSectionAnchor"
                       Classes="section-title"
                       Text="MEDIA FOLDERS"
                       Margin="0,20,0,10"/>

            <Border Classes="setting-card">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Media Folder Locations" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Choose the folders where your music files are stored."
                                           FontSize="12" Opacity="0.5"/>
                                <TextBlock Text="Browse them by hierarchy in the Folders tab."
                                           FontSize="12" Opacity="0.4" FontStyle="Italic"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="AddFolderButton"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Add Folder" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Folder list -->
                    <ItemsControl ItemsSource="{Binding MusicFolders}">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl:empty">
                                <Setter Property="IsVisible" Value="False"/>
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sys:String">
                                <Border Padding="12,8" Margin="0,2" CornerRadius="6"
                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1"
                                                Content="&#x2715;"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveFolderCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Opacity="0.5"
                                                Cursor="Hand"
                                                Padding="4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Library Management (scan) -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Library Scan" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Scan for new tracks or rebuild the search index."
                                       FontSize="12" Opacity="0.5"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ScanStatusText}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   VerticalAlignment="Center"/>
                        <Button Classes="pill-action"
                                Command="{Binding RescanCommand}"
                                IsEnabled="{Binding !IsScanning}"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand">
                            <TextBlock Text="Scan Library" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- PREFERENCES                                        -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="PREFERENCES" Margin="0,20,0,10"/>

            <!-- Scan on startup -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Scan on Startup" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Automatically scan music folders for new or changed files when Noctis starts."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding ScanOnStartup}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- LIBRARY OVERVIEW                                   -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="LIBRARY OVERVIEW" Margin="0,20,0,10"/>

            <Border Classes="setting-card">
                <StackPanel Spacing="18">
                    <TextBlock Text="Your Music Library" FontSize="15" FontWeight="SemiBold"/>

                    <!-- Primary stats: Songs · Artists · Albums · Listening Time -->
                    <UniformGrid Columns="4" Margin="0,2,0,0">
                        <Border CornerRadius="10" Padding="14,16" Margin="0,0,8,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalSongs}"
                                           FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Songs" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,16" Margin="4,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalArtists}"
                                           FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Artists" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,16" Margin="4,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalAlbums}"
                                           FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Albums" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,16" Margin="8,0,0,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalListeningTime}"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Listening Time" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Audio Quality: smaller chips, Hi-Res accented -->
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <TextBlock Text="Audio Quality" FontSize="12" Opacity="0.55"
                                   FontWeight="SemiBold" Classes="section-title"/>
                        <Grid ColumnDefinitions="*,*,*">
                            <Border Grid.Column="0" CornerRadius="8" Padding="12,10" Margin="0,0,6,0"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LosslessCount}"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Lossless" FontSize="11" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="8" Padding="12,10" Margin="3,0"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding HiResCount}"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Hi-Res Lossless" FontSize="11" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="8" Padding="12,10" Margin="6,0,0,0"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LossyCount}"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Lossy" FontSize="11" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Playlists footer (text-only so 0 doesn't dominate) -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="{Binding TotalPlaylists}" FontSize="12"
                                   FontWeight="SemiBold" Opacity="0.7"/>
                        <TextBlock Text="playlists" FontSize="12" Opacity="0.55"/>
                    </StackPanel>
                </StackPanel>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- STORAGE                                            -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="STORAGE" Margin="0,20,0,10"/>

            <Border Classes="setting-card">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Disk Usage" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Space used by Noctis data on your system."
                                           FontSize="12" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Command="{Binding OpenDataFolderCommand}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Open Data Folder" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <!-- Library size (music files on disk) -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Library Size"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding TotalFileSize}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Library data -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Library Data"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageLibraryData}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Artwork cache -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Artwork Cache"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageArtwork}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Playlists -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Playlists"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StoragePlaylists}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Settings -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Settings"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageSettings}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3"/>

                        <!-- Total -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Column="0" Text="Total"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageTotal}"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ADVANCED                                           -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="ADVANCED" Margin="0,20,0,10"/>

            <!-- Reset Library -->
            <Border Classes="setting-card">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Reset Settings" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Reset all settings to defaults and clear library, playlists, artwork, and lyrics cache."
                                           FontSize="12" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Normal state -->
                        <Button Grid.Column="1"
                                Command="{Binding ShowResetConfirmCommand}"
                                IsVisible="{Binding !IsResetConfirmVisible}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Reset Settings" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Confirmation state -->
                    <StackPanel IsVisible="{Binding IsResetConfirmVisible}" Spacing="8">
                        <TextBlock Text="Are you sure? This action cannot be undone."
                                   FontSize="13" Foreground="#E74856"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Cancel"
                                    Command="{Binding CancelResetCommand}"
                                    Classes="pill-action"
                                    Padding="16,10"
                                    CornerRadius="18"
                                    Cursor="Hand"/>
                            <Button Content="Reset Everything"
                                    Command="{Binding ConfirmResetLibraryCommand}"
                                    Classes="pill-action danger"
                                    Padding="16,10"
                                    CornerRadius="18"
                                    Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
            <!-- Fetch Artist Images -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Fetch Artist Images" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Download profile pictures for artists in your library from Deezer. Use after clearing cache or adding new artists."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding FetchArtistImagesCommand}"
                            Classes="pill-action"
                            Padding="14,8"
                            CornerRadius="16"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <TextBlock Text="Fetch Images" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>
            <!-- Clear Artwork Cache -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Clear Artwork Cache" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Delete cached album artwork to free disk space. Artwork will be re-extracted on next scan."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                            <TextBlock Text="Note: This will remove all artworks from library."
                                       FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Command="{Binding ClearArtworkCacheCommand}"
                            Classes="pill-action"
                            Padding="14,8"
                            CornerRadius="16"
                            Cursor="Hand"
                            VerticalAlignment="Center">
                        <TextBlock Text="Clear Cache" FontSize="13"
                                   VerticalAlignment="Center"/>
                    </Button>
                </Grid>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ABOUT                                              -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="ABOUT" Margin="0,20,0,10"/>

            <Border Classes="setting-card" Padding="14,16">
                <StackPanel Spacing="10">
                    <!-- Top row: logo + version on left, Update button on right -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                            <Border Width="48" Height="48" CornerRadius="24"
                                    ClipToBounds="True">
                                <Image Source="avares://Noctis/Assets/Icons/Noctis%20Logo.png"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Noctis" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding AppVersion}"
                                           FontSize="12" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons (top-right) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">

                        <Button Command="{Binding CheckForUpdateCommand}"
                                Classes="pill"
                                VerticalAlignment="Center"
                                Padding="16,6"
                                Background="#E74856"
                                IsVisible="{Binding ShowCheckForUpdatesButton}">
                            <TextBlock Text="Check for Updates" FontSize="12" Foreground="White"/>
                        </Button>

                        <!-- Update Available button (replaces Check when a new release is detected) -->
                        <Button Command="{Binding DownloadUpdateCommand}"
                                Classes="pill"
                                VerticalAlignment="Center"
                                Padding="16,6"
                                Background="#E74856"
                                IsVisible="{Binding IsUpdateAvailable}">
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Update available"
                                           FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Install & Restart button (replaces Update when ready) -->
                        <Button Command="{Binding InstallUpdateCommand}"
                                Classes="pill"
                                VerticalAlignment="Center"
                                Padding="16,6"
                                IsVisible="{Binding IsReadyToInstall}">
                            <TextBlock Text="Install &amp; Restart" FontSize="12"/>
                        </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Update status area -->
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                IsVisible="{Binding UpdateStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12"
                                IsVisible="{Binding IsDownloadingUpdate}">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding DownloadProgress}"
                                     Height="4" CornerRadius="2"
                                     VerticalAlignment="Center"
                                     MinWidth="200" />
                        <Button Command="{Binding CancelUpdateCommand}"
                                Classes="pill"
                                Padding="16,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="Cancel" FontSize="12" />
                        </Button>
                    </StackPanel>

                    <Border Height="1"
                            Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            Opacity="0.2" Margin="0,4"/>

                    <Button Command="{Binding OpenGitHubCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="0" Margin="0,2,0,4" Cursor="Hand"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource GitHubIcon}"
                                      Width="14" Height="14"
                                      Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                      Opacity="0.5" />
                            <TextBlock Text="Star on GitHub"
                                       FontSize="12" Opacity="0.5"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <TextBlock Text="Modern music player for Windows."
                               FontSize="13" Opacity="0.6"/>
                    <TextBlock Text="Yours Truly, heartached."
                               FontSize="12" Opacity="0.4"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
    </Grid>

</UserControl>


