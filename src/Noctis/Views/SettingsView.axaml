<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:models="using:Noctis.Models"
             xmlns:sys="using:System"
             xmlns:conv="using:Noctis.Converters"
             xmlns:controls="using:Noctis.Controls"
             x:Class="Noctis.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:PercentageToWidthConverter x:Key="PercentageToWidth" />
        <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Section header style -->
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Opacity" Value="0.45"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Setting card -->
        <Style Selector="Border.setting-card">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="22,16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style Selector="Border.setting-card.advanced-first">
            <Setter Property="CornerRadius" Value="24,24,0,0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Border.setting-card.advanced-middle">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Border.setting-card.advanced-last">
            <Setter Property="CornerRadius" Value="0,0,24,24"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Selectable card used by the Song Transitions style picker -->
        <Style Selector="RadioButton.transition-card">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="card"
                            Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                            BorderBrush="Transparent"
                            BorderThickness="2"
                            CornerRadius="18"
                            Padding="18,14">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.transition-card:checked /template/ Border#card">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}"/>
        </Style>
        <Style Selector="RadioButton.transition-card:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>


        <!-- Setting row: label left, control right -->
        <Style Selector="Border.setting-row">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Liquid motion for every button in Settings -->
        <Style Selector="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12"/>
                    <BrushTransition Property="Background" Duration="0:0:0.16"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.045)"/>
        </Style>
        <Style Selector="Button.accent-swatch:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.accent-swatch:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <!-- Theme selection button -->
        <Style Selector="Button.theme-btn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.theme-btn /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.theme-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
        </Style>

        <!-- Profile avatar button: round, no rectangular hover overlay -->
        <Style Selector="Button.profile-avatar-btn /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="999"/>
        </Style>
        <Style Selector="Button.profile-avatar-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.profile-avatar-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- Profile name TextBox: no chrome on any state -->
        <Style Selector="TextBox.profile-input /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox.profile-input:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.profile-input:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.profile-input:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="Button.theme-btn.active /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}"/>
        </Style>

        <!-- Danger button -->
        <Style Selector="Button.danger /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrushDark1}"/>
        </Style>

        <!-- Accent button -->
        <Style Selector="Button.accent /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrushDark1}"/>
        </Style>

        <Style Selector="TextBox.accent-hex-input /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
        </Style>
        <Style Selector="TextBox.accent-hex-input:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.accent-hex-input:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox.accent-hex-input:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <!-- Pill-shaped action buttons -->
        <Style Selector="Button.pill-action">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.pill-action /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>

        <!-- Social links (GitHub / Discord) in the About card: brand-coloured icon,
             brighter label, and a soft brand-tinted pill on hover. -->
        <Style Selector="Button.social-link">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.social-link /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="999"/>
        </Style>
        <Style Selector="Button.social-discord:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#265865F2"/>
        </Style>
        <Style Selector="Button.social-github:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#26F1C40F"/>
        </Style>

        <!-- Pill ComboBox -->
        <Style Selector="ComboBox.pill-combo">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <DataValidationErrors>
                        <Panel>
                            <Border Name="Background"
                                    Background="{DynamicResource ButtonBackground}"
                                    BorderThickness="0"
                                    CornerRadius="16"
                                    Padding="{TemplateBinding Padding}"
                                    MinWidth="{TemplateBinding MinWidth}">
                                <Grid ColumnDefinitions="*,Auto">
                                    <ContentPresenter Name="PART_ContentPresenter"
                                                      Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                    <Border Grid.Column="1"
                                            Width="15"
                                            Height="15"
                                            Margin="4,0,4,0"
                                            Background="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            RenderOptions.BitmapInterpolationMode="HighQuality">
                                        <Border.OpacityMask>
                                            <ImageBrush Source="avares://Noctis/Assets/Icons/Arrow Down ICON.png" Stretch="Uniform"/>
                                        </Border.OpacityMask>
                                    </Border>
                                </Grid>
                            </Border>
                            <Popup Name="PART_Popup"
                                   PlacementTarget="{TemplateBinding}"
                                   IsOpen="{TemplateBinding IsDropDownOpen, Mode=TwoWay}"
                                   MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                   MinWidth="{TemplateBinding MinWidth}"
                                   IsLightDismissEnabled="True"
                                   WindowManagerAddShadowHint="False"
                                   Placement="BottomEdgeAlignedLeft">
                                <Border Background="{DynamicResource ComboBoxDropDownBackground}"
                                        BorderBrush="{DynamicResource ComboBoxDropDownBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="0,4">
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter Name="PART_ItemsPresenter"
                                                        ItemsPanel="{TemplateBinding ItemsPanel}"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Panel>
                    </DataValidationErrors>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="ComboBox.pill-combo:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>
        <Style Selector="ComboBox.pill-combo.stable-popup:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>
        <Style Selector="ComboBox.pill-combo:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
        </Style>
        <!-- Selected item highlight. Foreground tracks the accent's contrast colour so the
             label stays readable even when the accent is white (otherwise white-on-white). -->
        <Style Selector="ComboBox.pill-combo ComboBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="ComboBox.pill-combo ComboBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrushDark1}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
        <!-- Pill-shaped hover/selection highlight in the dropdown list, matching the
             rounded MenuItems in the page options menu. Margin insets each row so the
             highlight floats; CornerRadius on the content presenter clips it to a pill. -->
        <Style Selector="ComboBox.pill-combo ComboBoxItem">
            <Setter Property="Margin" Value="4,1"/>
            <Setter Property="Padding" Value="11,6"/>
            <Setter Property="CornerRadius" Value="999"/>
        </Style>
        <Style Selector="ComboBox.pill-combo ComboBoxItem /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="999"/>
        </Style>

        <!-- Pill dropdown items for plain (default-template) pill combos, e.g. ReplayGain Mode. -->
        <Style Selector="ComboBox.pill-list ComboBoxItem">
            <Setter Property="Margin" Value="4,1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="CornerRadius" Value="999"/>
        </Style>
        <Style Selector="ComboBox.pill-list ComboBoxItem /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="999"/>
        </Style>

        <!-- Token field: identical treatment to the metadata editor's text fields. The inner
             PART_BorderElement gets the same CornerRadius so the rounded corners render clean
             (the earlier square-corner artifact came from leaving PART_BorderElement unstyled). -->
        <Style Selector="TextBox.metadata-info-field">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeWhiteBrush}" />
        </Style>
        <Style Selector="TextBox.metadata-info-field /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>
        <Style Selector="TextBox.metadata-info-field:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
        </Style>
        <Style Selector="TextBox.metadata-info-field:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
        </Style>
        <Style Selector="ComboBox.transition-pill">
            <Setter Property="Width" Value="132"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="ComboBox.transition-pill /template/ Border#Background">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>
        <Style Selector="ComboBox.transition-pill:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>

        <!-- Accent sliders (horizontal) -->
        <Style Selector="Slider.accent-slider">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="TickPlacement" Value="None"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ Track">
            <Setter Property="Height" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Margin" Value="0,0,-9,0"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Margin" Value="-9,0,0,0"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Height" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ RepeatButton#PART_IncreaseButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="Slider.accent-slider /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <DoubleTransition Property="Width" Duration="0:0:0.12"/>
                    <DoubleTransition Property="Height" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-slider:pointerover /template/ Thumb">
            <Setter Property="Width" Value="19.44"/>
            <Setter Property="Height" Value="19.44"/>
        </Style>

        <!-- Accent sliders (vertical EQ) -->
        <Style Selector="Slider.accent-vertical">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="ClipToBounds" Value="False"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ Track">
            <Setter Property="Width" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border/>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Margin" Value="0,-9,0,0"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Margin" Value="0,0,0,-9"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="Opacity" Value="0.95"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Width" Value="8"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ RepeatButton#PART_IncreaseButton /template/ Border">
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Opacity" Value="0.45"/>
        </Style>
        <Style Selector="Slider.accent-vertical /template/ Thumb">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform" Value="scale(1)"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="999"/>
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.14">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                    <DoubleTransition Property="Width" Duration="0:0:0.12"/>
                    <DoubleTransition Property="Height" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Slider.accent-vertical:pointerover /template/ Thumb">
            <Setter Property="RenderTransform" Value="scale(1)"/>
        </Style>

        <!-- Pre-amp pill slider: the real Slider is transparent and only handles hit
             testing; the visible pill track/fill/thumb are drawn on a Canvas and driven
             from code-behind (PillSliderVisualHelper), matching the metadata volume slider. -->
        <Style Selector="Slider.preamp-horizontal">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource IslandSliderFilled}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Settings tab strip -->
        <Style Selector="Button.settings-tab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.settings-tab /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="CornerRadius" Value="999"/>
        </Style>
        <Style Selector="Button.settings-tab.active /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">

    <!-- Tab strip -->
    <StackPanel Grid.Row="0" Margin="28,4,40,10" Spacing="10">
        <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Classes="settings-tab" Classes.active="{Binding IsGeneralTabSelected}"
                    Command="{Binding SelectSettingsTabCommand}" CommandParameter="General">
                <TextBlock Text="General" FontSize="13" FontWeight="SemiBold"/>
            </Button>
            <Button Classes="settings-tab" Classes.active="{Binding IsAppearanceTabSelected}"
                    Command="{Binding SelectSettingsTabCommand}" CommandParameter="Appearance">
                <TextBlock Text="Appearance" FontSize="13" FontWeight="SemiBold"/>
            </Button>
            <Button Classes="settings-tab" Classes.active="{Binding IsAudioTabSelected}"
                    Command="{Binding SelectSettingsTabCommand}" CommandParameter="Audio">
                <TextBlock Text="Audio" FontSize="13" FontWeight="SemiBold"/>
            </Button>
            <Button Classes="settings-tab" Classes.active="{Binding IsLibraryTabSelected}"
                    Command="{Binding SelectSettingsTabCommand}" CommandParameter="Library">
                <TextBlock Text="Library" FontSize="13" FontWeight="SemiBold"/>
            </Button>
            <Button Classes="settings-tab" Classes.active="{Binding IsIntegrationsTabSelected}"
                    Command="{Binding SelectSettingsTabCommand}" CommandParameter="Integrations">
                <TextBlock Text="Integrations" FontSize="13" FontWeight="SemiBold"/>
            </Button>
            <Button Classes="settings-tab" Classes.active="{Binding IsAboutTabSelected}"
                    Command="{Binding SelectSettingsTabCommand}" CommandParameter="About">
                <TextBlock Text="About" FontSize="13" FontWeight="SemiBold"/>
            </Button>
        </StackPanel>
    </StackPanel>

    <ScrollViewer x:Name="SettingsScrollViewer"
                  Grid.Row="1"
                  Focusable="True"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,8,40,28" HorizontalAlignment="Stretch" Spacing="4">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- GENERAL                                             -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel x:Name="GeneralTabPanel" IsVisible="{Binding IsGeneralTabVisible}" Spacing="4">

            <!-- Profile -->
            <Border Classes="setting-card" Padding="18,16" Margin="0,0,0,16">
                <Grid ColumnDefinitions="Auto,*">
                    <!-- Round avatar (click to change) -->
                    <Button Grid.Column="0"
                            Classes="profile-avatar-btn"
                            Background="Transparent" BorderThickness="0"
                            Padding="0" Cursor="Hand"
                            Width="64" Height="64"
                            CornerRadius="999"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Change avatar"
                            Click="OnPickAvatarClick">
                        <Border Width="64" Height="64" CornerRadius="32"
                                ClipToBounds="True"
                                Background="{DynamicResource AccentColorBrush}">
                            <Panel>
                                <!-- Default initials/glyph when no avatar set -->
                                <TextBlock Text="?"
                                           FontSize="28" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentForegroundBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <!-- Picked avatar overlay -->
                                <controls:CachedImage SourcePath="{Binding ProfileAvatarPath}"
                                                      Stretch="UniformToFill"
                                                      IsVisible="{Binding ProfileAvatarPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </Panel>
                        </Border>
                    </Button>

                    <!-- Display name -->
                    <TextBox Grid.Column="1"
                             Classes="profile-input"
                             Text="{Binding ProfileName, Mode=TwoWay}"
                             Watermark="Your name"
                             FontSize="16" FontWeight="SemiBold"
                             Margin="16,0,0,0"
                             VerticalAlignment="Center"
                             Background="Transparent"
                             BorderThickness="0" Padding="0"
                             MinHeight="0"
                             KeyDown="OnProfileNameKeyDown"
                             Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                </Grid>
            </Border>

            <!-- Text Animation group -->
            <Border Classes="setting-card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Text Animation" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Control how long text scrolls in the player bar, Up Next, and menus."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Sub-header: Player Bar -->
                    <TextBlock Text="PLAYER BAR" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,4,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long track titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding TrackTitleMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long artist names" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding ArtistMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sub-header: Cover Flow -->
                    <TextBlock Text="COVER FLOW" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,8,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long track titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding CoverFlowMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long artist names" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding CoverFlowArtistMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long album titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding CoverFlowAlbumMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sub-header: Lyrics Page -->
                    <TextBlock Text="LYRICS PAGE" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,8,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long track titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LyricsTitleMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long artist/album names" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LyricsArtistMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sub-header: Mini Player -->
                    <TextBlock Text="MINI PLAYER" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,8,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long track titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding MiniPlayerTitleMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Animate long album titles" FontSize="13" VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding MiniPlayerAlbumMarqueeEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Sub-header: Sidebar -->
                    <TextBlock Text="SIDEBAR" FontSize="11" FontWeight="SemiBold" Opacity="0.4" Margin="0,8,0,2"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Hover to expand sidebar" FontSize="13"/>
                            <TextBlock Text="Slide the sidebar open on hover. Turn off to keep the icon-only rail with no animation."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding SidebarHoverExpand}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Collapse album editions -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Collapse Album Editions" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Show one tile per release in album grids instead of every edition. Other editions stay available under &quot;Other Versions&quot; on the album page."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding CollapseAlbumEditions}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ABOUT                                               -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel x:Name="AboutTabPanel" IsVisible="{Binding IsAboutTabVisible}" Spacing="4">

            <Border Classes="setting-card" Padding="18,16" Margin="0,0,0,16">
                <StackPanel Spacing="10">
                    <!-- Row 1: logo + version on left, update button on right -->
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                            <Border Width="40" Height="40" CornerRadius="20"
                                    ClipToBounds="True">
                                <Image Source="avares://Noctis/Assets/Icons/Noctis%20Logo.png"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="Noctis" FontSize="16" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding AppVersion}"
                                               FontSize="12" Opacity="0.5"
                                               VerticalAlignment="Center"/>
                                    <Border IsVisible="{Binding IsPrereleaseBuild}"
                                            Background="#E74856"
                                            CornerRadius="9"
                                            Padding="8,2"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="Pre-release"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Action buttons (top-right) -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Command="{Binding CheckForUpdateCommand}"
                                    Classes="pill"
                                    VerticalAlignment="Center"
                                    Padding="16,6"
                                    Background="#E74856"
                                    IsVisible="{Binding ShowCheckForUpdatesButton}">
                                <TextBlock Text="Check for Updates" FontSize="12" Foreground="White"/>
                            </Button>

                            <!-- Update Available button (replaces Check when a new release is detected) -->
                            <Button Command="{Binding DownloadUpdateCommand}"
                                    Classes="pill"
                                    VerticalAlignment="Center"
                                    Padding="16,6"
                                    Background="#E74856"
                                    IsVisible="{Binding IsUpdateAvailable}">
                                <TextBlock Text="Update available"
                                           FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                            </Button>

                            <!-- Install & Restart button (replaces Update when ready) -->
                            <Button Command="{Binding InstallUpdateCommand}"
                                    Classes="pill"
                                    VerticalAlignment="Center"
                                    Padding="16,6"
                                    Background="#E74856"
                                    IsVisible="{Binding IsReadyToInstall}">
                                <TextBlock Text="Install &amp; Restart" FontSize="12" Foreground="White"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Update status area -->
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                IsVisible="{Binding UpdateStatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12"
                                IsVisible="{Binding IsDownloadingUpdate}">
                        <ProgressBar Minimum="0" Maximum="100"
                                     Value="{Binding DownloadProgress}"
                                     Height="4" CornerRadius="2"
                                     VerticalAlignment="Center"
                                     MinWidth="200" />
                        <Button Command="{Binding CancelUpdateCommand}"
                                Classes="pill"
                                Padding="16,6"
                                VerticalAlignment="Center">
                            <TextBlock Text="Cancel" FontSize="12" />
                        </Button>
                    </StackPanel>

                    <!-- Row 2: GitHub + Discord (brand-coloured icons, hover pill) -->
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="-10,0,0,2">
                        <Button Classes="social-link social-github"
                                Command="{Binding OpenGitHubCommand}"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource StarIcon}"
                                          Width="14" Height="14"
                                          Foreground="#F1C40F" />
                                <TextBlock Text="Star on GitHub"
                                           FontSize="12" Opacity="0.85"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Classes="social-link social-discord"
                                Command="{Binding OpenDiscordCommand}"
                                Margin="-6,0,0,0"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{StaticResource DiscordIcon}"
                                          Width="14" Height="14"
                                          Foreground="#5865F2" />
                                <TextBlock Text="Join Discord"
                                           FontSize="12" Opacity="0.85"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1"
                            Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            Opacity="0.2" Margin="0,4"/>

                    <!-- Row 3: pre-release toggle -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,2">
                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Include pre-release updates" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Offer beta builds in the updater. Off = stable releases only."
                                       FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding IncludePrereleaseUpdates}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Signature -->
                    <TextBlock Text="Yours Truly, heartached."
                               FontSize="12" Opacity="0.4"/>
                </StackPanel>
            </Border>

            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- APPEARANCE                                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel x:Name="AppearanceTabPanel" IsVisible="{Binding IsAppearanceTabVisible}" Spacing="4">

            <Border Classes="setting-card" Padding="22,12">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Themes" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Choose how Noctis looks on your device."
                                   FontSize="12" Opacity="0.5"/>
                    </StackPanel>

                    <WrapPanel Orientation="Horizontal">
                        <WrapPanel.Styles>
                            <Style Selector="Button.theme-btn">
                                <Setter Property="Margin" Value="0,0,10,10"/>
                            </Style>
                        </WrapPanel.Styles>
                        <!-- Dark (pure black, silver accents) -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsDarkTheme}"
                                Command="{Binding SetDarkThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#000000"
                                        BorderBrush="#1A1A1A" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#E8E8E8" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#A8A8A8" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#707070" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Dark" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Gray (default) -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsGrayTheme}"
                                Command="{Binding SetGrayThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#1E1E1E"
                                        BorderBrush="#444" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#555" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#444" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#333" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Gray" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Midnight (deep blue-black) -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsMidnightTheme}"
                                Command="{Binding SetMidnightThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#0E1322"
                                        BorderBrush="#1E2640" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#7C8CFF" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#5A6BB0" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#3A4673" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Midnight" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Light -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsLightTheme}"
                                Command="{Binding SetLightThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        Background="#F5F5F5"
                                        BorderBrush="#CCC" BorderThickness="1">
                                    <StackPanel Margin="6,5" Spacing="3">
                                        <Border Height="3" Width="30" CornerRadius="1.5"
                                                Background="#CCC" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="20" CornerRadius="1.5"
                                                Background="#DDD" HorizontalAlignment="Left"/>
                                        <Border Height="3" Width="36" CornerRadius="1.5"
                                                Background="#E0E0E0" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Light" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- System -->
                        <Button Classes="theme-btn"
                                Classes.active="{Binding IsSystemTheme}"
                                Command="{Binding SetSystemThemeCommand}">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        BorderBrush="#888" BorderThickness="1">
                                    <Grid ColumnDefinitions="*,*">
                                        <Border Grid.Column="0" Background="#1E1E1E"
                                                CornerRadius="5,0,0,5">
                                            <StackPanel Margin="4,5,0,0" Spacing="3">
                                                <Border Height="3" Width="16" CornerRadius="1.5"
                                                        Background="#555" HorizontalAlignment="Left"/>
                                                <Border Height="3" Width="10" CornerRadius="1.5"
                                                        Background="#444" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Background="#F5F5F5"
                                                CornerRadius="0,5,5,0">
                                            <StackPanel Margin="2,5,0,0" Spacing="3">
                                                <Border Height="3" Width="16" CornerRadius="1.5"
                                                        Background="#CCC" HorizontalAlignment="Left"/>
                                                <Border Height="3" Width="10" CornerRadius="1.5"
                                                        Background="#DDD" HorizontalAlignment="Left"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="System" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- User-created themes -->
                        <ItemsControl ItemsSource="{Binding CustomThemes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CustomThemeTile">
                                    <Button Classes="theme-btn"
                                            Classes.active="{Binding IsActive}"
                                            Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ApplyCustomThemeCommand}"
                                            CommandParameter="{Binding Id}"
                                            Margin="0,0,10,10">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Edit"
                                                          Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).OpenThemeEditorCommand}"
                                                          CommandParameter="{Binding Id}"/>
                                                <MenuItem Header="Delete"
                                                          Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).DeleteCustomThemeCommand}"
                                                          CommandParameter="{Binding Id}"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                                            <Border Width="64" Height="40" CornerRadius="6"
                                                    Background="{Binding MainHex}"
                                                    BorderBrush="{Binding SidebarHex}"
                                                    BorderThickness="1">
                                                <StackPanel Margin="6,5" Spacing="3">
                                                    <Border Height="3" Width="30" CornerRadius="1.5"
                                                            Background="{Binding AccentHex}" HorizontalAlignment="Left"/>
                                                    <Border Height="3" Width="20" CornerRadius="1.5"
                                                            Background="{Binding SidebarHex}" HorizontalAlignment="Left"/>
                                                    <Border Height="3" Width="36" CornerRadius="1.5"
                                                            Background="{Binding SidebarHex}" Opacity="0.65"
                                                            HorizontalAlignment="Left"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       MaxWidth="64" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- "+ Custom" add tile -->
                        <Button Classes="theme-btn"
                                Command="{Binding OpenThemeEditorCommand}"
                                CommandParameter="{x:Null}"
                                Margin="0,0,10,10"
                                ToolTip.Tip="Create custom theme">
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <Border Width="64" Height="40" CornerRadius="6"
                                        BorderBrush="#55FFFFFF" BorderThickness="1">
                                    <TextBlock Text="+" FontSize="22" Opacity="0.7"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Custom" FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- Accent colour -->
            <Border Classes="setting-card">
                <StackPanel Spacing="16">

                    <!-- Header row -->
                    <Grid>
                        <StackPanel Spacing="2">
                            <TextBlock Text="Accent Color" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Pick a preset or open the picker for any custom color."
                                       FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>

                    <!-- Preset grid + custom-picker tile -->
                    <StackPanel Spacing="8">
                        <WrapPanel Orientation="Horizontal">
                            <!-- Preset swatches -->
                            <ItemsControl ItemsSource="{Binding AccentSwatches}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:AccentSwatch">
                                        <Button Classes="accent-swatch"
                                                Background="Transparent" BorderThickness="0" Padding="0"
                                                Margin="0,0,4,4" Cursor="Hand"
                                                ToolTip.Tip="{Binding Name}"
                                                Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).ApplyAccentPresetCommand}"
                                                CommandParameter="{Binding}">
                                            <Panel Width="44" Height="44">
                                                <Border Width="40" Height="40" CornerRadius="20"
                                                        Background="{Binding Hex}"
                                                        BorderBrush="#22000000"
                                                        BorderThickness="1"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Border Width="44" Height="44" CornerRadius="22"
                                                        BorderBrush="White" BorderThickness="2"
                                                        IsVisible="{Binding IsActive}"/>
                                            </Panel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Custom-color tile: rainbow ring + plus, opens reusable HSV/hex picker. -->
                            <Panel Width="58" Height="58" Margin="-55,100,0,0" VerticalAlignment="Top">
                                <controls:ColorPickerFlyout Hex="{Binding CustomAccentHex, Mode=TwoWay}"
                                                            SwatchSize="58"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            ToolTip.Tip="Custom Color"
                                                            Cursor="Hand">
                                    <controls:ColorPickerFlyout.SwatchContent>
                                        <Panel Width="58" Height="58">
                                            <!-- Rainbow ring -->
                                            <Border Width="40" Height="40" CornerRadius="20"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <ConicGradientBrush Center="50%,50%">
                                                        <GradientStop Offset="0.00" Color="#FF0000"/>
                                                        <GradientStop Offset="0.17" Color="#FFFF00"/>
                                                        <GradientStop Offset="0.33" Color="#00FF00"/>
                                                        <GradientStop Offset="0.50" Color="#00FFFF"/>
                                                        <GradientStop Offset="0.67" Color="#0000FF"/>
                                                        <GradientStop Offset="0.83" Color="#FF00FF"/>
                                                        <GradientStop Offset="1.00" Color="#FF0000"/>
                                                    </ConicGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!-- White inner disc with + glyph -->
                                            <Border Width="30" Height="30" CornerRadius="15"
                                                    Background="{DynamicResource AppMainBackground}"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="+"
                                                           FontSize="20" FontWeight="Light"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <Border Width="44" Height="44" CornerRadius="22"
                                                    BorderBrush="White" BorderThickness="2"
                                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                                    IsVisible="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).IsCustomAccentSelected}"/>
                                        </Panel>
                                    </controls:ColorPickerFlyout.SwatchContent>
                                </controls:ColorPickerFlyout>
                            </Panel>
                        </WrapPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Animated artwork -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Animated Artwork" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Show animated cover art when available."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding EnableAnimatedCovers}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Player bar opacity -->
            <Border Classes="setting-card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Player Bar Opacity" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Adjust the playback bar's background transparency. Higher is more solid and legible when it overlaps content."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <Slider Grid.Column="0"
                                Classes="accent-slider"
                                Minimum="0" Maximum="1"
                                Value="{Binding PlaybackBarBackgroundOpacity, Mode=TwoWay}"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding PlaybackBarBackgroundOpacity, StringFormat='{}{0:P0}'}"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center"
                                   MinWidth="44" TextAlignment="Right" Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- AUDIO                                               -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel x:Name="AudioTabPanel" IsVisible="{Binding IsAudioTabVisible}" Spacing="4">

            <TextBlock Classes="section-title" Text="PLAYBACK" Margin="0,4,0,10"/>

            <!-- Song Transitions (Apple-style; drives the AutoMix engine) -->
            <Border Classes="setting-card">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="Song Transitions" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Beginnings and endings of songs blend together seamlessly. Albums and some genres will still play without transitions."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding SongTransitionsEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Transition Style picker -->
                    <StackPanel Spacing="6" IsEnabled="{Binding SongTransitionsEnabled}">
                        <TextBlock Text="TRANSITION STYLE" FontSize="10" Opacity="0.45" Margin="2,4,0,2"/>

                        <RadioButton Classes="transition-card"
                                     GroupName="TransitionStyle"
                                     IsChecked="{Binding IsAutoMixStyle, Mode=TwoWay}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="AutoMix" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Songs transition at the perfect moment, based on analysis of the key and tempo of the music."
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Classes="transition-card"
                                     GroupName="TransitionStyle"
                                     IsChecked="{Binding IsCrossfadeStyle, Mode=TwoWay}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Crossfade" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Simple song transitions from one to the next for a set duration."
                                           FontSize="12" Opacity="0.55" TextWrapping="Wrap"/>
                            </StackPanel>
                        </RadioButton>

                        <!-- Crossfade Duration (only for the Crossfade style) -->
                        <StackPanel Spacing="6" Margin="2,4,0,0" IsVisible="{Binding IsCrossfadeStyle}">
                            <TextBlock Text="Crossfade Duration" FontSize="13" FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <Slider Grid.Column="0"
                                        Classes="accent-slider"
                                        Minimum="1" Maximum="12"
                                        Value="{Binding CrossfadeDuration, Mode=TwoWay}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding CrossfadeDuration, StringFormat='{}{0:0} seconds'}"
                                           FontSize="12" Opacity="0.7"
                                           VerticalAlignment="Center"
                                           MinWidth="74" TextAlignment="Right" Margin="12,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Sound Check -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Sound Check" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Keep song volume at a consistent level."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding SoundCheckEnabled}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Gapless playback -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Gapless Playback" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Pre-decode the next song so tracks flow into each other without a pause."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding GaplessPlaybackEnabled}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Exclusive mode (Windows WASAPI) -->
            <Border Classes="setting-card" IsVisible="{Binding IsExclusiveAudioSupported}">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Exclusive Mode" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Bit-perfect output: takes exclusive control of the audio device at the track's sample rate. Crossfade is unavailable while active; falls back to shared output if the device is busy."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ExclusiveAudioStatus}"
                                   IsVisible="{Binding ExclusiveAudioStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                   FontSize="12" Opacity="0.8" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding ExclusiveAudioEnabled}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Equalizer (lives under Playback — no redundant header) -->
            <Border Classes="setting-card" Padding="22,16,38,16" ClipToBounds="False">
                <StackPanel Spacing="16">
                    <!-- Header row with icon, preset selector, and reset button -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <StackPanel Grid.Column="0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Equalizer" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Parametric EQ — tune each band's frequency, gain, and width (Q)."
                                           FontSize="12" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>
                        <ComboBox Grid.Column="2"
                                  x:Name="EqPresetCombo"
                                  Classes="pill-combo stable-popup"
                                  Width="164"
                                  ItemsSource="{Binding VisibleEqPresets}"
                                  SelectedItem="{Binding SelectedEqPresetName}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0" />
                        <Button Grid.Column="3"
                                Classes="pill-action"
                                Command="{Binding ResetEqualizerCommand}"
                                CornerRadius="16"
                                Padding="14,8"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Reset"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Button>
                    </Grid>

                    <!-- Parametric band rows: frequency / gain / Q per band -->
                    <StackPanel Spacing="0" Margin="0,4,0,0">
                        <Grid ColumnDefinitions="120,*,64,92,34" Margin="0,0,0,4">
                            <TextBlock Grid.Column="0" Text="FREQUENCY" FontSize="10" Opacity="0.45"/>
                            <TextBlock Grid.Column="1" Text="GAIN" FontSize="10" Opacity="0.45" Margin="14,0,0,0"/>
                            <TextBlock Grid.Column="3" Text="Q" FontSize="10" Opacity="0.45" Margin="10,0,0,0"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding EqBands}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EqBandViewModel">
                                    <Grid ColumnDefinitions="120,*,64,92,34" Margin="0,3">
                                        <NumericUpDown Grid.Column="0"
                                                       Value="{Binding FrequencyHz}"
                                                       Minimum="20" Maximum="20000" Increment="10"
                                                       FormatString="0"
                                                       FontSize="12" MinHeight="0"
                                                       VerticalAlignment="Center"/>
                                        <Slider Grid.Column="1"
                                                Classes="accent-slider"
                                                Minimum="-12" Maximum="12"
                                                Value="{Binding GainDb}"
                                                TickFrequency="0.5" IsSnapToTickEnabled="True"
                                                Margin="14,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding GainLabel}"
                                                   FontSize="11" Opacity="0.7"
                                                   VerticalAlignment="Center" TextAlignment="Right"/>
                                        <NumericUpDown Grid.Column="3"
                                                       Value="{Binding Q}"
                                                       Minimum="0.1" Maximum="10" Increment="0.1"
                                                       FormatString="0.0#"
                                                       FontSize="12" MinHeight="0"
                                                       Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        <Button Grid.Column="4"
                                                Content="✕" FontSize="11" Padding="7,4"
                                                Background="Transparent" Cursor="Hand"
                                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                                IsEnabled="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).CanRemoveEqBand}"
                                                Command="{Binding $parent[UserControl].((vm:SettingsViewModel)DataContext).RemoveEqBandCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Remove band"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Classes="pill-action"
                                Command="{Binding AddEqBandCommand}"
                                IsEnabled="{Binding CanAddEqBand}"
                                CornerRadius="16"
                                Padding="14,8"
                                Margin="0,8,0,0"
                                Cursor="Hand"
                                HorizontalAlignment="Left">
                            <TextBlock Text="+ Add Band" FontSize="13" FontWeight="SemiBold"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>


            <TextBlock Classes="section-title" Text="AUDIO TOOLS" Margin="0,20,0,10"/>

            <Border Classes="setting-card">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="ffmpeg" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Used by the audio converter. Leave blank to auto-detect (next to Noctis, then PATH)."
                                   FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding FfmpegPath}"
                                 Watermark="(auto-detect)"
                                 CornerRadius="999"
                                 Padding="14,8"
                                 BorderThickness="1.5"
                                 MinHeight="0"
                                 KeyDown="OnFfmpegPathKeyDown" />
                        <Button Grid.Column="1"
                                Content="Browse"
                                Command="{Binding BrowseFfmpegCommand}"
                                Padding="14,8"
                                CornerRadius="999"
                                Margin="8,0,0,0"
                                Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="{Binding FfmpegStatus}"
                               FontSize="11" Opacity="0.6"
                               TextWrapping="Wrap"/>

                    <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Opacity="0.4" Margin="0,8,0,8"/>

                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="ReplayGain" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Scale per-track or per-album volume using REPLAYGAIN_* tags. Scan tracks first via right-click → Scan ReplayGain."
                                       FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding ReplayGainEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*" IsEnabled="{Binding ReplayGainEnabled}">
                        <TextBlock Grid.Column="0" Text="Mode" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1"
                                  Classes="pill-list"
                                  ItemsSource="{Binding ReplayGainModeOptions}"
                                  SelectedItem="{Binding ReplayGainMode}"
                                  HorizontalAlignment="Stretch"
                                  CornerRadius="999"
                                  Padding="14,8"/>
                    </Grid>
                    <Grid ColumnDefinitions="120,*,Auto">
                        <TextBlock Grid.Column="0" Text="Pre-amp (dB)" VerticalAlignment="Center"/>
                        <Grid Grid.Column="1" Height="20" ClipToBounds="False"
                              VerticalAlignment="Center" Margin="0,0,12,0">
                            <Canvas x:Name="PreampVisual"
                                    Height="20"
                                    ClipToBounds="False"
                                    IsHitTestVisible="False">
                                <Border x:Name="PreampTrackBackground"
                                        Height="6"
                                        CornerRadius="3"
                                        Background="{DynamicResource IslandSliderUnfilled}"
                                        Opacity="0.4"
                                        Canvas.Top="7"/>
                                <Border x:Name="PreampTrackFill"
                                        Height="6"
                                        CornerRadius="3"
                                        Background="{DynamicResource IslandSliderFilled}"
                                        Canvas.Top="7"/>
                                <Border x:Name="PreampThumb"
                                        Width="14"
                                        Height="14"
                                        CornerRadius="7"
                                        Background="{DynamicResource IslandSliderFilled}"
                                        BoxShadow="0 1 3 0 #40000000"
                                        Canvas.Top="3"/>
                            </Canvas>
                            <Slider x:Name="PreampSlider"
                                    Classes="preamp-horizontal"
                                    Value="{Binding ReplayGainPreampDb, Mode=TwoWay}"
                                    Minimum="-12" Maximum="12"
                                    HorizontalAlignment="Stretch"
                                    DoubleTapped="OnPreampSliderDoubleTapped" />
                        </Grid>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ReplayGainPreampDb, StringFormat='{}{0:+0.0;-0.0;0.0} dB'}"
                                   FontSize="12" Opacity="0.7"
                                   VerticalAlignment="Center" MinWidth="60"/>
                    </Grid>
                </StackPanel>
            </Border>

            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- INTEGRATIONS                                        -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel x:Name="IntegrationsTabPanel" IsVisible="{Binding IsIntegrationsTabVisible}" Spacing="4">

            <TextBlock Classes="section-title" Text="ACCOUNTS" Margin="0,4,0,10"/>

            <!-- Discord Rich Presence -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10"
                            Background="#5865F2" Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <Viewbox Width="22" Height="22"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="White"
                                      Data="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Discord Rich Presence" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Show your current song on Discord."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="2"
                                          IsChecked="{Binding DiscordRichPresenceEnabled}"
                                          VerticalAlignment="Center"
                                          Margin="12,0,0,0"/>
                </Grid>
            </Border>

            <!-- Last.fm -->
            <Border Classes="setting-card">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                Width="40" Height="40" CornerRadius="10"
                                Background="#D51007"
                                Margin="0,0,14,0"
                                VerticalAlignment="Top">
                            <Viewbox Width="22" Height="22"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="White"
                                          Data="M10.584 17.21l-.88-2.392s-1.43 1.594-3.573 1.594c-1.897 0-3.244-1.649-3.244-4.288 0-3.382 1.704-4.591 3.381-4.591 2.42 0 3.189 1.567 3.849 3.574l.88 2.749c.88 2.666 2.529 4.81 7.284 4.81 3.409 0 5.718-1.044 5.718-3.793 0-2.227-1.265-3.381-3.63-3.931l-1.758-.385c-1.21-.275-1.567-.77-1.567-1.595 0-.934.742-1.484 1.952-1.484 1.32 0 2.034.495 2.144 1.677l2.749-.33c-.22-2.474-1.924-3.492-4.729-3.492-2.474 0-4.893.935-4.893 3.932 0 1.87.907 3.051 3.189 3.601l1.87.44c1.402.33 1.869.907 1.869 1.704 0 1.017-.99 1.43-2.86 1.43-2.776 0-3.932-1.457-4.59-3.464l-.907-2.75c-1.155-3.573-2.997-4.893-6.653-4.893C2.144 5.333 0 7.89 0 12.233c0 4.18 2.144 6.434 5.993 6.434 3.106 0 4.591-1.457 4.591-1.457z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                    VerticalAlignment="Center" Spacing="2" Margin="0,0,12,0">
                            <TextBlock Text="Last.fm Scrobbling" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                            <TextBlock Text="Send plays to Last.fm."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap" MaxWidth="560"
                                       HorizontalAlignment="Left"
                                       Margin="-2,0,0,0"/>
                            <!-- ACCOUNT line sits inline with title/description so it pulls up tight
                                 against the description instead of dropping into its own grid row. -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding LastFmUsername, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        Margin="-2,2,0,0">
                                <TextBlock Text="ACCOUNT" FontSize="12" Opacity="0.45" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding LastFmUsername}" FontSize="12" Opacity="0.85" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Not connected state -->
                        <Button Grid.Column="2" Grid.Row="0"
                                IsVisible="{Binding !IsLastFmConnected}"
                                Content="Connect"
                                Classes="pill-action"
                                Command="{Binding LoginLastFmCommand}"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate>
                                    <ContentPresenter Background="{DynamicResource AccentColorBrush}"
                                                      Foreground="{DynamicResource AccentForegroundBrush}"
                                                      CornerRadius="16"
                                                      Padding="14,8"
                                                      FontSize="13"
                                                      FontWeight="SemiBold"
                                                      Content="{TemplateBinding Content}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <!-- Status text removed -->

                        <!-- Logout button (top-right, when connected) -->
                        <Button Grid.Column="2" Grid.Row="0"
                                IsVisible="{Binding IsLastFmConnected}"
                                Command="{Binding LogoutLastFmCommand}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Logout" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Enable Scrobbling (when connected) -->
                    <Grid IsVisible="{Binding IsLastFmConnected}" ColumnDefinitions="*,Auto" Margin="54,0,0,0">
                        <TextBlock Grid.Column="0"
                                   Text="Enable Scrobbling"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LastFmScrobblingEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ListenBrainz -->
            <Border Classes="setting-card">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">
                        <!-- Official multi-colour ListenBrainz logo (transparent PNG). It's the
                             hexagonal brand mark, so it stands on its own at the same 40×40 footprint
                             as the Discord / Last.fm tiles rather than sitting on a colour fill. -->
                        <Image Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                               Width="40" Height="40"
                               Margin="0,0,14,0"
                               VerticalAlignment="Top"
                               Source="avares://Noctis/Assets/Icons/ListenBrainz ICON.png"
                               RenderOptions.BitmapInterpolationMode="HighQuality"/>

                        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                    VerticalAlignment="Center" Spacing="2" Margin="0,0,12,0">
                            <TextBlock Text="ListenBrainz Scrobbling" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Left"/>
                            <TextBlock Text="Send plays to ListenBrainz."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap" MaxWidth="560"
                                       HorizontalAlignment="Left"
                                       Margin="-2,0,0,0"/>

                            <!-- ACCOUNT line sits inline with the title/description block so it pulls
                                 up tight against the description instead of dropping into its own grid row. -->
                            <StackPanel Orientation="Horizontal" Spacing="6"
                                        IsVisible="{Binding ListenBrainzUsername, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                        Margin="-2,2,0,0">
                                <TextBlock Text="ACCOUNT" FontSize="12" Opacity="0.45" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ListenBrainzUsername}" FontSize="12" Opacity="0.85" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Token row lives inside the same StackPanel as the title so it sits
                                 right under the description instead of leaving a gap. The Connect
                                 button is hoisted to column 2 (top-right) to match the Last.fm card. -->
                            <StackPanel IsVisible="{Binding !IsListenBrainzConnected}"
                                        Margin="-2,6,0,0"
                                        Spacing="4">
                                <TextBox x:Name="ListenBrainzTokenBox"
                                         Classes="metadata-info-field"
                                         Text="{Binding ListenBrainzToken}"
                                         PasswordChar="•"
                                         Watermark="ListenBrainz user token"
                                         FontSize="12"
                                         Width="280"
                                         HorizontalAlignment="Left"/>
                                <!-- Inline validation error (e.g. "Token required"), semantically red. -->
                                <TextBlock Text="{Binding ListenBrainzError}"
                                           IsVisible="{Binding ListenBrainzError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           Foreground="#E74856"
                                           FontSize="11"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Not connected state (top-right, mirrors the Last.fm Connect button) -->
                        <Button Grid.Column="2" Grid.Row="0"
                                IsVisible="{Binding !IsListenBrainzConnected}"
                                Content="Connect"
                                Classes="pill-action"
                                Command="{Binding TestListenBrainzCommand}"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Margin="0,0,0,4">
                            <Button.Template>
                                <ControlTemplate>
                                    <ContentPresenter Background="{DynamicResource AccentColorBrush}"
                                                      Foreground="{DynamicResource AccentForegroundBrush}"
                                                      CornerRadius="16"
                                                      Padding="14,8"
                                                      FontSize="13"
                                                      FontWeight="SemiBold"
                                                      Content="{TemplateBinding Content}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Logout button (top-right, when connected) -->
                        <Button Grid.Column="2" Grid.Row="0"
                                IsVisible="{Binding IsListenBrainzConnected}"
                                Command="{Binding LogoutListenBrainzCommand}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Logout" FontSize="13" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Enable Scrobbling (when connected) -->
                    <Grid IsVisible="{Binding IsListenBrainzConnected}" ColumnDefinitions="*,Auto" Margin="54,0,0,0">
                        <TextBlock Grid.Column="0"
                                   Text="Enable Scrobbling"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding ListenBrainzScrobblingEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Classes="section-title" Text="LYRICS" Margin="0,20,0,10"/>

            <Border Classes="setting-card">
                <StackPanel Spacing="10">
                    <TextBlock Text="Use online lyrics when local lyrics are missing."
                               FontSize="12" Opacity="0.5" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="LRCLIB" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Community lyrics database" FontSize="11" Opacity="0.5"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding LrcLibEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="NetEase Cloud Music" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="Large synced lyrics catalog" FontSize="11" Opacity="0.5"/>
                        </StackPanel>
                        <controls:LottieToggle Grid.Column="1"
                                              IsChecked="{Binding NetEaseEnabled}"
                                              VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>


            </StackPanel>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- LIBRARY (folders, scan, startup preferences)        -->
            <!-- ═══════════════════════════════════════════════════ -->
            <StackPanel x:Name="LibraryTabPanel" IsVisible="{Binding IsLibraryTabVisible}" Spacing="4">

            <Border Classes="setting-card">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Media Folder Locations" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Choose the folders where your music files are stored."
                                           FontSize="12" Opacity="0.5"/>
                                <TextBlock Text="Browse them by hierarchy in the Folders tab."
                                           FontSize="12" Opacity="0.4" FontStyle="Italic"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                x:Name="AddFolderButton"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Add Folder" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <!-- Folder list -->
                    <ItemsControl ItemsSource="{Binding MusicFolders}">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl:empty">
                                <Setter Property="IsVisible" Value="False"/>
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="sys:String">
                                <Border Padding="12,8" Margin="0,2" CornerRadius="6"
                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding}"
                                                   FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1"
                                                Content="&#x2715;"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).RemoveFolderCommand}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Opacity="0.5"
                                                Cursor="Hand"
                                                Padding="4"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Library Management (scan) -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Library Scan" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Find new tracks and update search."
                                       FontSize="12" Opacity="0.5"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ScanStatusText}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   VerticalAlignment="Center"/>
                        <Button Classes="pill-action"
                                Command="{Binding RescanCommand}"
                                IsEnabled="{Binding !IsScanning}"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand">
                            <TextBlock Text="Scan Library" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- Scan on startup (Library group) -->
            <Border Classes="setting-card">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Scan on Startup" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="Scan music folders when Noctis starts."
                                       FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <controls:LottieToggle Grid.Column="1"
                                          IsChecked="{Binding ScanOnStartup}"
                                          VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Snoozed tracks (hidden from shuffle + radio) -->
            <Border Classes="setting-card">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Snoozed Tracks" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock Text="Hidden from shuffle and radio until their snooze expires. Un-snooze to bring one back early."
                                   FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Text="No snoozed tracks."
                               FontSize="13" Opacity="0.45"
                               IsVisible="{Binding !HasSnoozedTracks}"/>

                    <ItemsControl ItemsSource="{Binding SnoozedTracks}">
                        <ItemsControl.Styles>
                            <Style Selector="ItemsControl:empty">
                                <Setter Property="IsVisible" Value="False"/>
                            </Style>
                        </ItemsControl.Styles>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Track">
                                <Border Padding="12,8" Margin="0,2" CornerRadius="6"
                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                    <Grid ColumnDefinitions="*,Auto,Auto">
                                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       FontSize="12" Opacity="0.55"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SnoozedUntil, StringFormat='Until {0:MMM d, yyyy}'}"
                                                   FontSize="12" Opacity="0.5"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0"/>
                                        <Button Grid.Column="2"
                                                Classes="pill-action"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).UnsnoozeCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="12,6"
                                                CornerRadius="14"
                                                Cursor="Hand"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="Un-snooze" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- LIBRARY OVERVIEW                                   -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="LIBRARY OVERVIEW" Margin="0,20,0,10"/>

            <Border Classes="setting-card">
                <StackPanel Spacing="18">
                    <TextBlock Text="Your Music Library" FontSize="15" FontWeight="SemiBold"/>

                    <!-- Primary stats: Songs · Artists · Albums · Listening Time -->
                    <UniformGrid Columns="4" Margin="0,2,0,0">
                        <Border CornerRadius="10" Padding="14,16" Margin="0,0,8,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalSongs}"
                                           FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Songs" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,16" Margin="4,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalArtists}"
                                           FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Artists" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,16" Margin="4,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalAlbums}"
                                           FontSize="24" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Albums" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="10" Padding="14,16" Margin="8,0,0,0"
                                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding TotalListeningTime}"
                                           FontSize="20" FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="Listening Time" FontSize="11" Opacity="0.55"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Audio Quality: smaller chips, Hi-Res accented -->
                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <TextBlock Text="Audio Quality" FontSize="12" Opacity="0.55"
                                   FontWeight="SemiBold" Classes="section-title"/>
                        <Grid ColumnDefinitions="*,*,*">
                            <Border Grid.Column="0" CornerRadius="8" Padding="12,10" Margin="0,0,6,0"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LosslessCount}"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Lossless" FontSize="11" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" CornerRadius="8" Padding="12,10" Margin="3,0"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding HiResCount}"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Hi-Res Lossless" FontSize="11" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" CornerRadius="8" Padding="12,10" Margin="6,0,0,0"
                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                <StackPanel Spacing="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding LossyCount}"
                                               FontSize="17" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Lossy" FontSize="11" Opacity="0.55"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <!-- Playlists footer (text-only so 0 doesn't dominate) -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="{Binding TotalPlaylists}" FontSize="12"
                                   FontWeight="SemiBold" Opacity="0.7"/>
                        <TextBlock Text="playlists" FontSize="12" Opacity="0.55"/>
                    </StackPanel>
                </StackPanel>
            </Border>


            <!-- Disk usage (Library Overview group) -->
            <Border Classes="setting-card">
                <StackPanel Spacing="14">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <StackPanel Grid.Column="0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Disk Usage" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Space used by Noctis data on your system."
                                           FontSize="12" Opacity="0.5"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Command="{Binding OpenDataFolderCommand}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Open Data Folder" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <StackPanel Spacing="8" Margin="0,4,0,0">
                        <!-- Library size (music files on disk) -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Library Size"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding TotalFileSize}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Library data -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Library Data"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageLibraryData}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Artwork cache -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Artwork Cache"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageArtwork}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Playlists -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Playlists"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StoragePlaylists}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                        <!-- Settings -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Settings"
                                       FontSize="13" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageSettings}"
                                       FontSize="13" Opacity="0.6" VerticalAlignment="Center" />
                        </Grid>
                        <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3"/>

                        <!-- Total -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                            <TextBlock Grid.Column="0" Text="Total"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="{Binding StorageTotal}"
                                       FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </Border>


            <!-- ═══════════════════════════════════════════════════ -->
            <!-- ADVANCED                                           -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TextBlock Classes="section-title" Text="ADVANCED" Margin="0,20,0,10"/>

            <!-- Combined Advanced card (Reset · Fetch Images · Clear Cache) -->
            <Border Classes="setting-card">
                <StackPanel Spacing="14">

                    <!-- Reset Settings -->
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Reset Settings" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="Restore defaults and clear saved library data."
                                               FontSize="12" Opacity="0.5"/>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Command="{Binding ShowResetConfirmCommand}"
                                    IsVisible="{Binding !IsResetConfirmVisible}"
                                    Classes="pill-action"
                                    Padding="14,8"
                                    CornerRadius="16"
                                    Cursor="Hand"
                                    VerticalAlignment="Center">
                                <TextBlock Text="Reset Settings" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                        <StackPanel IsVisible="{Binding IsResetConfirmVisible}" Spacing="8">
                            <TextBlock Text="Are you sure? This action cannot be undone."
                                       FontSize="13" Foreground="#E74856"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Cancel"
                                        Command="{Binding CancelResetCommand}"
                                        Classes="pill-action"
                                        Padding="16,10"
                                        CornerRadius="18"
                                        Cursor="Hand"/>
                                <Button Content="Reset Everything"
                                        Command="{Binding ConfirmResetLibraryCommand}"
                                        Classes="pill-action danger"
                                        Padding="16,10"
                                        CornerRadius="18"
                                        Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                    <!-- Fetch Artist Images -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Fetch Artist Images" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Download missing artist profile images from Deezer."
                                           FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding FetchArtistImagesCommand}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Fetch Images" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                    <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.2"/>

                    <!-- Clear Artwork Cache -->
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Clear Artwork Cache" FontSize="15" FontWeight="SemiBold"/>
                                <TextBlock Text="Delete cached artwork. It will rebuild on the next scan."
                                            FontSize="12" Opacity="0.5" TextWrapping="Wrap"/>
                                <TextBlock Text="Note: This removes all artwork from your library."
                                           FontSize="12" Foreground="#E74856" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Command="{Binding ClearArtworkCacheCommand}"
                                Classes="pill-action"
                                Padding="14,8"
                                CornerRadius="16"
                                Cursor="Hand"
                                VerticalAlignment="Center">
                            <TextBlock Text="Clear Cache" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
    </Grid>

</UserControl>


