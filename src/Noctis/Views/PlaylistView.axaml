<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:controls="using:Noctis.Controls"
             xmlns:conv="using:Noctis.Converters"
             xmlns:helpers="using:Noctis.Helpers"
             x:Class="Noctis.Views.PlaylistView"
             x:DataType="vm:PlaylistViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:ArtworkPathConverter x:Key="ArtworkConverter" />
        <conv:HexColorToBrushConverter x:Key="HexColorConverter" />
        <conv:GuidEqualsConverter x:Key="GuidEquals" />
        <conv:TrackPlaylistCommandParameterConverter x:Key="TrackPlaylistParamConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.featured-artist-tile:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)" />
        </Style>
        <Style Selector="Button.featured-artist-tile:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.featured-artist-tile:pressed">
            <Setter Property="RenderTransform" Value="scale(1)" />
        </Style>
        <Style Selector="Button.featured-artist-tile:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.neutral-desc-btn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1)" />
        </Style>
        <Style Selector="Button.neutral-desc-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>
        <Style Selector="Button.neutral-desc-btn:pressed">
            <Setter Property="RenderTransform" Value="scale(1)" />
        </Style>
        <Style Selector="Button.neutral-desc-btn:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">
        <DockPanel Grid.Row="0">

            <!-- ═══════════════ Playlist Header ═══════════════ -->
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="Auto,*,Auto"
                  Margin="24,16,24,20">

                <!-- Cover art: color tile + icon, or custom cover art -->
                <Border Grid.Column="0"
                        Width="340" Height="340"
                        CornerRadius="6"
                        ClipToBounds="True"
                        Margin="0,0,28,0"
                        BoxShadow="0 4 16 0 #40000000">
                    <Panel>
                        <!-- Colored background -->
                        <Border Background="{Binding PlaylistColor, Converter={StaticResource HexColorConverter}}" />
                        <!-- Fallback playlist icon -->
                        <PathIcon Data="{StaticResource PlaylistsIcon}"
                                  Width="56" Height="56"
                                  Foreground="#4DFFFFFF"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding ShowFallbackIcon}" />
                        <!-- Single album art -->
                        <controls:CachedImage SourcePath="{Binding Art1}"
                                              Stretch="UniformToFill"
                                              IsVisible="{Binding HasSingleArt}" />
                        <!-- 2x2 collage -->
                        <Grid RowDefinitions="*,*"
                              ColumnDefinitions="*,*"
                              IsVisible="{Binding HasCollageArt}">
                            <controls:CachedImage Grid.Row="0" Grid.Column="0"
                                                  SourcePath="{Binding Art1}"
                                                  Stretch="UniformToFill" />
                            <controls:CachedImage Grid.Row="0" Grid.Column="1"
                                                  SourcePath="{Binding Art2}"
                                                  Stretch="UniformToFill" />
                            <controls:CachedImage Grid.Row="1" Grid.Column="0"
                                                  SourcePath="{Binding Art3}"
                                                  Stretch="UniformToFill" />
                            <controls:CachedImage Grid.Row="1" Grid.Column="1"
                                                  SourcePath="{Binding Art4}"
                                                  Stretch="UniformToFill" />
                        </Grid>
                        <!-- Custom cover art (highest priority) -->
                        <controls:CachedImage SourcePath="{Binding PlaylistCoverArtPath}"
                                              Stretch="UniformToFill"
                                              IsVisible="{Binding HasCustomArt}" />
                    </Panel>
                </Border>

                <!-- Info column -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="4">

                    <!-- Playlist name -->
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="2"
                                   TextWrapping="Wrap"
                                   MaxWidth="800" />
                        <Border Background="#E74856" CornerRadius="999" Padding="10,4"
                                VerticalAlignment="Center"
                                IsVisible="{Binding IsSmartPlaylist}">
                            <TextBlock Text="Smart" FontSize="11" Foreground="White"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <!-- Stats line -->
                    <TextBlock FontSize="13" Opacity="0.5" Margin="0,2,0,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0} · {1} tracks · {2}">
                                <Binding Path="CreatedDateDisplay" />
                                <Binding Path="TrackCount" />
                                <Binding Path="TotalDuration" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <!-- Description (clickable) -->
                    <Button Classes="neutral-desc-btn"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            MinHeight="0"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand"
                            MaxWidth="500"
                            Margin="0,6,24,0"
                            Command="{Binding OpenDescriptionCommand}"
                            ToolTip.Tip="View playlist description"
                            IsVisible="{Binding HasDescription}">
                        <TextBlock Text="{Binding PlaylistDescription}"
                                   FontSize="14"
                                   Opacity="0.72"
                                   TextWrapping="Wrap"
                                   MaxLines="4"
                                   TextTrimming="CharacterEllipsis" />
                    </Button>

                    <!-- Play + Shuffle + Options -->
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,14,0,0">
                        <Button Command="{Binding PlayAllCommand}"
                                Padding="20,10"
                                CornerRadius="999"
                                Classes="accent-btn"
                            Background="#E74856"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource PlaySolidIcon}"
                                         Width="16" Height="16"
                                         Foreground="White"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Play"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ShuffleAllCommand}"
                                Padding="20,10"
                                CornerRadius="999"
                                Classes="accent-btn"
                            Background="#E74856"
                                Foreground="White"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="{StaticResource ShuffleIcon}"
                                         Width="16" Height="16"
                                         Foreground="White"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="Shuffle"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- ═══════════════ 3-dot Options Button ═══════════════ -->
                <Button Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        Width="32" Height="32"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Cursor="Hand"
                        ToolTip.Tip="Options">
                    <PathIcon Data="{StaticResource MoreDotsIcon}"
                             Width="14" Height="14"
                             Foreground="#E74856"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuItem Command="{Binding PlayAllCommand}"
                                      MaxWidth="400">
                                <MenuItem.Header>
                                    <TextBlock Text="Play"
                                               TextTrimming="CharacterEllipsis"
                                               FontWeight="Normal"
                                               FontSize="14"
                                               FontFamily="{Binding $parent[MenuItem].FontFamily}" />
                                </MenuItem.Header>
                                <MenuItem.Icon>
                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Shuffle"
                                      Command="{Binding ShuffleAllCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="{StaticResource ShuffleIcon}" Width="14" Height="14" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Play Next"
                                      Command="{Binding PlayNextAllCommand}">
                                <MenuItem.Icon>
                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Forward%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="Add to Queue"
                                      Command="{Binding AddAllToQueueCommand}">
                                <MenuItem.Icon>
                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Edit Playlist"
                                      Command="{Binding EditPlaylistCommand}">
                                <MenuItem.Icon>
                                    <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Edit%20Playlist%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                </MenuItem.Icon>
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="Delete Playlist"
                                      Command="{Binding DeletePlaylistCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                                </MenuItem.Icon>
                            </MenuItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <!-- ═══════════════ Column Headers ═══════════════ -->
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="48,2*,1.2*,1.2*,0.8*,70,40"
                  Margin="32,0,32,6">
                <TextBlock Grid.Column="1" Text="Song"
                           FontSize="12" FontWeight="SemiBold" Opacity="0.5"
                           Margin="12,0,0,0" />
                <TextBlock Grid.Column="2" Text="Artist"
                           FontSize="12" FontWeight="SemiBold" Opacity="0.5" />
                <TextBlock Grid.Column="3" Text="Album"
                           FontSize="12" FontWeight="SemiBold" Opacity="0.5" />
                <TextBlock Grid.Column="4" Text="Genre"
                           FontSize="12" FontWeight="SemiBold" Opacity="0.5" />
                <TextBlock Grid.Column="5" Text="Duration"
                           FontSize="12" FontWeight="SemiBold" Opacity="0.5"
                           HorizontalAlignment="Right" />
                <TextBlock Grid.Column="6" />
            </Grid>

            <Separator DockPanel.Dock="Top" Margin="24,0,24,2" />

            <Grid RowDefinitions="*,Auto">
                <!-- ═══════════════ Track List ═══════════════ -->
                <Grid Grid.Row="0" x:Name="TrackListWrapper" Margin="24,0,24,0">
                    <ListBox Classes="track-list"
                             ItemsSource="{Binding Tracks}"
                             x:Name="TrackList"
                             DragDrop.AllowDrop="True">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Focusable" Value="False" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:Track">
                                <Grid ColumnDefinitions="48,2*,1.2*,1.2*,0.8*,70,40"
                                      Margin="0,1" Background="Transparent"
                                      helpers:DragFileBehavior.EnableFileDrag="True">

                                <!-- Cover art thumbnail -->
                                <Border Grid.Column="0"
                                        Width="40" Height="40"
                                        CornerRadius="4"
                                        ClipToBounds="True"
                                        VerticalAlignment="Center"
                                        Background="#18FFFFFF">
                                    <Panel>
                                        <!-- Fallback icon -->
                                        <PathIcon Data="{StaticResource SongsIcon}"
                                                  Width="16" Height="16"
                                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsVisible="{Binding !HasAlbumArt}" />
                                        <!-- Album art -->
                                        <controls:CachedImage SourcePath="{Binding AlbumArtworkPath}"
                                                              Stretch="UniformToFill"
                                                              IsVisible="{Binding HasAlbumArt}" />
                                    </Panel>
                                </Border>

                                <!-- Song title -->
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal" Spacing="6"
                                            Margin="12,3,12,3"
                                            VerticalAlignment="Center">
                                    <controls:HighlightTextBlock Classes="one-line-explicit-title"
                                                                 DisplayText="{Binding TitleDisplay}"
                                                                 HighlightText="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).SearchText}"
                                                                 FontSize="13"
                                                                 FontWeight="SemiBold" />
                                    <Border Classes="explicit-badge compact"
                                            IsVisible="{Binding IsExplicit}"
                                            ToolTip.Tip="Explicit">
                                        <TextBlock Text="E"
                                                   Classes="explicit-badge-text compact"
                                                   FontSize="9"
                                                   Opacity="0.9" />
                                    </Border>
                                </StackPanel>

                                <!-- Artist (clickable, red) -->
                                <Button Grid.Column="2"
                                        Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                                        Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Command="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).ViewArtistCommand}"
                                        CommandParameter="{Binding Artist}">
                                    <controls:HighlightTextBlock DisplayText="{Binding ArtistDisplay}"
                                                                 HighlightText="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).SearchText}"
                                                                 FontSize="12"
                                                                 Foreground="#E74856"
                                                                 TextTrimming="CharacterEllipsis"
                                                                 VerticalAlignment="Center" />
                                </Button>

                                <!-- Album (clickable, red) -->
                                <Button Grid.Column="3"
                                        Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                                        Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Command="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).ViewAlbumCommand}"
                                        CommandParameter="{Binding}">
                                    <controls:HighlightTextBlock DisplayText="{Binding Album}"
                                                                 HighlightText="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).SearchText}"
                                                                 FontSize="12"
                                                                 Foreground="#E74856"
                                                                 TextTrimming="CharacterEllipsis"
                                                                 VerticalAlignment="Center" />
                                </Button>

                                <!-- Genre -->
                                <controls:HighlightTextBlock Grid.Column="4"
                                                             DisplayText="{Binding Genre}"
                                                             HighlightText="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).SearchText}"
                                                             FontSize="12"
                                                             Opacity="0.45"
                                                             TextTrimming="CharacterEllipsis"
                                                             VerticalAlignment="Center" />

                                <!-- Duration + favorite heart -->
                                <StackPanel Grid.Column="5"
                                            Orientation="Horizontal" Spacing="6"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <PathIcon Data="{StaticResource HeartFillIcon}"
                                             Width="11" Height="11"
                                             Foreground="#E74856"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding IsFavorite}" />
                                    <TextBlock Text="{Binding DurationFormatted}"
                                               FontSize="12"
                                               Opacity="0.5" />
                                </StackPanel>

                                <!-- 3-dots menu -->
                                <Button Grid.Column="6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        Width="32" Height="32"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Cursor="Hand"
                                        ToolTip.Tip="Options"
                                        Tag="{Binding}"
                                        Click="OnOptionsButtonClick">
                                    <PathIcon Data="{StaticResource MoreDotsIcon}"
                                             Width="14" Height="14"
                                             Foreground="#E74856"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Drop indicator line for drag reorder -->
                    <Border x:Name="PlaylistDropIndicator"
                            IsHitTestVisible="False"
                            IsVisible="False"
                            Height="2"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Margin="8,0"
                            CornerRadius="1"
                            Background="{DynamicResource AccentColorBrush}">
                        <Border.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </Border.RenderTransform>
                    </Border>

                    <!-- Empty state: manual playlists -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!Tracks.Count" />
                                <Binding Path="IsManualPlaylist" />
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <TextBlock Text="This playlist is empty"
                                   FontSize="16"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock Text="Drag tracks here from the library"
                                   FontSize="13"
                                   Opacity="0.3"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </StackPanel>

                    <!-- Empty state: smart playlists -->
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                        <StackPanel.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="!Tracks.Count" />
                                <Binding Path="IsSmartPlaylist" />
                            </MultiBinding>
                        </StackPanel.IsVisible>
                        <TextBlock Text="No tracks match the current rules"
                                   FontSize="16"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock Text="Try adjusting the smart playlist rules"
                                   FontSize="13"
                                   Opacity="0.3"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- ═══════════════ Featured Artists ═══════════════ -->
                <Border Grid.Row="1"
                        Margin="0,28,0,28"
                        Padding="0,20,0,26"
                        Background="#14FFFFFF"
                        IsVisible="{Binding HasFeaturedArtists}">
                    <StackPanel Spacing="18"
                                HorizontalAlignment="Left"
                                Margin="48,0,0,0">
                        <Button Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                MinHeight="0"
                                HorizontalAlignment="Center"
                                HorizontalContentAlignment="Center"
                                Cursor="Hand"
                                Command="{Binding OpenFeaturedArtistsCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock Text="Featured Artists"
                                           FontSize="18"
                                           FontWeight="Bold" />
                                <TextBlock Text="&#xE76C;"
                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                           FontSize="13"
                                           Opacity="0.55"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding FeaturedArtists}"
                                          HorizontalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="26" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PlaylistFeaturedArtist">
                                        <Button Classes="featured-artist-tile"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                Width="118"
                                                Cursor="Hand"
                                                Command="{Binding $parent[UserControl].((vm:PlaylistViewModel)DataContext).ViewArtistCommand}"
                                                CommandParameter="{Binding Name}">
                                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                                <Border Width="108"
                                                        Height="108"
                                                        CornerRadius="54"
                                                        ClipToBounds="True"
                                                        Background="#2E2E2E">
                                                    <Panel>
                                                        <controls:CachedImage SourcePath="{Binding ImagePath}"
                                                                              Stretch="UniformToFill"
                                                                              Width="108"
                                                                              Height="108"
                                                                              IsVisible="{Binding ImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                        <PathIcon Data="{StaticResource ArtistsIcon}"
                                                                  Width="34"
                                                                  Height="34"
                                                                  Foreground="#66FFFFFF"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  IsVisible="{Binding ImagePath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                    </Panel>
                                                </Border>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxWidth="118" />
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>

        </DockPanel>

    <!-- ═══════════════ Description Overlay ═══════════════ -->
    <!-- Playlist description popup is now shown via PlaylistDescriptionDialog window -->
    </Grid>

</UserControl>
