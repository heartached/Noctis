<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:presenters="using:Avalonia.Controls.Presenters"
        xmlns:vm="using:Noctis.ViewModels"
        xmlns:controls="using:Noctis.Controls"
        x:Class="Noctis.Views.MetadataWindow"
        x:DataType="vm:MetadataViewModel"
        Title="Studio"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False">

    <Window.Styles>
        <!-- Circular loading spinner (matches the Scan Library indicator): a rotating arc. -->
        <Style Selector="Ellipse.loading-spinner">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Stroke" Value="{DynamicResource AccentColorBrush}"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeDashArray" Value="11,5"/>
            <Setter Property="StrokeLineCap" Value="Round"/>
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Style.Animations>
                <Animation Duration="0:0:0.85" IterationCount="INFINITE" Easing="LinearEasing">
                    <KeyFrame Cue="0%"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="TextBox.metadata-info-field">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeWhiteBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="TextBox.metadata-info-field /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style Selector="TextBox.metadata-info-field:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style Selector="TextBox.metadata-info-field:focus-within /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <!-- Greyed out when disabled (e.g. start/stop time whose checkbox is unticked) -->
        <Style Selector="TextBox.metadata-info-field:disabled">
            <Setter Property="Opacity" Value="0.4" />
        </Style>

        <Style Selector="AutoCompleteBox.metadata-info-field">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="AutoCompleteBox.metadata-info-field /template/ TextBox#PART_TextBox">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeWhiteBrush}" />
        </Style>

        <Style Selector="AutoCompleteBox.metadata-info-field /template/ TextBox#PART_TextBox /template/ Border#PART_BorderElement">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style Selector="AutoCompleteBox.metadata-info-field /template/ TextBox#PART_TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style Selector="AutoCompleteBox.metadata-info-field:focus-within /template/ TextBox#PART_TextBox /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColorBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
        </Style>

        <Style Selector="ComboBox.metadata-info-field">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="UseLayoutRounding" Value="True" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeWhiteBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="ComboBox.metadata-info-field /template/ Border#Background">
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="ComboBox.metadata-info-field /template/ Border#HighlightBackground">
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <!-- Pill-shaped hover/selection highlight for dropdown items, matching the
             rounded menu highlight used elsewhere. Inset via margin so the pill
             doesn't bleed to the popup edges, and round the background presenter. -->
        <Style Selector="ComboBoxItem">
            <Setter Property="Margin" Value="4,1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="CornerRadius" Value="999" />
        </Style>
        <Style Selector="ComboBoxItem /template/ ContentPresenter">
            <Setter Property="CornerRadius" Value="999" />
        </Style>

        <!-- Sidebar tab rows: full-width vertical list, accent bar + tint when selected -->
        <Style Selector="TabItem">
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="SidebarRow"
                            Background="Transparent"
                            CornerRadius="9"
                            Cursor="Hand">
                        <Panel>
                            <Border x:Name="SelectionIndicator"
                                    Width="3"
                                    CornerRadius="2"
                                    Margin="4,9"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Stretch"
                                    Background="{DynamicResource AccentColorBrush}"
                                    IsVisible="False" />
                            <TextBlock Text="{TemplateBinding Header}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Margin="14,7,10,7"
                                       TextTrimming="CharacterEllipsis" />
                        </Panel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TabItem:pointerover /template/ Border#SidebarRow">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>

        <Style Selector="TabItem:selected /template/ Border#SidebarRow">
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>

        <Style Selector="TabItem:selected /template/ Border#SelectionIndicator">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="TabItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>

        <!-- Per-line nudge / clear buttons in the Synced Lyrics inline editor -->
        <Style Selector="Button.synced-nudge">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Width" Value="21" />
            <Setter Property="Height" Value="19" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.synced-nudge:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
        <Style Selector="Button.synced-nudge:disabled">
            <Setter Property="Opacity" Value="0.35" />
        </Style>

        <!-- Calm rows for the Timestamp Lyrics tab: each line stays quiet until you
             hover or edit it. Hovering brings its nudge/clear cluster to full strength;
             focusing the timestamp marks the line with an accent bar. -->
        <Style Selector="Border.synced-row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="0,7" />
            <Setter Property="Margin" Value="0,1" />
        </Style>
        <Style Selector="Border.synced-row:pointerover">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>
        <Style Selector="Border.synced-row:focus-within">
            <Setter Property="Background" Value="#1FFFFFFF" />
        </Style>

        <Style Selector="Border.synced-accent">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Background" Value="{DynamicResource AccentColorBrush}" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.synced-row:focus-within Border.synced-accent">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="StackPanel.synced-ctl">
            <Setter Property="Opacity" Value="0.16" />
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.synced-row:pointerover StackPanel.synced-ctl">
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Border.synced-row:focus-within StackPanel.synced-ctl">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <!-- Tab nav: vertical sidebar list on the left, selected content on the right. -->
        <Style Selector="TabControl">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <Grid ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    Width="200"
                                    Padding="10,14"
                                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="0,0,1,0">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter Name="PART_ItemsPresenter"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}" />
                                </ScrollViewer>
                            </Border>
                            <ContentPresenter Name="PART_SelectedContentHost"
                                              Grid.Column="1"
                                              Content="{TemplateBinding SelectedContent}"
                                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="ItemsPanel">
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter>
        </Style>

        <!-- Metadata volume slider uses custom visuals; the real Slider is transparent hit testing. -->
        <Style Selector="Slider.volume-horizontal">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource IslandSliderFilled}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <!-- Chromeless presenter for the artwork/animated search popups: the card
             inside draws all chrome, so the default flyout box must vanish.
             Padding leaves room for the card's drop shadow. -->
        <Style Selector="FlyoutPresenter.search-pop">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="MaxWidth" Value="680"/>
            <Setter Property="MaxHeight" Value="680"/>
        </Style>

    </Window.Styles>

    <!-- Full-window dimmed overlay that captures all input -->
    <Border Background="#50000000"
            PointerPressed="OnOverlayPointerPressed"
            PointerWheelChanged="OnOverlayWheel">

        <!-- Centered dialog card -->
        <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                CornerRadius="16"
                ClipToBounds="True"
                Width="852" Height="740"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BoxShadow="0 8 32 0 #80000000, 0 0 0 1 #33FFFFFF">

    <Grid Margin="0" RowDefinitions="Auto,*,Auto">

        <!-- Header: artwork + track title, artist, album -->
        <Border Grid.Row="0" DockPanel.Dock="Top"
                Padding="24,20,24,16"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
            <Grid ColumnDefinitions="104,16,*,Auto">
                <Border Grid.Column="0"
                        Width="104" Height="104"
                        CornerRadius="8"
                        ClipToBounds="True"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                    <Panel>
                        <TextBlock Text="Album"
                                   FontSize="11"
                                   Opacity="0.35"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding ShowAlbumArtPlaceholderText}" />
                        <PathIcon Data="{StaticResource SongsIcon}"
                                  Width="40" Height="40"
                                  Opacity="0.4"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding IsMultiSelect}" />
                        <Image Source="{Binding ArtworkPreview}"
                               Stretch="UniformToFill"
                               IsVisible="{Binding HasArtwork}" />
                    </Panel>
                </Border>

                <StackPanel Grid.Column="2"
                            Spacing="2"
                            VerticalAlignment="Center">
                    <Grid ColumnDefinitions="Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   Classes="one-line-explicit-title"
                                   Text="{Binding HeaderTitle}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   MaxWidth="350" />
                        <Border Grid.Column="1"
                                Classes="explicit-badge"
                                Margin="8,0,0,0"
                                IsVisible="{Binding HeaderIsExplicit}"
                                ToolTip.Tip="Explicit">
                            <TextBlock Text="E"
                                       Classes="explicit-badge-text"
                                       FontSize="9"
                                       Opacity="0.9" />
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding HeaderArtist}"
                               FontSize="13"
                               Opacity="0.7" />
                    <TextBlock Text="{Binding HeaderAlbum}"
                               FontSize="13"
                               Opacity="0.5" />

                    <!-- Audio quality badge: Lossless / Hi-Res Lossless / codec -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                IsVisible="{Binding HeaderAudioQualityBadge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <ToolTip.Tip>
                            <StackPanel Width="220" Spacing="4">
                                <TextBlock Text="{Binding HeaderAudioQualityBadge}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                                <TextBlock Text="{Binding HeaderAudioQualityDetail}"
                                           FontSize="12"
                                           Opacity="0.9"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                                <TextBlock Text="{Binding HeaderAudioQualityDescription}"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           Opacity="0.85"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
                            </StackPanel>
                        </ToolTip.Tip>
                        <Viewbox Width="16" Height="11" VerticalAlignment="Center" Margin="0,1,0,0" Opacity="0.5">
                            <Path Data="M8.184,0.35C9.944,0.35 10.703,3.296 11.338,5.238C11.673,3.842 11.497,3.542 11.857,3.542C11.99,3.542 12.126,3.633 12.126,3.798C12.126,3.809 12.123,3.839 12.117,3.883L12.091,4.058C12.02,4.522 11.845,5.494 11.654,6.144C13.198,10.191 14.345,4.861 14.474,3.772C14.493,3.615 14.612,3.542 14.731,3.542C14.891,3.542 15.022,3.662 14.997,3.843C14.72,5.605 14.295,8.35 12.547,8.35C11.582,8.35 11.04,7.595 10.611,6.73C9.54,4.626 9.047,1.093 7.997,1.093C7.66,1.093 7.411,1.444 7.394,1.444C7.362,1.444 7.337,1.301 7.023,0.909C7.322,0.567 7.734,0.35 8.184,0.35ZM2.458,0.354C5.211,0.354 5.456,7.618 7.014,7.618C7.197,7.618 7.394,7.507 7.61,7.256C7.729,7.458 7.851,7.638 7.978,7.796C7.667,8.151 7.28,8.35 6.795,8.35C5.054,8.349 4.306,5.434 3.663,3.466C3.511,4.097 3.432,4.669 3.402,4.925C3.382,5.088 3.263,5.163 3.143,5.163C3.009,5.163 2.874,5.071 2.874,4.908L2.874,4.908L2.877,4.87C2.966,4.223 3.146,3.243 3.347,2.56C3.079,1.858 2.745,1.091 2.252,1.091C1.257,1.091 0.687,3.591 0.527,4.925C0.508,5.088 0.388,5.163 0.268,5.163C0.135,5.163 0,5.071 0,4.908C0,4.896 0.001,4.883 0.002,4.87C0.283,2.836 0.808,0.354 2.458,0.354ZM5.315,0.35C5.809,0.35 6.339,0.608 6.797,1.211C6.822,1.241 7.078,1.639 7.159,1.777C8.277,3.802 8.818,7.627 9.881,7.627C10.065,7.627 10.264,7.513 10.484,7.256C10.604,7.458 10.726,7.638 10.852,7.796C10.542,8.15 10.155,8.35 9.67,8.35C6.933,8.349 6.636,1.09 5.128,1.09C4.788,1.09 4.536,1.444 4.519,1.444C4.487,1.444 4.462,1.301 4.148,0.909C4.455,0.558 4.87,0.35 5.315,0.35Z"
                                  Fill="{DynamicResource SystemControlForegroundBaseHighBrush}" />
                        </Viewbox>
                        <TextBlock Text="{Binding HeaderAudioQualityBadge}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Opacity="0.5" />
                    </StackPanel>
                </StackPanel>

                <!-- Favorite indicator -->
                <PathIcon Grid.Column="3"
                          Data="{StaticResource HeartFillIcon}"
                          Width="20" Height="20"
                          Foreground="#E74856"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Right"
                          IsVisible="{Binding HeaderIsFavorite}"
                          ToolTip.Tip="Favorited" />
            </Grid>
        </Border>

        <!-- Bottom: Cancel / Save buttons -->
        <Border Grid.Row="2" DockPanel.Dock="Bottom"
                Padding="24,12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8">
                </StackPanel>
                <Button Grid.Column="1"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="100"
                        Padding="0,10"
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        CornerRadius="999"
                        Margin="0,0,8,0"
                        Cursor="Hand" />
                <Button Grid.Column="2"
                        Command="{Binding SaveCommand}"
                        Width="100"
                        Padding="0,10"
                        Classes="accent-btn accent-pill"
                        Background="{DynamicResource AccentColorBrush}"
                        Foreground="{DynamicResource AccentForegroundBrush}"
                        FontWeight="Bold"
                        HorizontalContentAlignment="Center"
                        CornerRadius="999"
                        Cursor="Hand">
                    <Panel>
                        <TextBlock Text="Save"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !IsSaving}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding IsSaving}">
                            <TextBlock Text="Saving" VerticalAlignment="Center" />
                            <Ellipse Classes="loading-spinner"
                                     Stroke="{DynamicResource AccentForegroundBrush}" />
                        </StackPanel>
                    </Panel>
                </Button>
            </Grid>
        </Border>

        <!-- Tab control -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}"
                    Margin="0"
                    Padding="0"
                    ClipToBounds="True">

            <!-- ═══════════ DETAILS TAB ═══════════ -->
            <TabItem Header="Details" FontSize="14" FontWeight="SemiBold">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="24,16,24,24">
                        <!-- Search metadata: find & review tag changes -->
                        <StackPanel Spacing="10" IsVisible="{Binding ShowSearchMetadata}">
                            <Button Classes="accent-pill"
                                    Command="{Binding SearchMetadataCommand}"
                                    HorizontalAlignment="Left"
                                    Padding="11,5"
                                    FontSize="12"
                                    CornerRadius="999"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Content="Search metadata" />
                            <StackPanel Orientation="Horizontal" Spacing="8"
                                        IsVisible="{Binding ShowSearchMetadataStatusRow}"
                                        VerticalAlignment="Center">
                                <Ellipse Classes="loading-spinner"
                                         IsVisible="{Binding IsSearchingMetadata}"
                                         VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SearchMetadataStatus}"
                                           FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                            <Border IsVisible="{Binding IsSearchMetadataOpen}"
                                    Background="#14FFFFFF"
                                    BorderBrush="#2E808080" BorderThickness="1"
                                    CornerRadius="12" Padding="18,14,18,14">
                                <StackPanel Spacing="12">
                                    <StackPanel Spacing="1">
                                        <TextBlock Text="Found metadata"
                                                   FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="{Binding SearchMetadataStatus}"
                                                   FontSize="11.5" Opacity="0.55" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ItemsControl ItemsSource="{Binding MetadataChanges}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MetadataChangeRow">
                                                <CheckBox Classes="metadata-pill-checkbox" IsChecked="{Binding Apply}" Margin="0,3">
                                                    <StackPanel Spacing="1">
                                                        <TextBlock Text="{Binding Field}" FontSize="10.5" Opacity="0.45" />
                                                        <TextBlock TextWrapping="Wrap" FontSize="13"><Run Text="{Binding OldDisplay}" Foreground="#8CFFFFFF"/><Run Text="  →  " Foreground="#59FFFFFF"/><Run Text="{Binding NewValue}" FontWeight="SemiBold"/></TextBlock>
                                                    </StackPanel>
                                                </CheckBox>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                        <Button Content="Cancel" Command="{Binding CloseSearchMetadataCommand}"
                                                Padding="12,4" FontSize="12" CornerRadius="999"
                                                FontWeight="Bold" Cursor="Hand" />
                                        <Button Content="Apply" Command="{Binding ApplySearchMetadataCommand}"
                                                Classes="accent-pill"
                                                Padding="12,4" FontSize="12" CornerRadius="999"
                                                FontWeight="Bold" Cursor="Hand" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Title (per-track; hidden when editing a whole album) -->
                        <StackPanel Spacing="4" IsVisible="{Binding ShowTrackFields}">
                            <TextBlock Text="title" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <!-- Use Work & Movement -->
                        <CheckBox Classes="metadata-pill-checkbox"
                                  Content="Use Work &amp; Movement"
                                  IsChecked="{Binding UseWorkAndMovement}" />

                        <!-- Work Name (visible only when Work & Movement is enabled) -->
                        <StackPanel Spacing="4" IsVisible="{Binding UseWorkAndMovement}">
                            <TextBlock Text="work name" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding WorkName, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <!-- Movement index + count + title -->
                        <Grid ColumnDefinitions="Auto,8,Auto,16,*"
                              IsVisible="{Binding UseWorkAndMovement}">
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="movement" FontSize="12" Opacity="0.5" />
                                <TextBox Classes="metadata-info-field" Text="{Binding MovementNumber, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="of" FontSize="12" Opacity="0.5" />
                                <TextBox Classes="metadata-info-field" Text="{Binding MovementCount, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                            </StackPanel>
                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="title" FontSize="12" Opacity="0.5" />
                                <TextBox Classes="metadata-info-field" Text="{Binding MovementName, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <!-- Album -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="album" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Album, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding AlbumWatermark}" />
                        </StackPanel>

                        <!-- Album is compilation -->
                        <CheckBox Classes="metadata-pill-checkbox"
                                  Content="Album is compilation"
                                  IsChecked="{Binding IsCompilation}" />

                        <!-- Artist -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="artist" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Artist, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding ArtistWatermark}" />
                        </StackPanel>

                        <!-- Album Artist -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="album artist" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding AlbumArtist, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding AlbumArtistWatermark}" />
                        </StackPanel>

                        <!-- Performer (per-track; hidden when editing a whole album) -->
                        <StackPanel Spacing="4" IsVisible="{Binding ShowTrackFields}">
                            <TextBlock Text="performer" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Performer, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <!-- Composer -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="composer" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Composer, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding ComposerWatermark}" />
                        </StackPanel>

                        <!-- Show composer in all views -->
                        <CheckBox Classes="metadata-pill-checkbox"
                                  Content="Show composer in all views"
                                  IsChecked="{Binding ShowComposerInAllViews}" />

                        <!-- Grouping -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="grouping" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Grouping, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding GroupingWatermark}" />
                        </StackPanel>

                        <!-- Genre -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="genre" FontSize="12" Opacity="0.5" />
                            <ComboBox x:Name="GenreCombo"
                                      Classes="metadata-info-field"
                                      FontWeight="Normal"
                                      ItemsSource="{Binding GenreOptions}"
                                      SelectedItem="{Binding Genre}"
                                      PlaceholderText="{Binding GenreWatermark}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>

                        <!-- Year -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="year" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding YearWatermark}" Width="120" HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- Track number -->
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="track" FontSize="12" Opacity="0.5" VerticalAlignment="Center" Width="36" />
                            <TextBox Classes="metadata-info-field" Text="{Binding TrackNumber, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding TrackNumberWatermark}" Width="80" />
                            <TextBlock Text="of" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                            <TextBox Classes="metadata-info-field" Text="{Binding TrackCount, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding TrackCountWatermark}" Width="80" />
                        </StackPanel>

                        <!-- Disc number -->
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="disc" FontSize="12" Opacity="0.5" VerticalAlignment="Center" Width="36" />
                            <TextBox Classes="metadata-info-field" Text="{Binding DiscNumber, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding DiscNumberWatermark}" Width="80" />
                            <TextBlock Text="of" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                            <TextBox Classes="metadata-info-field" Text="{Binding DiscCount, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding DiscCountWatermark}" Width="80" />
                        </StackPanel>

                        <!-- Rating (per-track; hidden for album-scoped edits) -->
                        <StackPanel Spacing="6" IsVisible="{Binding ShowTrackFields}">
                            <TextBlock Text="rating" FontSize="12" Opacity="0.5" />
                            <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center">
                                <controls:RatingStars Value="{Binding Rating, Mode=TwoWay}"
                                                      IsInteractive="True"
                                                      StarSize="18"
                                                      StarSpacing="4"
                                                      Cursor="Hand"
                                                      Foreground="{DynamicResource AccentColorBrush}"
                                                      VerticalAlignment="Center" />
                                <CheckBox Classes="metadata-pill-checkbox"
                                          Content="Not Liked"
                                          IsChecked="{Binding IsDisliked}"
                                          VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <!-- BPM -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="bpm" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Bpm, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding BpmWatermark}" Width="120" HorizontalAlignment="Left" />
                        </StackPanel>

                        <!-- Play Count -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="play count" FontSize="12" Opacity="0.5" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock Text="{Binding PlayCountDisplay}" FontSize="14" VerticalAlignment="Center" />
                                <Button Content="Reset" Command="{Binding ResetPlayCountCommand}"
                                        Classes="accent-btn"
                                        Padding="14,5" FontSize="12" FontWeight="Bold" Cursor="Hand" VerticalAlignment="Center"
                                        Foreground="{DynamicResource AccentForegroundBrush}" Background="{DynamicResource AccentColorBrush}"
                                        CornerRadius="999" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Song comment -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="comment" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field"
                                     Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}" Watermark="{Binding CommentWatermark}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ ADVANCED DETAILS TAB ═══════════ -->
            <TabItem Header="Advanced Details" FontSize="14" FontWeight="SemiBold" IsVisible="{Binding ShowAdvancedTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="16" Margin="24,16,24,24">

                        <!-- ── Sorting ── -->
                        <TextBlock Text="SORTING" FontSize="11" FontWeight="Bold" Opacity="0.4" Margin="0,0,0,-8" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="title sort" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding TitleSort}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="artist sort" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding ArtistSort}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="album sort" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding AlbumSort}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="album artist sort" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding AlbumArtistSort}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="composer sort" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding ComposerSort}" />
                        </StackPanel>

                        <Separator Opacity="0.15" Margin="0,4" />

                        <!-- ── People & Credits ── -->
                        <TextBlock Text="PEOPLE &amp; CREDITS" FontSize="11" FontWeight="Bold" Opacity="0.4" Margin="0,0,0,-8" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="conductor" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Conductor}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="lyricist" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Lyricist}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="publisher / label" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Publisher}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="encoded by" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding EncodedBy}" />
                        </StackPanel>

                        <Separator Opacity="0.15" Margin="0,4" />

                        <!-- ── Identification ── -->
                        <TextBlock Text="IDENTIFICATION" FontSize="11" FontWeight="Bold" Opacity="0.4" Margin="0,0,0,-8" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="ISRC" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Isrc}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="catalog number" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding CatalogNumber}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="barcode / UPC" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Barcode}" />
                        </StackPanel>

                        <Separator Opacity="0.15" Margin="0,4" />

                        <!-- ── Content Descriptors ── -->
                        <TextBlock Text="CONTENT" FontSize="11" FontWeight="Bold" Opacity="0.4" Margin="0,0,0,-8" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="iTunes advisory" FontSize="12" Opacity="0.5" />
                            <ComboBox Classes="metadata-info-field"
                                      ItemsSource="{x:Static vm:MetadataViewModel.AdvisoryOptions}"
                                      SelectedItem="{Binding SelectedAdvisory}"
                                      HorizontalAlignment="Left"
                                      Width="120">
                                <ComboBox.SelectionBoxItemTemplate>
                                     <DataTemplate>
                                         <presenters:TextPresenter Text="{Binding}"
                                                                   FontWeight="Normal"
                                                                   VerticalAlignment="Center" />
                                     </DataTemplate>
                                </ComboBox.SelectionBoxItemTemplate>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <presenters:TextPresenter Text="{Binding}"
                                                                  FontWeight="Normal" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="language" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Language}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="mood" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Mood}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="description" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding AdvDescription}" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="release date" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding AdvReleaseDate}" Width="200" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="copyright" FontSize="12" Opacity="0.5" />
                            <TextBox Classes="metadata-info-field" Text="{Binding Copyright}" />
                        </StackPanel>

                        <Separator Opacity="0.15" Margin="0,4" />

                        <!-- ── Technical / Encoding ── -->
                        <TextBlock Text="TECHNICAL" FontSize="11" FontWeight="Bold" Opacity="0.4" Margin="0,0,0,-8" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="encoder" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding Encoder}" FontSize="14" Opacity="0.9" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" IsVisible="{Binding ReplayGainTrackGain, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2" Margin="0,0,12,8">
                                <TextBlock Text="track gain" FontSize="12" Opacity="0.5" />
                                <TextBlock Text="{Binding ReplayGainTrackGain}" FontSize="14" Opacity="0.9" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2" Margin="0,0,0,8">
                                <TextBlock Text="track peak" FontSize="12" Opacity="0.5" />
                                <TextBlock Text="{Binding ReplayGainTrackPeak}" FontSize="14" Opacity="0.9" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2" Margin="0,0,12,0">
                                <TextBlock Text="album gain" FontSize="12" Opacity="0.5" />
                                <TextBlock Text="{Binding ReplayGainAlbumGain}" FontSize="14" Opacity="0.9" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                                <TextBlock Text="album peak" FontSize="12" Opacity="0.5" />
                                <TextBlock Text="{Binding ReplayGainAlbumPeak}" FontSize="14" Opacity="0.9" />
                            </StackPanel>
                        </Grid>

                        <Separator Opacity="0.15" Margin="0,4" />

                        <!-- ── Custom Tags ── -->
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="CUSTOM TAGS" FontSize="11" FontWeight="Bold" Opacity="0.4" VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="+ Add"
                                    Command="{Binding AddCustomTagCommand}"
                                    Padding="10,4"
                                    FontSize="11"
                                    CornerRadius="999"
                                    Cursor="Hand" />
                        </Grid>

                        <ItemsControl ItemsSource="{Binding CustomTags}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CustomTagItem">
                                    <Grid ColumnDefinitions="*,8,2*,8,Auto" Margin="0,0,0,6">
                                        <TextBox Grid.Column="0"
                                                 Classes="metadata-info-field"
                                                 Text="{Binding Key}"
                                                 Watermark="Key" />
                                        <TextBox Grid.Column="2"
                                                 Classes="metadata-info-field"
                                                 Text="{Binding Value}"
                                                 Watermark="Value" />
                                        <Button Grid.Column="4"
                                                Content="✕"
                                                Command="{Binding $parent[ItemsControl].((vm:MetadataViewModel)DataContext).RemoveCustomTagCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="6,4"
                                                FontSize="11"
                                                CornerRadius="999"
                                                Cursor="Hand"
                                                VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Tags not covered by other tabs are shown here. Add custom key-value pairs to store any metadata."
                                   FontSize="11"
                                   Opacity="0.3"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding !CustomTags.Count}" />

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════ ARTWORK TAB ═══════════ -->
            <TabItem Header="Artwork" FontSize="14" FontWeight="SemiBold">
                <DockPanel Margin="24,16">
                    <!-- Toolbar: tab title (actions live in the stack beside the preview) -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="Artwork"
                               FontSize="14.5"
                               FontWeight="Bold"
                               Margin="2,0,0,12" />

                    <!-- Artwork action buttons (vertical stack right of the preview) -->
                    <StackPanel x:Name="ArtworkButtonsBar"
                                DockPanel.Dock="Right"
                                Orientation="Vertical"
                                Width="168"
                                VerticalAlignment="Center"
                                Spacing="9"
                                Margin="18,0,0,0">
                        <!-- Search popup: opened from code-behind, centered over the
                             artwork preview so it reads as part of the tab. -->
                        <FlyoutBase.AttachedFlyout>
                            <Flyout Placement="Center" ShowMode="Standard"
                                    FlyoutPresenterClasses="search-pop">
                                <Panel>
                                    <!-- Searching / status card (shown while loading, before results exist) -->
                                    <Border CornerRadius="16"
                                            Padding="26,20"
                                            MinWidth="220"
                                            Background="{DynamicResource AppSidebarBackground}"
                                            BorderBrush="#22FFFFFF" BorderThickness="1"
                                            BoxShadow="0 10 30 0 #90000000"
                                            HorizontalAlignment="Center"
                                            IsVisible="{Binding !HasArtworkSearchResults}">
                                        <StackPanel Spacing="12">
                                            <Ellipse Classes="loading-spinner"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     IsVisible="{Binding IsSearchingArtwork}" />
                                            <TextBlock Text="{Binding ArtworkSearchStatus}"
                                                       FontSize="12.5"
                                                       Opacity="0.85"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="260"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Full results card: hugs its content instead of a
                                         fixed width so a single result doesn't float in a
                                         huge empty box. -->
                                    <Border Padding="20,16,20,18" CornerRadius="16" MaxWidth="580"
                                            HorizontalAlignment="Center"
                                            Background="{DynamicResource AppSidebarBackground}"
                                            BorderBrush="#22FFFFFF" BorderThickness="1"
                                            BoxShadow="0 10 30 0 #90000000"
                                            IsVisible="{Binding HasArtworkSearchResults}">
                                    <StackPanel Spacing="14">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="Choose Artwork"
                                                       FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="From Apple Music"
                                                       FontSize="11" Opacity="0.5"/>
                                        </StackPanel>
                                        <ScrollViewer MaxHeight="340" HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding ArtworkSearchResults}"
                                                          Margin="0,0,-14,-14">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Spacing="7" Width="118"
                                                                    Margin="0,0,14,14"
                                                                    ToolTip.Tip="{Binding CollectionName}">
                                                            <Border CornerRadius="10" ClipToBounds="True"
                                                                    Width="118" Height="118"
                                                                    Background="#1AFFFFFF">
                                                                <Image Source="{Binding Thumbnail}"
                                                                       Stretch="UniformToFill"
                                                                       RenderOptions.BitmapInterpolationMode="HighQuality"/>
                                                            </Border>
                                                            <StackPanel Spacing="1">
                                                                <TextBlock Text="{Binding CollectionName}"
                                                                           FontSize="11.5" FontWeight="SemiBold"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxLines="1"/>
                                                                <TextBlock Text="{Binding ArtistName}"
                                                                           FontSize="10.5" Opacity="0.55"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           MaxLines="1"/>
                                                            </StackPanel>
                                                            <Grid ColumnDefinitions="*,6,*">
                                                                <Button Grid.Column="0"
                                                                        Content="Standard"
                                                                        Background="#1AFFFFFF"
                                                                        HorizontalAlignment="Stretch"
                                                                        HorizontalContentAlignment="Center"
                                                                        Padding="0,4"
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        CornerRadius="999"
                                                                        Cursor="Hand"
                                                                        Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).SelectStandardArtworkResultCommand}"
                                                                        CommandParameter="{Binding}" />
                                                                <Button Grid.Column="2"
                                                                        Content="Max"
                                                                        HorizontalAlignment="Stretch"
                                                                        HorizontalContentAlignment="Center"
                                                                        Padding="0,4"
                                                                        FontSize="10"
                                                                        FontWeight="SemiBold"
                                                                        CornerRadius="999"
                                                                        Cursor="Hand"
                                                                        Classes="accent-btn"
                                                                        Background="{DynamicResource AccentColorBrush}"
                                                                        Foreground="{DynamicResource AccentForegroundBrush}"
                                                                        Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).SelectHighestArtworkResultCommand}"
                                                                        CommandParameter="{Binding}" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <!-- Downloading indicator (shown after Standard/Max is clicked) -->
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Spacing="8"
                                                    IsVisible="{Binding IsDownloadingArtwork}">
                                            <Ellipse Classes="loading-spinner"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="Downloading…"
                                                       FontSize="11"
                                                       Opacity="0.75"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    </Border>
                                </Panel>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>

                        <Button x:Name="SearchArtworkBtn"
                                Command="{Binding SearchArtworkCommand}"
                                Classes="accent-pill"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Content="Search Artwork" />
                        <Button Command="{Binding AddArtworkCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Content="Add from file" />
                        <Button Command="{Binding DownloadArtworkCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                IsVisible="{Binding HasArtwork}"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Content="Download" />
                        <Button Classes="danger-ghost-pill"
                                Command="{Binding RemoveArtworkCommand}"
                                IsVisible="{Binding HasArtwork}"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12"
                                Content="Remove" />
                    </StackPanel>

                    <!-- Artwork preview centered in the space left of the action stack.
                         Also the anchor the search popup opens centered over. -->
                    <Border x:Name="ArtworkPreviewAnchor"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="400" Height="400"
                            CornerRadius="8"
                            ClipToBounds="True"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                        <Panel>
                            <TextBlock Text="No Artwork"
                                       FontSize="18"
                                       Opacity="0.3"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding !HasArtwork}" />
                            <Image Source="{Binding ArtworkPreview}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                   IsVisible="{Binding HasArtwork}" />
                        </Panel>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ═══════════ ANIMATED ARTWORK TAB ═══════════ -->
            <TabItem Header="Animated Artwork" FontSize="14" FontWeight="SemiBold" IsVisible="{Binding ShowAnimatedArtworkTab}">
                <DockPanel Margin="24,16">
                    <!-- Toolbar: tab title (actions live in the stack beside the preview) -->
                    <TextBlock DockPanel.Dock="Top"
                               Text="Animated Artwork"
                               FontSize="14.5"
                               FontWeight="Bold"
                               Margin="2,0,0,12" />

                    <!-- Action buttons (vertical stack right of the preview, mirrors the Artwork tab) -->
                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Vertical"
                                Width="168"
                                VerticalAlignment="Center"
                                Spacing="9"
                                Margin="18,0,0,0">
                        <Button x:Name="SearchAnimatedArtworkButton"
                                Content="Search Artwork"
                                Command="{Binding SearchAnimatedCoverCommand}"
                                Classes="accent-pill"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12"
                                ToolTip.Tip="{Binding AnimatedSearchStatus}" />

                        <!-- URL fallback for when search can't find the album -->
                        <StackPanel Spacing="4" IsVisible="{Binding !HasAnimatedCover}">
                            <TextBox Classes="metadata-info-field"
                                     Text="{Binding AnimatedSearchUrlInput, Mode=TwoWay}"
                                     Watermark="Apple Music URL or album ID"
                                     FontSize="12" />
                            <TextBlock Text="or paste a URL if search doesn't find your album"
                                       FontSize="10"
                                       Opacity="0.55"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Content="Add from file"
                                Command="{Binding AddAnimatedCoverCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12" />
                        <Button Content="Download"
                                Command="{Binding DownloadAnimatedCoverCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                IsVisible="{Binding HasAnimatedCover}"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12" />
                        <Button Classes="danger-ghost-pill"
                                Content="Remove"
                                Command="{Binding RemoveAnimatedCoverCommand}"
                                IsVisible="{Binding HasAnimatedCover}"
                                HorizontalAlignment="Stretch"
                                Padding="14,7"
                                CornerRadius="999"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                FontSize="12" />
                    </StackPanel>

                    <Border x:Name="AnimatedCoverPreviewAnchor"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="400" Height="400"
                            CornerRadius="8"
                            ClipToBounds="True"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                        <!-- Search popup: opened from code-behind, centered over the
                             preview so it reads as part of the tab. -->
                        <FlyoutBase.AttachedFlyout>
                            <Flyout Placement="Center" ShowMode="Standard"
                                    FlyoutPresenterClasses="search-pop">
                                <Panel>
                                    <Panel.Styles>
                                        <!-- Kill the accent-button hover/press scale that gets clipped by the flyout border. -->
                                        <Style Selector="Button.anim-variant:pointerover">
                                            <Setter Property="RenderTransform" Value="scale(1)" />
                                        </Style>
                                        <Style Selector="Button.anim-variant:pressed">
                                            <Setter Property="RenderTransform" Value="scale(1)" />
                                        </Style>
                                    </Panel.Styles>

                                    <!-- Searching / status card (shown while loading, before results exist) -->
                                    <Border CornerRadius="16"
                                            Padding="26,20"
                                            MinWidth="220"
                                            Background="{DynamicResource AppSidebarBackground}"
                                            BorderBrush="#22FFFFFF" BorderThickness="1"
                                            BoxShadow="0 10 30 0 #90000000"
                                            HorizontalAlignment="Center"
                                            IsVisible="{Binding !HasAnimatedArtworkSearchResults}">
                                        <StackPanel Spacing="12">
                                            <Ellipse Classes="loading-spinner"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     IsVisible="{Binding IsSearchingAnimatedCover}" />
                                            <TextBlock Text="{Binding AnimatedSearchStatus}"
                                                       FontSize="12.5"
                                                       Opacity="0.85"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"
                                                       MaxWidth="260"
                                                       HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Full results card -->
                                    <Border Padding="20,18" CornerRadius="18" Width="320"
                                            Background="{DynamicResource AppSidebarBackground}"
                                            BorderBrush="#22FFFFFF" BorderThickness="1"
                                            BoxShadow="0 10 30 0 #90000000"
                                            IsVisible="{Binding HasAnimatedArtworkSearchResults}">
                                        <StackPanel Spacing="12">
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="Choose Animated Artwork"
                                                           FontSize="14" FontWeight="Bold"/>
                                                <TextBlock Text="From Apple Music"
                                                           FontSize="11" Opacity="0.5"/>
                                            </StackPanel>

                                            <Border CornerRadius="10" ClipToBounds="True"
                                                    HorizontalAlignment="Center"
                                                    Width="240" Height="240"
                                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                                <Panel>
                                                    <Image Source="{Binding ArtworkPreview}"
                                                           Stretch="UniformToFill"/>
                                                    <controls:AnimatedCoverImage
                                                        Source="{Binding AnimatedPreviewPath}"
                                                        IsActive="{Binding AnimatedPreviewPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                                        IsVisible="{Binding AnimatedPreviewPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                </Panel>
                                            </Border>

                                            <StackPanel Spacing="1" HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding Album}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Artist}"
                                                           FontSize="11" Opacity="0.6"
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <ItemsControl ItemsSource="{Binding AnimatedArtworkSearchResults}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Center"
                                                                    Spacing="10"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Classes="accent-btn anim-variant"
                                                                Background="{DynamicResource AccentColorBrush}"
                                                                Foreground="{DynamicResource AccentForegroundBrush}"
                                                                CornerRadius="999"
                                                                Padding="16,7"
                                                                Cursor="Hand"
                                                                Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).SelectAnimatedArtworkResultCommand}"
                                                                CommandParameter="{Binding}">
                                                            <TextBlock Text="{Binding Label}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       HorizontalAlignment="Center"/>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Downloading indicator (shown after a variant is clicked) -->
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        Spacing="8"
                                                        IsVisible="{Binding IsDownloadingAnimatedCover}">
                                                <Ellipse Classes="loading-spinner"
                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="Downloading…"
                                                           FontSize="11"
                                                           Opacity="0.75"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Panel>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                        <Panel>
                            <TextBlock Text="No Animated Artwork"
                                       FontSize="18"
                                       Opacity="0.3"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding !HasAnimatedCover}" />

                            <!-- Still cover sits behind the video so there's no blank
                                 flash while the first frame decodes after a tab switch. -->
                            <Image Source="{Binding ArtworkPreview}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapInterpolationMode="HighQuality"
                                   IsVisible="{Binding HasAnimatedCover}" />

                            <controls:AnimatedCoverImage Source="{Binding AnimatedCoverPath}"
                                                         IsActive="{Binding HasAnimatedCover}"
                                                         IsVisible="{Binding HasAnimatedCover}" />
                        </Panel>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ═══════════ LYRICS TAB ═══════════ -->
            <TabItem Header="Plain Lyrics" FontSize="14" FontWeight="SemiBold" IsVisible="{Binding ShowLyricsTab}">
                <DockPanel Margin="24,16">
                    <!-- Toolbar: title left, Enable switch right -->
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="Auto,*,Auto"
                          Margin="0,0,0,12">
                        <TextBlock Grid.Column="0"
                                   Text="Plain Lyrics"
                                   FontSize="14.5"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0" />
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Enable"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <controls:LottieToggle IsChecked="{Binding HasCustomLyrics}"
                                                   VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Actions: bottom right -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Spacing="10"
                                Margin="0,12,0,0">
                        <Button Content="Share lyrics"
                                Command="{Binding ShareLyricsCommand}"
                                Padding="14,6"
                                CornerRadius="999"
                                FontWeight="SemiBold"
                                FontSize="12"
                                VerticalAlignment="Center"
                                Cursor="Hand" />
                    </StackPanel>

                    <TextBox Text="{Binding Lyrics}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             MinHeight="300"
                             BorderBrush="#44E04060"
                             BorderThickness="1"
                             CornerRadius="10"
                             IsEnabled="{Binding HasCustomLyrics}" />
                </DockPanel>
            </TabItem>

            <!-- ═══════════ SYNCED LYRICS TAB ═══════════ -->
            <TabItem Header="Synced Lyrics" FontSize="14" FontWeight="SemiBold" IsVisible="{Binding ShowSyncedLyricsTab}">
                <DockPanel Margin="24,16">
                    <!-- Toolbar: title + line-count chip left, Formatted/Raw toggle + Enable switch right -->
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
                          Margin="0,0,0,12">
                        <TextBlock Grid.Column="0"
                                   Text="Synced Lyrics"
                                   FontSize="14.5"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0" />
                        <Border Grid.Column="1"
                                Background="#12FFFFFF"
                                CornerRadius="999"
                                Padding="10,3"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasSyncedLines}">
                            <TextBlock Text="{Binding SyncedLyricLines.Count, StringFormat='{}{0} lines'}"
                                       FontSize="10.5"
                                       FontWeight="Bold"
                                       Opacity="0.75" />
                        </Border>
                        <Border Grid.Column="2"
                                Background="#12FFFFFF"
                                CornerRadius="999"
                                Padding="10,3"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasWordTimedLines}"
                                ToolTip.Tip="Lines carry per-word timing tags; switch to Raw to see them">
                            <TextBlock Text="word timing"
                                       FontSize="10.5"
                                       FontWeight="Bold"
                                       Opacity="0.75" />
                        </Border>
                        <ToggleButton Grid.Column="4"
                                      x:Name="SyncedRawToggle"
                                      Content="Raw"
                                      FontSize="11.5"
                                      FontWeight="SemiBold"
                                      Padding="13,4"
                                      CornerRadius="999"
                                      Cursor="Hand"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Show the raw LRC text with timing tags" />
                        <StackPanel Grid.Column="5"
                                    Orientation="Horizontal"
                                    Spacing="10"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Enable"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <controls:LottieToggle IsChecked="{Binding HasCustomSyncedLyrics}"
                                                   VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <!-- Actions: status left, Search / Remove right (destructive last) -->
                    <Grid DockPanel.Dock="Bottom"
                          Margin="0,12,0,0"
                          ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding SyncedLyricsSearchStatus}"
                                   FontSize="12"
                                   Opacity="0.75"
                                   VerticalAlignment="Center"
                                   Margin="2,0,16,0"
                                   TextTrimming="CharacterEllipsis"
                                   IsVisible="{Binding SyncedLyricsSearchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Spacing="10">
                            <Button Content="Search lyrics"
                                    Command="{Binding SearchSyncedLyricsCommand}"
                                    Padding="14,6"
                                    CornerRadius="999"
                                    Cursor="Hand"
                                    FontWeight="SemiBold"
                                    FontSize="12" />
                            <Button Classes="danger-ghost-pill"
                                    Content="Remove"
                                    Command="{Binding RemoveSyncedLyricsCommand}"
                                    IsEnabled="{Binding HasCustomSyncedLyrics}"
                                    Padding="14,6"
                                    CornerRadius="999"
                                    Cursor="Hand"
                                    FontWeight="SemiBold"
                                    FontSize="12" />
                        </StackPanel>
                    </Grid>

                    <!-- Read-only preview; full per-line editing lives in Timestamp Lyrics.
                         Formatted view parses lines into timestamp pills + clean text;
                         the Raw toggle swaps in the untouched LRC text. -->
                    <Border x:Name="SyncedPreviewCard"
                            BorderBrush="#44E04060"
                            BorderThickness="1"
                            CornerRadius="10"
                            Background="#18000000"
                            IsEnabled="{Binding HasCustomSyncedLyrics}">
                        <!-- The formatted preview is plain TextBlocks, which have no
                             theme disabled-state; dim the whole card so toggling
                             Enable off greys it like the Plain Lyrics TextBox. -->
                        <Border.Styles>
                            <Style Selector="Border#SyncedPreviewCard:disabled">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Style>
                        </Border.Styles>
                        <Panel MinHeight="300">
                            <TextBlock Text="No synced lyrics yet. Use “Search lyrics” to add them."
                                       IsVisible="{Binding !HasSyncedLines}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="380"
                                       Opacity="0.6"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="24" />

                            <!-- Formatted: one row per line, timestamp pill + text -->
                            <ScrollViewer IsVisible="{Binding !#SyncedRawToggle.IsChecked}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="12,10,16,0">
                                <StackPanel>
                                    <ItemsControl ItemsSource="{Binding SyncedLyricLines}"
                                                  IsVisible="{Binding HasSyncedLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SyncedLyricEditorLine">
                                                <Grid ColumnDefinitions="Auto,*" Margin="0,2">
                                                    <Border Grid.Column="0"
                                                            Background="#14FFFFFF"
                                                            CornerRadius="6"
                                                            MinWidth="78"
                                                            Padding="8,3"
                                                            VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding TimestampText}"
                                                                   FontFamily="Consolas, Menlo, Monaco, Courier New, monospace"
                                                                   FontSize="11.5"
                                                                   Foreground="{DynamicResource AccentColorBrush}"
                                                                   HorizontalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DisplayText}"
                                                               FontSize="13.5"
                                                               TextWrapping="Wrap"
                                                               Margin="12,3,8,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Height="16" />
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Raw: untouched LRC text with timing tags -->
                            <TextBox IsVisible="{Binding #SyncedRawToggle.IsChecked}"
                                     Text="{Binding SyncedLyrics}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas, Menlo, Monaco, Courier New, monospace"
                                     FontSize="12" />
                        </Panel>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ═══════════ TIMESTAMP LYRICS TAB ═══════════ -->
            <!-- Inline twin of the roomy pop-out editor. Binds the same MetadataViewModel,
                 so per-line edits flow through SyncedLyricLines and persist on Save. -->
            <TabItem Header="Timestamp Lyrics" FontSize="14" FontWeight="SemiBold" IsVisible="{Binding ShowSyncedLyricsTab}">
                <DockPanel Margin="24,16">
                    <!-- Toolbar: title + status chips left, nudge hint right -->
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="Auto,Auto,Auto,*"
                          Margin="0,0,0,12">
                        <TextBlock Grid.Column="0"
                                   Text="Timestamp Lyrics"
                                   FontSize="14.5"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0" />
                        <Border Grid.Column="1"
                                Background="#12FFFFFF"
                                CornerRadius="999"
                                Padding="10,3"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasSyncedLines}">
                            <TextBlock Text="{Binding SyncedLyricLines.Count, StringFormat='{}{0} lines'}"
                                       FontSize="10.5"
                                       FontWeight="Bold"
                                       Opacity="0.75" />
                        </Border>
                        <Border Grid.Column="2"
                                Background="#12FFFFFF"
                                CornerRadius="999"
                                Padding="10,3"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                IsVisible="{Binding HasWordTimedLines}"
                                ToolTip.Tip="Lines carry per-word timing tags; they are preserved on Save">
                            <TextBlock Text="word timing"
                                       FontSize="10.5"
                                       FontWeight="Bold"
                                       Opacity="0.75" />
                        </Border>
                        <TextBlock Grid.Column="3"
                                   Text="Hover over a line to nudge its timing."
                                   FontSize="12" Opacity="0.5"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="16,0,2,0"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>

                        <Border BorderBrush="#44E04060"
                                BorderThickness="1"
                                CornerRadius="6"
                                Background="#18000000">
                            <Panel MinHeight="300">
                                <TextBlock Text="No synced lyrics yet. Use “Search lyrics” on the Synced Lyrics tab to add them."
                                           IsVisible="{Binding !HasSyncedLines}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           MaxWidth="420"
                                           Opacity="0.6"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="24" />

                                <ScrollViewer IsVisible="{Binding HasSyncedLines}"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Padding="14,10,18,0">
                                    <!-- A real trailing spacer (below) carries the bottom gap. Neither
                                         ScrollViewer.Padding nor a content Margin is reliably folded into
                                         Avalonia's scroll extent, so the final row would otherwise stay
                                         clipped at the bottom edge. -->
                                    <StackPanel>
                                    <ItemsControl ItemsSource="{Binding SyncedLyricLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SyncedLyricEditorLine">
                                                <Border Classes="synced-row">
                                                    <Grid ColumnDefinitions="3,Auto,*,Auto">
                                                        <!-- Accent bar: marks the line currently being edited -->
                                                        <Border Grid.Column="0"
                                                                Classes="synced-accent"
                                                                Width="3"
                                                                CornerRadius="999"
                                                                Margin="0,3" />
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding TimestampText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                                 Watermark="--:--.--"
                                                                 FontFamily="Consolas, Menlo, Monaco, Courier New, monospace"
                                                                 FontSize="12"
                                                                 Width="92"
                                                                 Margin="11,0,0,0"
                                                                 Padding="10,5"
                                                                 Classes="pill-input"
                                                                 VerticalAlignment="Center"
                                                                 VerticalContentAlignment="Center"
                                                                 HorizontalContentAlignment="Center"
                                                                 ToolTip.Tip="Type a timestamp (mm:ss.xx); blank clears it" />
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding DisplayText}"
                                                                   FontSize="14"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   Margin="14,0,14,0" />
                                                        <StackPanel Grid.Column="3"
                                                                    Classes="synced-ctl"
                                                                    Orientation="Horizontal"
                                                                    Spacing="6"
                                                                    Margin="0,0,16,0"
                                                                    VerticalAlignment="Center">
                                                            <Button Classes="synced-nudge"
                                                                    Content="−"
                                                                    ToolTip.Tip="Nudge 0.1s earlier"
                                                                    IsEnabled="{Binding HasTimestamp}"
                                                                    Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).NudgeSyncedLineBackCommand}"
                                                                    CommandParameter="{Binding}" />
                                                            <Button Classes="synced-nudge"
                                                                    Content="+"
                                                                    ToolTip.Tip="Nudge 0.1s later"
                                                                    IsEnabled="{Binding HasTimestamp}"
                                                                    Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).NudgeSyncedLineForwardCommand}"
                                                                    CommandParameter="{Binding}" />
                                                            <Button Classes="synced-nudge"
                                                                    Content="✕"
                                                                    ToolTip.Tip="Clear timestamp"
                                                                    IsEnabled="{Binding HasTimestamp}"
                                                                    Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).ClearSyncedLineTimestampCommand}"
                                                                    CommandParameter="{Binding}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                        <Border Height="24" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Panel>
                        </Border>
                </DockPanel>
            </TabItem>

            <!-- OPTIONS TAB -->
            <TabItem Header="Options" FontSize="14" FontWeight="SemiBold">
                <StackPanel Margin="24,14" Spacing="10">

                    <!-- Media Kind (Music, Podcast, Audiobook, ...) -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="media kind" FontSize="12" Opacity="0.5" />
                        <ComboBox Classes="metadata-info-field"
                                  ItemsSource="{x:Static vm:MetadataViewModel.AvailableMediaKinds}"
                                  SelectedItem="{Binding MediaKind}"
                                  HorizontalAlignment="Left"
                                  Width="180" />
                    </StackPanel>

                    <Separator Opacity="0.15" Margin="0,2" />

                    <!-- Release type override (Auto, Album, Single, EP, ...) -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="release type" FontSize="12" Opacity="0.5" />
                        <ComboBox Classes="metadata-info-field"
                                  ItemsSource="{x:Static vm:MetadataViewModel.AvailableReleaseTypes}"
                                  SelectedItem="{Binding ReleaseTypeOverride}"
                                  HorizontalAlignment="Left"
                                  Width="180" />
                    </StackPanel>

                    <Separator Opacity="0.15" Margin="0,2" />

                    <!-- Start / Stop Time (inline) -->
                    <Grid ColumnDefinitions="Auto,24,Auto" HorizontalAlignment="Left">
                        <Grid Grid.Column="0" ColumnDefinitions="34,30,130" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="start" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                            <CheckBox Classes="metadata-pill-checkbox"
                                      Grid.Column="1"
                                      IsChecked="{Binding HasStartTime}"
                                      Padding="0" Margin="0" MinWidth="0"
                                      VerticalAlignment="Center" />
                            <TextBox Classes="metadata-info-field"
                                     Grid.Column="2"
                                     Text="{Binding StartTime}"
                                     IsEnabled="{Binding HasStartTime}"
                                     Width="130"
                                     CornerRadius="999"
                                     Padding="14,6"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <Grid Grid.Column="2" ColumnDefinitions="34,30,130" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Grid.Column="0" Text="stop" FontSize="12" Opacity="0.5" VerticalAlignment="Center" />
                            <CheckBox Classes="metadata-pill-checkbox"
                                      Grid.Column="1"
                                      IsChecked="{Binding HasStopTime}"
                                      Padding="0" Margin="0" MinWidth="0"
                                      VerticalAlignment="Center" />
                            <TextBox Classes="metadata-info-field"
                                     Grid.Column="2"
                                     Text="{Binding StopTime}"
                                     IsEnabled="{Binding HasStopTime}"
                                     Width="130"
                                     CornerRadius="999"
                                     Padding="14,6"
                                     VerticalAlignment="Center" />
                        </Grid>
                    </Grid>

                    <Separator Opacity="0.15" Margin="0,2" />

                    <!-- Remember playback position -->
                    <CheckBox Classes="metadata-pill-checkbox"
                              Content="Remember playback position"
                              IsChecked="{Binding RememberPlaybackPosition}" />

                    <!-- Skip when shuffling -->
                    <CheckBox Classes="metadata-pill-checkbox"
                              Content="Skip when shuffling"
                              IsChecked="{Binding SkipWhenShuffling}" />

                    <Separator Opacity="0.15" Margin="0,2" />

                    <!-- Volume Adjust -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="volume adjust" FontSize="12" Opacity="0.5" />
                        <Grid ColumnDefinitions="*,52">
                            <Grid Grid.Column="0" Height="20" ClipToBounds="False">
                                <Canvas x:Name="VolumeAdjustVisual"
                                        Height="20"
                                        ClipToBounds="False"
                                        IsHitTestVisible="False">
                                    <Border x:Name="VolumeAdjustTrackBackground"
                                            Height="6"
                                            CornerRadius="3"
                                            Background="{DynamicResource IslandSliderUnfilled}"
                                            Opacity="0.4"
                                            Canvas.Top="7"/>
                                    <Border x:Name="VolumeAdjustTrackFill"
                                            Height="6"
                                            CornerRadius="3"
                                            Background="{DynamicResource IslandSliderFilled}"
                                            Canvas.Top="7"/>
                                    <Border x:Name="VolumeAdjustThumb"
                                            Width="14"
                                            Height="14"
                                            CornerRadius="7"
                                            Background="{DynamicResource IslandSliderFilled}"
                                            BoxShadow="0 1 3 0 #40000000"
                                            Canvas.Top="3"/>
                                </Canvas>
                                <Slider x:Name="VolumeAdjustSlider"
                                        Classes="volume-horizontal"
                                        Value="{Binding VolumeAdjust, Mode=TwoWay}"
                                        Minimum="-100" Maximum="100"
                                        HorizontalAlignment="Stretch"
                                        DoubleTapped="OnVolumeAdjustSliderDoubleTapped" />
                            </Grid>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VolumeAdjust, StringFormat='{}{0}%'}"
                                       FontSize="12"
                                       Opacity="0.6"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <Separator Opacity="0.15" Margin="0,2" />

                    <!-- Equalizer Preset -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="equalizer" FontSize="12" Opacity="0.5" Margin="8,0,0,0" />
                        <ComboBox Classes="metadata-info-field"
                                  ItemsSource="{x:Static vm:MetadataViewModel.OptionsEqPresets}"
                                  SelectedItem="{Binding SelectedEqPreset}"
                                  HorizontalAlignment="Left"
                                  Width="104" />
                    </StackPanel>

                    <!-- Rename by pattern (multi-select only) -->
                    <StackPanel Spacing="8" IsVisible="{Binding ShowRenameSection}">
                        <Separator Opacity="0.15" Margin="0,2" />
                        <CheckBox Classes="metadata-pill-checkbox"
                                  Content="Rename files by pattern"
                                  IsChecked="{Binding ApplyRename}" />
                        <TextBlock Text="Tokens: %artist% %albumartist% %album% %title% %tracknumber% %tracknumber2% %discnumber% %year% %genre% %composer%"
                                   FontSize="11" Opacity="0.55" TextWrapping="Wrap" />
                        <TextBox Classes="metadata-info-field"
                                 Text="{Binding RenamePattern}"
                                 IsEnabled="{Binding ApplyRename}" />
                        <Border Background="#10FFFFFF" CornerRadius="8" Padding="10"
                                IsVisible="{Binding ApplyRename}">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Preview (first 8 tracks)" FontSize="11" Opacity="0.6" Margin="0,0,0,4" />
                                <ItemsControl ItemsSource="{Binding RenamePreviews}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MetadataViewModel+RenamePreview">
                                            <Grid ColumnDefinitions="*,Auto,*,Auto" Margin="0,1">
                                                <TextBlock Grid.Column="0" Text="{Binding OriginalName}" FontSize="11" Opacity="0.7" TextTrimming="CharacterEllipsis" Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="1" Text="→" FontSize="11" Opacity="0.5" Margin="0,0,8,0" />
                                                <TextBlock Grid.Column="2" Text="{Binding NewName}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="3" Text="conflict" FontSize="10"
                                                           Foreground="#E74856" FontWeight="SemiBold"
                                                           Margin="8,0,0,0"
                                                           IsVisible="{Binding Conflict}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </TabItem>

            <!-- ═══════════ FILE TAB ═══════════ -->
            <TabItem Header="File" FontSize="14" FontWeight="SemiBold" IsVisible="{Binding ShowFileTab}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="14" Margin="24,16,24,24">
                        <!-- Format -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Format" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding FileFormat}" FontSize="14" />
                        </StackPanel>

                        <!-- Duration -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="duration" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding Duration}" FontSize="14" />
                        </StackPanel>

                        <!-- File Size -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="size" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding FileSize}" FontSize="14" />
                        </StackPanel>

                        <!-- Bitrate -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Bitrate" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding Bitrate}" FontSize="14" />
                        </StackPanel>

                        <!-- Bit Depth -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Bit Depth" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding BitsPerSample}" FontSize="14" />
                        </StackPanel>

                        <!-- Sample Rate -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="sample rate" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding SampleRate}" FontSize="14" />
                        </StackPanel>

                        <!-- Channels -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="channels" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding Channels}" FontSize="14" />
                        </StackPanel>

                        <!-- Codec -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="Codec" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding Codec}" FontSize="14" />
                        </StackPanel>

                        <!-- Lossless / Lossy -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="quality" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding LosslessOrLossy}" FontSize="14" />
                        </StackPanel>

                        <Separator Opacity="0.3" Margin="0,4" />

                        <!-- Date Modified -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="date modified" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding DateModified}" FontSize="14" />
                        </StackPanel>

                        <!-- Date Added -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="date added" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding DateAdded}" FontSize="14" />
                        </StackPanel>

                        <Separator Opacity="0.3" Margin="0,4" />

                        <!-- Folder name -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="folder name" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding FolderName}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Opacity="0.9" />
                        </StackPanel>

                        <!-- Copyright -->
                        <StackPanel Spacing="2"
                                    IsVisible="{Binding Copyright, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="copyright" FontSize="12" Opacity="0.5" />
                            <TextBlock Text="{Binding Copyright}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Opacity="0.9" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
        </Border>
    </Border>
</Window>
