<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        x:Class="Noctis.Views.CommandPaletteDialog"
        x:DataType="vm:CommandPaletteViewModel"
        Title="Command palette"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False">

    <Window.Styles>
        <Style Selector="ListBox.palette-list ListBoxItem">
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="2,1"/>
        </Style>
    </Window.Styles>

    <!-- Dimmed overlay; click outside closes -->
    <Border Background="#70000000" PointerPressed="OnOverlayPointerPressed">

        <!-- Palette card anchored near the top, Spotlight-style -->
        <Border PointerPressed="OnCardPointerPressed"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,110,0,0"
                Width="600"
                CornerRadius="12"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BoxShadow="0 12 40 0 #80000000">
            <StackPanel>
                <TextBox x:Name="QueryBox"
                         Text="{Binding Query, Mode=TwoWay}"
                         Watermark="Search songs, albums, artists, pages and actions…"
                         FontSize="15"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="16,14"/>
                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                <ListBox x:Name="ResultsList"
                         Classes="palette-list"
                         ItemsSource="{Binding Results}"
                         SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                         MaxHeight="420"
                         Background="Transparent"
                         Padding="6"
                         KeyboardNavigation.TabNavigation="None">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:PaletteItem">
                            <Grid ColumnDefinitions="Auto,*,Auto" Background="Transparent"
                                  PointerReleased="OnItemPointerReleased">
                                <PathIcon Grid.Column="0"
                                          Data="{Binding Icon}"
                                          Width="15" Height="15"
                                          Opacity="0.7"
                                          Margin="2,0,12,0"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Subtitle}" FontSize="11" Opacity="0.55"
                                               TextTrimming="CharacterEllipsis"
                                               IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Category}"
                                           FontSize="10" Opacity="0.4"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
                <TextBlock Text="↑↓ navigate · Enter run · Esc close"
                           FontSize="10" Opacity="0.4"
                           Margin="16,8,16,10"/>
            </StackPanel>
        </Border>
    </Border>
</Window>
