<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        x:Class="Noctis.Views.CreatePlaylistDialog"
        x:DataType="vm:CreatePlaylistDialogViewModel"
        Title="Create New Playlist"
        CanResize="False"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <!-- Full-window dimmed overlay that captures all input.
         Starts transparent; code-behind fades it in on open and back out
         before closing (same animation as the Add to Playlist dialog). -->
    <Border x:Name="DialogOverlay"
            Background="#50000000"
            Opacity="0"
            PointerPressed="OnOverlayPointerPressed"
            PointerWheelChanged="OnOverlayWheel">
        <Border.Transitions>
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.18">
                    <DoubleTransition.Easing>
                        <CubicEaseOut/>
                    </DoubleTransition.Easing>
                </DoubleTransition>
            </Transitions>
        </Border.Transitions>

        <!-- Centered dialog card -->
        <Border x:Name="DialogCard"
                CornerRadius="24"
                ClipToBounds="True"
                Background="{DynamicResource AppMainBackground}"
                Width="450"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                RenderTransformOrigin="50%,50%"
                RenderTransform="scale(0.96)"
                BoxShadow="0 8 32 0 #80000000, 0 0 0 1 #33FFFFFF">
            <Border.Transitions>
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18">
                        <TransformOperationsTransition.Easing>
                            <CubicEaseOut/>
                        </TransformOperationsTransition.Easing>
                    </TransformOperationsTransition>
                </Transitions>
            </Border.Transitions>
            <DockPanel>

                <!-- Bottom: Create / Cancel buttons -->
                <Border DockPanel.Dock="Bottom"
                        Padding="24,12,24,16">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Button Grid.Column="1"
                                Content="Cancel"
                                Command="{Binding CancelCommand}"
                                Width="100"
                                Padding="0,8"
                                FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                CornerRadius="999"
                                Margin="0,0,8,0"
                                Cursor="Hand" />
                        <Button Grid.Column="2"
                                Content="Create"
                                Command="{Binding CreateCommand}"
                                Width="100"
                                Padding="0,8"
                                Classes="accent-btn"
                                Background="{DynamicResource AccentColorBrush}"
                                Foreground="{DynamicResource AccentForegroundBrush}"
                                FontWeight="Bold"
                                HorizontalContentAlignment="Center"
                                CornerRadius="999"
                                Cursor="Hand" />
                    </Grid>
                </Border>

                <!-- Content: same pill inputs as the Add to Playlist create form -->
                <StackPanel Margin="24,20,24,16" Spacing="14">

                    <!-- Title -->
                    <TextBlock Text="Create New Playlist"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />

                    <StackPanel Spacing="10" Margin="0,4,0,0">
                        <TextBox Text="{Binding PlaylistName}"
                                 Classes="crisp-input"
                                 Watermark="Playlist name"
                                 CornerRadius="999"
                                 Padding="14,8"
                                 x:Name="NameTextBox" />
                        <TextBlock Text="Name is required"
                                   FontSize="11"
                                   Foreground="{DynamicResource AccentColorBrush}"
                                   IsVisible="{Binding ShowNameRequiredError}" />
                        <TextBox Text="{Binding PlaylistDescription}"
                                 Classes="crisp-input"
                                 Watermark="Description (optional)"
                                 CornerRadius="999"
                                 Padding="14,8" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Border>
</Window>
