<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:ctrl="using:Noctis.Controls"
             x:Class="Noctis.Views.LibraryArtistsView"
             x:DataType="vm:LibraryArtistsViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Styles>
        <!-- Keep portrait tiles visually static on hover/press (image is the affordance) -->
        <Style Selector="Button.artist-tile:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button.artist-tile:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">
        <!-- Right margin trimmed to 2 so the vertical scrollbar sits at the window edge. -->
        <DockPanel Grid.Row="0" Margin="16,8,2,16">

        <!-- Content area with overlay for empty state -->
        <Grid>
            <!-- Artist grid: outer ListBox virtualizes rows, inner UniformGrid lays out 7 portraits per row -->
            <ListBox x:Name="ArtistListBox"
                     ItemsSource="{Binding ArtistRows}"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,8,0,115"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     SelectionMode="Single"
                     AutoScrollToSelectedItem="False">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Focusable" Value="False" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="m:ArtistRow">
                        <ItemsControl ItemsSource="{Binding Artists}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="7" Rows="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type m:Artist}">
                                    <Button Classes="artist-tile"
                                            Focusable="False"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="4,6"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Cursor="Hand"
                                            Command="{Binding $parent[UserControl].((vm:LibraryArtistsViewModel)DataContext).OpenArtistCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                                            <!-- Circular portrait with icon fallback -->
                                            <Border Width="124" Height="124"
                                                    CornerRadius="62"
                                                    Background="#2E2E2E"
                                                    ClipToBounds="True"
                                                    HorizontalAlignment="Center">
                                                <Panel>
                                                    <PathIcon Data="{StaticResource ArtistsIcon}"
                                                              Width="44"
                                                              Height="44"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Opacity="0.35" />
                                                    <ctrl:CachedImage SourcePath="{Binding ImagePath}"
                                                                      Stretch="UniformToFill"
                                                                      Width="124"
                                                                      Height="124"
                                                                      IsVisible="{Binding ImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </Panel>
                                            </Border>
                                            <ctrl:HighlightTextBlock DisplayText="{Binding Name}"
                                                                     HighlightText="{Binding $parent[UserControl].((vm:LibraryArtistsViewModel)DataContext).SearchText, FallbackValue=''}"
                                                                     FontSize="13"
                                                                     FontWeight="SemiBold"
                                                                     TextWrapping="NoWrap"
                                                                     MaxLines="1"
                                                                     TextTrimming="CharacterEllipsis"
                                                                     TextAlignment="Center"
                                                                     MaxWidth="132"
                                                                     HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state overlay -->
            <StackPanel IsVisible="{Binding !ArtistRows.Count}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="No artists found"
                           FontSize="18"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="Add music folders in Settings to get started"
                           FontSize="13"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>

        </DockPanel>
    </Grid>

</UserControl>
