<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Noctis.Views.ConfirmationDialog"
        Title="Confirm"
        CanResize="False"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False">

    <!-- Full-window dimmed overlay that captures all input -->
    <Border Background="#50000000"
            PointerPressed="OnOverlayPointerPressed"
            PointerWheelChanged="OnOverlayWheel">

        <!-- Centered dialog card -->
        <Border Background="{DynamicResource AppMainBackground}"
                CornerRadius="24"
                ClipToBounds="True"
                Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BoxShadow="0 8 32 0 #60000000">
        <DockPanel Margin="0">

            <!-- Bottom: Confirm / Cancel buttons -->
            <Border DockPanel.Dock="Bottom"
                    Padding="24,12,24,16">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <Button Grid.Column="1"
                            Content="Confirm"
                            Click="OnConfirmClick"
                            Width="100"
                            Padding="0,8"
                            Classes="accent-btn"
                                Background="#E04060"
                            Foreground="White"
                            FontWeight="SemiBold"
                            HorizontalContentAlignment="Center"
                            CornerRadius="999"
                            Margin="0,0,8,0"
                            Cursor="Hand" />
                    <Button Grid.Column="2"
                            Content="Cancel"
                            Click="OnCancelClick"
                            Width="100"
                            Padding="0,8"
                            HorizontalContentAlignment="Center"
                            CornerRadius="999"
                            Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Message -->
            <StackPanel Margin="24,16,24,8" VerticalAlignment="Center">
                <TextBlock x:Name="MessageText"
                           Text="Are you sure?"
                           FontSize="14"
                           TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>
        </Border>
    </Border>
</Window>
