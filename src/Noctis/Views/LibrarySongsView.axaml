<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:controls="using:Noctis.Controls"
             xmlns:conv="using:Noctis.Converters"
             xmlns:helpers="using:Noctis.Helpers"
             x:Class="Noctis.Views.LibrarySongsView"
             x:DataType="vm:LibrarySongsViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:ArtworkPathConverter x:Key="ArtworkConverter" />
        <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry" />
        <conv:TrackPlaylistCommandParameterConverter x:Key="TrackPlaylistParamConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        <Separator Grid.Row="0" Classes="page-top-separator" />
        <DockPanel Grid.Row="1" Margin="16,8,16,16">

        <!-- Column headers (sortable) -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*,80,*,*,*,70,50,30"
              Margin="8,0,8,8">
            <Button Grid.Column="0" Content="Title" Command="{Binding SortCommand}" CommandParameter="Title"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="1" Content="Time" Command="{Binding SortCommand}" CommandParameter="Time"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="2" Content="Artist" Command="{Binding SortCommand}" CommandParameter="Artist"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="3" Content="Album" Command="{Binding SortCommand}" CommandParameter="Album"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="4" Content="Genre" Command="{Binding SortCommand}" CommandParameter="Genre"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="5" Content="Favorites" Command="{Binding SortCommand}" CommandParameter="IsFavorite"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="6" Content="Plays" Command="{Binding SortCommand}" CommandParameter="Plays"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="7" Text="" FontSize="12" />
        </Grid>

        <Separator DockPanel.Dock="Top" Margin="0,0,0,4" />

        <!-- Content area with overlay for empty state -->
        <Grid>
            <!-- Track list -->
            <ListBox Classes="track-list"
                     ItemsSource="{Binding FilteredTracks}"
                     SelectionMode="Multiple"
                     x:Name="TrackList">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Track">
                    <Grid ColumnDefinitions="*,80,*,*,*,70,50,30"
                          Margin="0,2"
                          Background="Transparent"
                          helpers:DragFileBehavior.EnableFileDrag="True"
                          x:Name="TrackRow">

                        <Grid.ContextMenu>
                            <ContextMenu Opened="OnContextMenuOpened">
                                <!-- Track header -->
                                <MenuItem IsHitTestVisible="False" Focusable="False">
                                    <MenuItem.Template>
                                        <ControlTemplate>
                                            <Border Padding="11,8" Background="Transparent">
                                                <ContentPresenter Content="{TemplateBinding Header}" />
                                            </Border>
                                        </ControlTemplate>
                                    </MenuItem.Template>
                                    <MenuItem.Header>
                                        <Grid ColumnDefinitions="40,10,*">
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4" ClipToBounds="True"
                                                    Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                                <Panel>
                                                    <TextBlock Text="&#x266A;" FontSize="14" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" Opacity="0.3"
                                                               IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                    <Image Source="{Binding AlbumArtworkPath, Converter={StaticResource ArtworkConverter}}"
                                                           Stretch="UniformToFill"
                                                           IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </Panel>
                                            </Border>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                <Grid ColumnDefinitions="Auto,Auto">
                                                    <controls:MarqueeTextBlock Grid.Column="0" Text="{Binding Title}"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               MaxDisplayWidth="240" IsForArtist="False" />
                                                    <Border Grid.Column="1"
                                                            Classes="explicit-badge compact"
                                                            Margin="4,0,0,0"
                                                            VerticalAlignment="Center"
                                                            IsVisible="{Binding IsExplicit}">
                                                        <TextBlock Text="E"
                                                                   Classes="explicit-badge-text compact"
                                                                   FontSize="9"
                                                                   Opacity="0.9" />
                                                    </Border>
                                                </Grid>
                                                <controls:MarqueeTextBlock Text="{Binding Artist}" FontSize="11" Foreground="#E74856"
                                                           MaxDisplayWidth="240" IsForArtist="True" HorizontalAlignment="Left" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="{Binding Title, StringFormat='Play &quot;{0}&quot;'}"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).PlayFromHereCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Shuffle"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ShuffleAllCommand}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Shuffle%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Play Next"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).PlayNextCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Forward%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Add to Queue"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).AddToQueueCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem x:Name="AddToPlaylistMenuItem1" Header="Add to Playlist">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Playlists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                    <MenuItem Header="Create New Playlist"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).AddToNewPlaylistCommand}"
                                              CommandParameter="{Binding}" />
                                    <Separator x:Name="PlaylistSeparator1" />
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Add to Favorites"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ToggleFavoriteCommand}"
                                          CommandParameter="{Binding}"
                                          IsVisible="{Binding !IsFavorite}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Your%20Favorites%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Remove from Favorites"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ToggleFavoriteCommand}"
                                          CommandParameter="{Binding}"
                                          IsVisible="{Binding IsFavorite}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Metadata"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).OpenMetadataCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Metadata%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Search Lyrics"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).SearchLyricsCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Lyrics%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="View Album"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewAlbumCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Albums%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="View Artist"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewArtistCommand}"
                                          CommandParameter="{Binding Artist}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Artists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Show in Folder"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ShowInExplorerCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Folder%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="Remove from Library"
                                          Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).RemoveFromLibraryCommand}"
                                          CommandParameter="{Binding}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <!-- Title + Explicit badge -->
                        <Grid Grid.Column="0"
                              ColumnDefinitions="Auto,Auto"
                              VerticalAlignment="Center">
                            <TextBlock Grid.Column="0"
                                       Classes="one-line-explicit-title"
                                       Text="{Binding Title}"
                                       FontSize="13"
                                       MaxWidth="300" />
                            <Border Grid.Column="1"
                                    Classes="explicit-badge compact"
                                    Margin="6,0,0,0"
                                    IsVisible="{Binding IsExplicit}"
                                    ToolTip.Tip="Explicit">
                                <TextBlock Text="E"
                                           Classes="explicit-badge-text compact"
                                           FontSize="9"
                                           Opacity="0.9" />
                            </Border>
                        </Grid>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding DurationFormatted}"
                                   FontSize="12"
                                   Opacity="0.5"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                                Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewArtistCommand}"
                                CommandParameter="{Binding Artist}">
                            <TextBlock Text="{Binding Artist}"
                                       FontSize="12"
                                       Foreground="#E04060"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="3"
                                Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                                Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewAlbumCommand}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="{Binding Album}"
                                       FontSize="12"
                                       Foreground="#E74856"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </Button>
                        <TextBlock Grid.Column="4"
                                   Text="{Binding Genre}"
                                   FontSize="12"
                                   Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                        <PathIcon Grid.Column="5"
                                 Data="{StaticResource HeartFillIcon}"
                                 Width="12" Height="12"
                                 Foreground="#E74856"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsFavorite}" />
                        <TextBlock Grid.Column="6"
                                   Text="{Binding PlayCount}"
                                   FontSize="12"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <!-- 3-dots menu button -->
                        <Button Grid.Column="7"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Width="32" Height="32"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                Tag="{Binding}"
                                ToolTip.Tip="Options">
                            <PathIcon Data="{StaticResource MoreDotsIcon}"
                                     Width="14" Height="14"
                                     Foreground="#E74856"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                            <Button.Flyout>
                                <MenuFlyout Placement="BottomEdgeAlignedRight" Opened="OnTrackFlyoutOpened">
                                    <!-- Track header -->
                                    <MenuItem IsHitTestVisible="False" Focusable="False">
                                        <MenuItem.Template>
                                            <ControlTemplate>
                                                <Border Padding="11,8" Background="Transparent">
                                                    <ContentPresenter Content="{TemplateBinding Header}" />
                                                </Border>
                                            </ControlTemplate>
                                        </MenuItem.Template>
                                        <MenuItem.Header>
                                            <Grid ColumnDefinitions="40,10,*">
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="4" ClipToBounds="True"
                                                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}">
                                                    <Panel>
                                                        <TextBlock Text="&#x266A;" FontSize="14" HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" Opacity="0.3"
                                                                   IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                                        <Image Source="{Binding AlbumArtworkPath, Converter={StaticResource ArtworkConverter}}"
                                                               Stretch="UniformToFill"
                                                               IsVisible="{Binding AlbumArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                    </Panel>
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <Grid ColumnDefinitions="Auto,Auto">
                                                        <controls:MarqueeTextBlock Grid.Column="0" Text="{Binding Title}"
                                                                   FontWeight="SemiBold" FontSize="13"
                                                                   MaxDisplayWidth="240" IsForArtist="False" />
                                                        <Border Grid.Column="1"
                                                                Classes="explicit-badge compact"
                                                                Margin="4,0,0,0"
                                                                VerticalAlignment="Center"
                                                                IsVisible="{Binding IsExplicit}">
                                                            <TextBlock Text="E"
                                                                       Classes="explicit-badge-text compact"
                                                                       FontSize="9"
                                                                       Opacity="0.9" />
                                                        </Border>
                                                    </Grid>
                                                    <controls:MarqueeTextBlock Text="{Binding Artist}" FontSize="11" Foreground="#E74856"
                                                               MaxDisplayWidth="240" IsForArtist="True" HorizontalAlignment="Left" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="{Binding Title, StringFormat='Play &quot;{0}&quot;'}"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).PlayFromHereCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Shuffle"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ShuffleAllCommand}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Shuffle%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Play Next"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).PlayNextCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Forward%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Add to Queue"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).AddToQueueCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Queue%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem x:Name="AddToPlaylistMenuItem2" Header="Add to Playlist">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Playlists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                        <MenuItem Header="Create New Playlist"
                                                  Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).AddToNewPlaylistCommand}"
                                                  CommandParameter="{Binding}" />
                                        <Separator x:Name="PlaylistSeparator2" />
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Add to Favorites"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ToggleFavoriteCommand}"
                                              CommandParameter="{Binding}"
                                              IsVisible="{Binding !IsFavorite}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Your%20Favorites%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Remove from Favorites"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ToggleFavoriteCommand}"
                                              CommandParameter="{Binding}"
                                              IsVisible="{Binding IsFavorite}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource HeartFillIcon}" Width="14" Height="14" Foreground="#E74856" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Metadata"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).OpenMetadataCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Metadata%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Search Lyrics"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).SearchLyricsCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Lyrics%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="View Album"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewAlbumCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Albums%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="View Artist"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewArtistCommand}"
                                              CommandParameter="{Binding Artist}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Artists%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Show in Folder"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ShowInExplorerCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Folder%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Remove from Library"
                                              Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).RemoveFromLibraryCommand}"
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <PathIcon Data="{StaticResource TrashIcon}" Width="14" Height="14" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state overlay -->
            <StackPanel IsVisible="{Binding !FilteredTracks.Count}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="No songs found"
                           FontSize="18"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="Add music folders in Settings to get started"
                           FontSize="13"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>

        </DockPanel>
    </Grid>

</UserControl>
