<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:controls="using:Noctis.Controls"
             xmlns:conv="using:Noctis.Converters"
             xmlns:helpers="using:Noctis.Helpers"
             x:Class="Noctis.Views.LibrarySongsView"
             x:DataType="vm:LibrarySongsViewModel"
             Focusable="True"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:ArtworkPathConverter x:Key="ArtworkConverter" />
        <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry" />
    </UserControl.Resources>

    <Grid RowDefinitions="*">
        <!-- Right margin trimmed to 2 so the vertical scrollbar sits near the window
             edge (matches the Albums section) instead of being inset ~16px from it. -->
        <DockPanel Grid.Row="0" Margin="16,8,2,16">

        <!-- Column headers (sortable). Optional columns (Rating, BPM, Bitrate, Sample
             rate) live in Auto columns whose cells carry fixed widths, so hidden
             columns collapse to zero in both the header and the rows.
             Margin 1,_,9,_ mirrors the track-list row insets (1px ListBoxItem border
             each side + 8px right padding) so header cells sit exactly over row cells. -->
        <Grid DockPanel.Dock="Top"
              ColumnDefinitions="*,80,*,*,Auto,80,Auto,55,Auto,Auto,Auto,42"
              Margin="1,0,9,8">
            <Button Grid.Column="0" Content="Title" Command="{Binding SortCommand}" CommandParameter="Title"
                    Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Left" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="1" Content="Time" Command="{Binding SortCommand}" CommandParameter="Time"
                    Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Center" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            <Button Grid.Column="2" Content="Artist" Command="{Binding SortCommand}" CommandParameter="Artist"
                    Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Left" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Button Grid.Column="3" Content="Album" Command="{Binding SortCommand}" CommandParameter="Album"
                    Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Left" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            <Border Grid.Column="4" Width="110"
                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowGenreColumn, FallbackValue=True}">
                <Button Content="Genre" Command="{Binding SortCommand}" CommandParameter="Genre"
                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Left" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Left" />
            </Border>
            <Button Grid.Column="5" Content="Favorites" Command="{Binding SortCommand}" CommandParameter="IsFavorite"
                    Background="Transparent" BorderThickness="0" Padding="0" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            <Border Grid.Column="6" Width="84"
                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowRatingColumn, FallbackValue=True}">
                <Button Content="Rating" Command="{Binding SortCommand}" CommandParameter="Rating"
                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Center" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            </Border>
            <Button Grid.Column="7" Content="Plays" Command="{Binding SortCommand}" CommandParameter="Plays"
                    Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Center" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            <Border Grid.Column="8" Width="48"
                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowBpmColumn, FallbackValue=False}">
                <Button Content="BPM" Command="{Binding SortCommand}" CommandParameter="Bpm"
                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Center" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            </Border>
            <Border Grid.Column="9" Width="72"
                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowBitrateColumn, FallbackValue=False}">
                <Button Content="Bitrate" Command="{Binding SortCommand}" CommandParameter="Bitrate"
                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Center" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            </Border>
            <Border Grid.Column="10" Width="68"
                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowSampleRateColumn, FallbackValue=False}">
                <Button Content="Sample" Command="{Binding SortCommand}" CommandParameter="SampleRate"
                        Background="Transparent" BorderThickness="0" Padding="0" MinWidth="0" HorizontalContentAlignment="Center" FontSize="12" FontWeight="SemiBold" Opacity="0.7" Cursor="Hand" HorizontalAlignment="Center" />
            </Border>
            <!-- Column chooser -->
            <Button Grid.Column="11"
                    Background="Transparent" BorderThickness="0" Padding="0"
                    Width="24" Height="20" MinWidth="0"
                    HorizontalAlignment="Center"
                    Cursor="Hand" Opacity="0.6"
                    ToolTip.Tip="Choose columns">
                <PathIcon Data="{StaticResource MoreDotsIcon}" Width="12" Height="12"/>
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <MenuItem Header="Genre" ToggleType="CheckBox" StaysOpenOnClick="True"
                                  IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowGenreColumn, Mode=TwoWay}"/>
                        <MenuItem Header="Rating" ToggleType="CheckBox" StaysOpenOnClick="True"
                                  IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowRatingColumn, Mode=TwoWay}"/>
                        <MenuItem Header="BPM" ToggleType="CheckBox" StaysOpenOnClick="True"
                                  IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowBpmColumn, Mode=TwoWay}"/>
                        <MenuItem Header="Bitrate" ToggleType="CheckBox" StaysOpenOnClick="True"
                                  IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowBitrateColumn, Mode=TwoWay}"/>
                        <MenuItem Header="Sample rate" ToggleType="CheckBox" StaysOpenOnClick="True"
                                  IsChecked="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowSampleRateColumn, Mode=TwoWay}"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Separator DockPanel.Dock="Top" Margin="0,0,0,4" />

        <!-- Content area with overlay for empty state -->
        <Grid>
            <!-- Track list -->
            <ListBox Classes="track-list"
                     ItemsSource="{Binding FilteredTracks}"
                     SelectionMode="Multiple"
                     AutoScrollToSelectedItem="False"
                     Padding="0,0,0,115"
                     x:Name="TrackList">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Focusable" Value="False" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="m:Track">
                    <Border Classes.now-playing="{Binding IsNowPlaying}">
                    <Grid ColumnDefinitions="*,80,*,*,Auto,80,Auto,55,Auto,Auto,Auto,42"
                          Margin="0,2"
                          Background="Transparent"
                          helpers:DragFileBehavior.EnableFileDrag="True"
                          x:Name="TrackRow">

                        <!-- Title + Explicit badge -->
                        <Grid Grid.Column="0"
                              ColumnDefinitions="Auto,Auto"
                              ClipToBounds="True"
                              VerticalAlignment="Center"
                              LayoutUpdated="OnTitleCellLayoutUpdated">
                            <controls:HighlightTextBlock Grid.Column="0"
                                                         Classes="one-line-explicit-title"
                                                         DisplayText="{Binding TitleDisplay}"
                                                         HighlightText="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).SearchText}"
                                                         FontSize="13"
                                                         FontWeight="SemiBold"
                                                         TextWrapping="NoWrap"
                                                         MaxLines="1"
                                                         TextTrimming="CharacterEllipsis" />
                            <Border Grid.Column="1"
                                    Classes="explicit-badge compact"
                                    Margin="6,0,4,0"
                                    IsVisible="{Binding IsExplicit}"
                                    ToolTip.Tip="Explicit">
                                <TextBlock Text="E"
                                           Classes="explicit-badge-text compact"
                                           FontSize="9"
                                           Opacity="0.9" />
                            </Border>
                        </Grid>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding DurationFormatted}"
                                   FontSize="12"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2"
                                Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                                Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewArtistCommand}"
                                CommandParameter="{Binding Artist}">
                            <controls:HighlightTextBlock DisplayText="{Binding ArtistDisplay}"
                                                         HighlightText="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).SearchText}"
                                                         FontSize="12"
                                                         FontWeight="SemiBold"
                                                         Foreground="{DynamicResource AccentTextExactBrush}"
                                                         TextTrimming="CharacterEllipsis"
                                                         VerticalAlignment="Center" />
                        </Button>
                        <Button Grid.Column="3"
                                Background="Transparent" BorderThickness="0" Padding="0" MinHeight="0"
                                Cursor="Hand" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Command="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).ViewAlbumCommand}"
                                CommandParameter="{Binding}">
                            <controls:HighlightTextBlock DisplayText="{Binding Album}"
                                                         HighlightText="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).SearchText}"
                                                         FontSize="12"
                                                         FontWeight="SemiBold"
                                                         Foreground="{DynamicResource AccentTextExactBrush}"
                                                         TextTrimming="CharacterEllipsis"
                                                         VerticalAlignment="Center" />
                        </Button>
                        <Border Grid.Column="4" Width="110"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowGenreColumn, FallbackValue=True}">
                            <controls:HighlightTextBlock DisplayText="{Binding Genre}"
                                                         HighlightText="{Binding $parent[UserControl].((vm:LibrarySongsViewModel)DataContext).SearchText}"
                                                         FontSize="12"
                                                         FontWeight="SemiBold"
                                                         Foreground="{DynamicResource AccentTextExactBrush}"
                                                         TextTrimming="CharacterEllipsis"
                                                         HorizontalAlignment="Left"
                                                         VerticalAlignment="Center" />
                        </Border>
                        <PathIcon Grid.Column="5"
                                 Data="{StaticResource HeartFillIcon}"
                                 Width="12" Height="12"
                                 Foreground="#E74856"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsFavorite}" />
                        <Border Grid.Column="6" Width="84"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowRatingColumn, FallbackValue=True}">
                            <controls:RatingStars Value="{Binding Rating}"
                                                  StarSize="11"
                                                  StarSpacing="2"
                                                  IsHitTestVisible="False"
                                                  Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                                  Opacity="0.7"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsVisible="{Binding !!Rating}" />
                        </Border>

                        <TextBlock Grid.Column="7"
                                   Text="{Binding PlayCount}"
                                   FontSize="12"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <!-- Optional columns: BPM / Bitrate / Sample rate -->
                        <Border Grid.Column="8" Width="48"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowBpmColumn, FallbackValue=False}">
                            <TextBlock Text="{Binding Bpm}"
                                       FontSize="12" Opacity="0.5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       IsVisible="{Binding !!Bpm}" />
                        </Border>
                        <Border Grid.Column="9" Width="72"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowBitrateColumn, FallbackValue=False}">
                            <TextBlock Text="{Binding BitrateFormatted}"
                                       FontSize="12" Opacity="0.5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="10" Width="68"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Settings.ShowSampleRateColumn, FallbackValue=False}">
                            <TextBlock Text="{Binding SampleRateFormatted}"
                                       FontSize="12" Opacity="0.5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <!-- 3-dots menu button -->
                        <Button Grid.Column="11"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Width="28" Height="28"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Cursor="Hand"
                                Tag="{Binding}"
                                ToolTip.Tip="Options"
                                Click="OnOptionsButtonClick">
                            <PathIcon Data="{StaticResource MoreDotsIcon}"
                                     Width="14" Height="14"
                                     Foreground="{DynamicResource AccentTextExactBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Button>
                    </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
            </ListBox>

            <!-- Empty state overlay -->
            <StackPanel IsVisible="{Binding !FilteredTracks.Count}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="No songs found"
                           FontSize="18"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="Add music folders in Settings to get started"
                           FontSize="13"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>

        </DockPanel>
    </Grid>

</UserControl>
