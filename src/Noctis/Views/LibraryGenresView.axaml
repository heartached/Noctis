<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:conv="using:Noctis.Converters"
             x:Class="Noctis.Views.LibraryGenresView"
             x:DataType="vm:LibraryGenresViewModel"
             Background="{DynamicResource AppMainBackground}">

    <UserControl.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorConverter" />
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        <Separator Grid.Row="0" Classes="page-top-separator" />
        <DockPanel Grid.Row="1" Margin="16,8,16,16">

        <!-- Content area with overlay for empty state -->
        <Grid>
            <!-- Genre tiles grid -->
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredGenres}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:GenreItem">
                            <Button Classes="album-tile"
                                    Width="200"
                                    Height="120"
                                    Margin="8"
                                    Command="{Binding $parent[ItemsControl].((vm:LibraryGenresViewModel)DataContext).OpenGenreCommand}"
                                    CommandParameter="{Binding}">

                                <!-- Context menu -->
                                <Button.ContextMenu>
                                    <ContextMenu DataContext="{Binding}">
                                        <MenuItem Header="Play"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryGenresViewModel)DataContext).PlayGenreCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Play%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="View Genre"
                                                  Command="{Binding $parent[UserControl].((vm:LibraryGenresViewModel)DataContext).OpenGenreCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Border Width="14" Height="14" Background="{DynamicResource SystemControlForegroundBaseHighBrush}" RenderOptions.BitmapInterpolationMode="HighQuality"><Border.OpacityMask><ImageBrush Source="avares://Noctis/Assets/Icons/Genres%20ICON.png" Stretch="Uniform" /></Border.OpacityMask></Border>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>

                                <Border CornerRadius="12"
                                        ClipToBounds="True"
                                        Background="{Binding Color, Converter={StaticResource HexColorConverter}}">
                                    <Panel>
                                        <!-- Subtle music note watermark -->
                                        <PathIcon Data="{StaticResource BulletListIcon}"
                                                 Width="48" Height="48"
                                                 Foreground="White"
                                                 Opacity="0.12"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"
                                                 Margin="0,0,12,8" />

                                        <!-- Genre info -->
                                        <StackPanel VerticalAlignment="Bottom"
                                                    Margin="16,0,16,14"
                                                    Spacing="2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="17"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1" />
                                            <TextBlock Foreground="White"
                                                       Opacity="0.75"
                                                       FontSize="12">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} songs">
                                                        <Binding Path="TrackCount" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Panel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state overlay -->
            <StackPanel IsVisible="{Binding !FilteredGenres.Count}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="No genres found"
                           FontSize="18"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="Scan your music library to discover genres"
                           FontSize="13"
                           Opacity="0.3"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>
        </Grid>

        </DockPanel>
    </Grid>

</UserControl>
