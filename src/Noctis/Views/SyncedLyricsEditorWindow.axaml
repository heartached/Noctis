<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noctis.ViewModels"
        x:Class="Noctis.Views.SyncedLyricsEditorWindow"
        x:DataType="vm:MetadataViewModel"
        Title="Edit synced lyrics"
        CanResize="False"
        Width="880" Height="720"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False">

    <Window.Styles>
        <!-- Per-line nudge / clear buttons (roomy here, so they never clip) -->
        <Style Selector="Button.synced-nudge">
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="Button.synced-nudge:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#33FFFFFF" />
        </Style>
        <Style Selector="Button.synced-nudge:disabled">
            <Setter Property="Opacity" Value="0.35" />
        </Style>

        <Style Selector="Button.lrc-pill">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.lrc-pill:pointerover">
            <Setter Property="Background" Value="#33FFFFFF"/>
        </Style>
    </Window.Styles>

    <!-- Full-window dimmed overlay -->
    <Border Background="#98000000" PointerPressed="OnOverlayPointerPressed">

        <!-- Centered dialog card -->
        <Border PointerPressed="OnCardPointerPressed"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch"
                Margin="0,30"
                Padding="24,20"
                Width="840"
                CornerRadius="14"
                ClipToBounds="True"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Edit synced lyrics" FontSize="22" FontWeight="Bold"/>
                        <TextBlock FontSize="13" Opacity="0.7">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} — {1}">
                                    <Binding Path="HeaderTitle"/>
                                    <Binding Path="HeaderArtist"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Background="Transparent" BorderThickness="0"
                            Width="32" Height="32" Padding="0"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Cursor="Hand" Click="OnCloseClick">
                        <PathIcon Data="{StaticResource DismissIcon}" Width="16" Height="16" Opacity="0.75"/>
                    </Button>
                </Grid>

                <!-- Toolbar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,14,0,10">
                    <CheckBox Classes="metadata-pill-checkbox"
                              IsChecked="{Binding EditSyncedAsText}"
                              MinWidth="0" Padding="0" Margin="0"
                              ToolTip.Tip="Edit the raw [mm:ss.xx] LRC text directly (advanced / bulk paste)" />
                    <TextBlock Text="Edit as text"
                               FontSize="14" VerticalAlignment="Center" Margin="-4,0,0,0" />
                </StackPanel>

                <!-- Editor surface -->
                <Panel Grid.Row="2">
                    <Border IsVisible="{Binding !EditSyncedAsText}"
                            BorderBrush="#44E04060"
                            BorderThickness="1"
                            CornerRadius="8"
                            Background="#18000000">
                        <Panel>
                            <TextBlock Text="No synced lyrics yet. Close this and use “Search lyrics”, or switch to “Edit as text” and paste an LRC."
                                       IsVisible="{Binding !HasSyncedLines}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="420"
                                       Opacity="0.6"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="24" />

                            <ScrollViewer IsVisible="{Binding HasSyncedLines}"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Padding="14,10,18,14">
                                <ItemsControl ItemsSource="{Binding SyncedLyricLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SyncedLyricEditorLine">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" Margin="0,3">
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding TimestampText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                         Watermark="--:--.--"
                                                         FontFamily="Consolas, Menlo, Monaco, Courier New, monospace"
                                                         FontSize="12"
                                                         Width="92"
                                                         Padding="10,5"
                                                         CornerRadius="999"
                                                         VerticalAlignment="Center"
                                                         VerticalContentAlignment="Center"
                                                         HorizontalContentAlignment="Center"
                                                         ToolTip.Tip="Type a timestamp (mm:ss.xx); blank clears it" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Text}"
                                                           FontSize="14"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           Margin="14,0,14,0" />
                                                <Button Grid.Column="2"
                                                        Classes="synced-nudge"
                                                        Content="−"
                                                        ToolTip.Tip="Nudge 0.1s earlier"
                                                        IsEnabled="{Binding HasTimestamp}"
                                                        Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).NudgeSyncedLineBackCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="3"
                                                        Classes="synced-nudge"
                                                        Content="+"
                                                        Margin="6,0,0,0"
                                                        ToolTip.Tip="Nudge 0.1s later"
                                                        IsEnabled="{Binding HasTimestamp}"
                                                        Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).NudgeSyncedLineForwardCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Grid.Column="4"
                                                        Classes="synced-nudge"
                                                        Content="✕"
                                                        Margin="6,0,0,0"
                                                        ToolTip.Tip="Clear timestamp"
                                                        IsEnabled="{Binding HasTimestamp}"
                                                        Command="{Binding $parent[Window].((vm:MetadataViewModel)DataContext).ClearSyncedLineTimestampCommand}"
                                                        CommandParameter="{Binding}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Panel>
                    </Border>

                    <TextBox IsVisible="{Binding EditSyncedAsText}"
                             Text="{Binding SyncedLyrics}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             BorderBrush="#44E04060"
                             BorderThickness="1"
                             CornerRadius="8"
                             FontFamily="Consolas, Menlo, Monaco, Courier New, monospace" />
                </Panel>

                <!-- Footer -->
                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,14,0,0">
                    <TextBlock Grid.Column="0"
                               Text="Changes apply when you press Save in the metadata window."
                               FontSize="12" Opacity="0.6"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Classes="lrc-pill"
                            Background="{DynamicResource AccentColorBrush}"
                            Foreground="{DynamicResource AccentForegroundBrush}"
                            Content="Done"
                            Click="OnCloseClick"/>
                </Grid>
            </Grid>
        </Border>
    </Border>
</Window>
