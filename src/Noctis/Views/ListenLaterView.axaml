<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:ctrl="using:Noctis.Controls"
             x:Class="Noctis.Views.ListenLaterView"
             x:DataType="vm:ListenLaterViewModel"
             Background="{DynamicResource AppMainBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="24,24,36,12" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <PathIcon Data="{StaticResource BookmarkIcon}" Width="22" Height="22" Opacity="0.9"/>
                <TextBlock Text="Listen Later" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Clear all"
                    FontSize="12"
                    Padding="14,6"
                    CornerRadius="999"
                    Cursor="Hand"
                    Command="{Binding ClearAllCommand}"
                    IsVisible="{Binding HasItems}"/>
        </Grid>

        <!-- Bookmark rows -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24,4,24,115">
                <ItemsControl ItemsSource="{Binding Rows}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ListenLaterRow">
                            <Button Background="Transparent"
                                    BorderThickness="0"
                                    Padding="10,8"
                                    CornerRadius="10"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Cursor="Hand"
                                    Command="{Binding $parent[UserControl].((vm:ListenLaterViewModel)DataContext).OpenRowCommand}"
                                    CommandParameter="{Binding}">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Play"
                                                  Command="{Binding $parent[UserControl].((vm:ListenLaterViewModel)DataContext).PlayRowCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource PlayIcon}" Width="13" Height="13"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <MenuItem Header="Open"
                                                  Command="{Binding $parent[UserControl].((vm:ListenLaterViewModel)DataContext).OpenRowCommand}"
                                                  CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Remove" Classes="danger"
                                                  Command="{Binding $parent[UserControl].((vm:ListenLaterViewModel)DataContext).RemoveRowCommand}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <PathIcon Data="{StaticResource TrashIcon}" Width="13" Height="13"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>

                                <Grid ColumnDefinitions="Auto,14,*,Auto,Auto" VerticalAlignment="Center">
                                    <!-- Artwork / icon -->
                                    <Border Grid.Column="0" Width="46" Height="46" CornerRadius="8"
                                            ClipToBounds="True" Background="#1AFFFFFF">
                                        <Panel>
                                            <TextBlock Text="&#x266A;" FontSize="20" Opacity="0.2"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <ctrl:CachedImage SourcePath="{Binding ArtworkPath}"
                                                              Stretch="UniformToFill"
                                                              IsVisible="{Binding ArtworkPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                        </Panel>
                                    </Border>

                                    <!-- Name + subtitle -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <Border Background="#22808080" CornerRadius="999" Padding="7,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding KindLabel}" FontSize="10" Opacity="0.7"/>
                                            </Border>
                                            <Border Background="#33E74856" CornerRadius="999" Padding="7,1"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding IsMissing}">
                                                <TextBlock Text="Not in library" FontSize="10" Foreground="#E74856"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Subtitle}" FontSize="12" Opacity="0.55"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                    </StackPanel>

                                    <!-- Added date -->
                                    <TextBlock Grid.Column="3" Text="{Binding AddedLabel}"
                                               FontSize="11" Opacity="0.45"
                                               VerticalAlignment="Center"
                                               Margin="0,0,16,0"/>

                                    <!-- Remove button -->
                                    <Button Grid.Column="4"
                                            Background="Transparent" BorderThickness="0"
                                            Width="30" Height="30" Padding="0"
                                            Cursor="Hand"
                                            ToolTip.Tip="Remove"
                                            Command="{Binding $parent[UserControl].((vm:ListenLaterViewModel)DataContext).RemoveRowCommand}"
                                            CommandParameter="{Binding}">
                                        <PathIcon Data="{StaticResource DismissIcon}" Width="12" Height="12" Opacity="0.5"/>
                                    </Button>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty state -->
                <StackPanel IsVisible="{Binding !HasItems}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,80,0,0"
                            Spacing="8">
                    <TextBlock Text="Nothing saved for later"
                               FontSize="18" Opacity="0.5"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Right-click a song or album and choose 'Listen Later'"
                               FontSize="13" Opacity="0.3"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>

</UserControl>
