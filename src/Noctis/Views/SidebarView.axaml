<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Noctis.ViewModels"
             xmlns:m="using:Noctis.Models"
             xmlns:conv="using:Noctis.Converters"
             xmlns:ctrl="using:Noctis.Controls"
             x:Class="Noctis.Views.SidebarView"
             x:DataType="vm:SidebarViewModel"
             Background="{DynamicResource IslandBackground}"
             Foreground="{DynamicResource IslandForeground}">

    <UserControl.Resources>
        <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry" />
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush" />
        <conv:BoolToHorizontalAlignmentConverter x:Key="BoolToAlignment" />
        <conv:BoolToThicknessConverter x:Key="BoolToThickness" />
    </UserControl.Resources>

    <Border CornerRadius="20">
        <DockPanel LastChildFill="True">

            <!-- Top spacing -->
            <Border DockPanel.Dock="Top" Height="4" />

            <!-- Back + contextual search, pinned above the scrolling nav.
                 State (can-go-back, search visibility/watermark/text) comes from TopBarViewModel. -->
            <StackPanel DockPanel.Dock="Top"
                        Orientation="Vertical"
                        Spacing="10"
                        HorizontalAlignment="{Binding IsExpanded, Converter={StaticResource BoolToAlignment}}"
                        Margin="{Binding IsExpanded, Converter={StaticResource BoolToThickness}, ConverterParameter='6,2,0,6;0,2,0,6'}">
                <StackPanel.Styles>
                    <Style Selector="Button.rail-action">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Width" Value="32"/>
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="CornerRadius" Value="999"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                    <Style Selector="Button.rail-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="#22FFFFFF"/>
                    </Style>
                    <Style Selector="Button.rail-action:disabled">
                        <Setter Property="Opacity" Value="0.3"/>
                    </Style>
                    <!-- Expanded sidebar: align with the nav rows (icon column at the same
                         x-offset: 6 panel margin + 10 padding) and show the text label. -->
                    <Style Selector="Button.rail-action.expanded">
                        <Setter Property="Width" Value="NaN"/>
                        <Setter Property="Padding" Value="10,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                    </Style>
                </StackPanel.Styles>

                <Button Classes="rail-action"
                        Margin="0,8,0,0"
                        Classes.expanded="{Binding IsExpanded}"
                        Command="{Binding TopBar.BackCommand}"
                        IsEnabled="{Binding TopBar.IsBackButtonVisible, FallbackValue=False}"
                        ToolTip.Tip="Back">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Grid Width="28" Height="28">
                            <!-- Y nudge centers the chevron glyph in the circular button
                                 (the geometry sits slightly high in its viewbox). -->
                            <PathIcon Data="{StaticResource ChevronLeftIcon}" Width="17" Height="17"
                                      Foreground="{DynamicResource IslandForeground}">
                                <PathIcon.RenderTransform>
                                    <TranslateTransform Y="0.5" />
                                </PathIcon.RenderTransform>
                            </PathIcon>
                        </Grid>
                        <TextBlock Text="Back"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsExpanded}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="SearchButton"
                        Classes="rail-action"
                        Classes.expanded="{Binding IsExpanded}"
                        IsEnabled="{Binding TopBar.IsSearchVisible, FallbackValue=False}"
                        Click="OnSearchButtonClick"
                        ToolTip.Tip="Search (Ctrl+F)">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <Grid Width="28" Height="28">
                            <PathIcon Data="{StaticResource SearchIcon}" Width="16" Height="16"
                                      Foreground="{DynamicResource IslandForeground}"/>
                            <!-- Active-filter dot: search text survives the pill closing,
                                 so mark the icon while a query is filtering the page. -->
                            <Ellipse Width="7" Height="7"
                                     Fill="{DynamicResource AccentColorBrush}"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Top"
                                     Margin="0,2,2,0"
                                     IsVisible="{Binding TopBar.SearchText.Length, FallbackValue=False}"/>
                        </Grid>
                        <TextBlock Text="Search"
                                   FontSize="15"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsExpanded}"/>
                    </StackPanel>
                </Button>

                <!-- Persistent search pill: a non-light-dismiss popup (unlike the old
                     flyout) so it stays open while the user browses the filtered page.
                     Closed explicitly via the Search button toggle or Esc; opened via
                     the button or Ctrl+F. Open/close animation lives in code-behind. -->
                <Popup x:Name="SearchPopup"
                       PlacementTarget="{Binding #SearchButton}"
                       Placement="Right"
                       HorizontalOffset="4"
                       IsLightDismissEnabled="False"
                       WindowManagerAddShadowHint="False"
                       IsOpen="{Binding TopBar.IsSearchOpen, Mode=TwoWay}"
                       Opened="OnSearchPopupOpened">
                    <Border x:Name="SearchPopupContent"
                            Background="{DynamicResource IslandBackground}"
                            BorderBrush="{DynamicResource IslandBorder}"
                            BorderThickness="1"
                            CornerRadius="999"
                            Padding="12,5">
                        <Grid ColumnDefinitions="*,Auto" Width="180">
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="0"
                                     Classes="search-box"
                                     Text="{Binding TopBar.SearchText, Mode=TwoWay}"
                                     Watermark="{Binding TopBar.SearchWatermark}"
                                     KeyDown="OnSearchBoxKeyDown"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="12" Padding="4,2"
                                     VerticalAlignment="Center"/>
                            <Button Grid.Column="1"
                                    Command="{Binding TopBar.ClearSearchCommand}"
                                    IsVisible="{Binding TopBar.SearchText.Length, FallbackValue=False}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="6,2" Cursor="Hand" VerticalAlignment="Center">
                                <TextBlock Text="&#x2715;" FontSize="11" Opacity="0.5"/>
                            </Button>
                        </Grid>
                    </Border>
                </Popup>
            </StackPanel>

            <!-- Divider between rail actions and navigation -->
            <Border DockPanel.Dock="Top"
                    Height="1"
                    Background="{DynamicResource IslandForeground}"
                    Opacity="0.1"
                    Margin="8,0,8,6" />

            <!-- Scrollable content fills remaining space. Scrollbar stays hidden
                 (wheel/touch still scroll) so it never cuts through the 60px
                 collapsed rail when many playlists overflow the viewport. -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <!-- Main navigation: Home, Songs, Albums, Artists, Playlists, Settings -->
                    <ListBox Classes="sidebar"
                             x:Name="NavList"
                             ItemsSource="{Binding NavItems}"
                             SelectedItem="{Binding SelectedNavItem, Mode=OneWay}"
                             SelectionChanged="OnNavListSelectionChanged"
                             Margin="6,0,6,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:NavItem">
                                <StackPanel Orientation="Horizontal" Spacing="14"
                                            ToolTip.Tip="{Binding Label}"
                                            HorizontalAlignment="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded, Converter={StaticResource BoolToAlignment}}">
                                    <Grid Width="28"
                                          Height="28"
                                          VerticalAlignment="Center">
                                        <Border Width="20"
                                                Height="20"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                RenderOptions.BitmapInterpolationMode="HighQuality"
                                                Background="{DynamicResource IslandForeground}">
                                            <Border.OpacityMask>
                                                <ImageBrush Source="{Binding IconGlyph, Converter={StaticResource IconKeyToGeometry}}"
                                                            Stretch="Uniform" />
                                            </Border.OpacityMask>
                                        </Border>
                                        <!-- Update-available dot (top-right of icon; visible in
                                             both expanded and icon-only rail) -->
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{DynamicResource AccentColorBrush}"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Top"
                                                 Margin="0,-1,-1,0"
                                                 IsVisible="{Binding ShowBadge}" />
                                    </Grid>
                                    <TextBlock Text="{Binding Label}"
                                               VerticalAlignment="Center"
                                               IsVisible="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Horizontal divider -->
                    <Border Height="1"
                            Background="{DynamicResource IslandForeground}"
                            Opacity="0.1"
                            Margin="8,8,8,8" />

                    <!-- Favorites -->
                    <ListBox Classes="sidebar"
                             x:Name="FavoritesList"
                             ItemsSource="{Binding FavoritesItems}"
                             SelectedItem="{Binding SelectedNavItem, Mode=OneWay}"
                             SelectionChanged="OnNavListSelectionChanged"
                             Margin="6,0,6,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:NavItem">
                                <StackPanel Orientation="Horizontal" Spacing="10"
                                            ToolTip.Tip="{Binding Label}"
                                            HorizontalAlignment="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded, Converter={StaticResource BoolToAlignment}}">
                                    <!-- Heart cover art thumbnail -->
                                    <Border Width="28" Height="28"
                                            CornerRadius="14"
                                            ClipToBounds="True"
                                            VerticalAlignment="Center"
                                            Background="{DynamicResource AccentColorBrush}">
                                        <!-- Heart badge. Width/Height = icon SIZE.
                                             To nudge position, change X and Y below:
                                               X  -> sideways  (positive = RIGHT, negative = LEFT)
                                               Y  -> up/down    (positive = DOWN,  negative = UP)
                                             1 = 1 pixel. -->
                                        <Path Data="{StaticResource FavoritesFilledIcon}"
                                              Width="14" Height="10"
                                              Stretch="Uniform"
                                              Fill="{DynamicResource AccentForegroundBrush}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                            <Path.RenderTransform>
                                                <TranslateTransform X="1.3" Y="0" />
                                            </Path.RenderTransform>
                                        </Path>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="1"
                                                IsVisible="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded}">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="13" />
                                        <TextBlock FontSize="11"
                                                   Opacity="0.5">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} songs">
                                                    <Binding Path="$parent[UserControl].((vm:SidebarViewModel)DataContext).FavoritesCount" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Horizontal divider below Favorites -->
                    <Border Height="1"
                            Background="{DynamicResource IslandForeground}"
                            Opacity="0.1"
                            Margin="8,2,8,8" />

                    <!-- Playlists header (only visible when expanded) -->
                    <TextBlock Margin="18,4,12,4"
                               IsVisible="{Binding IsExpanded}"
                               Text="PLAYLISTS"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Opacity="0.5"
                               VerticalAlignment="Center" />

                    <!-- User playlists: pinned first, then folders, then loose playlists -->
                    <ListBox Classes="sidebar"
                             x:Name="PlaylistList"
                             ItemsSource="{Binding SidebarRows}"
                             SelectedItem="{Binding SelectedNavItem, Mode=OneWay}"
                             SelectionChanged="OnNavListSelectionChanged"
                             MaxHeight="528"
                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                             Margin="6,0,6,4">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="m:PlaylistNavItem">
                                <Panel>

                                <!-- Folder header row -->
                                <StackPanel Orientation="Horizontal" Spacing="10"
                                            ToolTip.Tip="{Binding Label}"
                                            IsVisible="{Binding IsFolder}"
                                            HorizontalAlignment="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded, Converter={StaticResource BoolToAlignment}}">
                                    <Border Width="28" Height="28"
                                            CornerRadius="8"
                                            VerticalAlignment="Center"
                                            Background="#22808080">
                                        <Panel>
                                            <PathIcon Data="{StaticResource ChevronRightIcon}"
                                                      Width="11" Height="11"
                                                      Opacity="0.8"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IsVisible="{Binding !IsExpanded}" />
                                            <PathIcon Data="{StaticResource ChevronRightIcon}"
                                                      Width="11" Height="11"
                                                      Opacity="0.8"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RenderTransform="rotate(90deg)"
                                                      IsVisible="{Binding IsExpanded}" />
                                        </Panel>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Spacing="1"
                                                IsVisible="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded}">
                                        <TextBlock Text="{Binding Label}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="120" />
                                        <TextBlock FontSize="11"
                                                   Opacity="0.5">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} playlists">
                                                    <Binding Path="TrackCount" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Playlist row -->
                                <StackPanel Orientation="Horizontal" Spacing="10"
                                            ToolTip.Tip="{Binding Label}"
                                            IsVisible="{Binding !IsFolder}"
                                            HorizontalAlignment="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded, Converter={StaticResource BoolToAlignment}}">
                                    <!-- Indent for playlists inside an expanded folder -->
                                    <Border Width="14" IsVisible="{Binding IsInFolder}" />
                                    <!-- Playlist artwork thumbnail -->
                                    <Border Width="28" Height="28"
                                            CornerRadius="14"
                                            ClipToBounds="True"
                                            VerticalAlignment="Center">
                                        <Panel>
                                            <!-- Layer 1: Colored background (always present) -->
                                            <Border Background="{Binding Color, Converter={StaticResource HexColorToBrush}}"
                                                    CornerRadius="14" />

                                            <!-- Layer 2: Fallback playlist icon -->
                                            <PathIcon Data="{StaticResource PlaylistsIcon}"
                                                      Width="12" Height="12"
                                                      Foreground="#80FFFFFF"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      IsVisible="{Binding ShowFallbackIcon}" />

                                            <!-- Layer 3: Single album art (only 1 unique art) -->
                                            <ctrl:CachedImage SourcePath="{Binding Art1}"
                                                              Stretch="UniformToFill"
                                                              IsVisible="{Binding HasSingleArt}" />

                                            <!-- Layer 4: 2x2 collage (2+ unique arts) -->
                                            <Grid RowDefinitions="*,*"
                                                  ColumnDefinitions="*,*"
                                                  IsVisible="{Binding HasCollageArt}">
                                                <ctrl:CachedImage Grid.Row="0" Grid.Column="0"
                                                                  SourcePath="{Binding Art1}"
                                                                  Stretch="UniformToFill" />
                                                <ctrl:CachedImage Grid.Row="0" Grid.Column="1"
                                                                  SourcePath="{Binding Art2}"
                                                                  Stretch="UniformToFill" />
                                                <ctrl:CachedImage Grid.Row="1" Grid.Column="0"
                                                                  SourcePath="{Binding Art3}"
                                                                  Stretch="UniformToFill" />
                                                <ctrl:CachedImage Grid.Row="1" Grid.Column="1"
                                                                  SourcePath="{Binding Art4}"
                                                                  Stretch="UniformToFill" />
                                            </Grid>

                                            <!-- Layer 5: Custom cover art (highest priority, covers everything) -->
                                            <ctrl:CachedImage SourcePath="{Binding CoverArtPath}"
                                                              Stretch="UniformToFill"
                                                              IsVisible="{Binding HasCustomArt}" />
                                        </Panel>
                                    </Border>

                                    <!-- Playlist name and track count (only when expanded) -->
                                    <StackPanel VerticalAlignment="Center" Spacing="1"
                                                IsVisible="{Binding $parent[UserControl].((vm:SidebarViewModel)DataContext).IsExpanded}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="120" />
                                            <PathIcon Data="{StaticResource StarIcon}"
                                                      Width="11" Height="11"
                                                      Foreground="#F1C40F"
                                                      Opacity="0.9"
                                                      VerticalAlignment="Center"
                                                      IsVisible="{Binding IsPinned}" />
                                        </StackPanel>
                                        <TextBlock FontSize="11"
                                                   Opacity="0.5"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} songs">
                                                    <Binding Path="TrackCount" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                </Panel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>


                </StackPanel>
            </ScrollViewer>

        </DockPanel>
    </Border>

</UserControl>
